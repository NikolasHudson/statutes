\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F535}{\*\bkmkend codeChapter_5F535}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 535}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{MONEY AND INTEREST}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a716.75}}}{{\f5\fs12\qc{, 535B.7}}}{{\f5\fs12\qc{, 535D.13}}}{{\f5\fs12\qc{, 536.13}}}{{\f5\fs12\qc{, 536.16}}}{{\f5\fs12\qc{, 536A.30}}}{{\f5\fs12\qc{, 537.1301}}}{{\f5\fs12\qc{, 537.2301}}}{{\f5\fs12\qc{, 554.14103}}}{{\f5\fs12\qc{, 669.14}}}\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{535.1}}}{\*\bkmkstart stylerid1_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Denominations of money.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The money of account of this state is the dollar, cent, and mill, and all public accounts, and the proceedings of all courts in relation to money, shall be kept and expressed in the above denominations. Demands expressed in money of another denomination shall not be affected by the provisions of }{{\f5\fs18\hyphpar0\qj{this section}}}{, but in any action or proceeding based thereon it shall be reduced to and computed by the denominations given.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7943, 944; R60, \'a71785, 1786; C73, \'a72075, 2076; C97, \'a73037; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{9403;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, S79, }{{\f5\fs18\hyphpar0\qj{C81, \'a7535.1}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{535.2}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Rate of interest.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, the rate of interest shall be five cents on the hundred by the year in the following cases, unless the parties shall agree in writing for the payment of interest at a rate not exceeding the rate permitted by }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Money due by express contract.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Money after the same becomes due.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Money loaned.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Money received to the use of another and retained beyond a reasonable time, without the owner\u8217\'3fs consent, express or implied.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Money due on the settlement of accounts from the day the balance is ascertained.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Money due upon open accounts after six months from the date of the last item.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Money due, or to become due, where there is a contract to pay interest, and no rate is stipulated.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The following persons may agree in writing to pay any rate of interest, and a person so agreeing in writing shall not plead or interpose the claim or defense of usury in any action or proceeding, and the person agreeing to receive the interest is not subject to any penalty or forfeiture for agreeing to receive or for receiving the interest:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person borrowing money for the purpose of acquiring real property or refinancing a contract for deed.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person borrowing money or obtaining credit in an amount which exceeds the threshold amount as defined in }}}{{\f5\fs18\hyphpar0\qj{section 537.1301}}}{{\f5\fs18\hyphpar0\qj{, exclusive of interest, for the purpose of constructing improvements on real property, whether or not the real property is owned by the person.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vendee under a contract for deed to real property.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A domestic or foreign corporation, and a real estate investment trust as defined in }}}{{\f5\fs18\hyphpar0\qj{section 856 of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{, and a person purchasing securities as defined in }}}{{\f5\fs18\hyphpar0\qj{chapter 502}}}{{\f5\fs18\hyphpar0\qj{ on credit from a broker or dealer registered or licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 502}}}{{\f5\fs18\hyphpar0\qj{ or under the federal }}}{{\f5\fs18\hyphpar0\qj{Securities Exchange Act of 1934}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{15 U.S.C. \'a778a et seq., as amended}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person borrowing money or obtaining credit for business or agricultural purposes, or a person borrowing money or obtaining credit in an amount which exceeds the threshold amount, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 537.1301}}}{{\f5\fs18\hyphpar0\qj{, for personal, family, or household purposes. As used in this paragraph, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fagricultural purpose\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means as defined in }}}{{\f5\fs18\hyphpar0\qj{section 535.13}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fbusiness purpose\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes but is not limited to a commercial, service, or industrial enterprise carried on for profit and an investment activity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In determining exemptions under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, the rules of construction stated in this paragraph apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The purpose for which money is borrowed is the purpose to which a majority of the loan proceeds are applied or are designated in the agreement to be applied.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Loan proceeds used to refinance or pay a prior loan owed by the same borrower are applied for the same purposes and in the same proportion as the original principal of the loan that is refinanced or paid.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the lender releases the original borrower from all personal liability with respect to the loan, loan proceeds used to pay a prior loan by a different borrower are applied for the new borrower\u8217\'3fs purposes in agreeing to pay the prior loan.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the lender releases the original borrower from all personal liability with respect to the loan, the assumption of a loan by a new borrower is treated as if the new borrower had obtained a new loan and had used all of the proceeds to pay the loan assumed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This paragraph does not modify or limit }}}{{\f5\fs18\hyphpar0\qj{section 535.8, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{With respect to any transaction referred to in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ supersedes any interest-rate or finance-charge limitations contained in the Code, including but not limited to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{chapters 321}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{322}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{524}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{533}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{536A}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{537}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The maximum lawful rate of interest which may be provided for in any written agreement for the payment of interest entered into during any calendar month commencing on or after April 13, 1979, shall be two percentage points above the monthly average ten-year constant maturity interest rate of United States government notes and bonds as published by the board of governors of the federal reserve system for the calendar month second preceding the month during which the maximum rate based thereon will be effective, rounded to the nearest one-fourth of one percent per year.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On or before the twentieth day of each month the superintendent of banking shall determine the maximum lawful rate of interest for the following calendar month as prescribed herein, and shall cause this rate to be published, as a notice in the Iowa administrative bulletin or as a legal notice in a newspaper of general circulation published in Polk county, prior to the first day of the following calendar month. This maximum lawful rate of interest shall be effective on the first day of the calendar month following publication. The determination of the maximum lawful rate of interest by the superintendent of banking shall be exempt from the provisions of }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any rate of interest specified in any written agreement providing for the payment of interest shall, if such rate was lawful at the time the agreement was made, remain lawful during the entire term of the agreement, including any extensions or renewals thereof, for all money due or to become due thereunder including future advances, if any.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any written agreement for the payment of interest made pursuant to a prior written agreement by a lender to lend money in the future, either to the other party to such prior written agreement or a third party beneficiary of such prior agreement, may provide for payment of interest at the lawful rate of interest at the time of the execution of the prior agreement regardless of the time at which the subsequent agreement is executed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any contract, note or other written agreement providing for the payment of a rate of interest permitted by }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ which contains any provisions providing for an increase in the rate of interest prescribed therein shall, if such increase could be to a rate which would have been unlawful at the time the agreement was made, also provide for a reduction in the rate of interest prescribed therein, to be determined in the same manner and with the same frequency as any increase so provided for.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding the provisions of }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{, with respect to any agreement which was executed prior to August 3, 1978, and which contained a provision for the adjustment of the rate of interest specified in that agreement, the maximum lawful rate of interest which may be imposed under that agreement shall be nine cents on the hundred by the year, and any excess charge shall be a violation of }}}{{\f5\fs18\hyphpar0\qj{section 535.4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding the limitation contained in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, with respect to a written agreement for the repayment of money loaned, which was executed prior to August 3, 1978, and which provided for the payment of over fifty percent of the initial principal amount of the loan as a single payment due at the end of the term of the agreement, the interest rate may be adjusted after June 3, 1980, according to the terms of the agreement to any rate of interest permitted by the laws of this state as of the date an adjustment in interest is to be made. This paragraph does not authorize adjustment of interest in any manner other than that expressly permitted by the terms of the written agreement, and nothing contained in this paragraph authorizes the collection of additional interest with respect to any portion of a loan which was repaid prior to the effective date of an interest rate adjustment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f,}}}{{\f5\fs18\hyphpar0\qj{ when a written agreement providing for the repayment of money loaned, and requiring the payment of over fifty percent of the initial principal amount of the loan as a single payment due at the end of the term of the agreement is extended, renewed, or otherwise amended by the parties on or after August 3, 1978, the parties may agree to the payment of interest from the effective date of the extension, renewal, or amendment, at a rate and in a manner that is lawful for a new agreement made on that date.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ shall not apply to any loan which is subject to the provisions of }}}{{\f5\fs18\hyphpar0\qj{section 636.46}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding the provisions of}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/1980/CH1156.pdf" }{\fldrslt \cf5 \f5 \fs18{{ 1980 Iowa Acts, ch. 1156}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{, with respect to any agreement which was executed on or after August 3, 1978, and prior to July 1, 1979, and which contained a provision for the adjustment of the rate of interest specified in the agreement, the maximum lawful rate of interest which may be imposed under that agreement shall be that rate which is two and one-half percentage points above the rate initially to be paid under the agreement, provided that the greatest interest rate adjustment which may be made at any one time shall be one-half of one percent and an interest rate adjustment may not be made until at least one year has passed since the last interest rate adjustment, and any excess charge shall be a violation of }}}{{\f5\fs18\hyphpar0\qj{section 535.4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding the limitation contained in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, with respect to a written agreement for the repayment of money loaned which was executed on or after August 3, 1978, and prior to July 1, 1979, and which provided for the payment of over fifty percent of the initial principal amount of the loan as a single payment due at the end of the term of the agreement, the interest rate may be adjusted after June 3, 1980, according to the terms of the agreement to any rate of interest permitted by the laws of this state as of the date an adjustment in interest is to be made. This paragraph does not authorize adjustment of interest in any manner other than that expressly permitted by the terms of the written agreement, and nothing contained in this paragraph authorizes the collection of additional interest with respect to any portion of a loan which was repaid prior to the effective date of an interest rate adjustment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not apply to a charge imposed for late payment of rent. }}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7945; R60, \'a71787; C73, \'a72077; C97, \'a73038; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{9404;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, S79, }{{\f5\fs18\hyphpar0\qj{C81, \'a7535.2}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1153, \'a74, 5}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{93 Acts, ch 154, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 125, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 25, \'a765}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1017, \'a7132}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 97, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1026, \'a7143}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1037, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1092, \'a7119, 189}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7103A.58}}}{{\f5\fs12\hyphpar0\qj{, 322C.12}}}{{\f5\fs12\hyphpar0\qj{, 455B.396}}}{{\f5\fs12\hyphpar0\qj{, 533.316}}}{{\f5\fs12\hyphpar0\qj{, 535.8}}}{{\f5\fs12\hyphpar0\qj{, 535.11}}}{{\f5\fs12\hyphpar0\qj{, 535.12}}}{{\f5\fs12\hyphpar0\qj{, 536A.23}}}{{\f5\fs12\hyphpar0\qj{, 602.8102(5)}}}{{\f5\fs12\hyphpar0\qj{, 668.13}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Life insurance policy loans; see }{{\f5\fs12\hyphpar0\qj{\'a7511.36}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{535.3}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Interest rate }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ judgments and decrees }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ periodic compensation payments.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Interest shall be allowed on all money due on judgments and decrees of courts at a rate calculated according to }}}{{\f5\fs18\hyphpar0\qj{section 668.13}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, interest due pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 85.30}}}{{\f5\fs18\hyphpar0\qj{ shall accrue from the date each compensation payment is due at an annual rate equal to the one-year treasury constant maturity published by the federal reserve in the most recent H15 report settled as of the date of injury, plus two percent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Interest on periodic payments for child, spousal, or medical support shall not accrue until thirty days after the payment becomes due and owing and shall accrue at a rate of ten percent per annum thereafter. Additionally, interest on these payments shall not accrue on amounts being paid through income withholding pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 252D}}}{{\f5\fs18\hyphpar0\qj{ for the time these payments are unpaid solely because the date on which the payor of income withholds income based upon the payor\u8217\'3fs regular pay cycle varies from the provisions of the support order.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7946; R60, \'a71789; C73, \'a72078; C97, \'a73039; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{9405;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, S79, }{{\f5\fs18\hyphpar0\qj{C81, \'a7535.3}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{87 Acts, ch 157, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1141, \'a733}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 175, \'a7232}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 197, \'a72 \u8211\'3f 4, 16}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 23, \'a723}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a785.22}}}{{\f5\fs12\hyphpar0\qj{, 85.30}}}{{\f5\fs12\hyphpar0\qj{, 85.47}}}{{\f5\fs12\hyphpar0\qj{, 85.48}}}{{\f5\fs12\hyphpar0\qj{, 87.11}}}{{\f5\fs12\hyphpar0\qj{, 97A.14A}}}{{\f5\fs12\hyphpar0\qj{, 97B.50A}}}{{\f5\fs12\hyphpar0\qj{, 249A.53}}}{{\f5\fs12\hyphpar0\qj{, 249B.6}}}{{\f5\fs12\hyphpar0\qj{, 252C.6}}}{{\f5\fs12\hyphpar0\qj{, 411.22}}}{{\f5\fs12\hyphpar0\qj{, 445.3}}}{{\f5\fs12\hyphpar0\qj{, 486A.104}}}{{\f5\fs12\hyphpar0\qj{, 488.107}}}{{\f5\fs12\hyphpar0\qj{, 502.102}}}{{\f5\fs12\hyphpar0\qj{, 515B.5}}}{{\f5\fs12\hyphpar0\qj{, 535.11}}}{{\f5\fs12\hyphpar0\qj{, 657A.3}}}{{\f5\fs12\hyphpar0\qj{, 657A.6}}}{{\f5\fs12\hyphpar0\qj{, 715B.4}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{535.4}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Illegal rate prohibited \u8212\'3f usury.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{No person shall, directly or indirectly, receive in money or in any other thing, or in any manner, any greater sum or value for the loan of money, or upon contract founded upon any sale or loan of real or personal property, than is in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ prescribed.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a71790; C73, \'a72079; C97, \'a73040; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{9406;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, S79, }{{\f5\fs18\hyphpar0\qj{C81, \'a7535.4}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7535.2}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{535.5}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Penalty for usury.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If it is ascertained in an action brought on a contract that a rate of interest has been contracted for, directly or indirectly, in money or in property, greater than is authorized by }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, the rate shall work a forfeiture of eight cents on the hundred by the year upon the amount of the principal remaining unpaid upon the contract at the time judgment is rendered, and the court shall enter final judgment in favor of the plaintiff and against the defendant for the principal sum remaining unpaid without costs, and also against the defendant and in favor of the state, to be paid to the treasurer of state for deposit in the general fund of the state, for the amount of the forfeiture. If unlawful interest is contracted for the plaintiff shall not have judgment for more than the principal sum, whether the unlawful interest is incorporated with the principal or not.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a71791; C73, \'a72080; C97, \'a73041; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{9407;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, S79, }{{\f5\fs18\hyphpar0\qj{C81, \'a7535.5}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 185, \'a752, 62}}}{; }{{\f5\fs18\hyphpar0\qj{83 Acts, ch 186, \'a710109, 10201, 10204}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{535.6}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{535.7}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Assignee of usurious contract.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Any assignee of a usurious contract, becoming such in good faith in the usual course of business and without notice of such fact, may recover of the usurer the full amount of the consideration paid by the assignee therefor, less any sum that may have been realized on the contract, anything in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ contained to the contrary notwithstanding.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a71792; C73, \'a72081; C97, \'a73042; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{9409;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, S79, }{{\f5\fs18\hyphpar0\qj{C81, \'a7535.7}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{535.8}}}{\*\bkmkstart stylerid1_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Loan charges limited.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E12_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E12_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Definitions.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, unless the context otherwise requires:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLender\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person who makes or originates a loan; a person who is identified as a lender on the loan documents; a person who arranges, negotiates, or brokers a loan; and a person who provides any goods or services as an incident to or as a condition required for the making or closing of the loan. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLender\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include a licensed attorney admitted to practice in this state acting solely as an incident to the practice of law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLoan\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a loan of money which is wholly or in part to be used for the purpose of purchasing real property which is a single-family or two-family dwelling occupied or to be occupied by the borrower. A loan includes the refinancing of a contract of sale, and the refinancing of a prior loan, whether or not the borrower also was the borrower under the prior loan, and the assumption of a prior loan.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPoints and fees\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the fees and charges that are included in the definition of points and fees in }}}{{\f5\fs18\hyphpar0\qj\cf1{12 C.F.R. \'a71026.32(b)(1)}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a lender that is a financial institution as defined in }}}{{\f5\fs18\hyphpar0\qj{section 537.1301}}}{{\f5\fs18\hyphpar0\qj{ makes a loan in which the points and fees the borrower is charged by all lenders in connection with the loan do not exceed the amounts specified in }}}{{\f5\fs18\hyphpar0\qj\cf1{12 C.F.R. \'a71026.43(e)(3)}}}{{\f5\fs18\hyphpar0\qj{, the loan shall not be subject to the provisions of }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{, paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{. If a lender that is a mortgage banker licensed under }}}{{\f5\fs18\hyphpar0\qj{section 535B.5}}}{{\f5\fs18\hyphpar0\qj{ or registered under }}}{{\f5\fs18\hyphpar0\qj{section 535B.3}}}{{\f5\fs18\hyphpar0\qj{ makes a loan in which the points and fees the borrower is charged by all lenders in connection with the loan do not exceed the amounts specified in }}}{{\f5\fs18\hyphpar0\qj\cf1{12 C.F.R. \'a71026.43(e)(3)}}}{{\f5\fs18\hyphpar0\qj{, the loan shall not be subject to the provisions of }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ applies to the financial institution lender that originates the loan and to subsequent purchasers of the loan originated by the financial institution.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ shall not be construed to change the prohibition against the sale of title insurance or sale of insurance against loss or damage by reason of defective title or encumbrances as provided in }}}{{\f5\fs18\hyphpar0\qj{section 515.48, subsection 10}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A borrower may be charged by a lender, in connection with a loan made pursuant to a written agreement executed by the borrower on or after July 1, 1983, or in connection with a loan made pursuant to a written commitment by the lender mailed or delivered to the borrower on or after that date, a loan origination or processing fee, a broker fee, or both, which together do not exceed two percent of an amount which is equal to the loan principal; except that to the extent of an assumption by a new borrower of the obligation to make payments under a prior loan, or to the extent that the loan principal is used to refinance a prior loan between the same borrower and the same lender, the borrower may be charged by a lender a loan origination or processing fee, a broker fee, or both, which together do not exceed an amount which is a reasonable estimate of the expenses of processing the loan assumption or refinancing but which does not exceed one percent of the unpaid balance of the loan that is assumed or refinanced. In addition, a borrower may be charged by a lender, in contemplation of or in connection with a loan, a commitment fee, closing fee, or both, that is agreed to in writing by the lender and the borrower. A loan fee paid by a borrower to a lender under this paragraph is compensation to the lender solely for the use of money, notwithstanding any provision of the agreement to the contrary. However, a loan fee collected under this paragraph shall be disregarded for purposes of determining the maximum charge permitted by }}}{{\f5\fs18\hyphpar0\qj{section 535.2}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{535.9}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{. A lender is prohibited from charging a borrower in connection with a loan a loan origination or processing fee, broker fee, closing fee, commitment fee, or similar charge other than expressly authorized by this paragraph or a payment reduction fee authorized by }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A borrower may be charged by a lender in connection with a loan any of the following costs which are incurred by the lender in connection with the loan and which are disclosed to the borrower:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Credit reports.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Appraisal fees paid to a third party, or when the appraisal is performed by the lender, a fee which is a reasonable estimate of the expense incurred by the lender in performing the appraisal.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Attorney\u8217\'3fs opinions.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Abstracting fees paid to a third party, or when the abstracting is performed by the lender, a fee which is a reasonable estimate of the expense incurred by the lender in performing the abstracting.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(e)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{County recorder\u8217\'3fs fees.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(f)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Inspection fees.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(g)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Mortgage guarantee insurance charge.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(h)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Surveying of property.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Termite inspection.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(j)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The cost of a title guaranty issued by the Iowa finance authority pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 16}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(k)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A bona fide and reasonable settlement or closing fee which is paid to a third party to settle or close the loan.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The lender shall not charge the borrower for the cost of revenue stamps or real estate commissions which are paid by the seller.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A lender shall not charge the borrower any costs other than expressly permitted by this paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. However, additional costs incurred in connection with a loan under this paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, if bona fide and reasonable, may be collected by a state-chartered financial institution licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 524}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{533}}}{{\f5\fs18\hyphpar0\qj{, to the extent permitted under applicable federal law as determined by the office of the comptroller of the currency of the United States department of treasury, the national credit union administration, or the office of thrift supervision of the United States department of treasury. Such costs shall apply only to the same type of state-chartered entity as the federally chartered entity affected and shall apply to and may be collected by an insurer organized under }}}{{\f5\fs18\hyphpar0\qj{chapter 508}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{515}}}{{\f5\fs18\hyphpar0\qj{, or otherwise authorized to conduct the business of insurance in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the purpose of the loan is to enable the borrower to purchase a single-family or two-family dwelling, for the borrower\u8217\'3fs residence, any provision of a loan agreement which prohibits the borrower from transferring the borrower\u8217\'3fs interest in the property to a third party for use by the third party as the third party\u8217\'3fs residence, or any provision which requires or permits the lender to make a change in the interest rate, the repayment schedule or the term of the loan as a result of a transfer by the borrower of the borrower\u8217\'3fs interest in the property to a third party for use by the third party as the third party\u8217\'3fs residence shall not be enforceable except as provided in the following sentence. If the lender on reasonable grounds believes that its security interest or the likelihood of repayment is impaired, based solely on criteria which is not more restrictive than that used to evaluate a new mortgage loan application, the lender may accelerate the loan, or to offset any such impairment, may adjust the interest rate, the repayment schedule or the term of the loan. A provision of a loan agreement which violates this paragraph is void.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a lender collects a fee or charge which is prohibited by paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ or which exceeds the amount permitted by paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, the person from whom the fee was collected has the right to recover the unlawful fee or charge or the unlawful portion of the fee or charge, plus attorney fees and costs incurred in any action necessary to effect recovery.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 628.3}}}{{\f5\fs18\hyphpar0\qj{ when a foreclosure of a mortgage on real property results from the enforcement of a due-on-sale clause, the mortgagor may redeem the real property at any time within eighteen months from the day of sale under the levy, and the mortgagor shall, in the meantime, be entitled to the possession thereof; and for the first fifteen months thereafter such right of redemption is exclusive. Any real property redeemed by the debtor shall thereafter be free and clear from any liability for any unpaid portion of the judgment under which the real property was sold. The right of redemption established by this paragraph is not subject to waiver by the mortgagor and the period of redemption established by this paragraph shall not be reduced. The times for redemption by creditors provided in }}}{{\f5\fs18\hyphpar0\qj{sections 628.5}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{628.15}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{628.16}}}{{\f5\fs18\hyphpar0\qj{ shall be extended to sixteen months in any case in which the mortgagor\u8217\'3fs period for redemption is extended by this paragraph. This paragraph does not apply to foreclosure of a mortgage if for any reason other than enforcement of a due-on-sale clause. As used in this paragraph, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fdue-on-sale clause\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any type of covenant which gives the mortgagee the right to demand payment of the outstanding balance or a major part thereof upon a transfer by the mortgagor to a third party of an interest of the mortgagor in property covered by the mortgage. This paragraph applies to any foreclosure occurring on or after May 10, 1980. However, this paragraph does not apply if the lender establishes, based on reasonable criteria which are not more restrictive than those used to evaluate new mortgage-loan applications, that the security interest or the likelihood of repayment is impaired as a result of the transfer of interest.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This lettered paragraph applies only to a mortgage given in connection with a loan as defined in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A lender who offers to make a loan with only those fees authorized by }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{ may also offer in exchange for the payment of an interest reduction fee to make a loan on all of the same terms except at a lower interest rate and with the lower payments resulting from the lower interest rate. Prior to accepting an application for a loan which includes a payment reduction fee, the lender shall provide the potential borrower with a written disclosure describing in plain language the specific terms which the loan would have both with the payment reduction fee and without it. This disclosure shall include a good faith example showing the amount of the payment reduction fee and the reduction in payments which would result from the payment of this fee in a typical loan transaction. A payment reduction fee which complies with }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ may be collected in connection with a loan in addition to the fees authorized by }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A lender shall not, as a condition of making a loan as defined in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, require the borrower to place money, or to place property other than that which is given as security for the loan, on deposit with or in the possession or control of the lender or some other person if the effect is to increase the yield to the lender with respect to that loan; provided that }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not prohibit a lender from requiring the borrower to deposit money without interest with the lender in an escrow account for the payment of insurance premiums, property taxes and special assessments payable by the borrower to third persons. Any lender who requires an escrow account shall not violate the provisions of }}}{{\f5\fs18\hyphpar0\qj{section 507B.5, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If any lender receives interest either in a manner or in an amount which is prohibited by }}}{{\f5\fs18\hyphpar0\qj{subsection 6}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the borrower shall have the right to recover all amounts collected or earned by the lender, whether or not from the borrower, in violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, plus attorney fees, plus court costs incurred in any action necessary to effect such recovery.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A lender shall not use an appraisal for any purpose in connection with making a loan under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ if the appraisal is performed by a person who is employed by or affiliated with any person receiving a commission or fee from the seller of the property. If a lender violates }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ the borrower is entitled to recover any actual damages plus the costs paid by the borrower, plus attorney fees incurred in an action necessary to effect recovery.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, S79, }{{\f5\fs18\hyphpar0\qj{C81, \'a7535.8}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 176, \'a71, 2}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 124, \'a719, 20}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 252, \'a739}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1141, \'a774}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1175, \'a7262}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 19, \'a7113, 114}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1160, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1191, \'a779, 80}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1017, \'a7133}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1037, \'a73 \u8211\'3f 6}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1148, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 81, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1033, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a716.18}}}{{\f5\fs12\hyphpar0\qj{, 524.905}}}{{\f5\fs12\hyphpar0\qj{, 533.315}}}{{\f5\fs12\hyphpar0\qj{, 535.2}}}{{\f5\fs12\hyphpar0\qj{, 535.10}}}{{\f5\fs12\hyphpar0\qj{, 536A.20}}}{{\f5\fs12\hyphpar0\qj{, 537.1301}}}{{\f5\fs12\hyphpar0\qj{, 537.2501}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{535.9}}}{\*\bkmkstart stylerid1_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Prepayment penalties on loans secured by real estate mortgages prohibited.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3floan\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a loan of money which is wholly or in part to be used for the purpose of purchasing real property which is a single-family or a two-family dwelling occupied or to be occupied by the borrower, or which is payable over a term of five years or less for the purpose of purchasing agricultural land. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLoan\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes the refinancing of a contract of sale, and the refinancing of a prior loan, whether or not the borrower also was the borrower under the prior loan, and the assumption of a prior loan.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Whenever a borrower under a loan prepays part or all of the outstanding balance of the loan the lender shall not receive an amount in payment of interest which is greater than the amount determined by applying the rate of interest agreed upon by the lender and the borrower to the unpaid balance of the loan for a period of time during which the borrower had the use of the money loaned; and the lender shall not impose any penalty or other charge in addition to the amount of interest due as a result of the repayment of that loan at a date earlier than is required by the terms of the loan agreement. A lender may, however, require advance notice of not more than thirty days of a borrower\u8217\'3fs intent to repay the entire outstanding balance of a loan if the payment of that balance, together with any partial prepayments made previously by the borrower, will result in the repayment of the loan at a date earlier than is required by the terms of the loan agreement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If any lender receives an amount of interest greater than permitted by }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, or imposes any penalty or other charge prohibited by }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the borrower shall have the right to recover all amounts paid the lender which are in excess of the amounts permitted by }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, plus attorney\u8217\'3fs fees and court costs incurred in any action necessary to effect such recovery.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, S79, }{{\f5\fs18\hyphpar0\qj{C81, \'a7535.9}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1075, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7533.315}}}{{\f5\fs12\hyphpar0\qj{, 535.8}}}{{\f5\fs12\hyphpar0\qj{, 536A.23}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{535.10}}}{\*\bkmkstart stylerid1_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Home equity line of credit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, the term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fhome equity line of credit\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an arrangement pursuant to which all of the following are applicable:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amounts borrowed and the interest and other charges are debited to an account.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The interest is computed on the account periodically.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The borrower has the right to pay in full at any time without penalty or to pay in the installments which are established by the loan agreement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The lender agrees to permit the borrower to borrow money from time to time with the maximum amount of each borrowing established by the loan agreement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The account is secured by an interest in real estate. The priority of the secured interest in the real estate shall be determined by }}}{{\f5\fs18\hyphpar0\qj{section 654.12A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, a home equity line of credit is subject to }}}{{\f5\fs18\hyphpar0\qj{chapter 537}}}{{\f5\fs18\hyphpar0\qj{. However, }}}{{\f5\fs18\hyphpar0\qj{sections 537.2307}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{537.2402}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{537.2510}}}{{\f5\fs18\hyphpar0\qj{ do not apply.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A lender may collect in connection with establishing or renewing a home equity line of credit the costs listed in }}}{{\f5\fs18\hyphpar0\qj{section 535.8, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, charges for insurance as described in }}}{{\f5\fs18\hyphpar0\qj{section 537.2501, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, and a loan processing fee as agreed between the borrower and the lender, and annually may collect an account maintenance fee of not more than fifteen dollars. Fees collected under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be disregarded for purposes of determining the maximum charge permitted by }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The parties to a home equity line of credit which is not a consumer credit transaction, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 537.1301}}}{{\f5\fs18\hyphpar0\qj{, may contract for a delinquency charge under terms no more favorable than those permitted for open-end credit under }}}{{\f5\fs18\hyphpar0\qj{section 537.2502}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The interest rate on a home equity line of credit shall not exceed one and three-quarters percent per month.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Real estate which is the consumer\u8217\'3fs principal dwelling shall not be subject to foreclosure when the balance secured is two thousand dollars or less.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1272, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 35, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 15, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1037, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 29, \'a784}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7535.17}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{535.11}}}{\*\bkmkstart stylerid1_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Finance charge on accounts receivable.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except where the parties have agreed in writing for the payment of a different finance charge or rate of interest, a creditor may charge a finance charge on the unpaid balances of an account receivable at a rate not exceeding that permitted by }}}{{\f5\fs18\hyphpar0\qj{subsection 3 or 4}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ if the creditor gives notice as required by }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As a condition of imposing a finance charge under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the creditor shall give notice to the debtor as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In a transaction that is subject to the Truth in Lending Act, the creditor shall give all disclosures as required by that Act and at the time or times required by that Act.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In a transaction that is not subject to the Truth in Lending Act, the creditor shall give written notice to the debtor at the time the debt arises. The notice shall be contained on the invoice or bill of sale evidencing the credit transaction, and shall disclose the rate of the finance charge and the date or day of the month before which payment must be received if the finance charge is to be avoided. With respect to open accounts, this notice shall be given at the time credit is initially extended; provided that additional advance notice in writing shall be given to the debtor not less than ninety days prior to any change in the terms of the agreement or of rate of the finance charge or date payment is due. For purposes of this paragraph, notice is given if the invoice or bill of sale is delivered with the goods, whether or not the debtor is present at the time of delivery.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fTruth in Lending Act\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means as defined in }}}{{\f5\fs18\hyphpar0\qj{section 537.1302}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{With respect to an account other than an open account, the creditor may impose a finance charge not exceeding that permitted by }}}{{\f5\fs18\hyphpar0\qj{section 537.2201, subsections 2 through 5}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{With respect to an open account, the creditor may impose a finance charge not exceeding that permitted by }}}{{\f5\fs18\hyphpar0\qj{section 537.2202, subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ffinance charge\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means as defined in }}}{{\f5\fs18\hyphpar0\qj{section 537.1301}}}{{\f5\fs18\hyphpar0\qj{; and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3faccount receivable\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a debt arising from the retail sale of goods or services or both on credit; and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fopen account\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an account receivable consisting of debt arising from the extension of open-end credit, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 537.1301}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not supersede any of the provisions of }}}{{\f5\fs18\hyphpar0\qj{chapter 537}}}{{\f5\fs18\hyphpar0\qj{, except that }}}{{\f5\fs18\hyphpar0\qj{section 537.3212}}}{{\f5\fs18\hyphpar0\qj{ does not apply to a consumer credit transaction in which a finance charge is imposed under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. }}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not authorize the compounding of a finance charge.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The finance charge authorized by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is in lieu of interest or a finance charge authorized under }}}{{\f5\fs18\hyphpar0\qj{section 535.2, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, or any other provision of law. The rate of a finance charge imposed pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is applicable to a judgment in an action on the account, notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 535.3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a creditor imposes a finance charge in violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the debtor shall have the right to recover all amounts unlawfully received by the creditor as finance charges, plus attorney\u8217\'3fs fees and court costs incurred in any action to effect recovery. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ does not limit remedies which may be available under }}}{{\f5\fs18\hyphpar0\qj{chapter 537}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{C81, \'a7535.11}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1153, \'a76, 18(1)}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1100, \'a772}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 80, \'a7340}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{535.12}}}{\*\bkmkstart stylerid1_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Loans by agricultural credit corporation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An agricultural credit corporation may lend money pursuant to a written promissory note or other writing evidencing the loan obligation, at a rate of interest which is not more than four percentage points above the lending rate in effect at the farm credit bank of Omaha, Nebraska, for the month during which the writing evidencing the loan obligation is made, provided that the loan is for an agricultural production purpose and further provided that the loan would, but for }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, be subject to the maximum rate of interest prescribed by }}}{{\f5\fs18\hyphpar0\qj{section 535.2, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On or prior to the first day of each calendar month following June 13, 1980, the superintendent of banking shall determine the maximum rate of interest which may be charged pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ on loans made by an agricultural credit corporation during that month, and shall cause the maximum rate to be published as soon after determination as possible, as a notice in the Iowa administrative bulletin or as a legal notice in a newspaper of general circulation published in Polk county. The maximum rate so determined shall be effective as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ regardless of the date of publication of the notice, except that no agricultural credit corporation shall be found in violation of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ solely on account of having made a loan on or prior to the day on which a notice of a maximum rate is published as provided in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, if the loan would have been lawful if made during the preceding calendar month.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not prohibit an agricultural credit corporation from lending money as otherwise permitted by law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAgricultural credit corporation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a corporation which has been designated by the farm credit bank of Omaha, Nebraska, as an agricultural credit corporation eligible to sell or discount loans to that bank pursuant to }}}{{\f5\fs18\hyphpar0\qj{12 U.S.C. \'a72075}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAgricultural production purpose\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a purpose related to the production of agricultural products. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAgricultural products\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes agricultural, horticultural, viticultural, and dairy products, livestock, wildlife, poultry, bees, forest products thereof, and any and all products produced on farms.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{C81, \'a7535.12}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 257, \'a726}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1092, \'a7190}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1011, \'a7104, 105}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7524.103}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{535.13}}}{\*\bkmkstart stylerid1_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{As used in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, unless the context otherwise requires:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAgricultural products\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes agricultural, horticultural, viticultural, and dairy products, livestock, wildlife, poultry, bees, forest products, fish and shellfish, and any products thereof, including processed and manufactured products, and any and all products raised or produced on farms and any processed or manufactured products thereof.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAgricultural purpose\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a purpose related to the production, harvest, exhibition, marketing, transportation, processing, or manufacture of agricultural products by a person who cultivates, plants, propagates, or nurtures the agricultural products.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{C81, \'a7535.13}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1153, \'a77}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2017 Acts, ch 29, \'a7155}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7535.2}}}{{\f5\fs12\hyphpar0\qj{, 558.70}}}{{\f5\fs12\hyphpar0\qj{, 615.1}}}{{\f5\fs12\hyphpar0\qj{, 615.3}}}{{\f5\fs12\hyphpar0\qj{, 628.26}}}{{\f5\fs12\hyphpar0\qj{, 628.28}}}{{\f5\fs12\hyphpar0\qj{, 654.20}}}{{\f5\fs12\hyphpar0\qj{, 655A.9}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{535.14}}}{\*\bkmkstart stylerid1_2E18_2E2_2E2}{\*\bkmkend stylerid1_2E18_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Prompt crediting of payment on loans secured by residential real property.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A lender is subject to the requirements set forth in }{{\f5\fs18\hyphpar0\qj{section 537.3206}}}{, regarding the prompt crediting of payments, with respect to a loan secured by a lien or security interest on owner-occupied residential real property. For purposes of }{{\f5\fs18\hyphpar0\qj{this section}}}{, }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fresidential real property\u8221\'3f}}}{ means residential real property as defined in }{{\f5\fs18\hyphpar0\qj{section 535B.1}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{99 Acts, ch 15, \'a72}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{535.15}}}{\*\bkmkstart stylerid1_2E19_2E2_2E2}{\*\bkmkend stylerid1_2E19_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Open-end credit and credit card disclosure.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/1999/CH0073.pdf" }{\fldrslt \cf5 \f5 \fs18{{99 Acts, ch 73, \'a71}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{535.16}}}{\*\bkmkstart stylerid1_2E2_30_2E2_2E2}{\*\bkmkend stylerid1_2E2_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Delivery of copies of debt documents.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A lender or other secured party shall provide to a debtor, at the time a document relating to a debt is signed, a copy of the document signed by the debtor. Receipt of a copy required by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ may be acknowledged anywhere on the document or on a separate acknowledgment of receipt.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A lender or other secured party shall provide to a debtor copies of all documents signed by the debtor relating to the debt at any other time, upon request, for a charge that shall not exceed the reasonable cost of copying the document.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1081, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 163, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1023, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1041, \'a7127}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{535.17}}}{\*\bkmkstart stylerid1_2E21_2E2_2E2}{\*\bkmkend stylerid1_2E21_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Requirements of credit agreements \u8212\'3f statute of frauds \u8212\'3f modifications.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A credit agreement is not enforceable in contract law by way of action or defense by any party unless a writing exists which contains all of the material terms of the agreement and is signed by the party against whom enforcement is sought.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Unless otherwise expressly agreed in writing, a modification of a credit agreement which occurs after the person asserting the modification has been notified in writing that oral or implied modifications to the credit agreement are unenforceable and should not be relied upon, is not enforceable in contract law by way of action or defense by any party unless a writing exists containing the material terms of the modification and is signed by the party against whom enforcement is sought. This notification can be included among the terms of a credit agreement, can be included on a separate form or together with other disclosures that are provided when the agreement is made, or can be given wholly apart from the agreement and at any time after the agreement has been made. To be effective, the notification and its language must be conspicuous. A person who gives a notification is bound by it to the same extent as the person notified. A notification with respect to any credit agreement is effective with respect to all other credit agreements then in effect between the parties if the notification conspicuously so provides. When a modification is required by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ to be in writing and signed, such requirement cannot be modified except by clear and explicit language in a writing signed by the person against whom the modification is to be enforced.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A notification referred to in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ in the following form in boldface, ten point type, complies with the requirements of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb80\ri1084\li1084\sa80{{\f5\fs18\hyphpar0\qj{\~\~}}}{IMPORTANT:}{{\f5\fs18\hyphpar0\qj{\~\~}}}{READ BEFORE SIGNING. The terms of this agreement should be read carefully because only those terms in writing are enforceable. No other terms or oral promises not contained in this written contract may be legally enforced. You may change the terms of this agreement only by another written agreement.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{subsections 1 and 2}}}{{\f5\fs18\hyphpar0\qj{, a credit agreement or modification of a credit agreement which is not in writing, but which is valid in other respects, is enforceable if the party against whom enforcement is sought admits in court that the agreement or modification was made, but no agreement or modification is enforceable under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ beyond the terms admitted.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, unless the context otherwise requires:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAction\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes petition, complaint, counterclaim, cross-claim, or any other pleading or proceeding to enforce affirmatively any right or duty or to recover damages for the nonperformance of any duty.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fContract\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a promise or set of promises for the breach of which the law would give a remedy or the performance of which the law would recognize a duty, and includes promissory obligations based on instruments and similar documents or on the contract doctrine of promissory estoppel.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCredit agreement\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any contract made or acquired by a lender to loan money, finance any transaction, or otherwise extend credit for any purpose, and includes all of the terms of the contract. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCredit agreement\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not mean a contract to loan money, finance a transaction, or otherwise extend credit by means of or pursuant to a credit card, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 537.1301, subsection 17}}}{{\f5\fs18\hyphpar0\qj{, or pursuant to open-end credit, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 537.1301, subsection 32}}}{{\f5\fs18\hyphpar0\qj{, or pursuant to a home equity line of credit, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 535.10}}}{{\f5\fs18\hyphpar0\qj{ whether the loan, financing, or credit is for consumer or business purposes or a consumer rental purchase agreement as defined in }}}{{\f5\fs18\hyphpar0\qj{section 537.3604, subsection 8}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDefense\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes setoff, recoupment, and any basis or means for barring or reducing liability or obligation on any claim.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLender\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any person primarily in the business of loaning money, or financing sales, leases, or other provision of property or services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fModification\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes change, addition, waiver, rescission, and any other variation of any kind whether expressly made or implied by, or inferred from, conduct of any kind.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ shall be interpreted and applied purposively to ensure that contract actions and defenses on credit agreements are supported by clear and certain written proof of the terms of such agreements to protect against fraud and to enhance the clear and predictable understanding of rights and duties under credit agreements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ entirely displaces principles of common law and equity that would make or recognize exceptions to or otherwise limit or dilute the force and effect of its provisions concerning the enforcement in contract law of credit agreements or modifications of credit agreements. However, }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ does not displace any additional or other requirements of contract law, which shall continue to apply, with respect to the making of enforceable contracts, including the requirement of consideration or other basis of validation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not apply to a credit agreement made primarily for a personal, family, or household purpose where the credit extended is twenty thousand dollars or less.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1176, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 54, \'a776}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{535.18}}}{\*\bkmkstart stylerid1_2E22_2E2_2E2}{\*\bkmkend stylerid1_2E22_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Consumer credit terms for service members }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ enforcement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The superintendent of banking and the superintendent of credit unions, as applicable, shall have the authority to enforce the consumer protection provisions of }{{\f5\fs18\hyphpar0\qj{10 U.S.C. \'a7987}}}{ concerning limitations on terms of consumer credit extended to service members and their dependents.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2010 Acts, ch 1171, \'a75}}}\par}}