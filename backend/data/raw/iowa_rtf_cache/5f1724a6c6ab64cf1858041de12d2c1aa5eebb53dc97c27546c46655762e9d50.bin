\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F542}{\*\bkmkend codeChapter_5F542}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 542}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{PUBLIC ACCOUNTANTS}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a710A.506}}}{{\f5\fs12\qc{, 11.31A}}}{{\f5\fs12\qc{, 15E.208}}}{{\f5\fs12\qc{, 80A.2}}}{{\f5\fs12\qc{, 99D.20}}}{{\f5\fs12\qc{, 99E.9}}}{{\f5\fs12\qc{, 99F.13}}}{{\f5\fs12\qc{, 203.16}}}{{\f5\fs12\qc{, 203C.24}}}{{\f5\fs12\qc{, 272C.1}}}{{\f5\fs12\qc{, 272C.6}}}{{\f5\fs12\qc{, 272C.9}}}{{\f5\fs12\qc{, 421.62}}}{{\f5\fs12\qc{, 669.14}}}{{\f5\fs12\qc{, 714E.1}}}{{\f5\fs12\qc{, 714H.4}}}\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{542.1}}}{\*\bkmkstart stylerid1_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Title.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This chapter}}}{ shall be known and may be cited as the }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fIowa Accountancy Act of 2001\u8221\'3f}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 55, \'a71, 38}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{542.2}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Legislative intent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{It is the policy of this state, and the purpose of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, to promote the reliability of information that is used for guidance in financial transactions or for accounting for or assessing the financial status or performance of commercial, noncommercial, and governmental enterprises. The reliance of the public in general and of the business community in particular on sound financial reporting imposes on persons engaged in such practice certain obligations both to their clients and to the public. These obligations, which }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ is intended to enforce, include the obligation to maintain independence in thought and action, to strive continuously to improve one\u8217\'3fs professional skills, to observe where applicable generally accepted accounting principles and generally accepted auditing standards, to promote sound and informative financial reporting, to hold the affairs of clients in confidence, and to maintain high standards of personal conduct in all matters affecting one\u8217\'3fs fitness to practice public accountancy. The public interest requires that persons professing special competence in accountancy or offering assurance as to the reliability or fairness of presentation of such information shall have demonstrated their qualifications to do so, and that persons who have not demonstrated and maintained such qualifications not be permitted to represent themselves as having such special competence or to offer such assurance; that the conduct of persons licensed as having special competence in accountancy be regulated in all aspects of their professional work; that a public authority competent to prescribe and assess the qualifications and to regulate the conduct of licensees be established; and that the use of titles that have a capacity or tendency to deceive the public as to the status or competence of the persons using such titles be prohibited.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 55, \'a72, 38}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{542.3}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{As used in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, unless the context otherwise requires:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAttest\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fattest service\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means providing any of the following services:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An audit or other engagement to be performed in accordance with the statements on auditing standards.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A review of a financial statement to be performed in accordance with the statements on standards for accounting and review services.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{ Any engagement to be performed in accordance with the statements on standards for attestation engagements.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any engagement to be performed in accordance with the standards of the public company accounting oversight board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The standards specified in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ are those standards adopted by the board, by rule, by reference to the standards developed for general application by the American institute of certified public accountants, the public company accounting oversight board, or other recognized national accountancy organization.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fBoard\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the Iowa accountancy examining board established under }}}{{\f5\fs18\hyphpar0\qj{section 542.4}}}{{\f5\fs18\hyphpar0\qj{ or its predecessor under prior law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCertificate\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a certificate as a certified public accountant issued under }}}{{\f5\fs18\hyphpar0\qj{section 542.6}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{542.19}}}{{\f5\fs18\hyphpar0\qj{, or a certificate issued under corresponding prior law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCertified public accountant\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person licensed by the board who holds a certificate issued under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or corresponding prior law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCertified public accounting firm\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a sole proprietorship, a corporation, a partnership, a limited liability company, or any other form of organization issued a permit to practice as a firm of certified public accountants under }}}{{\f5\fs18\hyphpar0\qj{section 542.7}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fClient\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person or entity that agrees with a licensee or licensee\u8217\'3fs employer to receive a professional service.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCommission\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a brokerage or other participation fee. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCommission\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include a contingent fee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCompilation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a service performed in accordance with statements on standards for accounting and review services and presented in the form of financial statements, which provides information that is the representation of management without undertaking to express any assurance on the statements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fContingent fee\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a fee established for the performance of a service pursuant to an arrangement under which a fee will not be charged unless a specified finding or result is attained, or under which the amount of the fee is otherwise dependent upon the finding or result of such service. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fContingent fee\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not mean a fee fixed by a court or other public authority, or a fee related to any tax matter which is based upon the results of a judicial proceeding or the findings of a governmental agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fHome office\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ is the location specified by the client as the address to which an attest or compilation service is directed, which may be a subunit or subsidiary or an entity or the principal office of an entity, as the board may further define by rule.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLicense\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a certificate issued under }}}{{\f5\fs18\hyphpar0\qj{section 542.6}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{542.19}}}{{\f5\fs18\hyphpar0\qj{, a permit issued under }}}{{\f5\fs18\hyphpar0\qj{section 542.7}}}{{\f5\fs18\hyphpar0\qj{, or a license issued under }}}{{\f5\fs18\hyphpar0\qj{section 542.8}}}{{\f5\fs18\hyphpar0\qj{; or a certificate, permit, or license issued under corresponding prior law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLicensed public accountant\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person licensed by the board who does not hold a certificate as a certified public accountant under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, and who offers to perform or performs for the public any of the following services:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Records financial transactions in books of record.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Makes adjustments of financial transactions in books of record.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Makes trial balances from books of record.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prepares internal verification and analysis of books or accounts of original entry.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prepares financial statements, schedules, or reports.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Devises and installs systems or methods of bookkeeping, internal controls of financial data, or the recording of financial data.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(7)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prepares compilations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Nothing contained in this definition or elsewhere in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall be construed to permit a licensed public accountant to give an opinion attesting to the reliability of any representation embracing financial information.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLicensed public accounting firm\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a sole proprietorship, a corporation, a partnership, a limited liability company, or any other form of organization issued a permit to practice as a firm of licensed public accountants under }}}{{\f5\fs18\hyphpar0\qj{section 542.8}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLicensee\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the holder of a license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fManager\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a manager of a limited liability company.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{16.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMember\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a member of a limited liability company.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{17.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fNASBA\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the national association of state boards of accountancy.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{18.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fOffice\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any Iowa workplace identified or advertised to the general public as a location where public accounting services are performed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{19.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPeer review\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a study, appraisal, or review of one or more aspects of the professional work of a licensee or firm that performs attest or compilation services, by a licensed person or persons who are not affiliated with the licensee or firm being reviewed. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPeer review\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include a peer review conducted pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 272C}}}{{\f5\fs18\hyphpar0\qj{ in connection with a disciplinary investigation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{20.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPeer review records\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a file, report, or other information relating to the professional competence of an applicant in the possession of a peer review team, or information concerning the peer review developed by a peer review team in the possession of an applicant. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPeer review records\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes peer review reports.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{21.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPeer review reports\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a study, appraisal, or review of one or more aspects of a certified public accounting firm\u8217\'3fs compliance with applicable accounting, auditing, and other attestation standards adopted by generally recognized standard-setting bodies.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{22.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPeer review team\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person or organization participating in the peer review function, but does not include the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{23.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPermit\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a permit to practice as either a certified public accounting firm issued under }}}{{\f5\fs18\hyphpar0\qj{section 542.7}}}{{\f5\fs18\hyphpar0\qj{ or licensed public accounting firm under }}}{{\f5\fs18\hyphpar0\qj{section 542.8}}}{{\f5\fs18\hyphpar0\qj{ or under corresponding provisions of prior law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{24.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPractice of public accounting\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the performance or the offering to perform, by a person holding oneself out to the public as a certified public accountant or a licensed public accountant, one or more kinds of professional services involving the use of accounting, attest, or auditing skills, including the issuance of reports on financial statements, or of one or more kinds of management advisory, financial advisory, or consulting services, or the preparation of tax returns or the furnishing of advice on tax matters. However, with respect to licensed public accountants, the }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fpractice of public accounting\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall not include attest or auditing services or the rendering of an opinion attesting to the reliability of any representation embracing financial information.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{25.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPractice privilege\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an authorization to practice public accounting in Iowa or for clients with a home office in Iowa without licensure under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, as provided in }}}{{\f5\fs18\hyphpar0\qj{section 542.20}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{26.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPrincipal place of business\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the primary location from which public accounting services are performed, as the board may further define by rule. A person or firm may only have one principal place of business at any one time.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{27.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fReport\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, when used with reference to any attest or compilation services, means a report, opinion, or other form of a writing that states or implies assurance as to the reliability of the attested information or compiled financial statements and that includes or is accompanied by a statement or implication that the person or firm issuing the report has special knowledge or competence in accounting or auditing. Such statement or implication of special knowledge or competence may arise from use by the issuer of the report of names or titles indicating that the person or firm is an accountant or auditor, or from the language of the report itself. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fReport\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes any form of language which disclaims an opinion when such form of language is conventionally understood to imply a positive assurance as to the reliability of the attested information or compiled financial statements referred to or special knowledge or competence on the part of the person or firm issuing the language, and any other form of language that is conventionally understood to imply such assurance or such special knowledge or competence.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{28.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fState\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a state of the United States, the District of Columbia, Puerto Rico, the United States Virgin Islands, the Commonwealth of the Northern Mariana Islands, or Guam.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{29.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSubstantial equivalency\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ is a determination by the board that the education, examination, and experience requirements contained in the statutes and administrative rules of another jurisdiction are comparable to, or exceed, the education, examination, and experience requirements contained in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or that an individual licensee\u8217\'3fs education, examination, and experience qualifications are comparable to or exceed the education, examination, and experience requirements contained in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 55, \'a73, 38}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1106, \'a71 \u8211\'3f 4, 15}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 127, \'a750, 89}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 13, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 78, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1085, \'a72, 3, 7, 8}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a711.31A}}}{{\f5\fs12\hyphpar0\qj{, 15.517}}}{{\f5\fs12\hyphpar0\qj{, 542.8}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2022 amendment to subsection 20 applies retroactively to July 1, 2002; }{{\f5\fs12\hyphpar0\qj{2022 Acts, ch 1085, \'a78}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 21 applies retroactively to July 1, 2002; }{{\f5\fs12\hyphpar0\qj{2022 Acts, ch 1085, \'a78}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{542.4}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Iowa accountancy examining board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An Iowa accountancy examining board is created within the department of inspections, appeals, and licensing to administer and enforce }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall consist of five members, appointed by the governor and subject to senate confirmation, all of whom shall be residents of this state. Four of the five members shall be holders of certificates issued under }}}{{\f5\fs18\hyphpar0\qj{section 542.6}}}{{\f5\fs18\hyphpar0\qj{ and one shall not be a certified public accountant or licensed public accountant and shall represent the general public. At least three of the holders of certificates issued under }}}{{\f5\fs18\hyphpar0\qj{section 542.6}}}{{\f5\fs18\hyphpar0\qj{ shall also be qualified to supervise attest services as provided in }}}{{\f5\fs18\hyphpar0\qj{section 542.7}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A certified or licensed member of the board shall be actively engaged in practice as a certified public accountant or as a licensed public accountant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Professional associations or societies composed of certified public accountants or licensed public accountants may recommend the names of potential board members to the governor. However, the governor is not bound by the recommendations. A board member is not required to be a member of any professional association or society composed of certified public accountants or licensed public accountants.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The term of each member of the board shall be three years, as designated by the governor, and appointments to the board are subject to the requirements of }}}{{\f5\fs18\hyphpar0\qj{sections 4A.12}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{69.19}}}{{\f5\fs18\hyphpar0\qj{. Vacancies occurring during a term shall be filled by appointment by the governor for the unexpired term. Upon the expiration of the member\u8217\'3fs term of office, a member shall continue to serve until a successor shall have been appointed and taken office.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The public members of the board shall be allowed to participate in administrative, clerical, or ministerial functions incident to giving the examinations, but shall not determine the content or determine the correctness of the answers. The licensed public accountant member shall not determine the content of the certified public accountant examination or determine the correctness of the answers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any member of the board whose certificate under }}}{{\f5\fs18\hyphpar0\qj{section 542.6}}}{{\f5\fs18\hyphpar0\qj{ or license under }}}{{\f5\fs18\hyphpar0\qj{section 542.8}}}{{\f5\fs18\hyphpar0\qj{ is revoked or suspended shall automatically cease to be a member of the board, and the governor may, after a hearing, remove any member of the board for neglect of duty or other just cause.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who has served three successive complete terms shall not be eligible for reappointment, but appointment to fill an unexpired term shall not be considered a complete term for this purpose.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall elect annually from among its members a chairperson and such other officers as the board may determine to be appropriate. The board shall meet at such times and places as may be fixed by the board. A majority of the board members in office shall constitute a quorum at any meeting. The board shall maintain a registry of the names and addresses of all licensees and permittees under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Members of the board are entitled to receive a per diem as specified in }}}{{\f5\fs18\hyphpar0\qj{section 7E.6}}}{{\f5\fs18\hyphpar0\qj{ for each day spent on performance of duties as members and shall be reimbursed for all actual and necessary expenses incurred in the performance of duties as members.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All moneys collected by the board from fees authorized to be charged by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall be received and accounted for by the board and shall be paid monthly to the treasurer of state for deposit in the licensing and regulation fund created in }}}{{\f5\fs18\hyphpar0\qj{section 10A.507}}}{{\f5\fs18\hyphpar0\qj{. Expenses of administering }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall be paid from moneys appropriated to the department pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 10A.507}}}{{\f5\fs18\hyphpar0\qj{ and from appropriations made by the general assembly, which expenses may include but shall not be limited to the costs of conducting investigations and of taking testimony and procuring the attendance of witnesses before the board or its committees; all legal proceedings taken under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ for the enforcement of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{; and educational programs for the benefit of the public and licensees and their employees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall maintain the confidentiality of information relating to the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The contents of the examination.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The examination results other than final score except for information about the results of the examination given to the person examined.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A member of the board who willfully communicates or seeks to communicate such information in a manner which violates confidentiality requirements, and any person who willfully requests, obtains, or seeks to obtain such information, is guilty of a simple misdemeanor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director of the department of inspections, appeals, and licensing shall provide staffing assistance to the board for implementing }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board may join professional organizations and associations to promote the improvement of the standards of the practice of accountancy and for the protection and welfare of the public. The board may provide social security numbers of licensees to NASBA, provided that the numbers are solely used by NASBA for inclusion in a national database of licensees, the numbers are submitted in an encrypted format or through such alternative means as will assure the confidentiality of the numbers, and NASBA maintains the confidentiality of the numbers and agrees not to disseminate the numbers to any other person or entity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall have the power to take all action that is necessary and proper to effectuate the purposes of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, including the power to sue and be sued in its official name as an agency of this state. The board shall also have the power to issue subpoenas to compel the attendance of witnesses and the production of documents; to administer oaths; to take testimony; to cooperate with the appropriate authorities in other states in investigation and enforcement concerning violations of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and comparable statutes of other states; and to receive evidence concerning all matters within the scope of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. In case of disobedience of a subpoena, the board may invoke the aid of any district court in requiring the attendance and testimony of witnesses and the production of documentary evidence.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ governing the administration and enforcement of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and the conduct of licensees and permittees. Rules adopted shall include but not be limited to the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Rules governing the board\u8217\'3fs meetings and the conduct of its business.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Rules of procedure governing the conduct of investigations and hearings by the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Rules specifying the educational and experience qualifications required for the issuance of a certificate under }}}{{\f5\fs18\hyphpar0\qj{section 542.6}}}{{\f5\fs18\hyphpar0\qj{ and the continuing professional education required for renewal of a certificate under }}}{{\f5\fs18\hyphpar0\qj{section 542.6}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Rules specifying the educational and experience qualifications required for the issuance of a license under }}}{{\f5\fs18\hyphpar0\qj{section 542.8}}}{{\f5\fs18\hyphpar0\qj{ and the continuing professional education required for renewal of a license under }}}{{\f5\fs18\hyphpar0\qj{section 542.8}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Rules of professional conduct directed to control the quality and probity of services provided by a licensee, and, among other areas, pertaining to a licensee\u8217\'3fs independence, integrity, and objectivity; competence and technical standards; responsibilities to the public; and responsibilities to a client.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Rules relating to the propriety of opinions on financial statements by a certified public accountant who is not independent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Rules relating to actions discreditable to the practice as a certified public accountant or licensed public accountant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Rules relating to professional confidences between a certified public accountant or licensed public accountant and a client.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Rules governing technical competence and the expression of opinions on financial statements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Rules governing the failure to disclose a material fact known to the certified public accountant or licensed public accountant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{k.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Rules relating to a material misstatement known to the certified public accountant or licensed public accountant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{l.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Rules governing negligent conduct in an examination or in making a report on an examination.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{m.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Rules governing failure to direct attention to any material departure from generally accepted accounting principles.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{n.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Rules governing the professional standards applicable to a licensee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{o.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Rules governing the manner and circumstances of use of the titles \u8220\'3fcertified public accountant\u8221\'3f and \u8220\'3fCPA\u8221\'3f.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{p.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Rules governing the manner and circumstances of use of the titles \u8220\'3faccounting practitioner\u8221\'3f and \u8220\'3fAP\u8221\'3f, and \u8220\'3flicensed public accountant\u8221\'3f and \u8220\'3fLPA\u8221\'3f.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{q.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Rules regarding peer review that may be required to be performed under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{r.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Rules on substantial equivalency under }}}{{\f5\fs18\hyphpar0\qj{section 542.19}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{s.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Rules on practice privilege under }}}{{\f5\fs18\hyphpar0\qj{section 542.20}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{t.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Such other rules as the board deems necessary or appropriate for administering }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, including but not limited to rules establishing fees and rules of professional conduct, pertaining to corporations or limited liability companies practicing accounting, which the board deems consistent with or required by the public welfare. The board may adopt rules governing the style, name, and title of corporations and limited liability companies and governing the affiliation of corporations and limited liability companies with other organizations.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 55, \'a74, 38}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1050, \'a758}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1177, \'a735}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1031, \'a759}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1059, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1106, \'a75, 6, 15}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71664, 1665}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 108, \'a741}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1004, \'a747}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1170, \'a7344}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a711.31A}}}{{\f5\fs12\hyphpar0\qj{, 542.3}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Confirmation, see }{{\f5\fs12\hyphpar0\qj{\'a72.32}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{542.5}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Qualifications for a certificate as a certified public accountant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A certificate as a certified public accountant may be granted to a person of good moral character who makes application pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 542.6}}}{{\f5\fs18\hyphpar0\qj{ and who satisfies the education, experience, and examination requirements of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and rules adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An applicant for a certificate who has been convicted of forgery, embezzlement, obtaining money under false pretenses, theft, extortion, conspiracy to defraud, or other similar offense, or of any crime involving moral character or honesty, in a court of competent jurisdiction in this state, or another state, territory, or a district of the United States, or in a foreign jurisdiction, may be denied a certificate by the board on the grounds of the conviction. For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fconviction\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a conviction for an indictable offense and includes a guilty plea, deferred judgment from the time of entry of the deferred judgment until the time the defendant is discharged by the court without entry of judgment, or other finding of guilt by a court of competent jurisdiction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An applicant for a certificate who has had a professional license of any kind revoked in this or any other jurisdiction may be denied a certificate by the board on the grounds of the revocation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who makes a false statement of material fact on an application for a certificate, or who causes to be submitted, or has been a party to preparing or submitting a false application for a certificate, may be denied a certificate by the board on the grounds of the false statement or submission. A certificate holder found to have made such a false statement or who has caused to be submitted, or was a party to preparing or submitting any false application for a certificate, may have the holder\u8217\'3fs certificate suspended or revoked by the board on the grounds of the false statement or submission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A certified public accountant shall notify the board of such accountant\u8217\'3fs conviction of an offense included in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, within thirty days of such conviction. Failure of the certified public accountant to notify the board of the conviction within thirty days of the date of the conviction is sufficient grounds for revocation of the certificate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board, when considering the denial or revocation of a certificate pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsections 2 through 5}}}{{\f5\fs18\hyphpar0\qj{, shall consider the nature of the offense; any aggravating or extenuating circumstances which are documented; the time lapsed since the revocation, conduct, or conviction; the rehabilitation, treatment, or restitution performed by the applicant or certificate holder; and any other factors the board deems relevant. Character references may be required, but shall not be obtained from certified public accountants. An applicant shall not be denied a certificate because of age, citizenship, race, religion, marital status, or national origin, although the application may require citizenship information.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An applicant shall complete at least one hundred fifty semester hours, or the trimester or quarter equivalent of one hundred fifty semester hours, of college education, and receive a baccalaureate or higher degree conferred by a college or university recognized by the board, the total educational program to include a concentration in accounting or what the board determines to be substantially equivalent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An applicant must pass an examination which shall be offered at least twice per year and which shall test the applicant\u8217\'3fs knowledge of the subjects of accounting and auditing, and such other related subjects as the board may specify by rule, including but not limited to business law and taxation. The examination shall be held at a time determined by the board and may be changed from time to time. The board shall prescribe by rule the methods of applying for and conducting the examination, including methods for grading and determining a passing grade required of an applicant for a certificate. However, the board, to the extent possible, shall ensure the examination, grading of the examination, and the passing grades are uniform with those applicable in all other states. The board may make such use of all or any part of a nationally recognized uniform certified public accountant examination and advisory grading service, and may contract with third parties to perform such administrative services with respect to the examination as it deems appropriate to perform the duties of the board with respect to examination.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board may admit to the examination a candidate who will complete the educational requirements for a baccalaureate degree with a concentration in accounting or what the board determines by rule to be substantially equivalent to a concentration in accounting within one hundred twenty days immediately following the date of the examination or who has completed those requirements. However, the board shall not report the results of the examination until the candidate has met the educational requirements for a baccalaureate degree and shall not issue the certificate until the candidate has fully satisfied the requirements of }}}{{\f5\fs18\hyphpar0\qj{subsection 7}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Applicants who fail the examination once shall be allowed to take the examination again at a time determined by the board. Applicants who fail the examination twice shall be allowed to take the examination again at the discretion of the board. The board may by rule prescribe the terms and conditions under which a candidate who passes two or more subjects of the examination conducted in this state or by the licensing authority of another state may be reexamined in only the failed subjects and receive credit for the passed subjects. An applicant who has failed the examination may request in writing information from the board concerning the applicant\u8217\'3fs examination grade and subject areas or questions which the applicant failed to answer correctly, except that if the board administers a uniform, standardized examination, the board shall only be required to provide the examination grade and such other information concerning the applicant\u8217\'3fs examination results which are available to the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board, by rule, may establish an examination fee to be charged each applicant by the board or by a third party administering the examination.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An applicant for initial issuance of a certificate must have no less than one year of experience. The experience shall include providing any type of service or advice involving the use of accounting, attest, compilation, management advisory, financial advisory, tax, or consulting skills, as verified by a licensee, meeting requirements prescribed by the board by rule. The experience is acceptable if it was gained through employment in government, industry, academia, or public practice.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person holding a certificate as a certified public accountant issued by the state prior to July 1, 2002, is deemed to have met the requirements of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 55, \'a75, 38}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1031, \'a760}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7542.6}}}{{\f5\fs12\hyphpar0\qj{, 542.7}}}{{\f5\fs12\hyphpar0\qj{, 542.8}}}{{\f5\fs12\hyphpar0\qj{, 542.10}}}{{\f5\fs12\hyphpar0\qj{, 542.19}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For future amendment to subsection 7, effective July 1, 2026, see }{{\f5\fs12\hyphpar0\qj{2025 Acts, ch 40, \'a71, 9}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For future strike of subsection 12, effective July 1, 2026, see }{{\f5\fs12\hyphpar0\qj{2025 Acts, ch 40, \'a72, 9}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For future amendment to subsection 13, effective July 1, 2026, see }{{\f5\fs12\hyphpar0\qj{2025 Acts, ch 40, \'a73, 9}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{542.6}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Issuance and renewal of certificates \u8212\'3f maintenance of competency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall issue a certificate to a person who makes application on a form prescribed and furnished by the board and who demonstrates either of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the person\u8217\'3fs qualifications, including where applicable the qualifications prescribed by }}}{{\f5\fs18\hyphpar0\qj{section 542.5}}}{{\f5\fs18\hyphpar0\qj{, satisfy the requirements of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, or that the person holds a certificate issued under prior law.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the person holds in good standing a certificate or license to practice as a certified public accountant in another state or equivalent designation from a foreign country, and is eligible under the substantial equivalency or other provisions of }}}{{\f5\fs18\hyphpar0\qj{section 542.19}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The holder of a certificate issued under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall only provide attest services in a certified public accounting firm that is issued a permit under }}}{{\f5\fs18\hyphpar0\qj{section 542.7}}}{{\f5\fs18\hyphpar0\qj{, or through a certified public accounting firm with a practice privilege under }}}{{\f5\fs18\hyphpar0\qj{section 542.20}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A certificate shall be initially issued, and renewed, for a period of not more than three years, but in any event shall expire on a date specified by rule. A person who fails to renew a certificate as a certified public accountant by the expiration date shall be allowed to do so within thirty days following its expiration, but the board may assess a reasonable penalty. The board shall specify by rule the conditions under which a lapsed certificate may be reinstated, including the imposition of administrative penalties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A certificate holder, for renewal of a certificate under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, shall participate in a program of learning designed to maintain professional competency. Such program of learning must comply with rules adopted by the board. The board, by rule, may grant an exception to this requirement for a certificate holder who does not perform or offer to perform for the public one or more kinds of services involving the use of accounting or auditing skills, including issuance of reports on financial statements or the use of one or more kinds of management advisory, financial advisory, or consulting services, or the preparation of tax returns or the furnishing of advice on tax matters. A certificate holder entitled to an exception by rule of the board shall place the word \u8220\'3finactive\u8221\'3f adjacent to the holder\u8217\'3fs certified public accountant title on any business card, letterhead, or other document or device, with the exception of the certificate holder\u8217\'3fs certified public accountant certificate, on which the certificate holder\u8217\'3fs certified public accountant title appears.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall charge an application fee for initial issuance or renewal of a certificate in an amount prescribed by the board by rule.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An applicant for initial issuance or renewal of a certificate shall list in the application all states in which the applicant has applied for or holds a certificate, license, or permit and list any past denial, revocation, or suspension of a certificate, license, or permit. A holder of or applicant for a certificate under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall notify the board in writing, within thirty days after its occurrence, of any issuance, denial, revocation, or suspension of a certificate, license, or permit by another state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board, by rule, shall require as a condition for renewal of a certificate under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, by any certificate holder who performs compilation services for the public other than through a certified public accounting firm or licensed public accounting firm, that such individual undergo, no more frequently than once every three years, a peer review conducted in such manner as the board shall by rule specify, and such review shall include verification that such individual has met the competency requirements set out in professional standards for such services. The provisions of }}}{{\f5\fs18\hyphpar0\qj{section 542.7, subsections 10, 11, and 12}}}{{\f5\fs18\hyphpar0\qj{, shall apply to the peer review required in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 55, \'a76, 38}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1106, \'a77, 15}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 78, \'a72}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7542.3}}}{{\f5\fs12\hyphpar0\qj{, 542.4}}}{{\f5\fs12\hyphpar0\qj{, 542.5}}}{{\f5\fs12\hyphpar0\qj{, 542.7}}}{{\f5\fs12\hyphpar0\qj{, 542.8}}}{{\f5\fs12\hyphpar0\qj{, 542.9}}}{{\f5\fs12\hyphpar0\qj{, 542.13}}}{{\f5\fs12\hyphpar0\qj{, 542.19}}}{{\f5\fs12\hyphpar0\qj{, 542.20}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{542.7}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Firm permits to practice \u8212\'3f attest experience and peer review.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall issue or renew a permit to practice to a certified public accounting firm that makes application and demonstrates the qualifications set forth in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. A person or firm holding a permit to practice issued by this state prior to July 1, 2002, is deemed to have met the requirements of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A firm must hold a permit issued under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ if the firm has an office in this state and uses the title \u8220\'3fCPAs\u8221\'3f, \u8220\'3fCPA firm\u8221\'3f, \u8220\'3fcertified public accountants\u8221\'3f, or \u8220\'3fcertified public accounting firm\u8221\'3f.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A firm which is not subject to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ may practice public accounting in this state without a permit issued under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ in conformance with }}}{{\f5\fs18\hyphpar0\qj{section 542.20}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A firm that holds a permit issued under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall designate to the board the licensee or nonlicensee owner who is responsible for the proper licensure of the firm and the firm\u8217\'3fs compliance with all applicable laws and rules of this state. If such firm has one or more offices in this state, the firm shall designate to the board one or more persons who are licensed under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ who are responsible for the proper registration of each Iowa office of the firm and each office\u8217\'3fs compliance with all applicable laws and rules of this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A permit shall be initially issued and renewed for a period of not more than three years, but in any event shall expire on a date specified by rule. An application for a permit shall be made in such form, and in the case of an application for renewal, between such dates as the board may by rule specify.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An applicant for initial issuance or renewal of a permit to practice as a firm shall show that notwithstanding any other provision of law, a simple majority of the ownership of the firm, in terms of financial interests and voting rights of all partners, officers, shareholders, members, and managers, belongs to holders of a certificate issued by a state, and that such partners, officers, shareholders, members, and managers, who perform professional services in this state or for clients in this state, hold a certificate issued under }}}{{\f5\fs18\hyphpar0\qj{section 542.6}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{542.19}}}{{\f5\fs18\hyphpar0\qj{, or by another state if the holder has a practice privilege under }}}{{\f5\fs18\hyphpar0\qj{section 542.20}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A certified public accounting firm may include a nonlicensee owner, which for purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ means an owner that does not hold a valid certificate to practice public accounting in any state, provided all of the following occur:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All nonlicensee owners are active participants in the firm or an affiliated entity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All nonlicensee owners comply with all applicable rules of professional conduct adopted by the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Such firm complies with other requirements as established by the board by rule.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{chapter 496C}}}{{\f5\fs18\hyphpar0\qj{ or any other provision of law to the contrary, a certified public accounting firm organized as a professional corporation under }}}{{\f5\fs18\hyphpar0\qj{chapter 496C}}}{{\f5\fs18\hyphpar0\qj{ may have nonlicensee owners provided that the firm complies with the requirements of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{chapter 489, subchapter XI}}}{{\f5\fs18\hyphpar0\qj{, or any other provision of law to the contrary, a certified public accounting firm organized as a professional limited liability company under }}}{{\f5\fs18\hyphpar0\qj{chapter 489, subchapter XI}}}{{\f5\fs18\hyphpar0\qj{, may have nonlicensee members provided that the professional limited liability company complies with the requirements of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensee or person with a practice privilege under }}}{{\f5\fs18\hyphpar0\qj{section 542.20}}}{{\f5\fs18\hyphpar0\qj{ who is responsible for supervising attest or compilation services and signs or authorizes someone to sign the accountant\u8217\'3fs report on behalf of the firm shall meet the experience or competency requirements set out in nationally recognized professional standards for such services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensee or person with a practice privilege under }}}{{\f5\fs18\hyphpar0\qj{section 542.20}}}{{\f5\fs18\hyphpar0\qj{ who signs or authorizes someone to sign the accountant\u8217\'3fs report on behalf of the firm shall meet the experience or competency requirements established in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board may deny the issuance or renewal of or revoke a permit, or otherwise discipline the holder of a permit issued under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, if a nonlicensee owner\u8217\'3fs professional license has been revoked in any jurisdiction or a nonlicensee owner has been convicted of a crime described in }}}{{\f5\fs18\hyphpar0\qj{section 542.5, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, if the board determines that such revocation or conviction is detrimental to the public interest and would be a ground for discipline if applicable to a licensee under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An applicant for initial issuance or renewal of a permit to practice as a certified public accounting firm is required to register each office of the firm within this state with the board and to show that all attest and compilation services rendered in this state are under the charge of a person holding a valid certificate issued under }}}{{\f5\fs18\hyphpar0\qj{section 542.6}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{542.19}}}{{\f5\fs18\hyphpar0\qj{, or by another state if the holder has a practice privilege under }}}{{\f5\fs18\hyphpar0\qj{section 542.20}}}{{\f5\fs18\hyphpar0\qj{. However, the requirements of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not apply to the office of auditor of state if the auditor of state otherwise complies with the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 11.31A}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board, by rule, shall establish and charge an application fee for each application for initial issuance or renewal of a permit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An applicant for initial issuance or renewal of a permit shall list in the application all states in which the applicant has applied for or holds a permit as a certified public accounting firm and list any past denial, revocation, or suspension of a permit by another state. A holder of or applicant for a permit shall notify the board in writing within thirty days after an occurrence of any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A change in the number or location of offices within this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A change in the identity of a person in charge of such offices.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The issuance, denial, revocation, or suspension of a permit by another state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A firm, after receiving or renewing a permit which is not in compliance with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ as a result of a change in firm ownership or personnel, shall take corrective action to bring the firm back into compliance as quickly as possible or apply to modify or amend the permit. The board may grant a reasonable period of time for a firm to take such corrective action. Failure to comply within a reasonable period as deemed by the board shall result in the suspension or revocation of the firm\u8217\'3fs permit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board, by rule, shall require as a condition of renewal of a permit to practice as a certified public accounting firm, that an applicant undergo, no more frequently than once every three years, a peer review conducted in such manner as the board specifies. The review shall include a verification that any individual in the firm who is responsible for supervising attest and compilation services and who signs or authorizes someone to sign the accountant\u8217\'3fs report on behalf of the firm meets the competency requirements set forth in the professional standards for such services.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Such rules shall include reasonable provision for compliance by an applicant showing that the applicant, within the preceding three years, has undergone a peer review that is a satisfactory equivalent to the peer review required under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. An applicant\u8217\'3fs completion of a peer review program endorsed or supported by the American institute of certified public accountants, or other substantially similar review as determined by the board, satisfies the requirements of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An applicant for a permit to practice as a certified public accounting firm, at the time of renewal, may request in writing upon forms provided by the board, a waiver from the requirements of }}}{{\f5\fs18\hyphpar0\qj{subsection 8}}}{{\f5\fs18\hyphpar0\qj{. The board may grant a waiver upon a showing satisfactory to the board of any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant does not engage in, and does not intend to engage in during the following year, financial reporting areas of practice, including but not limited to audits, compilations, and reviews. An applicant granted a waiver pursuant to this paragraph shall immediately notify the board if the applicant engages in such practice, and shall be subject to peer review.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reasons of health.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Military service.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Instances of hardship.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Other good cause as determined by the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Peer review records are privileged and confidential, and are not subject to discovery, subpoena, or other means of legal compulsion. Peer review records are not admissible in evidence in a judicial, administrative, or arbitration proceeding. Unless the subject of a peer review timely objects in writing to the administering entity of the peer review program, the administering entity shall make available to the board within thirty days of the issuance of the peer review acceptance letter the final peer review report or such peer review records as are designated by the peer review program in which the administering entity participates. The subject of a peer review may voluntarily submit the final peer review report directly to the board. Information or documents discoverable from sources other than a peer review team do not become nondiscoverable from such other sources because they are made available to or are in the possession of a peer review team. Information or documents publicly available from the American institute of certified public accountants relating to quality or peer review are not privileged or confidential under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. A person or organization participating in the peer review process shall not testify as to the findings, recommendations, evaluations, or opinions of a peer review team in a judicial, administrative, or arbitration proceeding.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{However, notwithstanding any provision of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ to the contrary, peer review reports concerning the office of auditor of state shall be considered a public record pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 22}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person is not liable as a result of an act, omission, or decision made in connection with the person\u8217\'3fs service on a peer review team, unless the act, omission, or decision is made with actual malice. A person is not liable as a result of providing information to a peer review team, or for disclosure of privileged matters to a peer review team.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The costs of the peer review shall be paid by the applicant.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 55, \'a77, 38}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1119, \'a7112}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 108, \'a7100}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1106, \'a78, 15}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 13, \'a73 \u8211\'3f 7}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 78, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1085, \'a74, 5, 7, 8}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 152, \'a7160, 161}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7542.3}}}{{\f5\fs12\hyphpar0\qj{, 542.4}}}{{\f5\fs12\hyphpar0\qj{, 542.6}}}{{\f5\fs12\hyphpar0\qj{, 542.7A}}}{{\f5\fs12\hyphpar0\qj{, 542.9}}}{{\f5\fs12\hyphpar0\qj{, 542.13}}}{{\f5\fs12\hyphpar0\qj{, 542.20}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2022 amendments to subsections 4 and 10 apply retroactively to July 1, 2002; }{{\f5\fs12\hyphpar0\qj{2022 Acts, ch 1085, \'a78}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{542.7A}}}{\*\bkmkstart stylerid1_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Office of auditor of state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The office of auditor of state shall qualify as a certified public accounting firm subject to the requirements of }}}{{\f5\fs18\hyphpar0\qj{sections 11.31}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{11.31A}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{542.7}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{section 542.7}}}{{\f5\fs18\hyphpar0\qj{, the auditor of state shall be deemed to be the owner of the office of auditor of state and the office of auditor of state shall be deemed to comply with the ownership requirements of }}}{{\f5\fs18\hyphpar0\qj{section 542.7}}}{{\f5\fs18\hyphpar0\qj{ if the auditor of state is a certified public accountant or all divisions of the office of auditor of state performing attest services are led by a certified public accountant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The provisions of }}}{{\f5\fs18\hyphpar0\qj{sections 542.9}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{542.17}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{542.18}}}{{\f5\fs18\hyphpar0\qj{ shall not apply to the office of auditor of state as a certified public accounting firm under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2022 Acts, ch 1085, \'a76, 7, 8}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section applies retroactively to July 1, 2002; }{{\f5\fs12\hyphpar0\qj{2022 Acts, ch 1085, \'a78}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{542.8}}}{\*\bkmkstart stylerid1_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Qualifications for and issuance of a license as a licensed public accountant \u8212\'3f renewal of license \u8212\'3f firm registration \u8212\'3f peer review.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The license of a licensed public accountant shall be granted by the board to any person who meets one of the following requirements:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant holds a license as an accounting practitioner issued under the laws of this state in full force and effect on July 1, 2002, and has completed additional educational requirements as prescribed by the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant has satisfactorily completed the examination prescribed in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ after having met one of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant has had two or more years\u8217\'3f actual experience in practice as an accountant as an employee of a certified public accountant, an accounting practitioner, or a licensed public accountant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant submits evidence satisfactory to the board that the applicant is a graduate of a four-year college or university accredited by the north central accreditation association or other regional accreditation association having equivalent standards, with a major in accounting, or that the applicant is a graduate in accountancy from a business or correspondence school accredited by the accrediting commission for business schools or the accrediting commission of the national home study council.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant submits evidence of at least five years of continuous experience engaged in performing any of the services delineated in }}}{{\f5\fs18\hyphpar0\qj{section 542.3, subsection 12}}}{{\f5\fs18\hyphpar0\qj{, on a full-time basis.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An examination shall be conducted by the board as often as deemed necessary, but not less than two times per year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The examination shall be designed and given in a manner as to fairly test the applicant\u8217\'3fs knowledge of accounting. The examination shall not include questions relating to the subject of auditing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board, in its discretion, may use all or any part of a standard or uniform examination and advisory grading service that is provided or furnished by a national accounting organization or society to assist the board in the performance of its duties under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. The identity of the person taking the examination shall be concealed until after the examination papers have been graded.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If an applicant has partially passed an examination given in another state determined by the board to be substantially equivalent to the examination required by this state and meets eligibility requirements that the board finds to be substantially equivalent to those prescribed by this state, the results of the other state\u8217\'3fs examination shall be accepted as though given in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An applicant who successfully passes all subjects in which examined shall be issued a license as a licensed public accountant by the board. The cost of the license shall be based upon the administrative costs of the board and the costs of issuing the license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An applicant who fails the examination once shall be allowed to take the examination at the next scheduled time. Thereafter, the applicant shall be allowed to take the examination at the discretion of the board. An applicant who passes a portion of the examination shall have the right to be reexamined in the remaining subjects at a future examination, and if the applicant passes the remaining subjects, the applicant shall be considered to have passed the entire examination. An applicant who fails the examination may request in writing information from the board concerning the applicant\u8217\'3fs examination grade and subject areas or questions which the applicant failed to answer correctly, except that if the board administers a uniform, standardized examination, the board shall only be required to provide the examination grade and such other information concerning the applicant\u8217\'3fs examination results which is available to the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An applicant for initial issuance of a license must have no less than one year of experience. The experience shall include providing any type of service or advice involving the use of accounting, compilation, management advisory, financial advisory, tax, or consulting skills, as verified by a licensee, meeting requirements prescribed by the board by rule. The experience is acceptable if gained through employment in government, industry, academia, or public practice.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The licensed public accountant license shall expire in intervals as determined by the board. The board shall notify a person licensed under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ of the date of expiration of the license and the amount of the fee required for its renewal. The notice shall be mailed at least one month in advance of the expiration date. A person who fails to renew a license as a licensed public accountant by the expiration date shall be allowed to do so within thirty days following its expiration, but the board may assess a reasonable penalty.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensee, for renewal of a license under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, shall participate in a program of learning designed to maintain professional competency. Such program of learning must comply with rules adopted by the board. The board, by rule, may grant an exception to this requirement for a licensee who does not perform or offer to perform for the public one or more kinds of services involving the use of accounting or auditing skills, including issuance of reports on financial statements or the use of one or more kinds of management advisory, financial advisory, or consulting services, or the preparation of tax returns or the furnishing of advice on tax matters. A licensee entitled to an exception by rule of the board shall place the word \u8220\'3finactive\u8221\'3f adjacent to the licensee\u8217\'3fs licensed public accountant title on any business card, letterhead, or other document or device, with the exception of the licensee\u8217\'3fs licensed public accountant license, on which the licensee\u8217\'3fs licensed public accountant title appears.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board, in its discretion, may waive an examination and issue a license as a licensed public accountant to an applicant for one of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant holds a license as a licensed public accountant, an accounting practitioner, or similar title issued, after examination, by a state which extends by substantial equivalency privileges to a licensed public accountant of this state, and who, at the time of issuance of the registration, possessed the basic qualifications set forth in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant has passed the examination required under the laws of another state and possesses the basic qualifications set forth in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ at the time the applicant applied for registration in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person applying for a license as a licensed public accountant shall pay a fee as determined by the board based upon the costs of issuing such licenses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall issue or renew a permit to practice as a licensed public accounting firm to a person that makes application and demonstrates the qualification set forth in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ or to a licensed public accounting firm originally registered in another state that provides evidence that the qualifications met in the other state are substantially equivalent to those required by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. A firm must hold a permit issued under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ in order to use the title \u8220\'3fLPAs\u8221\'3f or \u8220\'3fLicensed Public Accountants\u8221\'3f in a firm name.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An applicant for initial issuance or renewal of a permit to practice as a firm under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ must show that notwithstanding any other provision of law, a simple majority of the ownership of the firm, in terms of financial interests and voting rights of all partners, officers, shareholders, members, and managers, belongs to the holders of a certificate or license issued by a state, and that such partners, officers, shareholders, members, and managers who perform professional services in this state or for clients in this state hold a certificate issued under }}}{{\f5\fs18\hyphpar0\qj{section 542.6}}}{{\f5\fs18\hyphpar0\qj{ or a license issued under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, or another state if the holder has a practice privilege under }}}{{\f5\fs18\hyphpar0\qj{section 542.20}}}{{\f5\fs18\hyphpar0\qj{. To qualify for firm licensure at least one partner, officer, shareholder, member, or manager shall hold a license under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensed public accounting firm may include a nonlicensee owner, which for purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ means an owner that does not hold a valid license or certificate to practice public accounting in any state, provided all of the following occur:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Such firm designates a licensee who is responsible for the proper registration of the firm, and identifies that individual to the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All nonlicensee owners are of good moral character and active participants in the firm or an affiliated entity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All nonlicensee owners comply with all applicable rules of professional conduct adopted by the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Such firm complies with other requirements as established by the board by rule.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An individual licensee or person with a practice privilege under }}}{{\f5\fs18\hyphpar0\qj{section 542.20}}}{{\f5\fs18\hyphpar0\qj{ who is responsible for compilation services and signs or authorizes someone to sign the accountant\u8217\'3fs report on behalf of the firm shall meet the competency requirements set out in nationally recognized professional standards for such services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An individual licensee or person with a practice privilege under }}}{{\f5\fs18\hyphpar0\qj{section 542.20}}}{{\f5\fs18\hyphpar0\qj{ who signs or authorizes someone to sign the accountant\u8217\'3fs report on behalf of the firm shall meet the competency requirements set out in nationally recognized professional standards for such services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board may deny the issuance or renewal of, or revoke a permit, or otherwise discipline the holder of a permit issued under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ if a nonlicensee owner\u8217\'3fs professional license has been revoked in any jurisdiction or a nonlicensee owner has been convicted of a crime described in }}}{{\f5\fs18\hyphpar0\qj{section 542.5, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, if the board determines that such revocation or conviction is detrimental to the public interest and would be a ground for discipline if applicable to a licensee under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An applicant for initial issuance or renewal of a permit to practice as a licensed public accounting firm is required to register each office of the firm within this state with the board and to show that all compilation services rendered in this state are under the charge of a person holding a valid certificate issued under }}}{{\f5\fs18\hyphpar0\qj{section 542.6}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{542.19}}}{{\f5\fs18\hyphpar0\qj{, or a license issued under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, or another state if the holder has a practice privilege under }}}{{\f5\fs18\hyphpar0\qj{section 542.20}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board, by rule, shall establish and charge an application fee for each application for initial issuance or renewal of a permit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An applicant for initial issuance or renewal of a permit shall list in the application all states in which the applicant has applied for or holds a permit as a certified public accountant or a licensed public accounting firm and list any past denial, revocation, or suspension of a permit by another state. A holder of or applicant for a permit shall notify the board in writing within thirty days after an occurrence of any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A change in the identity of a partner, officer, shareholder, member, or manager who performs professional services in this state or for clients in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A change in the number or location of offices within this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A change in the identity of a person in charge of such offices.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The issuance, denial, revocation, or suspension of a permit by another state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{16.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A firm, after receiving or renewing a permit which is not in compliance with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ as a result of a change in firm ownership or personnel, shall take corrective action to bring the firm back into compliance as quickly as possible or apply to modify or amend the permit. The board may grant a reasonable period of time for a firm to take such corrective action. Failure to comply within a reasonable period as deemed by the board shall result in the suspension or revocation of the firm permit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{17.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board, by rule, shall require as a condition of renewal of a permit to practice as a licensed public accounting firm, that an applicant undergo, no more frequently than once every three years, a peer review conducted in such manner as the board specifies. The review shall include verification that any individual in the firm who is responsible for supervising compilation services and who signs or authorizes someone to sign the accountant\u8217\'3fs report on a financial statement on behalf of the firm meets the competency requirements set forth in the professional standards for such services. Such rules shall include reasonable provision for compliance by an applicant showing that the applicant, within the preceding three years, has undergone a peer review that is a satisfactory equivalent to the peer review required under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. An applicant\u8217\'3fs completion of a peer review program endorsed or supported by the national society of accountants, or other substantially similar review as determined by the board, satisfies the requirements of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{18.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An applicant for a permit to practice as a licensed public accounting firm, at the time of renewal, may request in writing upon forms provided by the board, a waiver from the requirements of }}}{{\f5\fs18\hyphpar0\qj{subsection 17}}}{{\f5\fs18\hyphpar0\qj{. The board may grant a waiver upon a showing satisfactory to the board of any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant does not engage in, and does not intend to engage in during the following year, financial reporting areas of practice, including but not limited to compilations. An applicant granted a waiver pursuant to this paragraph shall immediately notify the board if the applicant engages in such practice, and shall be subject to peer review.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reasons of health.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Military service.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Instances of hardship.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Other good cause as determined by the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{19.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Peer review records are privileged and confidential, and are not subject to discovery, subpoena, or other means of legal compulsion. Peer review records are not admissible in evidence in a judicial, administrative, or arbitration proceeding. Unless the subject of a peer review timely objects in writing to the administering entity of the peer review program, the administering entity shall make available to the board within thirty days of the issuance of the peer review acceptance letter the final peer review report or such peer review records as are designated by the peer review program in which the administering entity participates. The subject of a peer review may voluntarily submit the final peer review report directly to the board. Information or documents discoverable from sources other than a peer review team do not become nondiscoverable from such other sources because they are made available to or are in the possession of a peer review team. Information or documents publicly available from the national society of accountants relating to quality or peer review are not privileged or confidential under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. A person or organization participating in the peer review process shall not testify as to the findings, recommendations, evaluations, or opinions of a peer review team in a judicial, administrative, or arbitration proceeding.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{20.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person is not liable as a result of an act, omission, or decision made in connection with the person\u8217\'3fs service in a peer review team, unless the act, omission, or decision is made with actual malice. A person is not liable as a result of providing information to a peer review team, or for disclosure of privileged matters to a peer review team.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{21.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The costs of the peer review shall be paid by the applicant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{22.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board, by rule, shall require as a condition for renewal of a license under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ by any license holder who performs compilation services for the public other than through a licensed public accounting firm or a certified public accounting firm, that such individual undergo, no more frequently than once every three years, a peer review conducted in such manner as the board shall by rule specify, and such review shall include verification that such individual has met the competency requirements set out in professional standards for such services.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 55, \'a78, 38}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 108, \'a7101}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1106, \'a79, 10, 15}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1055, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 78, \'a74, 5}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7542.3}}}{{\f5\fs12\hyphpar0\qj{, 542.4}}}{{\f5\fs12\hyphpar0\qj{, 542.9}}}{{\f5\fs12\hyphpar0\qj{, 542.13}}}{{\f5\fs12\hyphpar0\qj{, 542.20}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{542.9}}}{\*\bkmkstart stylerid1_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Appointment of secretary of state as agent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Application for a certificate under }{{\f5\fs18\hyphpar0\qj{section 542.6}}}{, a license under }{{\f5\fs18\hyphpar0\qj{section 542.8}}}{, a permit to practice under }{{\f5\fs18\hyphpar0\qj{section 542.7}}}{, or a certificate under }{{\f5\fs18\hyphpar0\qj{section 542.19}}}{ by a person or a firm not a resident of this state constitutes appointment of the secretary of state as the applicant\u8217\'3fs agent upon whom process may be served in any action or proceeding against the applicant arising out of a transaction or operation connected with or incidental to services performed by the applicant while a licensee within this state.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 55, \'a79, 38}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7542.7A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{542.10}}}{\*\bkmkstart stylerid1_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Enforcement against a holder of a certificate, permit, or license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{After notice and hearing pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 542.11}}}{{\f5\fs18\hyphpar0\qj{, the board may revoke, suspend for a period of time not to exceed two years, or refuse to renew a license; reprimand, censure, or limit the scope of practice of any licensee; impose an administrative penalty not to exceed one thousand dollars per violation against an individual licensee or ten thousand dollars per violation against a firm licensee; require remedial actions; or place any licensee on probation; all with or without terms, conditions, and in combinations of remedies, for any one or more of the following reasons:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Fraud or deceit in obtaining a license, which may also result in permanent revocation of the license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Dishonesty, fraud, or gross negligence in the practice of public accounting.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Engaging in any activity prohibited under }}}{{\f5\fs18\hyphpar0\qj{section 542.13}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{542.20}}}{{\f5\fs18\hyphpar0\qj{ or permitting persons under the licensee\u8217\'3fs supervision to do so.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Violation of a rule of professional conduct adopted by the board under the authority granted by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Conviction of a felony under the laws of any state or the United States.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Conviction of any crime, any element of which is dishonesty or fraud as provided in }}}{{\f5\fs18\hyphpar0\qj{section 542.5, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, under the laws of any state or the United States.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Cancellation, revocation, suspension, or refusal to renew the authority to practice as a certified public accountant, licensed public accountant, or accounting practitioner, or the acceptance of the voluntary surrender of a license to practice as a certified public accountant, licensed public accountant, or accounting practitioner to conclude a pending disciplinary action, by any other state or foreign authority for any cause other than failure to pay appropriate fees in the other jurisdiction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Suspension or revocation of the right to practice before any state or federal agency, or the public company accounting oversight board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Conduct discreditable to the public accounting profession.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Violation of }}}{{\f5\fs18\hyphpar0\qj{section 272C.10}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Multiple violations arising from the same factual circumstances or from different factual circumstances containing a common error shall be considered as a single violation for the purpose of imposition of an administrative penalty.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In lieu of or in addition to any remedy specifically provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, the board may require a licensee to satisfy a peer review or desk review process on such terms as the board may specify, satisfactorily complete a continuing education program, or such additional remedies as the board may specify by rule.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 55, \'a710, 38}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1106, \'a711, 15}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7272C.3}}}{{\f5\fs12\hyphpar0\qj{, 272C.4}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{542.11}}}{\*\bkmkstart stylerid1_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Investigations and hearings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board may initiate proceedings under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ upon written complaint or on its own motion pursuant to other information received by the board suggesting violations of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or board rules. The board may conduct an investigation as needed to determine whether probable cause exists to initiate such proceedings. In aid of such investigation, the board may issue subpoenas to compel witnesses to testify or persons to produce evidence consistent with the provisions of }}}{{\f5\fs18\hyphpar0\qj{section 272C.6, subsection 3}}}{{\f5\fs18\hyphpar0\qj{. The board may also review the publicly available public accounting work product of licensees on a general or random basis to determine whether reasonable grounds exist to initiate proceedings under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or to conduct a more specific investigation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A written notice stating the nature of the charge or charges against the accused and the time and place of the hearing before the board on the charges shall be served on the accused not less than thirty days prior to the date of hearing either personally or by mailing a copy by restricted certified mail to the last known address of the accused.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At any hearing, the accused may appear in person or by counsel, produce evidence and witnesses on behalf of the accused, cross-examine witnesses, and examine evidence which is produced against the accused. A firm may appear by a partner, officer, director, shareholder, member, or manager.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board may issue subpoenas in any proceeding to compel witnesses to testify and to produce documentary evidence on behalf of the board and shall issue such subpoenas upon the application of the accused, pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 17A.13, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{section 272C.6, subsection 3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Evidence supporting the board\u8217\'3fs charges may be presented at any hearing by an assistant attorney general.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The decision of the board shall be by a majority vote of a quorum of the board. Licensee discipline shall only be imposed upon the majority vote of the members of the board not disqualified pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 17A.17, subsection 8}}}{{\f5\fs18\hyphpar0\qj{, or other applicable law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Judicial review may be sought in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 55, \'a711, 38}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7272C.5}}}{{\f5\fs12\hyphpar0\qj{, 542.10}}}{{\f5\fs12\hyphpar0\qj{, 542.14}}}{{\f5\fs12\hyphpar0\qj{, 542.15}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{542.12}}}{\*\bkmkstart stylerid1_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Reinstatement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In any case in which the board has suspended, revoked, or restricted a license, refused to renew a license, or accepted the voluntary surrender of a license to conclude a pending disciplinary investigation or action, the board may, upon written application, modify or terminate the suspension, reissue the license, or modify or remove the restriction, with or without terms and conditions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board is vested with discretionary authority to specify by rule the manner in which such applications shall be made, the times within which they shall be made, the circumstances in which a hearing will be held, and the grounds upon which such applications will be decided. The rules shall provide at a minimum that the burden is on the licensee to produce evidence that the basis for revocation, suspension, restriction, refusal to renew, or voluntarily surrender no longer exists and that it will be in the public interest for the board to grant the application on such terms and conditions as the board deems desirable.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 55, \'a712, 38}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{542.13}}}{\*\bkmkstart stylerid1_2E18_2E2_2E2}{\*\bkmkend stylerid1_2E18_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Unlawful acts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Only a certified public accountant may issue a report on financial statements of a person, firm, organization, or governmental unit, or offer to render or render any attest service. Only a certified public accountant or licensed public accountant may render compilation services. This restriction does not prohibit such acts by a public official or public employee in the performance of that person\u8217\'3fs duties; or prohibit the performance by any nonlicensee of other services involving the use of accounting skills, including the preparation of tax returns, management advisory services, and the preparation of financial statements without the issuance of reports on such financial statements. A nonlicensee may prepare financial statements and issue nonattest transmittals or information on such statements or transmittals which do not purport to be in compliance with the statements on standards for accounting and review services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensee performing attest or compilation services must provide those services consistent with professional standards.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person not holding a certificate shall not use or assume the title \u8220\'3fcertified public accountant\u8221\'3f or the abbreviation \u8220\'3fCPA\u8221\'3f or any other title, designation, words, letters, abbreviation, sign, card, or device tending to indicate that such person is a certified public accountant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A firm shall not provide attest services or assume or use the title \u8220\'3fcertified public accountants\u8221\'3f or the abbreviation \u8220\'3fCPAs\u8221\'3f or any other title, designation, words, letters, abbreviation, sign, card, or device tending to indicate that such firm is a certified public accounting firm unless the firm holds a permit issued under }}}{{\f5\fs18\hyphpar0\qj{section 542.7}}}{{\f5\fs18\hyphpar0\qj{ and ownership of the firm satisfies the requirements of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and rules adopted by the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not assume or use the title \u8220\'3flicensed public accountant\u8221\'3f or the abbreviation \u8220\'3fLPA\u8221\'3f or any other title, designation, words, letters, abbreviation, sign, card, or device tending to indicate that such person is a licensed public accountant unless that person holds a license issued under }}}{{\f5\fs18\hyphpar0\qj{section 542.8}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A firm not holding a permit issued under }}}{{\f5\fs18\hyphpar0\qj{section 542.8}}}{{\f5\fs18\hyphpar0\qj{ shall not assume or use the title \u8220\'3flicensed public accountants\u8221\'3f, the abbreviation \u8220\'3fLPAs\u8221\'3f, or any other title, designation, words, letters, abbreviation, sign, card, or device tending to indicate that such firm is composed of licensed public accountants.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person or firm not holding a certificate, permit, or license issued under }}}{{\f5\fs18\hyphpar0\qj{section 542.6}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{542.7}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{542.8}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{542.19}}}{{\f5\fs18\hyphpar0\qj{ shall not assume or use the title \u8220\'3fcertified accountant\u8221\'3f, \u8220\'3fchartered accountant\u8221\'3f, \u8220\'3fenrolled accountant\u8221\'3f, \u8220\'3flicensed accountant\u8221\'3f, \u8220\'3fregistered accountant\u8221\'3f, \u8220\'3faccredited accountant\u8221\'3f, or any other title or designation likely to be confused with the title \u8220\'3fcertified public accountant\u8221\'3f or \u8220\'3flicensed public accountant\u8221\'3f, or use any of the abbreviations \u8220\'3fCA\u8221\'3f, \u8220\'3fLA\u8221\'3f, \u8220\'3fRA\u8221\'3f, \u8220\'3fAA\u8221\'3f, or similar abbreviation likely to be confused with the abbreviation \u8220\'3fCPA\u8221\'3f or \u8220\'3fLPA\u8221\'3f. The title \u8220\'3fenrolled agent\u8221\'3f or \u8220\'3fEA\u8221\'3f may be used by individuals so designated by the internal revenue service. Nothing in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall restrict truthful advertising of a bona fide credential or title which in context is not deceptive or misleading to the public.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A nonlicensee shall not use language in any statement relating to the affairs of a person or entity which is conventionally used by licensees in reports on financial statements or any attest service. The board shall develop and issue language which nonlicensees may use in connection with such financial information.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person or firm not holding a certificate, permit, or license issued under }}}{{\f5\fs18\hyphpar0\qj{section 542.6}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{542.7}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{542.8}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{542.19}}}{{\f5\fs18\hyphpar0\qj{ shall not assume or use any title or designation that includes the word \u8220\'3faccountant\u8221\'3f, \u8220\'3fauditor\u8221\'3f, or \u8220\'3faccounting\u8221\'3f in connection with any other language that implies that such person or firm holds such a certificate, permit, or license or has special competence as an accountant or auditor. However, }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ does not prohibit an officer, partner, member, manager, or employee of a firm or organization from affixing that person\u8217\'3fs own signature to a statement in reference to the financial affairs of such firm or organization with wording which designates the position, title, or office that the person holds, or prohibit any act of a public official or employee in the performance of such person\u8217\'3fs duties. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ does not otherwise prohibit the use of the title or designation \u8220\'3faccountant\u8221\'3f by persons other than those holding a certificate or license under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person holding a certificate or license or firm holding a permit under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall not use a professional or firm name or designation that is misleading about the legal form of the firm, or about the persons who are partners, officers, members, managers, or shareholders of the firm, or about any other matter. However, the name of one or more former partners, members, managers, or shareholders may be included in the name of a firm or its successor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not apply to a person or firm holding a certification, designation, degree, or license granted in a foreign country entitling the holder to engage in the practice of public accountancy or its equivalent in such country, whose activities in this state are limited to providing professional services to a person or firm who is a resident of, government of, or business entity of the country in which the person holds such entitlement, who does not perform attest or compilation services, and who does not issue reports with respect to the information of any other person, firm, or governmental unit in this state, and who does not use in this state any title or designation other than the one under which the person practices in such country, followed by a translation of such title or designation into the English language, if it is in a different language, and by the name of such country.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A holder of a certificate issued under }}}{{\f5\fs18\hyphpar0\qj{section 542.6}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{542.19}}}{{\f5\fs18\hyphpar0\qj{ shall not perform attest services in a firm that does not hold a permit issued under }}}{{\f5\fs18\hyphpar0\qj{section 542.7}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An individual licensee shall not issue a report in standard form upon a compilation of financial information through any form of business that does not hold a permit issued under }}}{{\f5\fs18\hyphpar0\qj{section 542.7}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{542.8}}}{{\f5\fs18\hyphpar0\qj{ unless the report discloses the name of the business through which the individual is issuing the report and the individual licensee does all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Signs the compilation report identifying the individual as a certified public accountant or licensed public accountant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Meets competency requirements provided in applicable standards.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Undergoes, no less frequently than once every three years, a peer review conducted in a manner as specified by the board. The review shall include verification that such individual has met the competency requirements set out in professional standards for such services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not prohibit a practicing attorney from preparing or presenting records or documents customarily prepared by an attorney in connection with the attorney\u8217\'3fs professional work in the practice of law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensee shall not for a commission recommend or refer a client to any product or service, or for a commission recommend or refer another person to any product or service to be supplied by a client, or receive a commission, when the licensee also performs for that client any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An audit or review of a financial statement.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A compilation of a financial statement when the licensee expects, or reasonably might expect, that a third party will use the financial statement and the licensee\u8217\'3fs compilation report does not disclose a lack of independence.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An examination of prospective financial information.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The prohibitions under this paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ apply during the period in which the licensee is engaged to perform any of the services identified in subparagraph (1), subparagraph divisions (a) through (c), and the period covered by any historical financial statements involved in such services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensee who is not prohibited by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ from performing services for or receiving a commission and who is paid or expects to be paid a commission shall disclose that fact to any person or entity to whom the licensee recommends or refers a product or service to which the commission relates.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensee who accepts a referral fee for recommending a service of a licensee or referring a licensee to any person or entity or who pays a referral fee to obtain a client shall disclose such acceptance or payment to the client.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{16.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensee shall not do any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Perform professional services for a contingent fee, or receive such fee from a client for whom the licensee or the licensee\u8217\'3fs firm performs any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An audit or review of a financial statement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A compilation of a financial statement when the licensee expects, or reasonably might expect, that a third party will use the financial statement and the licensee\u8217\'3fs compilation report does not disclose a lack of independence.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An examination of prospective financial information.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prepare for a client an original or amended tax return or claim for a tax refund for a contingent fee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ applies during the period in which the licensee is engaged to perform any of the listed services and the period covered by any historical financial statements involved in such listed services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, a contingent fee is a fee established for the performance of a service pursuant to an arrangement in which a fee will not be charged unless a specified finding or result is attained, or in which the amount of the fee is otherwise dependent upon the finding or result of such service. A fee shall not be considered as being a contingent fee if fixed by a court or other public authority, or, in a tax matter, if determined based on the results of a judicial proceeding or the findings of a governmental agency. A licensee\u8217\'3fs fee may vary depending on the complexity of the services rendered.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{17.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Nothing contained in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall be construed to authorize any person engaged in the practice as a certified public accountant or licensed public accountant or any member or employee of such firm to engage in the practice of law individually or within entities licensed under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{18.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Nothing in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be construed to prohibit the practice of public accounting and lawful use of titles by persons or firms exercising a practice privilege in conformance with }}}{{\f5\fs18\hyphpar0\qj{section 542.20}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 55, \'a713, 38}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1119, \'a7113}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 44, \'a793}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1106, \'a712, 15}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1055, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 13, \'a78}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7542.10}}}{{\f5\fs12\hyphpar0\qj{, 542.14}}}{{\f5\fs12\hyphpar0\qj{, 542.15}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{542.14}}}{\*\bkmkstart stylerid1_2E19_2E2_2E2}{\*\bkmkend stylerid1_2E19_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Injunction against unlawful acts, civil penalties, and consent agreements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If, as a result of an investigation under }}}{{\f5\fs18\hyphpar0\qj{section 542.11}}}{{\f5\fs18\hyphpar0\qj{ or otherwise, the board believes that a person or firm has engaged, or is about to engage, in an act or practice which constitutes or will constitute a violation of }}}{{\f5\fs18\hyphpar0\qj{section 542.13}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{542.20}}}{{\f5\fs18\hyphpar0\qj{, the board may make application to the district court for an order enjoining such act or practice. Upon a showing by the board that such person or firm has engaged, or is about to engage, in any such act or practice, an injunction, restraining order, or other order as may be appropriate shall be granted by the court.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to a criminal penalty provided for in }}}{{\f5\fs18\hyphpar0\qj{section 542.15}}}{{\f5\fs18\hyphpar0\qj{, the board may issue an order to require compliance with }}}{{\f5\fs18\hyphpar0\qj{section 542.13}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{542.20}}}{{\f5\fs18\hyphpar0\qj{ or to revoke a practice privilege under }}}{{\f5\fs18\hyphpar0\qj{section 542.20}}}{{\f5\fs18\hyphpar0\qj{, and may impose a civil penalty not to exceed one thousand dollars for each offense upon a person who is not a licensee under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and who engages in conduct prohibited by }}}{{\f5\fs18\hyphpar0\qj{section 542.13}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{542.20}}}{{\f5\fs18\hyphpar0\qj{. Each day of a continued violation constitutes a separate offense. The board may impose a penalty up to ten thousand dollars per violation against a firm that violates }}}{{\f5\fs18\hyphpar0\qj{section 542.13}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{542.20}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board, in determining the amount of a civil penalty to be imposed, may consider any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Whether the amount imposed will be a substantial economic deterrent to the violation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The circumstances leading to the violation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The severity of the violation and the risk of harm to the public.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The economic benefits gained by the violator as a result of noncompliance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The interest of the public.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board, before issuing an order under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, shall provide the person written notice and the opportunity to request a hearing. The hearing must be requested within thirty days after receipt of the notice and shall be conducted in the same manner as provided for disciplinary proceedings involving a licensee under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board, in connection with a proceeding under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, may issue subpoenas to compel the attendance and testimony of witnesses and the disclosure of evidence, and may request the attorney general to bring an action to enforce the subpoena.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person aggrieved by the imposition of a civil penalty under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ may seek judicial review pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 17A.19}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a person fails to pay a civil penalty within thirty days after entry of an order imposing the civil penalty, or if the order is stayed pending an appeal, within ten days after the court enters a final judgment in favor of the board, the board shall notify the attorney general. The attorney general may commence an action to recover the amount of the penalty, including reasonable attorney fees and costs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An action to enforce an order under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ may be joined with an action for an injunction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board, in its discretion and in lieu of prosecuting a first offense under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, may enter into a consent agreement with a violator, or with a person guilty of aiding or abetting a violator, which acknowledges the violation and the violator\u8217\'3fs agreement to refrain from any further violations.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 55, \'a714, 38}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1106, \'a713, 15}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7542.16}}}{{\f5\fs12\hyphpar0\qj{, 542.20}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{542.15}}}{\*\bkmkstart stylerid1_2E2_30_2E2_2E2}{\*\bkmkend stylerid1_2E2_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Criminal penalties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who violates a provision of }}}{{\f5\fs18\hyphpar0\qj{section 542.13}}}{{\f5\fs18\hyphpar0\qj{ is guilty of a serious misdemeanor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the board has reason to believe that a person has committed a violation subject to }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, the board may certify the facts to the attorney general of this state, or to the county attorney of the county where the person maintains a business office, who, in the attorney general\u8217\'3fs or county attorney\u8217\'3fs discretion, may initiate an appropriate criminal proceeding.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If, after an investigation under }}}{{\f5\fs18\hyphpar0\qj{section 542.11}}}{{\f5\fs18\hyphpar0\qj{ or otherwise, the board has reason to believe that a person or firm has knowingly engaged in an act or practice that constitutes a violation subject to }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, the board may submit its information to the attorney general of any state, or other appropriate law enforcement official, who, in such official\u8217\'3fs discretion, may initiate an appropriate criminal proceeding.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 55, \'a715, 38}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7542.14}}}{{\f5\fs12\hyphpar0\qj{, 542.16}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{542.16}}}{\*\bkmkstart stylerid1_2E21_2E2_2E2}{\*\bkmkend stylerid1_2E21_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Single act evidence of practice.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{In an action brought under }{{\f5\fs18\hyphpar0\qj{section 542.14}}}{ or }{{\f5\fs18\hyphpar0\qj{542.15}}}{, evidence of the commission of a single act prohibited by }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ is sufficient to justify a penalty, injunction, restraining order, or conviction, without evidence of a general course of conduct.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 55, \'a716, 38}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{542.17}}}{\*\bkmkstart stylerid1_2E22_2E2_2E2}{\*\bkmkend stylerid1_2E22_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Confidential communications.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensee shall not voluntarily disclose information communicated to the licensee by a client relating to and in connection with services rendered to the client by the licensee, except with the permission of the client, or an heir, successor, or personal representative of the client. Such information is deemed to be confidential. However, }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not be construed as prohibiting the disclosure of information required to be disclosed by the standards of the public accounting profession in reporting on the examination of financial statements or in the performance of an attest service or as prohibiting disclosures in a court proceeding, in an investigation or proceeding under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{chapter 272C}}}{{\f5\fs18\hyphpar0\qj{, in an ethical investigation conducted by a private professional organization, in the course of a peer review, to another person active in the licensee\u8217\'3fs firm performing services for that client on a need-to-know basis, to persons associated with the investigative entity who need this information for the sole purpose of assuring quality control, or as otherwise required by law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not preclude a licensee from filing a complaint with, or responding to an inquiry made by, the board, a taxing authority or law enforcement authority of this state, or a licensing or similar authority of another state or the United States.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 55, \'a717, 38}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 13, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1041, \'a7127}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7542.7A}}}{{\f5\fs12\hyphpar0\qj{, 542.18}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{542.18}}}{\*\bkmkstart stylerid1_2E23_2E2_2E2}{\*\bkmkend stylerid1_2E23_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Licensees\u8217\'3f working papers \u8212\'3f clients\u8217\'3f records.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subject to }}}{{\f5\fs18\hyphpar0\qj{section 542.17}}}{{\f5\fs18\hyphpar0\qj{, all statements, records, schedules, working papers, and memoranda made by a licensee or a partner, shareholder, officer, director, member, manager, or employee of a licensee, incident to, or in the course of, rendering services to a client, except reports submitted by the licensee to the client and except for records that are part of the client\u8217\'3fs records, are the property of the licensee in the absence of an express agreement between the licensee and the client to the contrary. Such statement, record, schedule, working paper, or memorandum shall not be sold, transferred, or bequeathed, without the consent of the client or the client\u8217\'3fs personal representative or assignee, to anyone other than a surviving partner, stockholder, or member of the licensee, or any combined or merged firm or successor in interest to the licensee. }}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ shall not be construed as prohibiting a temporary transfer of working papers or other material necessary in the course of carrying out peer reviews or as otherwise interfering with the disclosure of information pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 542.17}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensee shall furnish to a client or former client, upon request and reasonable notice, the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A copy of the licensee\u8217\'3fs working papers, to the extent that such working papers include records that would ordinarily constitute part of the client\u8217\'3fs records and are not otherwise available to the client.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Accounting or other records belonging to, or obtained from or on behalf of, the client that the licensee removed from the client\u8217\'3fs premises or received for the client\u8217\'3fs account. The licensee may make and retain copies of such documents of the client when they form the basis for work done by the licensee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This chapter}}}{{\f5\fs18\hyphpar0\qj{ does not require a licensee to keep any working papers beyond the period prescribed in any other applicable statute.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 55, \'a718, 38}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7542.7A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{542.19}}}{\*\bkmkstart stylerid1_2E24_2E2_2E2}{\*\bkmkend stylerid1_2E24_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Substantial equivalency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An individual whose principal place of business is not in this state shall be granted a certificate to practice as a certified public accountant in this state if the board determines that the individual holds in good standing a valid certificate or license to practice as a certified public accountant in the state in which the individual\u8217\'3fs principal place of business is located, and that the individual satisfies one of the following conditions:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The other state\u8217\'3fs licensing or certification standards are substantially equivalent to those required by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant\u8217\'3fs individual qualifications are substantially equivalent to those required by }}}{{\f5\fs18\hyphpar0\qj{section 542.5}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant satisfies all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant passed the examination required for issuance of the applicant\u8217\'3fs certificate or license with grades that would have been passing grades at the time in this state;}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant has at least four years of experience within the ten years immediately preceding the application which occurred after passing the examination upon which the applicant\u8217\'3fs certificate or license was based and which in the board\u8217\'3fs opinion is substantially equivalent to that required by }}}{{\f5\fs18\hyphpar0\qj{section 542.5, subsection 12}}}{{\f5\fs18\hyphpar0\qj{; and,}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the applicant\u8217\'3fs certificate or license was issued more than four years prior to the filing of the application in this state, the applicant has fulfilled the continuing professional education requirements described in }}}{{\f5\fs18\hyphpar0\qj{section 542.6, subsection 3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An individual who holds in good standing a valid certificate or license to practice as a certified public accountant in another state and who desires to establish the holder\u8217\'3fs principal place of business in this state shall request the issuance of a certificate from the board prior to establishing such principal place of business. The board shall issue a certificate to an individual who satisfies one or more of the conditions described in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall issue a certificate to a holder of a substantially equivalent foreign designation, upon satisfaction of all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The foreign authority which issued the designation allows a person who holds a valid certificate issued by this state to obtain such foreign authority\u8217\'3fs comparable designation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The foreign designation satisfies all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The designation was issued by a foreign authority that regulates the practice of public accountancy and the foreign designation has not expired or been revoked or suspended.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The designation entitles the holder to issue reports on financial statements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The designation was issued upon the basis of education, examination, and experience requirements established by the foreign authority or by law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant satisfies all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The designation was issued based on education and examination standards substantially equivalent to those in effect in this state at the time the foreign designation was granted.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant satisfies an experience requirement, substantially equivalent to the requirement set out in }}}{{\f5\fs18\hyphpar0\qj{section 542.5, subsection 12}}}{{\f5\fs18\hyphpar0\qj{, in the jurisdiction which issued the foreign designation or has completed four years of professional experience in this state; or meets equivalent requirements prescribed by the board by rule, within the ten years immediately preceding the application.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant has passed qualifying examinations in national standards and the laws, rules, and code of ethical conduct in effect in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant shall list in the application all jurisdictions, foreign and domestic, in which the applicant has applied for or holds a designation to practice public accountancy. A holder of a certificate issued under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall notify the board in writing, within thirty days after its occurrence, of any issuance, denial, revocation, or suspension of a designation or commencement of a disciplinary or enforcement action by any jurisdiction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An applicant under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall comply with all applicable provisions of }}}{{\f5\fs18\hyphpar0\qj{section 542.5, subsections 1 through 6}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{section 542.6}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall adopt rules to implement }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ which will expedite the application process to the extent reasonably possible.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 55, \'a719, 38}}}{; }{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 44, \'a794}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7542.3}}}{{\f5\fs12\hyphpar0\qj{, 542.4}}}{{\f5\fs12\hyphpar0\qj{, 542.6}}}{{\f5\fs12\hyphpar0\qj{, 542.7}}}{{\f5\fs12\hyphpar0\qj{, 542.8}}}{{\f5\fs12\hyphpar0\qj{, 542.9}}}{{\f5\fs12\hyphpar0\qj{, 542.13}}}{{\f5\fs12\hyphpar0\qj{, 542.20}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For future amendment to subsection 1, paragraph c, subparagraph (2), effective July 1, 2026, see }{{\f5\fs12\hyphpar0\qj{2025 Acts, ch 40, \'a74, 9}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For future amendment to subsection 3, paragraph c, subparagraph (2), effective July 1, 2026, see }{{\f5\fs12\hyphpar0\qj{2025 Acts, ch 40, \'a75, 9}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{542.20}}}{\*\bkmkstart stylerid1_2E25_2E2_2E2}{\*\bkmkend stylerid1_2E25_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Practice privilege.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ authorizes a person or firm whose principal place of business is not in this state to practice public accounting in Iowa in person, or by telephone, mail, or electronic means without licensure under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or notice to the board under the conditions described in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. Such a person or firm must hold a valid, unexpired license in good standing in the state of its principal place of business that is substantially equivalent to a comparable license issued in Iowa, and such a person or firm must be licensed to lawfully perform in its principal place of business all public accounting services offered or rendered under a practice privilege in Iowa.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A provision of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ or of any other section in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall not prevent the auditor of state, the department of agriculture and land stewardship, other governmental official or body, or a client from requiring that public accounting services performed in Iowa or for an Iowa client be performed by a person or firm holding a license under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The practice privilege authorized by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is temporary and shall cease if the license in the person\u8217\'3fs or firm\u8217\'3fs principal place of business expires, is no longer valid or in good standing, or otherwise no longer lawfully supports the conditions of the practice privilege described in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board may revoke a practice privilege, impose a civil penalty, issue an order to secure compliance with }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or board rules, or take such additional actions as are provided in }}}{{\f5\fs18\hyphpar0\qj{section 542.14}}}{{\f5\fs18\hyphpar0\qj{ if a person or firm acting or purporting to act under a practice privilege violates }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or board rules. In addition, or as an alternative to such action, the board may refer a complaint to the state regulatory body that issued the license to the person or firm.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A violation of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or board rules by a person or firm acting or purporting to act under a practice privilege is a ground to deny the violator\u8217\'3fs subsequent application for licensure under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A violation of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or board rules by a person acting or purporting to act under a practice privilege is a ground to deny a subsequent application for initial or renewal licensure under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ by the violator\u8217\'3fs firm, and is a ground for discipline against such firm.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A violation of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or board rules by a person or firm acting or purporting to act under a practice privilege is a ground for discipline against a licensee under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ who aided or abetted the violation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A certified public accounting firm that is licensed in the state of its principal place of business and is not required to hold an Iowa firm license under }}}{{\f5\fs18\hyphpar0\qj{section 542.7}}}{{\f5\fs18\hyphpar0\qj{ may practice in this state without a firm license under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or notice to the board if the firm\u8217\'3fs practice in this state is performed by individuals who hold a license under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or who practice in conformance with }}}{{\f5\fs18\hyphpar0\qj{subsection 6}}}{{\f5\fs18\hyphpar0\qj{, under the following conditions:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The firm shall not have an office in Iowa which uses the title \u8220\'3fCPAs\u8221\'3f, \u8220\'3fCPA firm\u8221\'3f, \u8220\'3fcertified public accountants\u8221\'3f, or \u8220\'3fcertified public accounting firm\u8221\'3f.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The firm shall not make any representation tending to falsely indicate that the firm is licensed under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The firm, upon a client\u8217\'3fs or prospective client\u8217\'3fs request, shall provide accurate information on the state or states of licensure, principal place of business, contact information, and manner in which licensure status can be verified.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The firm shall comply with all professional standards, laws, and rules that apply to licensees performing the same professional services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The firm shall comply with the ownership and peer review requirements of }}}{{\f5\fs18\hyphpar0\qj{section 542.7}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An individual who is licensed in the state of the individual\u8217\'3fs principal place of business may exercise the privileges of a certificate holder of this state without obtaining a certificate under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or providing notice to the board, under the following conditions:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The individual must meet the criteria for substantial equivalency reciprocity under }}}{{\f5\fs18\hyphpar0\qj{section 542.19, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The individual shall not have an office in Iowa at which the individual uses the title \u8220\'3fCPA\u8221\'3f. The individual may, however, perform public accounting services using the title \u8220\'3fCPA\u8221\'3f if performed at the office of a certified public accounting firm or licensed public accounting firm that holds a permit to practice under }}}{{\f5\fs18\hyphpar0\qj{section 542.7}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{542.8}}}{{\f5\fs18\hyphpar0\qj{, or at the office of a business entity that is not required to hold a firm permit under }}}{{\f5\fs18\hyphpar0\qj{section 542.7}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{542.8}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An individual who provides attest services in Iowa or for a client having a home office in Iowa must practice through a certified public accounting firm that is licensed under }}}{{\f5\fs18\hyphpar0\qj{section 542.7}}}{{\f5\fs18\hyphpar0\qj{, or through a certified public accounting firm that is validly licensed in the state of its principal place of business and complies with the ownership and peer review requirements of }}}{{\f5\fs18\hyphpar0\qj{section 542.7}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An individual who provides compilation services in Iowa or for a client having a home office in Iowa must comply with the peer review provisions of }}}{{\f5\fs18\hyphpar0\qj{section 542.6, subsection 6}}}{{\f5\fs18\hyphpar0\qj{, or provide such services through a certified public accounting firm, a licensed public accounting firm, or substantially equivalent firm that is validly licensed in the firm\u8217\'3fs principal place of business and is subject to the peer review and ownership provisions of }}}{{\f5\fs18\hyphpar0\qj{section 542.7}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{542.8}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The individual shall not make any representation tending to falsely indicate that the individual is licensed under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The individual, upon a client\u8217\'3fs or prospective client\u8217\'3fs request, shall provide accurate information on the state or states of licensure, principal place of business, contact information, and manner in which licensure status can be verified.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The individual shall comply with all professional standards, laws, and rules that apply to licensees performing the same professional services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As a condition of exercising the practice privilege provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 5 or 6}}}{{\f5\fs18\hyphpar0\qj{, the person or firm does all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Consents to the personal and subject matter jurisdiction and regulatory authority of the board, including but not limited to the board\u8217\'3fs jurisdiction to revoke the practice privilege or otherwise take action under }}}{{\f5\fs18\hyphpar0\qj{section 542.14}}}{{\f5\fs18\hyphpar0\qj{ for any violation of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or board rules.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Appoints the regulatory body of the state that issued the firm or individual license as the agent upon whom process may be served in any action or proceeding by the board against the firm or person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Agrees to supply the board, upon the board\u8217\'3fs request and without subpoena, such information or records as licensees are similarly required to provide the board under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ regarding themselves or, in the case of a firm, regarding the individuals practicing through the firm, including but not limited to licensure status in all jurisdictions; qualifications for substantial equivalency reciprocity under }}}{{\f5\fs18\hyphpar0\qj{section 542.19, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{; location of principal place of business and all other offices; criminal and disciplinary background; malpractice settlements and judgments; firm ownership and when applicable, information regarding nonlicensee owners; whether public accounting services are subject to peer review; proof of completion of peer review, when applicable; qualifications to supervise attest services, when applicable; and timely response to inquiries regarding complaints and investigations conducted under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Agrees to promptly cease offering or rendering public accounting services in this state or for clients having a home office in this state if the license in the person\u8217\'3fs or firm\u8217\'3fs principal place of business expires or is otherwise no longer valid or in good standing, or if any of the conditions for exercising the practice privilege are no longer satisfied, or if the board revokes the practice privilege.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensee of this state is subject to discipline in this state based on a violation of a comparable practice privilege afforded by another state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall adopt rules on the manner in which }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ applies to persons or firms that hold a lapsed Iowa license, have been subject to discipline in Iowa, have surrendered an Iowa license, or have otherwise held an Iowa license at one point in time that is no longer valid, active, or in good standing, and to persons or firms that have been convicted of a crime, the subject of discipline or denied licensure in any jurisdiction, or that would otherwise be subject to license denial or discipline if a license applicant or licensee in Iowa.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1106, \'a714, 15}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1031, \'a71 \u8211\'3f 4}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 78, \'a76 \u8211\'3f 8}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7542.3}}}{{\f5\fs12\hyphpar0\qj{, 542.4}}}{{\f5\fs12\hyphpar0\qj{, 542.6}}}{{\f5\fs12\hyphpar0\qj{, 542.7}}}{{\f5\fs12\hyphpar0\qj{, 542.8}}}{{\f5\fs12\hyphpar0\qj{, 542.10}}}{{\f5\fs12\hyphpar0\qj{, 542.13}}}{{\f5\fs12\hyphpar0\qj{, 542.14}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For future amendment to subsection 1, effective July 1, 2026, see }{{\f5\fs12\hyphpar0\qj{2025 Acts, ch 40, \'a76, 9}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For future amendment to subsection 6, paragraph a, effective July 1, 2026, see }{{\f5\fs12\hyphpar0\qj{2025 Acts, ch 40, \'a77, 9}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For future text of subsection 7, paragraph e, effective July 1, 2026, see }{{\f5\fs12\hyphpar0\qj{2025 Acts, ch 40, \'a78, 9}}}\par}}