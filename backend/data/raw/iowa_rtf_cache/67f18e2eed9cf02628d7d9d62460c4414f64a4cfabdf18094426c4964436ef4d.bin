ving existing ones.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2025 Acts, ch 136, \'a7109, 118}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{NEW section}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{15.522}}}{\*\bkmkstart stylerid1_2E6_2E36_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E36_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Eligible businesses and sectors.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The tax credit available pursuant to }}}{{\f5\fs18\hyphpar0\qj{this part}}}{{\f5\fs18\hyphpar0\qj{ shall be available only to a business primarily engaged in any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Advanced manufacturing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Bioscience.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Insurance and finance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Technology and innovation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyph