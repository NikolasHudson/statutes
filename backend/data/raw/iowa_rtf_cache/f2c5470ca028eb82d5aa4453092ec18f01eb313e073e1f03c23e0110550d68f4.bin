\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F9_303B}{\*\bkmkend codeChapter_5F9_303B}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 903B}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{SEX OFFENDER SPECIAL SENTENCING AND HORMONE TREATMENT}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a7216A.133}}}{{\f5\fs12\qc{, 607A.4}}}{{\f5\fs12\qc{, 901.1}}}{{\f5\fs12\qc{, 901A.2}}}{{\f5\fs12\qc{, 908.5}}}\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER I}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E5_2E1_2E2}{SPECIAL SENTENCING}{\*\bkmkend stylerid1_2E5_2E1_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{903B.1}}}{\*\bkmkstart stylerid1_2E5_2E2_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E2_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Special sentence }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ class \u8220\'3fB\u8221\'3f or class \u8220\'3fC\u8221\'3f felonies.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A person convicted of a class \u8220\'3fC\u8221\'3f felony or greater offense under }{{\f5\fs18\hyphpar0\qj{chapter 709}}}{ or }{{\f5\fs18\hyphpar0\qj{section 728.12}}}{, or a class \u8220\'3fB\u8221\'3f felony under }{{\f5\fs18\hyphpar0\qj{section 713.3, subsection 1}}}{, paragraph }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{, shall also be sentenced, in addition to any other punishment provided by law, to a special sentence committing the person into the custody of the director of the Iowa department of corrections for the rest of the person\u8217\'3fs life, with eligibility for parole as provided in }{{\f5\fs18\hyphpar0\qj{chapter 906}}}{. The board of parole shall determine whether the person should be released on parole or placed in a work release program. The special sentence imposed under }{{\f5\fs18\hyphpar0\qj{this section}}}{ shall commence upon completion of the sentence imposed under any applicable criminal sentencing provisions for the underlying criminal offense and the person shall begin the sentence under supervision as if on parole or work release. The person shall be placed on the corrections continuum in }{{\f5\fs18\hyphpar0\qj{chapter 901B}}}{, and the terms and conditions of the special sentence, including violations, shall be subject to the same set of procedures set out in }{{\f5\fs18\hyphpar0\qj{chapters 901B}}}{, }{{\f5\fs18\hyphpar0\qj{904}}}{, }{{\f5\fs18\hyphpar0\qj{906}}}{, and }{{\f5\fs18\hyphpar0\qj{908}}}{, and rules adopted under those chapters for persons on parole or work release. The revocation of release shall not be for a period greater than two years upon any first revocation, and five years upon any second or subsequent revocation. A special sentence shall be considered a category \u8220\'3fA\u8221\'3f sentence for purposes of calculating earned time under }{{\f5\fs18\hyphpar0\qj{section 903A.2}}}{.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 158, \'a739}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 119, \'a759}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 14, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 74, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1182, \'a755}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7692A.106}}}{{\f5\fs12\hyphpar0\qj{, 692A.125}}}{{\f5\fs12\hyphpar0\qj{, 901.5}}}{{\f5\fs12\hyphpar0\qj{, 906.15}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{903B.2}}}{\*\bkmkstart stylerid1_2E5_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Special sentence }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ class \u8220\'3fD\u8221\'3f felonies or misdemeanors.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A person convicted of a misdemeanor or a class \u8220\'3fD\u8221\'3f felony offense under }{{\f5\fs18\hyphpar0\qj{chapter 709}}}{, }{{\f5\fs18\hyphpar0\qj{section 726.2}}}{, or }{{\f5\fs18\hyphpar0\qj{section 728.12}}}{ shall also be sentenced, in addition to any other punishment provided by law, to a special sentence committing the person into the custody of the director of the Iowa department of corrections for a period of ten years, with eligibility for parole as provided in }{{\f5\fs18\hyphpar0\qj{chapter 906}}}{. The board of parole shall determine whether the person should be released on parole or placed in a work release program. The special sentence imposed under }{{\f5\fs18\hyphpar0\qj{this section}}}{ shall commence upon completion of the sentence imposed under any applicable criminal sentencing provisions for the underlying criminal offense and the person shall begin the sentence under supervision as if on parole or work release. The person shall be placed on the corrections continuum in }{{\f5\fs18\hyphpar0\qj{chapter 901B}}}{, and the terms and conditions of the special sentence, including violations, shall be subject to the same set of procedures set out in }{{\f5\fs18\hyphpar0\qj{chapters 901B}}}{, }{{\f5\fs18\hyphpar0\qj{904}}}{, }{{\f5\fs18\hyphpar0\qj{906}}}{, and }{{\f5\fs18\hyphpar0\qj{908}}}{, and rules adopted under those chapters for persons on parole or work release. The revocation of release shall not be for a period greater than two years upon any first revocation, and five years upon any second or subsequent revocation. A special sentence shall be considered a category \u8220\'3fA\u8221\'3f sentence for purposes of calculating earned time under }{{\f5\fs18\hyphpar0\qj{section 903A.2}}}{.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 158, \'a740}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 119, \'a760}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1182, \'a756}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7692A.106}}}{{\f5\fs12\hyphpar0\qj{, 692A.125}}}{{\f5\fs12\hyphpar0\qj{, 901.5}}}{{\f5\fs12\hyphpar0\qj{, 906.15}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{903B.3 through 903B.9}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER II}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E6_2E1_2E2}{HORMONAL INTERVENTION THERAPY}{\*\bkmkend stylerid1_2E6_2E1_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{903B.10}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Hormonal intervention therapy \u8212\'3f certain sex offenses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who has been convicted of a serious sex offense may, upon a first conviction and in addition to any other punishment provided by law, be required to undergo medroxyprogesterone acetate treatment as part of any conditions of release imposed by the court or the board of parole. The treatment prescribed in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ may utilize an approved pharmaceutical agent other than medroxyprogesterone acetate. Upon a second or subsequent conviction, the court or the board of parole shall require the person to undergo medroxyprogesterone acetate or other approved pharmaceutical agent treatment as a condition of release, unless, after an appropriate assessment, the court or board determines that the treatment would not be effective. In determining whether a conviction is a first or second conviction under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, a prior conviction for a criminal offense committed in another jurisdiction which would constitute a violation of }}}{{\f5\fs18\hyphpar0\qj{section 709.3, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, if committed in this state, shall be considered a conviction under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. }}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ shall not apply if the person voluntarily undergoes a permanent surgical alternative approved by the court or the board of parole.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a person is placed on probation and is not in confinement at the time of sentencing, the presentence investigation shall include a plan for initiation of treatment as soon as is reasonably possible after the person is sentenced. If the person is in confinement prior to release on probation or parole, treatment shall commence prior to the release of the person from confinement. Conviction of a serious sex offense shall constitute exceptional circumstances warranting a presentence investigation under }}}{{\f5\fs18\hyphpar0\qj{section 901.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, a }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fserious sex offense\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any of the following offenses in which the victim was a child who was, at the time the offense was committed, twelve years of age or younger:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Sexual abuse in the first degree, in violation of }}}{{\f5\fs18\hyphpar0\qj{section 709.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Sexual abuse in the second degree, in violation of }}}{{\f5\fs18\hyphpar0\qj{section 709.3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Sexual abuse in the third degree, in violation of }}}{{\f5\fs18\hyphpar0\qj{section 709.4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Lascivious acts with a child, in violation of }}}{{\f5\fs18\hyphpar0\qj{section 709.8}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Assault with intent, in violation of }}}{{\f5\fs18\hyphpar0\qj{section 709.11}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Indecent contact with a minor, in violation of }}}{{\f5\fs18\hyphpar0\qj{section 709.12}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Lascivious conduct with a minor, in violation of }}}{{\f5\fs18\hyphpar0\qj{section 709.14}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Sexual exploitation in violation of }}}{{\f5\fs18\hyphpar0\qj{section 709.15}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Sexual exploitation of a minor, in violation of }}}{{\f5\fs18\hyphpar0\qj{section 728.12, subsections 1 and 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Continuous sexual abuse of a child in violation of }}}{{\f5\fs18\hyphpar0\qj{section 709.23}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of corrections, in consultation with the board of parole, shall adopt rules which provide for the initiation of medroxyprogesterone acetate or other approved pharmaceutical agent treatment prior to the parole or work release of a person who has been convicted of a serious sex offense and who is required to undergo treatment as a condition of release by the board of parole. The department\u8217\'3fs rules shall also establish standards for the supervision of the treatment by the judicial district department of correctional services during the period of release. Each district department of correctional services shall adopt policies and procedures which provide for the initiation or continuation of medroxyprogesterone acetate or other approved pharmaceutical agent treatment as a condition of release for each person who is required to undergo the treatment by the court or the board of parole. The board of parole shall, in consultation with the department of corrections, adopt rules which relate to initiation or continuation of medroxyprogesterone acetate or other approved pharmaceutical agent treatment as a condition of any parole or work release. Any rules, standards, and policies and procedures adopted shall provide for the continuation of the treatment until the agency in charge of supervising the treatment determines that the treatment is no longer necessary.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who is required to undergo medroxyprogesterone acetate treatment, or treatment utilizing another approved pharmaceutical agent, pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, shall be required to pay a reasonable fee to pay for the costs of providing the treatment. A requirement that a person pay a fee shall include provision for reduction, deferral, or waiver of payment if the person is financially unable to pay the fee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who administers medroxyprogesterone acetate or any other pharmaceutical agent shall not be liable for civil damages for administering such pharmaceutical agents pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1171, \'a721}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C99, \'a7903B.1}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 180, \'a767}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 158, \'a733, 41}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{CS2005, \'a7903B.10}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2013 Acts, ch 90, \'a7256}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1115, \'a76}}}\par}}