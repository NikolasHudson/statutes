s18\hyphpar0\qj{Subchapter IV}}}{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~\~}}}{{\f5\fs18\hyphpar0\qj{General Provisions.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1194, \'a72, 40}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 54, \'a755}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{437A.2}}}{\*\bkmkstart stylerid1_2E6_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Purposes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The purposes of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ are to replace property taxes imposed on electric companies, natural gas companies, electric cooperatives, and municipal utilities with a system of taxation which will remove tax costs as a factor in a competitive environment by imposing like generation, transmission, and delivery taxes on similarly situated competitors who generate, transmit, or deliver electricity or natural gas in the same competitive service area, to preserve revenue neutrality and debt capacity for local governments and taxpayers, to preserve neutrality in the allocation and cost impact of any replacement tax among and upon consumers of electricity and natural gas in this state, and to provide a system of taxation which reduces existing administrative burdens on state government.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1194, \'a73, 40}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{437A.3}}}{\*\bkmkstart stylerid1_2E6_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{As used in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, unless the context otherwise requires:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAssessed value\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the base year assessed value, as adjusted by }}}{{\f5\fs18\hyphpar0\qj{section 437A.19, subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fBase year assessed value\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, for a taxpayer other than an electric company, natural gas company, or electric cooperative, means the value attributable to property identified in }}}{{\f5\fs18\hyphpar0\qj{section 427A.1, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fh\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, certified by the department of revenue to the county auditors for the assessment date of January 1, 1997, and the value attributable to property identified in }}}{{\f5\fs18\hyphpar0\qj{section 427A.1}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{section 427B.17, subsection 8}}}{{\f5\fs18\hyphpar0\qj{, as certified by the local assessors to the county auditors for the assessment date of January 1, 1997, provided, that for a taxpayer subject to }}}{{\f5\fs18\hyphpar0\qj{section 437A.17A}}}{{\f5\fs18\hyphpar0\qj{, such value shall be the value certified by the department of revenue and local assessors to the county auditors for the assessment date of January 1, 1998.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{However, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fbase year assessed value\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, for purposes of property of a taxpayer that is a municipal utility, if the property is not a major addition, and the property was initially assessed to the taxpayer as of January 1, 1998, and is not located in a county where the taxpayer had property that was assessed for purposes of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ as of January 1, 1997, means the value attributable to such property for the assessment date of January 1, 1998.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For taxpayers that are electric companies, natural gas companies, and electric cooperatives, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fbase year assessed value\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the average of the total of these values for each taxpayer for the assessment dates of January 1, 1993, through January 1, 1997, allocated among taxing districts in proportion to the allocation of the taxpayer\u8217\'3fs January 1, 1998, assessed value among taxing districts.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fBase year assessed value\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include value attributable to steam-operating property.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For new cogeneration facilities, the assessed value shall be determined as provided in }}}{{\f5\fs18\hyphpar0\qj{section 437A.16A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fBook\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3flist\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3frecord\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fschedule\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ kept by a county auditor, assessor, treasurer, recorder, sheriff, or other county officer means the county system as defined in }}}{{\f5\fs18\hyphpar0\qj{section 445.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCentrally assessed property tax\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means property tax imposed with respect to the value of property determined by the director pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 427.1, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, Code 1997, }}}{{\f5\fs18\hyphpar0\qj{section 428.29}}}{{\f5\fs18\hyphpar0\qj{, Code 1997, }}}{{\f5\fs18\hyphpar0\qj{ chapter 437}}}{{\f5\fs18\hyphpar0\qj{, Code 1997, and }}}{{\f5\fs18\hyphpar0\qj{chapter 438}}}{{\f5\fs18\hyphpar0\qj{, Code 1997, and allocated to electric service and natural gas service. For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fnatural gas service\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means such service provided by natural gas pipelines permitted pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 479}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCogeneration facility\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a facility with a capacity of two hundred megawatts or less that uses the same energy source for the sequential generation of electrical or mechanical power in combination with steam, heat, or other forms of useful energy and, except for ownership, meets the criteria to be a qualifying cogeneration facility as defined in the federal }}}{{\f5\fs18\hyphpar0\qj{Public Utility Regulatory Policies Act of 1978}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{16 U.S.C. \'a72601 et seq.}}}{{\f5\fs18\hyphpar0\qj{, and related federal regulations.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fNew cogeneration facility\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A cogeneration facility, regardless of capacity, which is first placed into service on or after January 1, 2009, that uses the same energy source for the sequential generation of electrical or mechanical power in combination with steam, heat, or other forms of useful energy and meets the criteria to be a qualifying cogeneration facility as defined in the federal }}}{{\f5\fs18\hyphpar0\qj{Public Utility Regulatory Policies Act of 1978}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{16 U.S.C. \'a72601 et seq.}}}{{\f5\fs18\hyphpar0\qj{, and related federal regulations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A cogeneration facility in service prior to January 1, 2009, that became subject to the replacement generation tax under }}}{{\f5\fs18\hyphpar0\qj{section 437A.6}}}{{\f5\fs18\hyphpar0\qj{ for the first time on or after January 1, 2009.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fConsumer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an end user of electricity or natural gas used or consumed within this state. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fConsumer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes any master-metered facility even though the electricity or natural gas delivered to such facility may ultimately be used by another person. A person to whom electricity or natural gas is delivered by a master-metered facility is not a consumer. A }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fmaster-metered facility\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any multi-occupancy premises where units are separately rented or owned and where electricity or natural gas is used in centralized heating, cooling, water-heating, or ventilation systems, where individual metering is impractical, where the facility is designated for elderly or handicapped persons and utility costs constitute part of the operating cost and are not apportioned to individual units, or where submetering or resale of service was permitted prior to 1966.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDelivery\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the physical transfer of electricity or natural gas to a consumer. Physical transfer to a consumer occurs when transportation of electricity or natural gas ends and such electricity or natural gas becomes available for use or consumption by a consumer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDirector\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the director of revenue.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fElectric company\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person engaged primarily in the production, delivery, service, or sales of electric energy whether formed or organized under the laws of this state or elsewhere. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fElectric company\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes a combination natural gas company and electric company. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fElectric company\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include an electric cooperative or a municipal utility.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fElectric competitive service area\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an electric service area assigned by the utilities commission under }}}{{\f5\fs18\hyphpar0\qj{chapter 476}}}{{\f5\fs18\hyphpar0\qj{ as of January 1, 1999, including utility property and facilities described in }}}{{\f5\fs18\hyphpar0\qj{section 476.23, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, which were owned and served by the electric company, electric cooperative, or municipal utility serving such area on January 1, 1999.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fElectric cooperative\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an electric utility provider formed or organized as an electric cooperative under the laws of this state or elsewhere. An electric cooperative shall also include an incorporated city utility provider. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fGeneration and transmission electric cooperative\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an electric cooperative which owns both transmission lines and property which is used to generate electricity. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDistribution electric cooperative\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an electric cooperative other than a generation and transmission electric cooperative or a municipal electric cooperative association.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fElectric power generating plant\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a nameplate rated electric power generating plant, which produces electric energy from other forms of energy, including all taxable land, buildings, and equipment used in the production of such electric energy.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fNew electric power generating plant\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An electric power generating plant that is owned by or leased to an electric company, electric cooperative, municipal utility, or any other taxpayer, and that initially generates electricity subject to replacement generation tax under }}}{{\f5\fs18\hyphpar0\qj{section 437A.6}}}{{\f5\fs18\hyphpar0\qj{ on or after January 1, 2003.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An electric power generating plant that is owned by or leased to an electric company, electric cooperative, municipal utility, or any other taxpayer, that initially generated electricity subject to replacement generation tax under }}}{{\f5\fs18\hyphpar0\qj{section 437A.6}}}{{\f5\fs18\hyphpar0\qj{ before January 1, 2003, and that is sold, leased, or transferred, in full or in part, on or after January 1, 2003. If any portion of an electric power generating plant is sold, the entire plant shall be treated as if it were a new electric power generating plant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fIncorporated city utility provider\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a corporation with assets worth one million dollars or more which has one or more platted villages located within the territorial limits of the tract of land which it owns, and which provides electricity to ten thousand or fewer customers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLease\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a contract between a lessor and lessee pursuant to which the lessee obtains a present possessory interest in tangible property without obtaining legal title in such property. A contract to transmit or deliver electricity or natural gas using operating property within this state is not a lease. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCapital lease\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a lease classified as a capital lease under generally accepted accounting principles.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLocal amount\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the first forty-four million four hundred forty-four thousand four hundred forty-five dollars of the acquisition cost of any major addition which is an electric power generating plant and the total acquisition cost of any other major addition.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLocal amount\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ for the purposes of determining the local taxable value for a new electric power generating plant shall annually be determined to be equal up to the first forty-four million four hundred forty-four thousand four hundred forty-five dollars of the taxable value of the new electric power generating plant. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLocal amount\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ for the purposes of determining the local assessed value for a new electric power generating plant shall be annually determined to be the percentage share of the taxable value of the new electric power generating plant allocated as the local amount multiplied by the total assessed value of the new electric power generating plant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLocal taxing authority\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a city, county, community college, school district, or other taxing authority located in this state and authorized to certify a levy on property located within such authority for the payment of bonds and interest or other obligations of such authority.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{16.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLocal taxing district\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a geographic area with a common consolidated property tax rate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{17.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLow capacity factor electric power generating plant\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means, for any tax year, an electric power generating plant, with the exception of an electric power generating plant owned or leased by an electric company, an electric cooperative, or a municipal utility, which operated during the preceding calendar year at a net capacity factor of twenty percent or less. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fNet capacity factor\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means net actual generation during the preceding calendar year divided by the product of nameplate capacity times the number of hours the plant was in the active state during the preceding calendar year. Upon commissioning, a plant is in the active state until it is decommissioned. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fNet actual generation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means net electrical megawatt hours produced by a plant during the preceding calendar year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{18.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMajor addition\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means either of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any acquisition on or after January 1, 1998, by a taxpayer, by transfer of ownership, self-construction, or capital lease of any interest in any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A building in this state where the acquisition cost of all interests acquired exceeds ten million dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An electric power generating plant, except a solar energy conversion facility, where the acquisition cost of all interests acquired exceeds ten million dollars.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A solar energy conversion facility where the acquisition cost of all interests exceeds one million dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of this subparagraph: }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fElectric power generating plant\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means each nameplate rated electric power generating plant owned solely or jointly by any person or electric power facility financed under the provisions of }}}{{\f5\fs18\hyphpar0\qj{chapter 28F}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{476A}}}{{\f5\fs18\hyphpar0\qj{ in which electrical energy is produced from other forms of energy, including all equipment used in the production of such energy through its step-up transformer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSolar energy conversion facility\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as defined in }}}{{\f5\fs18\hyphpar0\qj{section 476C.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Natural gas operating property within a local taxing district where the acquisition cost of all interests acquired exceeds one million dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any property described in }}}{{\f5\fs18\hyphpar0\qj{section 437A.16}}}{{\f5\fs18\hyphpar0\qj{ in this state acquired by a person not previously subject to taxation under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any acquisition on or after January 1, 2004, by a taxpayer, by transfer of ownership, self-construction, or capital lease of any interest in electric transmission operating property within a local taxing district where the acquisition cost of all interests acquired exceeds one million dollars.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, the acquisition cost of an asset acquired by capital lease is its capitalized value determined under generally accepted accounting principles.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{19.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMunicipal electric cooperative association\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an electric cooperative, the membership of which is composed entirely of municipal utilities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{20.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMunicipal utility\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means all or part of an electric light and power plant system or a natural gas system, either of which is owned by a city, including all land, easements, rights-of-way, fixtures, equipment, accessories, improvements, appurtenances, and other property necessary or useful for the operation of the municipal utility.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{21.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fNatural gas company\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person that owns, operates, or is engaged primarily in operating or utilizing pipelines for the purpose of distributing natural gas to consumers located within this state, excluding a gas distributing plant or company located entirely within any city and not a part of a pipeline transportation company. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fNatural gas company\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes a combination natural gas company and electric company. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fNatural gas company\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include a municipal utility.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{22.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fNatural gas competitive service area\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any of the fifty-two natural gas competitive service areas described as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each of the following municipal natural gas competitive service areas:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Taylor county, except for those areas of Taylor county which are contained within another municipal natural gas competitive service area as described in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The city of Brighton in Washington county and the area within two miles of the city limits plus sections 5, 6, 7, 8, 17, 18, 19, 20, 29, and 30 in Brighton township; sections 19, 30, and 33 in Franklin township; sections 1, 2, 11, 12, 13, 14, 23, 24, 25, and 36 in Dutch Creek township; and sections 25, 26, 35, and 36 in Seventy-Six township.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Davis county.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The city of Brooklyn in Poweshiek county and the area within two miles of the city limits.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(e)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The city of Cascade in Dubuque county and the area within two miles of the city limits.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(f)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The city of Cedar Falls in Black Hawk county and the area within one mile of the city limits, not including any part of the city of Waterloo.}}}\par}