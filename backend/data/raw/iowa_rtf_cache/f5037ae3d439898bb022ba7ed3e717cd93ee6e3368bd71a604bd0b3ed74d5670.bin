5\fs18\hyphpar0\qj{\u8220\'3fbook\u8221\'3f}}}{, }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3flist\u8221\'3f}}}{, }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3frecord\u8221\'3f}}}{, or }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fschedule\u8221\'3f}}}{ kept by a county auditor, assessor, treasurer, recorder, sheriff, or other county officer means the county system as defined in }{{\f5\fs18\hyphpar0\qj{section 445.1}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1148, \'a71}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{69.1A}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Holding over.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Except when otherwise provided, every officer elected or appointed for a fixed term shall hold office until a successor is elected and qualified, unless the officer resigns, or is removed or suspended, as provided by law.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7241; C73, \'a7784; C97, \'a71265; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1145;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a769.1}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2001, \'a769.1A}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a746.5}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{69.2}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{What constitutes vacancy \u8212\'3f hearing \u8212\'3f appeal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Every civil office shall be vacant if any of the following events occur:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A failure to elect at the proper election, or to appoint within the time fixed by law, unless the incumbent holds over.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A failure of the incumbent or holdover officer to qualify within the time prescribed by law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The incumbent ceasing to be a resident of the state, district, county, township, city, or ward by or for which the incumbent was elected or appointed, or in which the duties of the office are to be exercised. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not apply to appointed city officers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The resignation or death of the incumbent, or of the officer-elect before qualifying.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The removal of the incumbent from, or forfeiture of, the office, or the decision of a competent tribunal declaring the office vacant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The conviction of the incumbent of a felony or of any public offense involving the violation of the incumbent\u8217\'3fs oath of office.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of supervisors declares a vacancy in an elected county office upon finding that the county officer has been physically absent from the county for sixty consecutive days except in the case of a medical emergency; temporary active military duty; or temporary service with another government service, agency, or department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The incumbent simultaneously holding more than one elective office at the same level of government. This paragraph does not apply to the county agricultural extension council or the soil and water conservation district commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An incumbent statewide elected official or member of the general assembly simultaneously holding more than one elective office.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the status of an officeholder is in question, the entity or officer responsible for making an appointment to fill the vacancy shall decide whether a vacancy exists. The appointing entity or officer may act upon its own motion. If a petition signed by twenty-five registered voters of the jurisdiction is received, the appointing entity or officer shall convene within thirty days to consider whether a vacancy exists. The appointing entity or officer shall publish notice that a public hearing will be held to determine whether a vacancy exists. The notice shall include the time and place of the hearing and the name of the office and the officeholder whose status is in question. The public hearing shall be held not less than four nor more than fourteen days after publication of the notice. The officer whose status is in question shall be notified of the time and place of the hearing. Notice shall be sent by certified mail and must be postmarked at least fourteen days before the hearing. No later than seven days after the public hearing, the appointing entity or officer shall publish its decision. If the appointing entity or officer decides that the office is vacant, the publication shall state the date the vacancy occurred and what action will be taken to fill the vacancy.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The officer against whom the judgment was rendered may appeal to the district court no later than twenty days after official publication of the decision. However, the appeal will not supersede the execution of the judgment of the appointing entity or officer, unless the party gives a bond, with security to be approved by the district judge in a sum to be fixed by the judge. The amount of the bond shall be at least double the probable compensation of such officer for six months, which bond shall be conditioned that the officer will prosecute the appeal without delay and that, if the judgment appealed from is affirmed, the party will pay over to the successful party all compensation received by the party while in possession of the office after the judgment appealed from was rendered. The court shall hear the appeal in equity and determine anew all questions arising in the case.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If, upon appeal, the judgment is affirmed, the district court may render judgment upon the bond for the amount of damages awarded against the appellant and the sureties on the bond.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7334, 429; R60, \'a7564, 662, 1132; C73, \'a7504, 686, 781; C97, \'a71266; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1146;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a769.2}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 12, \'a71 \u8211\'3f 3}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 143, \'a741}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1223, \'a718, 38}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 158, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1134, \'a777, 115}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1149, \'a711, 12}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1063, \'a737}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a746.5}}}{{\f5\fs12\hyphpar0\qj{, 331.214}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Prohibitions concerning holding more than one office, }{{\f5\fs12\hyphpar0\qj{\'a739.11}}}{, }{{\f5\fs12\hyphpar0\qj{39.12}}}{, }{{\f5\fs12\hyphpar0\qj{441.17(1)}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Duty of holdover officer to requalify, }{{\f5\fs12\hyphpar0\qj{\'a763.7}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Removal from office; see also }{{\f5\fs12\hyphpar0\qj{chapter 66}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Vacancy on school board, }{{\f5\fs12\hyphpar0\qj{\'a7277.29}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Vacancy on board of supervisors, }{{\f5\fs12\hyphpar0\qj{\'a7331.214}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{69.3}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Possession of office.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{When a vacancy occurs in a public office, possession shall be taken of the office room, books, papers, and all things pertaining to the office, to be held until the qualification of a successor, as follows:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Of the office of the county auditor, by the county treasurer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Of the county treasurer, by the county auditor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Of any of the state officers, by the governor, or, in the absence or inability of the governor at the time of the occurrence, as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Of the secretary of state, by the treasurer of state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Of the auditor of state, by the secretary of state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Of the treasurer of state, by the secretary of state and auditor of state, who shall make an inventory of the money and warrants in the office, sign the inventory, and transmit it to the governor, and the secretary of state shall take the keys of the safe and desks, after depositing the books, papers, money, and warrants in them, and the auditor of state shall take the key to the office room.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7444; R60, \'a7671; C73, \'a7788; C97, \'a71267; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1147;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a769.3}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 186, \'a710034}}}{; }{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1237, \'a73}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.502}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{69.4}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Resignations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Resignations in writing by civil officers may be made as follows, except as otherwise provided:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{By the governor, to the general assembly, if in session, if not, to the secretary of state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{By state senators and representatives, and all officers appointed by the senate or house, or by the presiding officers thereof, to the respective presiding officers of the senate and house, when the general assembly is in session, and such presiding officers shall immediately transmit to the governor information of the resignation of any member thereof; when the general assembly is not in session, all such resignations shall be made to the governor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{By senators and representatives in Congress, all officers elected by the registered voters in the state or any district or division thereof larger than a county, or chosen by the general assembly, all judges of courts of record, all officers, trustees, inspectors, and members of all boards and commissions now or hereafter created under the laws of the state, and all persons filling any position of trust or profit in the state, for which no other provision is made, to the governor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{By all county and township officers, to the county auditor, except that of the auditor, which shall be to the board of supervisors.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{By all council members and officers of cities, to the clerk or mayor.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7430; R60, \'a7663; C73, \'a7782; C97, \'a71268; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1148;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a769.4}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 56, \'a77}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{69.5}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Vacancy in general assembly.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{When a vacancy shall occur in the office of senator or representative in the general assembly, except by resignation, the auditor of the county of the senator\u8217\'3fs or representative\u8217\'3fs residence shall notify the governor of such fact and the cause.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7443; R60, \'a7672; C73, \'a7789, 790; C97, \'a71269; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1149;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a769.5}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.510}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{69.6}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Vacancy in state boards.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{In case of a vacancy from any cause, other than resignation or expiration of term, occurring in any of the governing boards of the state institutions, the secretary thereof shall immediately notify the governor.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a71270; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1150;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a769.6}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{69.7}}}{\*\bkmkstart stylerid1_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Duty of officer receiving resignation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{An officer receiving any resignation, or notice of any vacancy, shall forthwith notify the board, tribunal, or officer, if any, empowered to fill the same by appointment.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a71271; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1151;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a769.7}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{69.8}}}{\*\bkmkstart stylerid1_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Vacancies \u8212\'3f how filled.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Vacancies shall be filled by the officer or board named, and in the manner, and under the conditions, following:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E13_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E13_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{United States senator.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In the office of United States senator, when the vacancy occurs when the senate of the United States is in session, or when such senate will convene prior to the next general election, by the governor. An appointment made under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be for the period until the vacancy is filled by election pursuant to law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E13_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E13_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{State offices.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In all state offices, judges of courts of record, officers, trustees, inspectors, and members of all boards or commissions, and all persons filling any position of trust or profit in the state, by the governor, except when some other method is specially provided. An appointment by the governor to fill a vacancy in the office of lieutenant governor shall be for the balance of the unexpired term. An appointment made under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ to a state office subject to }}}{{\f5\fs18\hyphpar0\qj{section 69.13}}}{{\f5\fs18\hyphpar0\qj{ shall be for the period until the vacancy is filled by election pursuant to law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{\*\bkmkstart stylerid1_2E13_2E6_2E1_2E2}{\*\bkmkend stylerid1_2E13_2E6_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{County offices.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In county offices, by the board of supervisors, unless an election is called as provided in }}}{{\f5\fs18\hyphpar0\qj{section 69.14A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{\*\bkmkstart stylerid1_2E13_2E7_2E1_2E2}{\*\bkmkend stylerid1_2E13_2E7_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Board of supervisors.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In the membership of the board of supervisors, by the treasurer, auditor, and recorder, or as provided in }}}{{\f5\fs18\hyphpar0\qj{section 69.14A}}}{{\f5\fs18\hyphpar0\qj{. If any of these offices have been abolished through consolidation, the county attorney shall serve on this committee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{\*\bkmkstart stylerid1_2E13_2E8_2E1_2E2}{\*\bkmkend stylerid1_2E13_2E8_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Elected township offices.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When a vacancy occurs in the office of township clerk or township trustee, the vacancy shall be filled by appointment by the trustees. All appointments to fill vacancies in township offices shall be until a successor is elected at the next general election and qualifies by taking the oath of office. If the term of office in which the vacancy exists will expire within seventy days after the next general election, the person elected to the office for the succeeding term shall qualify by taking the oath of office within ten days after the election and shall serve for the remainder of the unexpired term, as well as for the next four-year term.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{However, if the offices of two trustees are vacant the county board of supervisors shall fill the vacancies by appointment. If the offices of three trustees are vacant the board may fill the vacancies by appointment, or the board may adopt a resolution stating that the board will exercise all powers and duties assigned by law to the trustees of the township in which the vacancies exist until the vacancies are filled at the next general election. If a township office vacancy is not filled by the trustees within thirty days after the vacancy occurs, the board of supervisors may appoint a successor to fill the vacancy until the vacancy can be filled at the next general election.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7436; R60, \'a7664; C73, \'a7513, 783, 794; C97, \'a71272; S13, \'a71272; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1152;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81}}}{, }{{\f5\fs18\hyphpar0\qj{S81, \'a769.8}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a71204}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 186, \'a710035 \u8211\'3f 10037}}}{; }{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1155, \'a72}}}{; }{{\f5\fs18\hyphpar0\qj{87 Acts, ch 68, \'a74}}}{; }{{\f5\fs18\hyphpar0\qj{89 Acts, ch 215, \'a72, 3}}}{; }{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1180, \'a737}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1032, \'a7161}}}{; }{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 57, \'a773}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a769.14A}}}{{\f5\fs12\hyphpar0\qj{, 331.322}}}{{\f5\fs12\hyphpar0\qj{, 331.502}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{General power of governor; }{{\f5\fs12\hyphpar0\qj{Iowa Constitution, Art. IV, \'a710}}}{ }\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{County auditor to act temporarily for other officers, }{{\f5\fs12\hyphpar0\qj{\'a7331.502(6)}}}{ }\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Vacancies in city offices, }{{\f5\fs12\hyphpar0\qj{\'a7372.13(2)}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{69.9}}}{\*\bkmkstart stylerid1_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Person removed not eligible.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{No person can be appointed to fill a vacancy who has been removed from office within one year next preceding.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7441; R60, \'a7669; C73, \'a7787; C97, \'a71273; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1153;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a769.9}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.322}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{69.10}}}{\*\bkmkstart stylerid1_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Appointments.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Appointments under the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ shall be in writing, and filed in the office where the oath of office is required to be filed.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7439; R60, \'a7667; C73, \'a7785; C97, \'a71274; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1154;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a769.10}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.322}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Place of filing oath, }{{\f5\fs12\hyphpar0\qj{\'a764.23}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{69.11}}}{\*\bkmkstart stylerid1_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Tenure of vacancy appointee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{An officer filling a vacancy in an office which is filled by election of the people shall continue to hold until the next election at which such vacancy can be filled, as provided in }{{\f5\fs18\hyphpar0\qj{section 69.12}}}{, and until a successor is elected and qualified. Appointments to all other offices, made under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, shall continue for the remainder of the term of each office, and until a successor is appointed and qualified.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7429, 439; R60, \'a7662, 667, 1101; C73, \'a7530, 781, 785; C97, \'a71276; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1155;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a769.11}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a769.13}}}{{\f5\fs12\hyphpar0\qj{, 331.322}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{69.12}}}{\*\bkmkstart stylerid1_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Officers elected to fill vacancies \u8212\'3f tenure.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{When a vacancy occurs in any nonpartisan elective office of a political subdivision of this state, and the statutes governing the office in which the vacancy occurs require that it be filled by election or are silent as to the method of filling the vacancy, it shall be filled pursuant to }{{\f5\fs18\hyphpar0\qj{this section}}}{. As used in }{{\f5\fs18\hyphpar0\qj{this section}}}{, }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fpending election\u8221\'3f}}}{ means any election at which there will be on the ballot either the office in which the vacancy exists, or any other office to be filled or any public question to be decided by the voters of the same political subdivision in which the vacancy exists.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the unexpired term in which the vacancy occurs has more than seventy days to run after the date of the next pending election, the vacancy shall be filled in accordance with }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. The fact that absentee ballots were distributed or voted before the vacancy occurred or was declared shall not invalidate the election.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vacancy shall be filled at the next pending election if it occurs:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Seventy-four or more days before the election, if it is a general election.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Fifty-two or more days before the election, if it is a regularly scheduled or special city election. However, for those cities which may be required to hold a primary election, the vacancy shall be filled at the next pending election if it occurs seventy-three or more days before a regularly scheduled city election or fifty-nine or more days before a special city election.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Forty-five or more days before the election, if it is a regularly scheduled school election.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Sixty or more days before the election, if it is a special election.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Nomination papers on behalf of candidates for a vacant office to be filled pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be filed, in the form and manner prescribed by applicable law, by 5:00 p.m. on:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The final filing date for candidates filing with the state commissioner or commissioner, as the case may be, for a general election.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The candidate filing deadline specified in }}}{{\f5\fs18\hyphpar0\qj{section 376.4}}}{{\f5\fs18\hyphpar0\qj{ for the regular city election or the filing deadline specified in }}}{{\f5\fs18\hyphpar0\qj{section 372.13, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, for a special city election.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The fortieth day before a regularly scheduled school election.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The twenty-fifth day before a special election.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vacancy which occurs at a time when paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ does not permit it to be filled at the next pending election shall be filled by appointment as provided by law until the succeeding pending election.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When the unexpired term of office in which the vacancy occurs will expire within seventy days after the date of the next pending election, or after the date of a preceding election in which that office was on the ballot, the person elected to the office for the succeeding term shall also be deemed elected to fill the remainder of the unexpired term. If the vacancy is on a multimember body to which more than one nonincumbent is elected for the succeeding term, the nonincumbent who received the most votes shall be deemed elected to fill the remainder of the unexpired term. A person so elected to fill an unexpired term shall qualify within the time required by }}}{{\f5\fs18\hyphpar0\qj{sections 63.3}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{63.8}}}{{\f5\fs18\hyphpar0\qj{. Unless other requirements are imposed by law, qualification for the unexpired term shall also constitute qualification for the full term to which the person was elected.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7431 \u8211\'3f 435; R60, \'a7672, 1083, 1101; C73, \'a7513, 530, 789, 794, 795; C97, \'a71277, 1278; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1156, 1157;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a769.12, 69.13; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81}}}{, }{{\f5\fs18\hyphpar0\qj{S81, \'a769.12}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 34, \'a745}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{87 Acts, ch 221, \'a731}}}{; }{{\f5\fs18\hyphpar0\qj{89 Acts, ch 136, \'a759 \u8211\'3f 61}}}{; }{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1134, \'a778, 79, 115}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1115, \'a727, 28, 71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a769.11}}}{{\f5\fs12\hyphpar0\qj{, 69.14A}}}{{\f5\fs12\hyphpar0\qj{, 161A.5}}}{{\f5\fs12\hyphpar0\qj{, 260C.11}}}{{\f5\fs12\hyphpar0\qj{, 279.6}}}{{\f5\fs12\hyphpar0\qj{, 331.322}}}{{\f5\fs12\hyphpar0\qj{, 347A.1}}}{{\f5\fs12\hyphpar0\qj{, 358.9}}}{{\f5\fs12\hyphpar0\qj{, 358C.10}}}{{\f5\fs12\hyphpar0\qj{, 372.13}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{69.13}}}{\*\bkmkstart stylerid1_2E18_2E2_2E2}{\*\bkmkend stylerid1_2E18_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Vacancies \u8212\'3f senator in Congress and elective state officers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a vacancy occurs in the office of senator in the Congress of the United States, secretary of state, auditor of state, treasurer of state, secretary of agriculture, or attorney general eighty-nine or more days before a general election, and the unexpired term in which the vacancy exists has more than seventy days to run after the date of that general election, the vacancy shall be filled for the balance of the unexpired term at that general election and the person elected to fill the vacancy shall assume office as soon as a certificate of election has been issued and the person has qualified.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the unexpired term of office in which the vacancy occurs will expire within seventy days after the date of the next pending election, }}}{{\f5\fs18\hyphpar0\qj{section 69.11}}}{{\f5\fs18\hyphpar0\qj{ applies.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a769.13}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 136, \'a762}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 129, \'a721}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1067, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 170, \'a779}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1062, \'a794}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a743.6}}}{{\f5\fs12\hyphpar0\qj{, 43.77}}}{{\f5\fs12\hyphpar0\qj{, 69.8}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{69.14}}}{\*\bkmkstart stylerid1_2E19_2E2_2E2}{\*\bkmkend stylerid1_2E19_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Special election to fill vacancies.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A special election to fill a vacancy shall be held for a representative in Congress, or senator or representative in the general assembly, when the body in which such vacancy exists is in session, or will convene prior to the next general election, and the governor shall order, not later than five days from the date the vacancy exists, a special election, giving not less than forty days\u8217\'3f notice of such election. In the event the special election is to fill a vacancy in the general assembly while it is in session or within forty-five days of the convening of any session, the time limit provided in }{{\f5\fs18\hyphpar0\qj{this section}}}{ shall not apply and the governor shall order such special election at the earliest practical time, giving at least eighteen days\u8217\'3f notice of the special election. Any special election called under }{{\f5\fs18\hyphpar0\qj{this section}}}{ must be held on a Tuesday and shall not be held on the same day as a school election within the district.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7443; R60, \'a7672; C73, \'a7789; C97, \'a71279; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1158;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a769.14}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1224, \'a733}}}{; }{{\f5\fs18\hyphpar0\qj{95 Acts, ch 189, \'a717}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a742.4}}}{{\f5\fs12\hyphpar0\qj{, 43.24}}}{{\f5\fs12\hyphpar0\qj{, 43.73}}}{{\f5\fs12\hyphpar0\qj{, 43.78}}}{{\f5\fs12\hyphpar0\qj{, 44.4}}}{{\f5\fs12\hyphpar0\qj{, 49.11}}}{{\f5\fs12\hyphpar0\qj{, 50.30A}}}{{\f5\fs12\hyphpar0\qj{, 50.46}}}{{\f5\fs12\hyphpar0\qj{, 53.4}}}{{\f5\fs12\hyphpar0\qj{, 53.22}}}{{\f5\fs12\hyphpar0\qj{, 53.53}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{69.14A}}}{\*\bkmkstart stylerid1_2E2_30_2E2_2E2}{\*\bkmkend stylerid1_2E2_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Filling vacancy of elected county officer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vacancy on the board of supervisors shall be filled by one of the following procedures:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the population of the county is less than one hundred twenty-five thousand based on the most recent federal decennial census and if the county does not include the main campus of an institution of higher learning governed by the state board of regents, by appointment by the committee of county officers designated to fill the vacancy in }}}{{\f5\fs18\hyphpar0\qj{section 69.8}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The appointment shall be for the period until the next pending election as defined in }}}{{\f5\fs18\hyphpar0\qj{section 69.12}}}{{\f5\fs18\hyphpar0\qj{, and shall be made within forty days after the vacancy occurs. If the committee of county officers designated to fill the vacancy chooses to proceed under this paragraph, the committee shall publish notice in the manner prescribed by }}}{{\f5\fs18\hyphpar0\qj{section 331.305}}}{{\f5\fs18\hyphpar0\qj{ stating that the committee intends to fill the vacancy by appointment but that the electors of the district or county, as the case may be, have the right to file a petition requiring that the vacancy be filled by special election. The committee may publish notice in advance if an elected official submits a resignation to take effect at a future date. The committee may make an appointment to fill the vacancy after the notice is published or after the vacancy occurs, whichever is later. A person appointed to an office under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall have actually resided in the county which the appointee represents sixty days prior to appointment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{However, if within fourteen days after publication of the notice or within fourteen days after the appointment is made, a petition is filed with the county auditor requesting a special election to fill the vacancy, the appointment is temporary and a special election shall be called as provided in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. The petition shall meet the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 331.306}}}{{\f5\fs18\hyphpar0\qj{, except that in counties where supervisors are elected under plan \u8220\'3fthree\u8221\'3f, the number of signatures calculated according to the formula in }}}{{\f5\fs18\hyphpar0\qj{section 331.306}}}{{\f5\fs18\hyphpar0\qj{ shall be divided by the number of supervisor districts in the county.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the population of the county is one hundred twenty-five thousand or more based on the most recent federal decennial census or the county includes the main campus of an institution of higher learning governed by the state board of regents, by special election held to fill the office for the remaining balance of the unexpired term.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The committee of county officers designated to fill the vacancy in }}}{{\f5\fs18\hyphpar0\qj{section 69.8}}}{{\f5\fs18\hyphpar0\qj{ may, on its own motion, or shall, upon receipt of a petition as provided in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, call for a special election to fill the vacancy in lieu of appointment. The committee shall order the special election at the earliest practicable date, but giving at least thirty-two days\u8217\'3f notice of the election. A special election called under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be held on a Tuesday and shall not be held on the same day as a school election within the county.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{However, if a vacancy on the board of supervisors occurs after the date of the primary election and more than seventy-three days before the general election, a special election to fill the vacancy shall not be called by the committee or by petition. If the term of office in which the vacancy exists will expire more than seventy days after the general election, the office shall be listed on the ballot, as \u8220\'3fFor Board of Supervisors, To Fill Vacancy\u8221\'3f. The person elected at the general election shall assume office as soon as a certificate of election is issued and the person has qualified by taking the oath of office. The person shall serve the balance of the unexpired term.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the term of office in which the vacancy exists will expire within seventy days after the general election, the person elected to the succeeding term shall also serve the balance of the unexpired term. The person elected at the general election shall assume office as soon as a certificate of election is issued and the person has qualified by taking the oath of office.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For a vacancy declared by the board pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 331.214, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, by special election held to fill the office if the remaining balance of the unexpired term is two and one-half years or more. The committee of county officers designated to fill the vacancy in }}}{{\f5\fs18\hyphpar0\qj{section 69.8}}}{{\f5\fs18\hyphpar0\qj{ shall order the special election at the earliest practicable date, but giving at least thirty-two days\u8217\'3f notice of the election. A special election called under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be held on a Tuesday and shall not be held on the same day as a school election within the county. The office shall be listed on the ballot, as \u8220\'3fFor Board of Supervisors, To Fill Vacancy\u8221\'3f. The person elected at the special election shall serve the balance of the unexpired term.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vacancy in any of the offices listed in }}}{{\f5\fs18\hyphpar0\qj{section 39.17}}}{{\f5\fs18\hyphpar0\qj{ shall be filled by one of the two following procedures:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{By appointment by the board of supervisors.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The appointment shall be for the period until the next general election, and shall be made within forty days after the vacancy occurs. If the board of supervisors chooses to proceed under this paragraph, the board shall publish notice in the manner prescribed by }}}{{\f5\fs18\hyphpar0\qj{section 331.305}}}{{\f5\fs18\hyphpar0\qj{ stating that the board intends to fill the vacancy by appointment but that the electors of the county have the right to file a petition requiring that the vacancy be filled by special election. The board may publish notice in advance if an elected official submits a resignation to take effect at a future date. The board may make an appointment to fill the vacancy after the notice is published or after the vacancy occurs, whichever is later. A person appointed to an office under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, except for a county attorney, shall have actually resided in the county which the appointee represents sixty days prior to appointment. A person appointed to the office of county attorney shall be a resident of the county at the time of appointment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{However, if within fourteen days after the appointment is made, a petition is circulated and filed with the county auditor requesting a special election to fill the vacancy, the appointment is temporary and a special election shall be called as provided in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. The petition shall meet the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 331.306}}}{{\f5\fs18\hyphpar0\qj{. A signature shall not be considered valid if the signature is dated prior to the date on which the appointment was made.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{By special election held to fill the office for the remaining balance of the unexpired term.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of supervisors may, on its own motion, or shall, upon receipt of a petition as provided in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, call for a special election to fill the vacancy in lieu of appointment. The supervisors shall order the special election at the earliest practicable date, but giving at least thirty-two days\u8217\'3f notice of the election. A special election called under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be held on a Tuesday.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a vacancy in an elective county office occurs after the date of the primary election and more than seventy-three days before the general election, a special election to fill the vacancy shall not be called by the board of supervisors or by petition. If the term of office in which the vacancy exists will expire more than seventy days after the general election, the office shall be listed on the ballot with the name of the office and the additional description, \u8220\'3fTo Fill Vacancy\u8221\'3f. The person elected at the general election shall assume office as soon as a certificate of election is issued and the person has qualified by taking the oath of office. The person shall serve the balance of the unexpired term.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the term of office in which the vacancy exists will expire within seventy days after the general election, the person elected to the succeeding term shall also serve the balance of the unexpired term. The person elected at the general election shall assume office as soon as a certificate of election is issued and the person has qualified by taking the oath of office.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, in the event of a vacancy for which no eligible candidate residing in the county comes forward for appointment, a county board of supervisors may employ a person to perform the duties of the office for at least sixty days but no more than ninety days. After ninety days, the board shall proceed under }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{subsections 1 and 2}}}{{\f5\fs18\hyphpar0\qj{, if a nomination has been made at the primary election for an office in which a vacancy has been filled by appointment, the office shall be filled at the next general election, and not at any special election in the same political subdivision.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 215, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1238, \'a733}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1067, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1180, \'a738 \u8211\'3f 40}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 170, \'a780 \u8211\'3f 83}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1134, \'a780, 115}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1002, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1065, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1032, \'a7162}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 12, \'a769, 70, 73}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 15, \'a75, 6, 9}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a743.6}}}{{\f5\fs12\hyphpar0\qj{, 43.78}}}{{\f5\fs12\hyphpar0\qj{, 44.4}}}{{\f5\fs12\hyphpar0\qj{, 69.8}}}{{\f5\fs12\hyphpar0\qj{, 331.201}}}{{\f5\fs12\hyphpar0\qj{, 331.214}}}{{\f5\fs12\hyphpar0\qj{, 331.322}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 1, paragraph a, unnumbered paragraph 1 amended}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 1, paragraph b, unnumbered paragraph 1 amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\