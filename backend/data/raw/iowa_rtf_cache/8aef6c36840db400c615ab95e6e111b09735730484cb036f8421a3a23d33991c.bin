~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99D.1}}}{\*\bkmkstart stylerid1_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Short title.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This chapter}}}{ shall be known and may be cited as the }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fIowa Pari-mutuel Wagering Act\u8221\'3f}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 187, \'a71}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99D.2}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{As used in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ unless the context otherwise requires:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fApplicant\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an individual applying for an occupational license or the officers and members of the board of directors of a nonprofit corporation applying for a license to conduct a race where pari-mutuel wagering would be permitted under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fBreakage\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the odd cents by which the amount payable on each dollar wagered in a pari-mutuel pool exceeds a multiple of ten cents.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fClaimant agency\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a public agency as defined in }}}{{\f5\fs18\hyphpar0\qj{section 421.65, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, or the state court administrator as defined in }}}{{\f5\fs18\hyphpar0\qj{section 602.1101}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCommission\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the state racing and gaming commission created under }}}{{\f5\fs18\hyphpar0\qj{section 99D.5}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fHolder of occupational license\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person licensed by the commission to perform an occupation which the commission has identified as requiring a license to engage in within the racing industry in Iowa.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLicensee\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a nonprofit corporation licensed under }}}{{\f5\fs18\hyphpar0\qj{section 99D.9}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPari-mutuel wagering\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the system of wagering described in }}}{{\f5\fs18\hyphpar0\qj{section 99D.11}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fRace\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fracing\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3frace meeting\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ftrack\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fracetrack\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ refer to dog racing and horse racing, including but not limited to quarterhorse, thoroughbred, and harness racing, as approved by the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fRacetrack enclosure\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means all real property utilized for the conduct of a race meeting, including the racetrack, grandstand, concession stands, offices, barns, kennels and barn areas, employee housing facilities, parking lots, and any additional areas designated by the commission. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fRacetrack enclosure\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ also means all real property utilized by a licensee under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ who is not required to conduct live racing pursuant to the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 99D.9A}}}{{\f5\fs18\hyphpar0\qj{, on which pari-mutuel wagering on simultaneously telecast horse or dog races may be conducted and lawful gambling is authorized and licensed as provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{chapter 99F}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fWagering area\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means that portion of a racetrack in which a licensee may receive wagers of money from a person present in a licensed racetrack enclosure on a horse or dog in a race selected by the person making the wager as designated by the commission.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 187, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1265, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1266, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 67, \'a723}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 9, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1136, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 3, \'a724}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1172, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1036, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1126, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1064, \'a74, 28}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1118, \'a773, 74}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a799F.1}}}{{\f5\fs12\hyphpar0\qj{, 99F.4}}}{{\f5\fs12\hyphpar0\qj{, 99F.9}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99D.3}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Scope of provisions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This chapter}}}{ does not apply to horse-race or dog-race meetings unless the pari-mutuel system of wagering is used or intended to be used in connection with the horse-race or dog-race meetings. If the pari-mutuel system is used or intended to be used a person shall not conduct a race meeting without a license as provided by }{{\f5\fs18\hyphpar0\qj{section 99D.9}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 187, \'a73}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99D.4}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Pari-mutuel wagering legalized.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The system of wagering on the results of horse or dog races as provided by }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ is legal, when conducted within the racetrack enclosure at a licensed horse-race or dog-race meeting.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 187, \'a74}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99D.5}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Creation of state racing and gaming commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A state racing and gaming commission is created within the department of inspections, appeals, and licensing consisting of five members who shall be appointed by the governor subject to confirmation by the senate, and who shall serve not to exceed a three-year term at the pleasure of the governor. The term of each member shall begin and end as provided in }}}{{\f5\fs18\hyphpar0\qj{section 69.19}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vacancy on the commission shall be filled as provided in }}}{{\f5\fs18\hyphpar0\qj{section 2.32}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Not more than three members of the commission shall belong to the same political party. A member of the commission shall not have a financial interest in a racetrack.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Commission members are each entitled to receive an annual salary of ten thousand dollars. Members shall also be reimbursed for actual expenses incurred in the performance of their duties to a maximum of thirty thousand dollars per year for the commission. Each member shall be covered by the blanket surety bond of the state purchased pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 8A.321, subsection 12}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A member or a holder of an official\u8217\'3fs license shall not knowingly:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Have a pecuniary, equitable, or other interest in or engage in a business or employment which would be a conflict of interest or interfere or conflict with the proper discharge of the duties of the commission including any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A business which does business with a licensee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A business issued a concession operator\u8217\'3fs license.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Participate directly or indirectly as an owner, owner-trainer, trainer of a horse or dog, or jockey of a horse in a race meeting conducted in this state.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Place a wager on an entry in a race or on a gambling game operated on an excursion gambling boat or gambling structure.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A violation of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ is a serious misdemeanor. In addition, the individual may be subject to disciplinary actions pursuant to the commission rules.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A member, employee, or appointee of the commission, spouse of a member, employee, or appointee of the commission, or a family member related within the second degree of affinity or consanguinity to a member, employee, or appointee of the commission shall not do either of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Hold an occupational license except an official\u8217\'3fs license.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Enter directly or indirectly into any business dealing, venture, or contract with an owner or lessee of a racetrack.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A member who knowingly approves of a violation of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ is guilty of a serious misdemeanor.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 187, \'a75, 36}}}{; }{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1266, \'a74, 5}}}{; }{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1245, \'a7713, 714}}}{; }{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1267, \'a717}}}{; }{{\f5\fs18\hyphpar0\qj{89 Acts, ch 67, \'a724, 25}}}{; }{{\f5\fs18\hyphpar0\qj{89 Acts, ch 83, \'a721}}}{; }{{\f5\fs18\hyphpar0\qj{89 Acts, ch 231, \'a730}}}{; }{{\f5\fs18\hyphpar0\qj{91 Acts, ch 266, \'a721}}}{; }{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1203, \'a72}}}{; }{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1136, \'a74}}}{; }{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 177, \'a715}}}{; }{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 188, \'a74}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1032, \'a7201}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71869}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a799B.13}}}{{\f5\fs12\hyphpar0\qj{, 99B.42}}}{{\f5\fs12\hyphpar0\qj{, 99D.2}}}{{\f5\fs12\hyphpar0\qj{, 99E.1}}}{{\f5\fs12\hyphpar0\qj{, 99F.1}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Confirmation, see }{{\f5\fs12\hyphpar0\qj{\'a72.32}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99D.6}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{ Headquarters, meetings, and election of chairperson }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ administrator }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ employees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall have its headquarters in the city of Des Moines and shall meet at such times and places as it finds necessary for the discharge of its duties. The commission shall elect in July of each year one of its members as chairperson for the succeeding year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall appoint an administrator of the commission subject to confirmation by the senate. The administrator shall serve a four-year term. The term shall begin and end in the same manner as set forth in }}}{{\f5\fs18\hyphpar0\qj{section 69.19}}}{{\f5\fs18\hyphpar0\qj{. A vacancy shall be filled for the unexpired portion of the term in the same manner as a full-term appointment is made. The administrator shall be covered by the blanket surety bond of the state purchased pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 8A.321, subsection 12}}}{{\f5\fs18\hyphpar0\qj{. The compensation and employment terms of the administrator shall be set by the governor, taking into consideration the level of knowledge and experience of the administrator. The administrator shall keep a record of the proceedings of the commission and preserve the books, records, and documents entrusted to the administrator\u8217\'3fs care. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The administrator may hire other assistants and employees as necessary to carry out the commission\u8217\'3fs duties. Employees in the positions of equine veterinarian, canine veterinarian, and equine steward shall be exempt from the merit system provisions of }}}{{\f5\fs18\hyphpar0\qj{chapter 8A, subchapter IV}}}{{\f5\fs18\hyphpar0\qj{, and shall not be covered by a collective bargaining agreement. Some or all of the information required of applicants in }}}{{\f5\fs18\hyphpar0\qj{section 99D.8A, subsections 1 and 2}}}{{\f5\fs18\hyphpar0\qj{, may also be required of employees of the commission if the commission deems it necessary. }}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 187, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1265, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1245, \'a7715}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 115, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 231, \'a731}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1136, \'a75, 65}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 215, \'a726}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 29, \'a718}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1170, \'a790}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a799D.10}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Confirmation, see }{{\f5\fs12\hyphpar0\qj{\'a72.32}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99D.7}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Powers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The commission shall have full jurisdiction over and shall supervise all race meetings governed by }{{\f5\fs18\hyphpar0\qj{this chapter}}}{. The commission shall have the following powers and shall adopt rules pursuant to }{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{ to implement }{{\f5\fs18\hyphpar0\qj{this chapter}}}{:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To investigate applicants and determine the eligibility of applicants for a license and to select among competing applicants for a license the applicant which best serves the interests of the citizens of Iowa.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To identify occupations within the racing industry which require licensing and adopt standards for licensing the occupations including establishing fees for the occupational licenses. The fees shall be paid to the commission and used as required in }}}{{\f5\fs18\hyphpar0\qj{section 99D.17}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To adopt standards regarding the duration of thoroughbred and quarter horse racing seasons, so that a thoroughbred racing season shall not be less than sixty-seven days, and so that a quarter horse racing season shall not be less than twenty-six days. The thoroughbred and quarter horse racing seasons shall be run independently unless mutually agreed upon by the associations representing the thoroughbred and quarter horse owners and the licensee of the horse racetrack located in Polk county.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To adopt standards under which all race meetings shall be held and standards for the facilities within which the race meetings shall be held.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To regulate the purse structure for race meetings including establishing a minimum purse.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall, beginning January 1, 2012, regulate the purse structure for all horse racing so that seventy-six percent is designated for thoroughbred racing, fifteen and one-quarter percent is designated for quarter horse racing, and eight and three-quarters percent is designated for standardbred racing. The purse moneys designated for standardbred racing may only be used to support standardbred harness racing purses, breeder\u8217\'3fs awards, or expenses at the state fair, county fairs, or other harness racing tracks approved by the commission, or for the maintenance, construction, or repair of harness racing tracks located in Iowa and at the fairgrounds for such fairs or other harness racing tracks located in Iowa and approved by the commission. The horse racetrack in Polk county shall not provide funding to support standardbred racing at such county fairs that is not otherwise provided for in this paragraph.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The purse moneys designated for standardbred racing shall be payable to a nonprofit corporation operated exclusively for those purposes allowed an exempt organization under }}}{{\f5\fs18\hyphpar0\qj{section 501(c)(4) of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 422.3}}}{{\f5\fs18\hyphpar0\qj{, which was organized under the laws of this state on or before January 1, 2008, which exists for the promotion of the sport of harness racing in this state, and which received supplemental payments from the horse racetrack in Polk county for the conduct of harness racing during the 2010 calendar year. The nonprofit corporation receiving such purse moneys shall complete and provide to the commission an annual audit and accounting of the allocation of such moneys.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Of the purse moneys designated for thoroughbred racing, four percent shall be distributed to an organization representing owners of thoroughbred race horses for the purpose of paying the annual operating expenses of the organization and for the promotion and marketing of Iowa-bred horses. The organization receiving such purse moneys shall complete and provide to the commission an annual audit and accounting of the allocation of such moneys.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Of the purse moneys designated for quarter horse racing, two percent shall be distributed to an organization representing owners of quarter horse race horses for the purpose of paying the annual operating expenses of the organization and for the promotion and marketing of Iowa-bred horses. The organization receiving such purse moneys shall complete and provide to the commission an annual audit and accounting of the allocation of such moneys.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To cooperate with the department of agriculture and land stewardship to establish and operate, or contract for, a laboratory and related facilities to conduct saliva, urine, and other tests on animals that are to run or that have run in races governed by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To establish and provide for the disposition of fees for the testing of animals sufficient to cover the costs of the tests and to purchase the necessary equipment for the testing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To enter the office, racetrack, facilities, or other places of business of a licensee to determine compliance with }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To investigate alleged violations of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or the commission rules, orders, or final decisions and to take appropriate disciplinary action against a licensee or a holder of an occupational license for the violation, or institute appropriate legal action for enforcement, or both. Information gathered during an investigation is confidential during the pendency of the investigation. Decisions by the commission are final agency actions pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To authorize stewards, starters, and other racing officials to impose fines or other sanctions upon a person violating a provision of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or the commission rules, orders, or final orders, including authorization to expel a tout, bookmaker, or other person deemed to be undesirable from the racetrack facilities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To require the removal of a racing official, an employee of a licensee, or a holder of an occupational license, or employee of a holder of an occupational license for a violation of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or a commission rule or engaging in a fraudulent practice.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To prevent an animal from racing if the commission or commission employees with cause believe the animal or its owner, trainer, or an employee of the owner or trainer is in violation of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or commission rules.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To withhold payment of a purse if the outcome of a race is disputed or until tests are performed on the animals to determine if they were illegally drugged.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To provide for immediate determination of the disposition of a challenge by a racing official or representative of the commission by establishing procedures for informal hearings before a panel of stewards at a racetrack.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To require a licensee to file an annual balance sheet and profit and loss statement pertaining to the licensee\u8217\'3fs racing activities in this state, together with a list of the stockholders or other persons having any beneficial interest in the racing activities of each licensee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{16.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To issue subpoenas for the attendance of witnesses and subpoenas duces tecum for the production of books, records and other pertinent documents in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{, and to administer oaths and affirmations to the witnesses, when, in the judgment of the racing and gaming commission, it is necessary to enforce }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or the commission rules.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{17.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To keep accurate and complete records of its proceedings and to certify the records as may be appropriate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{18.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To require all licensees to use a computerized totalizator system for calculating odds and payouts from the pari-mutuel wagering pool and to establish standards to insure the security of the totalizator system.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{19.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To revoke or suspend licenses and impose fines not to exceed one thousand dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{20.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To require licensees to indicate in their racing programs those horses which are treated with the legal medication furosemide or phenylbutazone. The program shall also indicate if it is the first or subsequent time that a horse is racing with furosemide, or if the horse has previously raced with furosemide and the present race is the first race for the horse without furosemide following its use.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{21.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any contrary provision in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, to provide for interstate combined wagering pools related to simulcasting horse or dog races and all related interstate pari-mutuel wagering activities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{22.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To cooperate with the gambling treatment program administered by the department of health and human services to incorporate information regarding the gambling treatment program and its toll-free telephone number in printed materials distributed by the commission. The commission may require licensees to have the information available in a conspicuous place as a condition of licensure.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{23.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To establish a process to allow a person to be voluntarily excluded from advance deposit wagering as defined in }}}{{\f5\fs18\hyphpar0\qj{section 99D.11}}}{{\f5\fs18\hyphpar0\qj{, from an internet fantasy sports contest as defined in }}}{{\f5\fs18\hyphpar0\qj{section 99E.1}}}{{\f5\fs18\hyphpar0\qj{, from advance deposit sports wagering as defined in }}}{{\f5\fs18\hyphpar0\qj{section 99F.9}}}{{\f5\fs18\hyphpar0\qj{, and from the wagering area of a racetrack enclosure, from the gaming floor, and from the sports wagering area, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 99F.1}}}{{\f5\fs18\hyphpar0\qj{, of all other licensed facilities under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{chapter 99F}}}{{\f5\fs18\hyphpar0\qj{ as provided in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. The process shall provide that an initial request by a person to be voluntarily excluded shall be for a period of five years or life and any subsequent request following any five-year period shall be for a period of five years or life. The process established shall require that licensees be provided electronic access to names and social security numbers of persons voluntarily excluded through a secured interactive internet site maintained by the commission and information regarding persons voluntarily excluded shall be disseminated to all licensees under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{chapter 99E}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{chapter 99F}}}{{\f5\fs18\hyphpar0\qj{. The names, social security numbers, and information regarding persons voluntarily excluded shall be kept confidential unless otherwise ordered by a court or by another person duly authorized to release such information. The process established shall also require a person requesting to be voluntarily excluded be provided information compiled by the department of health and human services on gambling treatment options. The state and any licensee under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{chapter 99E}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{chapter 99F}}}{{\f5\fs18\hyphpar0\qj{ shall not be liable to any person for any claim which may arise from this process. In addition to any other penalty provided by law, any money or thing of value that has been obtained by, or is owed to, a voluntarily excluded person as a result of wagers made by the person after the person has been voluntarily excluded shall be forfeited by the person and shall be credited to the general fund of the state. The commission shall not initiate any administrative action or impose penalties on a licensee who voluntarily reports to the commission activity described in }}}{{\f5\fs18\hyphpar0\qj{section 99D.24, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{24.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To require licensees to establish a process with the state for licensees to have electronic access to names and social security numbers of debtors of claimant agencies through a secured interactive internet site maintained by the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{25.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To take any other action as may be reasonable or appropriate to enforce }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and the commission rules.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 187, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1265, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1266, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1137, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 231, \'a732}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 166, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 260, \'a71205}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1100, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 205, \'a734}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1212, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1136, \'a76 \u8211\'3f 8}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1172, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 182, \'a7101}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 111, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 90, \'a7257}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1033, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 132, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1099, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 132, \'a71, 22, 23}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1063, \'a750}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1054, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1143, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a762}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a712.10}}}{{\f5\fs12\hyphpar0\qj{, 99D.9}}}{{\f5\fs12\hyphpar0\qj{, 99D.10}}}{{\f5\fs12\hyphpar0\qj{, 99D.11}}}{{\f5\fs12\hyphpar0\qj{, 99D.22}}}{{\f5\fs12\hyphpar0\qj{, 99D.24}}}{{\f5\fs12\hyphpar0\qj{, 99D.28}}}{{\f5\fs12\hyphpar0\qj{, 99F.6}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For provisions governing authority of a person voluntarily excluded for life from all licensed facilities under }{{\f5\fs12\hyphpar0\qj{chapters 99D}}}{ and }{{\f5\fs12\hyphpar0\qj{99F}}}{ prior to July 1, 2017, to revoke the exclusion, see }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2017/CH0132.pdf" }{\fldrslt \cf5 \f5 \fs12{{2017 Acts, ch 132, \'a73}}}}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99D.8}}}{\*\bkmkstart stylerid1_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Horse or dog racing licenses \u8212\'3f applications.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A qualifying organization, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 513(d)(2)(C) of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 422.3}}}{{\f5\fs18\hyphpar0\qj{, exempt from federal income taxation under sections }}}{{\f5\fs18\hyphpar0\qj{501(c)(3)}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{501(c)(4)}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{501(c)(5)}}}{{\f5\fs18\hyphpar0\qj{ of the Internal Revenue Code or a nonprofit corporation organized under the laws of this state, whether or not it is exempt from federal income taxation, which is organized to distribute funds for educational, civic, public, charitable, patriotic, or religious uses, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 99B.1}}}{{\f5\fs18\hyphpar0\qj{, or which regularly conducts an agricultural and educational fair or exposition for the promotion of the horse, dog, or other livestock breeding industries of the state, or an agency, instrumentality, or political subdivision of the state, may apply to the commission for a license to conduct horse or dog racing. The application shall be filed with the administrator of the commission at least sixty days before the first day of the horse race or dog race meeting which the organization proposes to conduct, shall specify the day or days when and the exact location where it proposes to conduct racing, and shall be in a form and contain information as the commission prescribes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If any part of the net income of a licensee is determined to be unrelated business taxable income as defined in sections 511 through 514 of the Internal Revenue Code, or is otherwise taxable, the licensee shall be required to distribute such amount to political subdivisions in the state and organizations described in section 501(c)(3) of the Internal Revenue Code in the county in which the licensee operates.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An organization which meets the requirements of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, as amended, on or before July 1, 1988, shall be considered to have met the requirements of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ on the date that its initial application was originally filed.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 187, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1243, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 176, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 99, \'a750}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 54, \'a776}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a799D.9}}}{{\f5\fs12\hyphpar0\qj{, 99D.10}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99D.8A}}}{\*\bkmkstart stylerid1_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Requirements of applicant \u8212\'3f penalty \u8212\'3f consent to search.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not be issued a license to conduct races under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or an occupational license unless the person has completed and signed an application on the form prescribed and published by the commission. The application shall state the full name, social security number, residence, date of birth and other personal identifying information of the applicant that the commission deems necessary. The application shall state whether the applicant has any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A record of conviction of a felony.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An addiction to alcohol or a controlled substance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A history of mental illness or repeated acts of violence.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An applicant shall submit pictures, fingerprints, and descriptions of physical characteristics to the commission in the manner prescribed on the application forms. The fingerprints may be submitted to the federal bureau of investigation by the department of public safety through the state criminal history repository for the purpose of a national criminal history check.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall charge the applicant a fee set by the department of public safety, division of criminal investigation, to defray the costs associated with the search and classification of fingerprints required in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{. This fee is in addition to any other license fee charged by the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who knowingly makes a false statement on the application is guilty of an aggravated misdemeanor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The licensee or a holder of an occupational license shall consent to agents of the division of criminal investigation of the department of public safety or commission employees designated by the administrator of the commission to the search without a warrant of the licensee or holder\u8217\'3fs person, personal property and effects, and premises which are located within the racetrack enclosure or adjacent facilities under control of the licensee to inspect or investigate for criminal violations of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or violations of rules adopted by the commission.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1265, \'a74}}}{; }{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1266, \'a77}}}{; }{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1044, \'a75, 11}}}{; }{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 108, \'a729}}}{; }{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 35, \'a731}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a799D.6}}}{{\f5\fs12\hyphpar0\qj{, 99D.9}}}{{\f5\fs12\hyphpar0\qj{, 99D.10}}}{{\f5\fs12\hyphpar0\qj{, 99D.11}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99D.9}}}{\*\bkmkstart stylerid1_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Licenses \u8212\'3f terms and conditions \u8212\'3f revocation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the commission is satisfied that its rules and }}}{{\f5\fs18\hyphpar0\qj{sections 99D.8 through 99D.25}}}{{\f5\fs18\hyphpar0\qj{ applicable to licensees have been or will be complied with, it may issue a license for a period of not more than three years. The commission may decide which types of racing it will permit. The commission may permit dog racing, horse racing of various types, or both dog and horse racing. However, only quarter horse and thoroughbred racing shall be allowed to be conducted at the horse racetrack located in Polk county. The commission shall decide the number, location, and type of all racetracks licensed under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. The license shall set forth the name of the licensee, the type of license granted, the place where the race meeting is to be held, and the time and number of days during which racing may be conducted by the licensee. The commission shall not approve a license application if any part of the racetrack is to be constructed on prime farmland outside the city limits of an incorporated city. As used in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fprime farmland\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means as defined by the United States department of agriculture in }}}{{\f5\fs18\hyphpar0\qj\cf1{7 C.F.R. \'a7657.5(a)}}}{{\f5\fs18\hyphpar0\qj{. A license is not transferable or assignable. The commission may revoke any license issued for good cause upon reasonable notice and hearing. The commission shall conduct a neighborhood impact study to determine the impact of granting a license on the quality of life in neighborhoods adjacent to the proposed racetrack facility. The applicant for the license shall reimburse the commission for the costs incurred in making the study. A copy of the study shall be retained on file with the commission and shall be a public record. The study shall be completed before the commission may issue a license for the proposed facility.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A license shall only be granted to a nonprofit corporation or association upon the express condition that the nonprofit corporation or association shall not, by a lease, contract, understanding, or arrangement of any kind, grant, assign, or turn over to a person the operation of a race meeting licensed under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ or of the pari-mutuel system of wagering described in }}}{{\f5\fs18\hyphpar0\qj{section 99D.11}}}{{\f5\fs18\hyphpar0\qj{. }}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not prohibit a management contract approved by the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A license shall not be granted to a nonprofit corporation if there is substantial evidence that the applicant for a license:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Has been suspended or ruled off a recognized course in another jurisdiction by the racing board or commission of that jurisdiction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Has not demonstrated financial responsibility sufficient to meet adequately the requirements of the enterprise proposed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is not the true owner of the enterprise proposed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is not the sole owner, and other persons have ownership in the enterprise which fact has not been disclosed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is a corporation and ten percent of the stock of the corporation is subject to a contract or option to purchase at any time during the period for which the license is issued unless the contract or option was disclosed to the commission and the commission approved the sale or transfer during the period of the license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Has knowingly made a false statement of a material fact to the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Has failed to meet any monetary obligation in connection with a race meeting held in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A license shall not be granted to a nonprofit corporation if there is substantial evidence that stockholders or officers of the nonprofit corporation are not of good repute and moral character.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A license shall not be granted to a licensee for racing on more than one racetrack at the same time.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensee shall not loan to any person money or any other thing of value for the purpose of permitting that person to wager on any race.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensee shall not permit a financial institution, vendor, or other person to dispense cash or credit through an electronic or mechanical device including but not limited to a satellite terminal as defined in }}}{{\f5\fs18\hyphpar0\qj{section 527.2}}}{{\f5\fs18\hyphpar0\qj{, that is located in the wagering area. However, this paragraph shall not apply to cashless wagering systems where a person accesses a cash account through a mobile application used by the licensee to conduct cashless wagering. The mobile application shall include the statewide telephone number authorized by the department of health and human services to provide problem gambling information and extensive responsible gaming features in addition to those described in }}}{{\f5\fs18\hyphpar0\qj{section 99D.7, subsection 23}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When technologically available, a licensee shall ensure that a person may voluntarily bar the person\u8217\'3fs access to receive cash or credit from a financial institution, vendor, or other person through an electronic or mechanical device including but not limited to a satellite terminal as defined in }}}{{\f5\fs18\hyphpar0\qj{section 527.2}}}{{\f5\fs18\hyphpar0\qj{, that is located on the licensed premises.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon a violation of any of the conditions listed in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the commission shall immediately revoke the license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall require that a licensee utilize Iowa resources, goods, and services in the operation of a racetrack enclosure. The commission shall develop standards to assure that a substantial amount of all resources and goods used in the operation of a racetrack enclosure emanate from and are made in Iowa and that a substantial amount of all services and entertainment are provided by Iowans.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 187, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1266, \'a78 \u8211\'3f 10}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1021, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1136, \'a79 \u8211\'3f 11}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 111, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1143, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a763}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a799D.2}}}{{\f5\fs12\hyphpar0\qj{, 99D.3}}}{{\f5\fs12\hyphpar0\qj{, 99D.9C}}}{{\f5\fs12\hyphpar0\qj{, 99D.9D}}}{{\f5\fs12\hyphpar0\qj{, 99D.10}}}{{\f5\fs12\hyphpar0\qj{, 99D.14}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99D.9A}}}{\*\bkmkstart stylerid1_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Dog racetrack licensure }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ discontinuance of live racing requirement }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ fees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon written notification to the commission by September 1, 2014, and agreement to comply with the requirements of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, a licensee authorized to conduct pari-mutuel wagering at a dog racetrack and to conduct gambling games pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 99F.6}}}{{\f5\fs18\hyphpar0\qj{ as of January 1, 2014, may, as of the live racing cessation date, continue to maintain a license as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ for purposes of conducting gambling games and pari-mutuel wagering on simultaneously telecast horse or dog races without the requirement of scheduling performances of live races at the dog racetrack. For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3flive racing cessation date\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ is October 31, 2014, for the licensee of the pari-mutuel dog racetrack located in Dubuque county, and December 31, 2015, for the licensee of the pari-mutuel dog racetrack located in Pottawattamie county.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon the live racing cessation date of a licensee, all of the following shall occur:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall determine what portion of the unexpended moneys in the dog racing promotion fund created in }}}{{\f5\fs18\hyphpar0\qj{section 99D.12}}}{{\f5\fs18\hyphpar0\qj{ is attributable to the licensee as of the live racing cessation date of the licensee and shall transfer those moneys to the Iowa greyhound pari-mutuel racing fund created in }}}{{\f5\fs18\hyphpar0\qj{section 99D.9B}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any agreement which was approved by the commission for dog purse supplement payments for live racing by the licensee shall be terminated.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Within thirty days after the live racing cessation date of the licensee of the pari-mutuel dog racetrack located in Pottawattamie county, the kennel owners and operators and greyhound owners shall, at their expense, remove all of their property including the greyhounds from the racetrack.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To maintain a license under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ to conduct gambling games and pari-mutuel wagering on simultaneously telecast horse or dog races without the requirement of scheduling performances of live dog races, or to maintain a license under }}}{{\f5\fs18\hyphpar0\qj{section 99F.4A, subsection 9}}}{{\f5\fs18\hyphpar0\qj{, the licensee as of the date a payment under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ is due shall ensure payment of the live racing cessation fee to the commission for deposit in the Iowa greyhound pari-mutuel racing fund created in }}}{{\f5\fs18\hyphpar0\qj{section 99D.9B}}}{{\f5\fs18\hyphpar0\qj{, as required by }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as provided in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the live racing cessation fee shall be paid and determined as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the licensee authorized to conduct gambling games in Dubuque county pursuant to a license issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 99F.4A, subsection 9}}}{{\f5\fs18\hyphpar0\qj{, the payment of one million dollars by January 1, 2015, and one million dollars each succeeding January 1 for six consecutive calendar years.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the pari-mutuel dog racetrack located in Pottawattamie county, the payment of nine million two hundred eighty-five thousand eight hundred dollars by January 1, 2016, and nine million two hundred eighty-five thousand seven hundred dollars each succeeding January 1 for six consecutive calendar years. Payments required under this subparagraph shall be made by the manager of the pari-mutuel racetrack located in Pottawattamie county for deposit in the Iowa greyhound pari-mutuel racing fund created in }}}{{\f5\fs18\hyphpar0\qj{section 99D.9B}}}{{\f5\fs18\hyphpar0\qj{, as required by }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the licensee at the pari-mutuel racetrack located in Pottawattamie county as of January 1, 2014, fails to have the licensee\u8217\'3fs license renewed, the licensee\u8217\'3fs obligation and any obligation of the manager of the racetrack to make any further payments as provided in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall cease. However, the commission shall not issue a license to a subsequent or successor licensee at the pari-mutuel racetrack located in Pottawattamie county until all remaining unpaid installments of the live racing cessation fee required under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ are paid.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the licensee issued a license under }}}{{\f5\fs18\hyphpar0\qj{section 99F.4A, subsection 9}}}{{\f5\fs18\hyphpar0\qj{, fails to have the license renewed, the licensee\u8217\'3fs obligation to make any further payments as provided in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall cease. However, the commission shall not issue a license to a subsequent or successor licensee under }}}{{\f5\fs18\hyphpar0\qj{section 99F.4A, subsection 9}}}{{\f5\fs18\hyphpar0\qj{, until all remaining installments of the live racing cessation fee required under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ are paid.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the manager of the pari-mutuel racetrack located in Pottawattamie county as of January 1, 2014, pursuant to a management contract with the licensee, ceases to be the manager of the racetrack, the licensee\u8217\'3fs obligation and any obligation of the manager of the racetrack to make any further payments as provided in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall cease. However, the commission shall not approve a management contract with the licensee for a subsequent or successor manager until all remaining installments of the live racing cessation fee required under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ are paid.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon written notification to the commission by the licensee of the pari-mutuel dog racetrack located in Dubuque county as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, all of the following shall occur:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The licensee shall be authorized to maintain a license issued to the licensee by the commission to conduct gambling games pursuant to the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 99F.4A, subsection 9}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The licensee shall maintain a license under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ until December 31, 2014. The licensee shall, until the live racing cessation date of the licensee, conduct pari-mutuel wagering on live dog races and shall, until December 31, 2014, be authorized to simultaneously telecast horse or dog races as provided by an agreement to conduct live racing during the 2014 calendar year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The licensee of the pari-mutuel dog racetrack located in Pottawattamie county who is not required to conduct live racing pursuant to the requirements of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall do all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Remain licensed under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 99F.4A}}}{{\f5\fs18\hyphpar0\qj{ as a pari-mutuel dog racetrack licensed to conduct gambling games and pari-mutuel wagering on simultaneously telecast horse or dog races.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Continue to pay the annual license fee and regulatory fee as a pari-mutuel dog racetrack licensed to conduct gambling games pursuant to the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 99F.4A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Comply with all other applicable requirements of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{chapter 99F}}}{{\f5\fs18\hyphpar0\qj{ except for those requirements concerning live dog racing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{However, nothing in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall require the licensee of the pari-mutuel dog racetrack in Pottawattamie county to conduct pari-mutuel wagering on simultaneously telecast horse or dog races to remain licensed under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or to conduct gambling games without the requirement of scheduling performances of live dog races.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Compliance with the requirements of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and the establishment of the Iowa greyhound pari-mutuel racing fund in }}}{{\f5\fs18\hyphpar0\qj{section 99D.9B}}}{{\f5\fs18\hyphpar0\qj{ shall constitute a full satisfaction of and discharge from any and all liability or potential liability of a licensee authorized to conduct gambling games in Dubuque county pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 99F.4A, subsection 9}}}{{\f5\fs18\hyphpar0\qj{, the licensee of the pari-mutuel dog racetrack located in Pottawattamie county, and the Iowa greyhound association which may arise out of either of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The discontinuance of live dog racing or simulcasting.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Distributions made or not made from the Iowa greyhound pari-mutuel racing fund created in }}}{{\f5\fs18\hyphpar0\qj{section 99D.9B}}}{{\f5\fs18\hyphpar0\qj{ or the purse escrow fund created in the arbitration decision issued in December 1995 with regard to the purse supplements to be paid at the pari-mutuel dog racetrack in Pottawattamie county. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Compliance with the requirements of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and establishment of the Iowa greyhound pari-mutuel racing fund in }}}{{\f5\fs18\hyphpar0\qj{section 99D.9B}}}{{\f5\fs18\hyphpar0\qj{ shall immunize a licensee authorized to conduct gambling games in Dubuque county pursuant to a license issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 99F.4A, subsection 9}}}{{\f5\fs18\hyphpar0\qj{, the licensee of the pari-mutuel dog racetrack located in Pottawattamie county, and the Iowa greyhound association and their respective officers, directors, employees, board members, and agents against claims of liability as described in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ made by any person or entity.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2014 Acts, ch 1126, \'a72}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a799D.2}}}{{\f5\fs12\hyphpar0\qj{, 99D.9}}}{{\f5\fs12\hyphpar0\qj{, 99D.9B}}}{{\f5\fs12\hyphpar0\qj{, 99D.9C}}}{{\f5\fs12\hyphpar0\qj{, 99D.10}}}{{\f5\fs12\hyphpar0\qj{, 99D.11}}}{{\f5\fs12\hyphpar0\qj{, 99F.1}}}{{\f5\fs12\hyphpar0\qj{, 99F.4A}}}{{\f5\fs12\hyphpar0\qj{, 99F.6}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99D.9B}}}{\*\bkmkstart stylerid1_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Iowa greyhound pari-mutuel racing fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An Iowa greyhound pari-mutuel racing fund is created in the state treasury under the control of the racing and gaming commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The fund shall consist of all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Moneys in the dog racing promotion fund created in }}}{{\f5\fs18\hyphpar0\qj{section 99D.12}}}{{\f5\fs18\hyphpar0\qj{ that were deposited in the fund from a dog racetrack licensee that is no longer required to conduct live dog races pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 99D.9A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Moneys deposited in the fund from the live racing cessation fee established in }}}{{\f5\fs18\hyphpar0\qj{section 99D.9A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Fifty percent of the moneys deposited in the fund shall first be distributed to the Iowa greyhound association for deposit in the escrow account established by the Iowa greyhound association pursuant to the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 99D.9C}}}{{\f5\fs18\hyphpar0\qj{, provided the Iowa greyhound association is licensed under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ to conduct pari-mutuel wagering on live dog races or simultaneously telecast horse or dog races pursuant to the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 99D.9C}}}{{\f5\fs18\hyphpar0\qj{, by December 15, 2014. }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Moneys remaining in the fund following distribution to the Iowa greyhound association as provided in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be under the sole control of the commission. The commission shall determine the method by which moneys remaining in the fund will be distributed, provided that the commission shall distribute a portion of the moneys in the fund to no-kill animal adoption agencies to facilitate care for and adoption of greyhounds no longer racing as a result of the discontinuance of live racing. The commission may consider objective evidence, including purse payments to greyhound industry participants for the period beginning January 1, 2010, and ending December 31, 2014, in determining the method of distribution. The commission may hire an expert to assist in the task of making distributions from the fund. The commission may distribute moneys from the fund to greyhound industry participants and to kennel owners and operators and greyhound owners for costs incurred in removing property from the dog racetrack located in Pottawattamie county as required by }}}{{\f5\fs18\hyphpar0\qj{section 99D.9A, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. Prior to adoption of any formula for distribution, the commission shall allow for input from greyhound industry participants. The distribution decisions of the commission shall be final. The commission may use moneys in the fund to pay its direct and indirect administrative expenses incurred in administering the fund, including the hiring of experts to assist in the commission\u8217\'3fs distribution determination. Members of the commission, employees of the commission, and any experts hired by the commission pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be held harmless against any claim of liability made by any person arising out of the distribution of moneys from the fund by the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Section 8.33}}}{{\f5\fs18\hyphpar0\qj{ does not apply to moneys in the fund. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 12C.7, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, interest or earnings on moneys deposited in the fund shall be credited to the fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall adopt rules to administer }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2014 Acts, ch 1126, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 29, \'a719}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a799D.9}}}{{\f5\fs12\hyphpar0\qj{, 99D.9A}}}{{\f5\fs12\hyphpar0\qj{, 99D.9C}}}{{\f5\fs12\hyphpar0\qj{, 99D.10}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99D.9C}}}{\*\bkmkstart stylerid1_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Alternative dog racetrack and simulcasting licensure }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ live racing }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ lease agreement with gambling games licensee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The Iowa greyhound association may submit an application to the commission for a license under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ to conduct pari-mutuel wagering on live dog races or simultaneously telecast horse or dog races, subject to the requirements of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. Unless inconsistent with the requirements of this section, the Iowa greyhound association shall comply with all requirements for submitting an application for a license under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. If an application is submitted by October 1, 2014, the commission shall, subject to the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 99D.9}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, determine whether to approve the application for a license by December 1, 2014.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the commission approves an application for a license submitted by the Iowa greyhound association pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 99D.9}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the terms and conditions of the license shall, notwithstanding any provision of law to the contrary, authorize the licensee to conduct pari-mutuel wagering on live dog races or simultaneously telecast horse or dog races conducted at a racetrack enclosure located in Dubuque county subject to the requirements of a lease agreement entered into pursuant to the requirements of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The terms and conditions of the license shall also authorize the licensee to conduct pari-mutuel wagering on simultaneously telecast horse or dog races at the facility of a licensee authorized to conduct gambling games under }}}{{\f5\fs18\hyphpar0\qj{chapter 99F}}}{{\f5\fs18\hyphpar0\qj{ pursuant to an agreement with the licensee of that facility as authorized by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. A licensee issued a license pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall comply with all requirements of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ applicable to licensees unless otherwise inconsistent with the provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The Iowa greyhound association shall establish an escrow fund under its control for the receipt and deposit of moneys transferred to the Iowa greyhound association pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 99D.9B}}}{{\f5\fs18\hyphpar0\qj{. The Iowa greyhound association shall use moneys in the escrow fund to pay all reasonable and necessary costs and fees associated with conducting live racing and pari-mutuel wagering on simultaneously telecast horse or dog races, including but not limited to regulatory and administrative fees, capital improvements, purse supplements, operational costs, obligations pursuant to any purse supplement agreement as amended and approved by the commission, payment of rents for leased facilities and costs of maintenance of leased facilities, payment for products and services provided by the licensee authorized to conduct gambling games in Dubuque county pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 99F.4A, subsection 9}}}{{\f5\fs18\hyphpar0\qj{, costs to maintain the license, costs for posting a bond as required by }}}{{\f5\fs18\hyphpar0\qj{section 99D.10}}}{{\f5\fs18\hyphpar0\qj{, and administrative costs and fees incurred in connection with the pursuit of the continuation of live greyhound racing.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{However, if the Iowa greyhound association is not licensed to conduct pari-mutuel wagering on live dog races or simultaneously telecast horse or dog races subject to the requirements of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ or fails to conduct live dog racing during any calendar year beginning on or after January 1, 2015, the Iowa greyhound association shall transfer any unused moneys in the escrow fund to the commission for deposit in the Iowa greyhound pari-mutuel racing fund created in }}}{{\f5\fs18\hyphpar0\qj{section 99D.9B}}}{{\f5\fs18\hyphpar0\qj{ and shall receive no further distributions from the fund created in }}}{{\f5\fs18\hyphpar0\qj{section 99D.9B}}}{{\f5\fs18\hyphpar0\qj{. The commission shall require that an annual audit be conducted and submitted to the commission, in a manner determined by the commission, concerning the operation of the escrow fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A license issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall authorize the licensee to enter into an agreement with any licensee authorized to operate an excursion gambling boat or gambling structure under }}}{{\f5\fs18\hyphpar0\qj{chapter 99F}}}{{\f5\fs18\hyphpar0\qj{ to conduct, without the requirement to conduct live horse or dog races at the facility, pari-mutuel wagering on simultaneously telecast horse or dog races at the facility of the licensee authorized to operate an excursion gambling boat or gambling structure under }}}{{\f5\fs18\hyphpar0\qj{chapter 99F}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a lease agreement entered into with the city of Dubuque pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is terminated or is not renewed or extended, the licensee authorized to conduct gambling games in Dubuque county pursuant to a license issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 99F.4A, subsection 9}}}{{\f5\fs18\hyphpar0\qj{, shall be authorized to enter into an agreement with a licensee issued a license pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ to conduct pari-mutuel wagering on simultaneously telecast horse or dog races at the facility of the licensee as provided by }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the Iowa greyhound association is licensed as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and ceases to conduct live dog racing, all revenue generated from an agreement to simultaneously telecast horse or dog races as authorized by }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be used solely for the purpose of supplementing Iowa-whelped dogs racing at out-of-state facilities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon written request by the Iowa greyhound association to the city of Dubuque by July 8, 2014, the city of Dubuque shall be authorized to enter into an initial five-year lease agreement with a single option to renew the lease for an additional five years with the Iowa greyhound association beginning January 1, 2015, to permit the Iowa greyhound association to conduct pari-mutuel wagering on live dog races and simultaneously telecast horse or dog races at the dog racetrack located in Dubuque county. The lease agreement shall be contingent upon the Iowa greyhound association obtaining a license pursuant to the requirements of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The lease agreement shall provide for the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An annual lease payment of one dollar during the initial five-year lease for the racetrack enclosure, which includes the racetrack, kennels, grandstand, and space for a new simulcast facility, and one five-year renewal of the lease agreement at a fair market rental rate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Employees at the racetrack enclosure involved in pari-mutuel wagering as of the live racing cessation date, as provided in }}}{{\f5\fs18\hyphpar0\qj{section 99D.9A}}}{{\f5\fs18\hyphpar0\qj{, shall be offered employment by the Iowa greyhound association at the racetrack.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Existing collective bargaining agreements concerning employees at the racetrack shall be honored.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Live dog racing requirements. The requirements shall provide that the Iowa greyhound association conduct, for calendar year 2015, no fewer than sixty live race days with nine live races per day during the racing season, and for calendar year 2016 and subsequent calendar years covered by the lease agreement, no fewer than ninety-five live race days with nine live races per day during each racing season. However, upon mutual agreement by the parties subject to approval by the commission, the number of race days for one or more live racing seasons may be reduced so long as the Iowa greyhound association conducts a minimum number of live races and racing days during that season.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Termination provisions, to include termination of the agreement on January 1 of the year following the calendar year in which live dog racing as required by the agreement was not conducted by the Iowa greyhound association. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Terms concerning contracts entered into for the conduct of pari-mutuel wagering at the racetrack prior to the live racing cessation date, as provided in }}}{{\f5\fs18\hyphpar0\qj{section 99D.9A}}}{{\f5\fs18\hyphpar0\qj{, at the racetrack.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(7)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any other related items concerning the conduct of pari-mutuel wagering at the dog racetrack and the operation of the dog racetrack facility.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the parties are unable to reach agreement on any of the terms of the initial lease agreement by October 1, 2014, or to reach agreement on the fair market rental rate for purposes of the one five-year lease renewal by June 30, 2018, if the Iowa greyhound association requests arbitration concerning the renewal by June 18, 2018, the disputed terms of the lease shall be determined by binding arbitration in accordance with the rules of the American arbitration association as of the date for arbitration. A request for arbitration shall be in writing and a copy of the request shall be delivered to the other party. The parties shall each select one arbitrator and the two arbitrators shall choose a third arbitrator to complete the three-person arbitration panel. Each party shall deliver its final offer on each of the disputed items to the other party within fourteen days after the request for arbitration. After consultation with the parties, the arbitrators shall set a time and place for an arbitration hearing. The parties may continue to negotiate all offers until an agreement is reached or a decision is rendered by the arbitrators. For purposes of determining the fair market rental rate for purposes of the one five-year lease renewal, either party may argue, and present arguments and evidence, that the renewal lease rental rate should be based upon the market value of similarly situated undeveloped land, or upon its use as a greyhound track. The submission of the disputed items to the arbitrators shall be limited to those items upon which the parties have not reached agreement. However, the arbitrators shall have no authority to extend the term of the lease agreement beyond the initial five-year term or the one five-year renewal.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The arbitrators shall render a decision within fifteen days after the hearing. The arbitrators shall give written explanation for the decision and the decision of the arbitrators shall be final and binding on the parties, and any decision of the arbitrators may be entered in any court having competent jurisdiction. The decision by the arbitrators and the items agreed upon by the parties shall be deemed to be the lease agreement between the parties and such final lease agreement shall not be subject to the approval of the governing body of the city of Dubuque, the Iowa greyhound association, the commission, or any other government body. Each party to the arbitration shall bear its own expenses, including attorney fees, and the parties shall share equally the filing and other administrative fees of the American arbitration association and the expenses of the arbitrators.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2014 Acts, ch 1126, \'a74}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a799D.9}}}{{\f5\fs12\hyphpar0\qj{, 99D.9B}}}{{\f5\fs12\hyphpar0\qj{, 99D.10}}}{{\f5\fs12\hyphpar0\qj{, 99D.11}}}{{\f5\fs12\hyphpar0\qj{, 99D.20}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99D.9D}}}{\*\bkmkstart stylerid1_2E18_2E2_2E2}{\*\bkmkend stylerid1_2E18_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Alternative simulcasting licensure }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ horse and dog races.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An entity that has entered into an agreement with the Iowa horsemen\u8217\'3fs benevolent and protective association for source market fees related to simultaneously telecast horse or dog races may submit an application to the commission for a license under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ to conduct pari-mutuel wagering on simultaneously telecast horse or dog races, subject to the requirements of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. Unless inconsistent with the requirements of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, an entity submitting an application for a license under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall comply with all requirements for submitting an application for a license under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If an application for a license under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ is approved by the commission pursuant to the requirements of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{section 99D.9}}}{{\f5\fs18\hyphpar0\qj{, the entity submitting the application shall be granted a license under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ to conduct pari-mutuel wagering on simultaneously telecast horse or dog races conducted at a facility of a licensee authorized to conduct gambling games under }}}{{\f5\fs18\hyphpar0\qj{chapter 99D}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{chapter 99F}}}{{\f5\fs18\hyphpar0\qj{ pursuant to an agreement with the licensee of that facility as authorized by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. A licensee issued a license pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall comply with all requirements of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ applicable to licensees unless otherwise inconsistent with the provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A license issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall authorize the licensee to enter into an agreement with any licensee authorized to operate an excursion gambling boat or gambling structure under }}}{{\f5\fs18\hyphpar0\qj{chapter 99F}}}{{\f5\fs18\hyphpar0\qj{ to conduct, without the requirement to conduct live horse or dog races at the facility, pari-mutuel wagering on simultaneously telecast horse or dog races at the facility of the licensee authorized to operate an excursion gambling boat or gambling structure under }}}{{\f5\fs18\hyphpar0\qj{chapter 99F}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall establish an annual license fee and regulatory fee for any entity issued a license under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ to conduct pari-mutuel wagering on simultaneously telecast horse or dog races as authorized by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The commission shall not impose any other fees for simultaneously telecast horse or dog races conducted by any licensee under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall require that an annual audit be conducted and submitted to the commission, in a manner determined by the commission, concerning the operation of the simultaneously telecast horse or dog races by any licensee under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2022 Acts, ch 1143, \'a720}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a799D.9}}}{{\f5\fs12\hyphpar0\qj{, 99D.10}}}{{\f5\fs12\hyphpar0\qj{, 99D.15}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99D.10}}}{\*\bkmkstart stylerid1_2E19_2E2_2E2}{\*\bkmkend stylerid1_2E19_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Bond of licensee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A licensee licensed under }{{\f5\fs18\hyphpar0\qj{section 99D.9}}}{, including a licensee issued a license subject to the requirements of }{{\f5\fs18\hyphpar0\qj{section 99D.9C}}}{, shall post a bond to the state of Iowa before the license is issued in a sum as the commission shall fix, with sureties to be approved by the commission. The bond shall be used to guarantee that the licensee faithfully makes the payments, keeps its books and records and makes reports, and conducts its racing in conformity with }{{\f5\fs18\hyphpar0\qj{sections 99D.6 through 99D.23}}}{ and the rules adopted by the commission. The bond shall not be canceled by a surety on less than thirty days\u8217\'3f notice in writing to the commission. If a bond is canceled and the licensee fails to file a new bond with the commission in the required amount on or before the effective date of cancellation, the licensee\u8217\'3fs license shall be revoked. The total and aggregate liability of the surety on the bond is limited to the amount specified in the bond.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 187, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1126, \'a75}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a799D.9}}}{{\f5\fs12\hyphpar0\qj{, 99D.9C}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99D.11}}}{\*\bkmkstart stylerid1_2E2_30_2E2_2E2}{\*\bkmkend stylerid1_2E2_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Pari-mutuel wagering }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ advance deposit wagering }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ televising races }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ age restrictions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as permitted in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the licensee shall permit no form of wagering on the results of the races.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Licensees shall only permit the pari-mutuel or certificate method of wagering, or the advance deposit method of wagering, as defined in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The licensee may receive wagers of money only from a person present in a licensed racetrack enclosure on a horse or dog in the race selected by the person making the wager to finish first in the race or from a person engaging in advance deposit wagering as defined in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The person wagering shall acquire an interest in the total money wagered on all horses or dogs in the race as first winners in proportion to the amount of money wagered by the person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The licensee shall issue to each person wagering a certificate on which shall be shown the number of the race, the amount wagered, and the number or name of the horse or dog selected as first winner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As each race is run the licensee shall deduct sixteen percent from the total sum wagered on all horses or dogs as first winners. However, the commission shall authorize at the request of the licensee a deduction of a higher or lower percentage of the total sum wagered not to exceed eighteen percent and the additional deduction shall be retained by the licensee. The balance, after deducting breakage, shall be paid to the holders of certificates on the winning horse or dog in the proportion that the amount wagered by each certificate holder bears to the total amount wagered on all horses or dogs in the race as first winners. The licensee may pay a larger amount if approved by the commission. The licensee shall likewise receive other wagers on horses or dogs in places or combinations the commission may authorize. The method, procedure, and the authority and right of the licensee, as well as the deduction allowed to the licensee, shall be as specified with respect to wagers upon horses or dogs selected to run first. However, the commission shall authorize at the request of the licensee a deduction of a higher or lower percent of the total sum wagered not to exceed twenty-four percent on multiple or exotic wagering involving not more than two horses or dogs. The deduction authorized above twenty percent on the multiple or exotic wagering involving not more than two dogs or horses shall be retained by the licensee. For exotic wagering involving three or more horses or dogs, the commission shall authorize at the request of the licensee a deduction of a higher or lower percent of the total sum wagered not to exceed twenty-five percent on the exotic wagers. The additional deduction authorized above twenty-two percent on the multiple or exotic wagers involving more than two horses or dogs shall be retained by the licensee. One percent of the exotic wagers on three or more horses or dogs shall be distributed as provided in }}}{{\f5\fs18\hyphpar0\qj{section 99D.12}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All wagering shall be conducted within the racetrack enclosure where the licensed race is held, except as provided in paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission may authorize the licensee to simultaneously telecast within the racetrack enclosure or at the facility of a licensee authorized to operate an excursion gambling boat or gambling structure under }}}{{\f5\fs18\hyphpar0\qj{chapter 99F}}}{{\f5\fs18\hyphpar0\qj{, for the purpose of pari-mutuel wagering, a horse or dog race licensed by the racing authority of another state or foreign jurisdiction. It is the responsibility of each licensee to obtain the consent of appropriate racing officials in other states as required by the federal }}}{{\f5\fs18\hyphpar0\qj{Interstate Horseracing Act of 1978}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{15 U.S.C. \'a73001 }}}{{\f5\fs18\hyphpar0\qj{\u8211\'3f}}}{{\f5\fs18\hyphpar0\qj{ 3007}}}{{\f5\fs18\hyphpar0\qj{, to televise races for the purpose of conducting pari-mutuel wagering.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensee may also obtain the permission of a person licensed by the commission to conduct horse or dog races in this state to televise races conducted by that person for the purpose of conducting pari-mutuel wagering. However, arrangements made by a licensee to televise any race for the purpose of conducting pari-mutuel wagering are subject to the approval of the commission, and the commission shall select the races to be televised. The races selected by the commission shall be the same for all licensees approved by the commission to televise races for the purpose of conducting pari-mutuel wagering. Except for a licensee that is not obligated to schedule performances of live races pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 99D.9A}}}{{\f5\fs18\hyphpar0\qj{, or a licensee issued a license subject to the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 99D.9C}}}{{\f5\fs18\hyphpar0\qj{, the commission shall not authorize the simultaneous telecast or televising of and a licensee shall not simultaneously telecast or televise any horse or dog race for the purpose of conducting pari-mutuel wagering unless the simultaneous telecast or televising is done at the racetrack of a licensee that schedules no less than sixty performances of nine live races each day of the season.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of the taxes imposed under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, races televised by a licensee for purposes of pari-mutuel wagering shall be treated as if the races were held by the licensee. Notwithstanding any contrary provision in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, the commission may allow a licensee to adopt the same deductions as those of the pari-mutuel racetrack from which the races are being simultaneously telecast.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall authorize the licensee of the horse racetrack located in Polk county to conduct advance deposit wagering. An advance deposit wager may be placed in person at a licensed racetrack enclosure, or from any other location via a telephone-type device or any other electronic means. The commission may also issue an advance deposit wagering operator license to an entity who complies with subparagraph (3) and }}}{{\f5\fs18\hyphpar0\qj{section 99D.8A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fadvance deposit wagering\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a method of pari-mutuel wagering in which an individual may establish an account, deposit money into the account, and use the account balance to pay for pari-mutuel wagering. Of the net revenue, less all taxes paid and expenses directly related to account deposit wagering incurred by the licensee of the horse racetrack located in Polk county, received through advance deposit wagering, fifty percent shall be designated for the horse purses created pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 99D.7, subsection 5}}}{{\f5\fs18\hyphpar0\qj{, and fifty percent shall be designated for the licensee for the pari-mutuel horse racetrack located in Polk county.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Before granting an advance deposit wagering operator license to an entity other than the licensee of the horse racetrack located in Polk county, the commission shall enter into an agreement with the licensee of the horse racetrack located in Polk county, the Iowa horsemen\u8217\'3fs benevolent and protective association, and the prospective advance deposit wagering operator for the purpose of determining the payment of statewide source market fees and the host fees to be paid on all races subject to advance deposit wagering. The commission shall establish the term of such an advance deposit wagering operator license. Such an advance deposit wagering operator licensee shall accept wagers on live races conducted at the horse racetrack in Polk county from all of its account holders if it accepts wagers from any residents of this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An unlicensed advance deposit wagering operator or an individual taking or receiving wagers from residents of this state is guilty of a class \u8220\'3fD\u8221\'3f felony.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of this paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fadvance deposit wagering operator\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an advance deposit wagering operator licensed by the commission who has entered into an agreement with the licensee of the horse racetrack in Polk county and the Iowa horsemen\u8217\'3fs benevolent and protective association to provide advance deposit wagering.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person under the age of twenty-one years shall not make or attempt to make a pari-mutuel wager. A person who violates }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ commits a scheduled violation under }}}{{\f5\fs18\hyphpar0\qj{section 805.8C, subsection 5}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 187, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1266, \'a711 \u8211\'3f 13}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 216, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1175, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1261, \'a731}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 166, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1163, \'a723}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1203, \'a73, 4}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1207, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1021, \'a73, 4}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1211, \'a732}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1136, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 3, \'a725}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 88, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 111, \'a74 \u8211\'3f 7}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1023, \'a719, 20}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1033, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1126, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 156, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a799D.2}}}{{\f5\fs12\hyphpar0\qj{, 99D.7}}}{{\f5\fs12\hyphpar0\qj{, 99D.9}}}{{\f5\fs12\hyphpar0\qj{, 99D.10}}}{{\f5\fs12\hyphpar0\qj{, 99D.13}}}{{\f5\fs12\hyphpar0\qj{, 99D.16}}}{{\f5\fs12\hyphpar0\qj{, 99D.24}}}{{\f5\fs12\hyphpar0\qj{, 99D.27B}}}{{\f5\fs12\hyphpar0\qj{, 99F.4}}}{{\f5\fs12\hyphpar0\qj{, 805.8C(5)(a)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99D.12}}}{\*\bkmkstart stylerid1_2E21_2E2_2E2}{\*\bkmkend stylerid1_2E21_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Breakage.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A licensee shall deduct the breakage from the pari-mutuel pool which shall be distributed to the breeders of Iowa-foaled horses and Iowa-whelped dogs in the manner described in }{{\f5\fs18\hyphpar0\qj{section 99D.22}}}{. The remainder of the breakage shall be distributed as follows:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In horse races the breakage shall be retained by the licensee to supplement purses for races restricted to Iowa-foaled horses or to supplement purses won by Iowa-foaled horses by finishing first, second, third, or fourth in any other race. The purse supplements will be paid in proportion to the purse structure of the race. Two percent shall be deposited by the commission into a special fund to be known as the horse racing promotion fund. The commission each year shall approve a nonprofit organization to use moneys in the fund for research, education, and marketing of horse racing in the state, including public relations, and other promotional techniques. The nonprofit organization shall not engage in political activity. It shall be a condition of the allocation of funds that any organization receiving funds shall not expend the funds on political activity or on any attempt to influence legislation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In dog races the breakage shall be distributed as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Seventy-three percent shall be retained by the licensee to supplement purses for races won by Iowa-whelped dogs as provided in }}}{{\f5\fs18\hyphpar0\qj{section 99D.22}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Twenty-five percent shall be retained by the licensee and shall be put into a stake race for Iowa-whelped dogs. An amount equal to twelve percent of the winner\u8217\'3fs share shall be set aside and distributed to the breeder of the winning greyhound in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 99D.22}}}{{\f5\fs18\hyphpar0\qj{ and the remainder shall be apportioned as purse moneys for the stake race. All dogs racing in the stake race must have run in at least twelve races during the current racing season at the track sponsoring the stake race to qualify to participate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Two percent shall be deposited by the commission into a special fund to be known as the dog racing promotion fund. The commission each year shall approve a nonprofit organization to use moneys in the fund for research, education, and marketing of dog racing in the state, including public relations, and other promotional techniques. The nonprofit organization shall not engage in political activity. It shall be a condition of the allocation of funds that any organization receiving funds shall not expend the funds on political activity or on any attempt to influence legislation.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 187, \'a712}}}{; }{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1266, \'a714}}}{; }{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1137, \'a72}}}{; }{{\f5\fs18\hyphpar0\qj{89 Acts, ch 216, \'a72, 3}}}{; }{{\f5\fs18\hyphpar0\qj{91 Acts, ch 166, \'a74}}}{; }{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1203, \'a76}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a799D.9}}}{{\f5\fs12\hyphpar0\qj{, 99D.9A}}}{{\f5\fs12\hyphpar0\qj{, 99D.9B}}}{{\f5\fs12\hyphpar0\qj{, 99D.10}}}{{\f5\fs12\hyphpar0\qj{, 99D.11}}}{{\f5\fs12\hyphpar0\qj{, 99D.22}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99D.13}}}{\*\bkmkstart stylerid1_2E22_2E2_2E2}{\*\bkmkend stylerid1_2E22_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Unclaimed winnings \u8212\'3f appropriation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Winnings provided in }}}{{\f5\fs18\hyphpar0\qj{section 99D.11}}}{{\f5\fs18\hyphpar0\qj{ not claimed by the person who placed the wager within sixty days of the close of the racing meet during which the wager was placed shall be forfeited.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Winnings from each racetrack forfeited under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ shall escheat to the state and to the extent appropriated by the general assembly shall be used by the department of agriculture and land stewardship to administer }}}{{\f5\fs18\hyphpar0\qj{section 99D.22}}}{{\f5\fs18\hyphpar0\qj{. The remainder shall be paid over to the commission to pay all or part of the cost of drug testing at the tracks. To the extent the remainder paid over to the commission, less the cost of drug testing, is from unclaimed winnings from harness race meetings, the remainder shall be used as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{. To the extent the remainder paid to the commission, less the cost of drug testing, is from unclaimed winnings from licensed dog tracks, the commission shall remit annually five thousand dollars, or an equal portion of that amount, to each licensed dog track to carry out the racing dog adoption program pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 99D.27}}}{{\f5\fs18\hyphpar0\qj{. To the extent the remainder paid over to the commission, less the cost of drug testing, is from unclaimed winnings from tracks licensed for dog or horse races, the commission, on an annual basis, shall remit one-third of the amount to the treasurer of the city in which the racetrack is located, one-third of the amount to the treasurer of the county in which the racetrack is located, and one-third of the amount to the racetrack from which it was forfeited. If the racetrack is not located in a city, then one-third shall be deposited as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 556}}}{{\f5\fs18\hyphpar0\qj{. The amount received by the racetrack under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be used only for retiring the debt of the racetrack facilities and for capital improvements to the racetrack facilities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{One hundred twenty thousand dollars of winnings from wagers placed at harness race meetings forfeited under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ in a calendar year that escheat to the state and are paid over to the commission are appropriated to the racing commission for the fiscal year beginning in that calendar year to be used as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Eighty percent of the amount appropriated shall be allocated to qualified harness racing tracks, to be used by the tracks to supplement the purses for those harness races in which only Iowa-bred or owned horses may run. However, beginning with the allocation of the appropriation made for the fiscal year beginning July 1, 1992, the races for which the purses are to be supplemented under this paragraph shall be those in which only Iowa-bred two-year and three-year olds may run. In addition, the races must be held under the control or jurisdiction of the Iowa state fair board, established under }}}{{\f5\fs18\hyphpar0\qj{section 173.1}}}{{\f5\fs18\hyphpar0\qj{, or of a fair, as defined under }}}{{\f5\fs18\hyphpar0\qj{section 174.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Twenty percent of the amount appropriated shall be allocated to qualified harness racing tracks, to be used by the tracks for maintenance of and improvements to the tracks. Races held at the tracks must be under the control or jurisdiction of the Iowa state fair board, established under }}}{{\f5\fs18\hyphpar0\qj{section 173.1}}}{{\f5\fs18\hyphpar0\qj{, or of a fair, as defined under }}}{{\f5\fs18\hyphpar0\qj{section 174.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fqualified harness racing track\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a harness racing track that has either held at least one harness race meeting between July 1, 1985, and July 1, 1989, or after July 1, 1989, has applied to and been approved by the racing commission for the allocation of funds under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. The racing commission shall approve an application if the harness racing track has held at least one harness race meeting during the year preceding the year for which the track seeks funds under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 8.33}}}{{\f5\fs18\hyphpar0\qj{, unencumbered or unobligated funds remaining on June 30 of the fiscal year for which the funds were appropriated shall not revert but shall be available for expenditure for the following fiscal year for the purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 187, \'a713}}}{; }{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1246, \'a7509}}}{; }{{\f5\fs18\hyphpar0\qj{89 Acts, ch 216, \'a74, 5}}}{; }{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1233, \'a75}}}{; }{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1261, \'a732}}}{; }{{\f5\fs18\hyphpar0\qj{91 Acts, ch 166, \'a75}}}{; }{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1019, \'a74}}}{; }{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 3, \'a726}}}{; }{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 179, \'a7113, 114}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1032, \'a7201}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a799D.9}}}{{\f5\fs12\hyphpar0\qj{, 99D.10}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99D.14}}}{\*\bkmkstart stylerid1_2E23_2E2_2E2}{\*\bkmkend stylerid1_2E23_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Race meetings \u8212\'3f tax \u8212\'3f fees \u8212\'3f tax exemption.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensee under }}}{{\f5\fs18\hyphpar0\qj{section 99D.9}}}{{\f5\fs18\hyphpar0\qj{ shall pay the tax imposed by }}}{{\f5\fs18\hyphpar0\qj{section 99D.15}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensee shall pay a regulatory fee to be charged as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. In determining the regulatory fee to be charged as provided under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the commission shall use the amount appropriated to the commission plus the cost of salaries for no more than three special agents assigned pursuant to the provisions of }}}{{\f5\fs18\hyphpar0\qj{section 80.25A}}}{{\f5\fs18\hyphpar0\qj{, for each racetrack that has not been issued a table games license under }}}{{\f5\fs18\hyphpar0\qj{chapter 99F}}}{{\f5\fs18\hyphpar0\qj{ or no more than three special agents assigned pursuant to the provisions of }}}{{\f5\fs18\hyphpar0\qj{section 80.25A}}}{{\f5\fs18\hyphpar0\qj{, for each racetrack that has been issued a table games license under }}}{{\f5\fs18\hyphpar0\qj{chapter 99F}}}{{\f5\fs18\hyphpar0\qj{, plus any direct and indirect support costs for the division of criminal investigation\u8217\'3fs duties pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapters 99D}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{99E}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{99F}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{section 80.25A}}}{{\f5\fs18\hyphpar0\qj{, as the basis for determining the amount of revenue to be raised from the regulatory fee.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Indirect support costs under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be calculated at the same rate used in accordance with the federal office of management and budget cost principles for state, local, and Indian tribal governments that receive a federally approved indirect cost rate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{ section 99D.17}}}{{\f5\fs18\hyphpar0\qj{, the portion of the fee paid pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ relating to the costs of special agents plus any direct and indirect support costs for the agents, for the division of criminal investigation\u8217\'3fs racetrack activities, shall be deposited into the gaming enforcement revolving fund established in }}}{{\f5\fs18\hyphpar0\qj{section 80.43}}}{{\f5\fs18\hyphpar0\qj{. However, the department of public safety shall transfer, on an annual basis, the portion of the regulatory fee attributable to the indirect support costs of the special agents to the general fund of the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{ section 99D.17}}}{{\f5\fs18\hyphpar0\qj{, the portion of the fee paid pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ relating to the costs of the commission shall be deposited into the gaming regulatory revolving fund established in }}}{{\f5\fs18\hyphpar0\qj{section 99F.20}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The aggregate amount of the regulatory fee assessed under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ during each fiscal year shall be reduced by an amount equal to the unexpended moneys from the previous fiscal year that were deposited into the revolving funds established in sections }}}{{\f5\fs18\hyphpar0\qj{80.43}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{99F.20}}}{{\f5\fs18\hyphpar0\qj{ during that previous fiscal year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{By January 1, 2015, and by January 1 of every year thereafter, the division of criminal investigation shall provide the co-chairpersons and ranking members of the joint appropriations subcommittee on the justice system, the legislative services agency, and the commission with a report detailing the activities of the division during the previous fiscal year for each racetrack enclosure.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The division of criminal investigation shall conduct a review relating to the number of special agents permitted for each racetrack under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ and the activities of such agents. The review shall also include comments from the commission and licensees and be combined with the review conducted under }}}{{\f5\fs18\hyphpar0\qj{section 99F.10, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fg\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. The division of criminal investigation shall file a report detailing the review conducted pursuant to this paragraph with the co-chairpersons and ranking members of the joint appropriations subcommittee on the justice system and the legislative services agency by July 1, 2020.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The licensee shall also pay to the commission a licensee fee of two hundred dollars for each racing day of each horse-race or dog-race meeting for which a license has been issued.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{No other license tax, permit tax, occupation tax, or racing fee, shall be levied, assessed, or collected from a licensee by the state or by a political subdivision, except as provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{No other excise tax shall be levied, assessed, or collected from the licensee on horse racing, dog racing, pari-mutuel wagering or admission charges by the state or by a political subdivision, except as provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Real property used in the operation of a racetrack or racetrack enclosure which is exempt from property taxation under another provision of the law, including being exempt because it is owned by a city, county, state, or charitable or nonprofit entity, may be subject to real property taxation by any taxing district in which the real property used in the operation of the racetrack or racetrack enclosure is located. To subject such real property to taxation, the taxing authority of the taxing district shall pass a resolution imposing the tax and, if the resolution is passed prior to September 1, 1997, shall notify the local assessor and the owner of record of the real property by September 1, 1997, preceding the fiscal year in which the real property taxes are due and payable. The assessed value shall be determined and notice of the assessed value shall be provided to the county auditor by the local assessor by October 15, 1997, and the owner may protest the assessed value to the local board of review by December 1, 1997. For resolutions passed on or after September 1, 1997, the taxing authority shall notify the local assessor and owner of record prior to the next assessment year and the valuation and appeal shall be done in the manner and time as for other valuations. Property taxes due as a result of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be paid to the county treasurer in the manner and time as other property taxes. The county treasurer shall remit the tax revenue to those taxing authorities imposing the property tax under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. Real property subject to tax as provided in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall continue to be taxed until such time as the taxing authority of the taxing district repeals the resolution subjecting the property to taxation.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 187, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1266, \'a715, 16}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 216, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 9, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 158, \'a747}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1229, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1136, \'a713, 14}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1190, \'a724}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 127, \'a746, 89}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1134, \'a715, 21}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 139, \'a748, 49}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 142, \'a734}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 166, \'a725}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1185, \'a7121}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a712.10}}}{{\f5\fs12\hyphpar0\qj{, 80.43}}}{{\f5\fs12\hyphpar0\qj{, 99D.9}}}{{\f5\fs12\hyphpar0\qj{, 99D.10}}}{{\f5\fs12\hyphpar0\qj{, 99D.17}}}{{\f5\fs12\hyphpar0\qj{, 99F.4A}}}{{\f5\fs12\hyphpar0\qj{, 99F.10}}}{{\f5\fs12\hyphpar0\qj{, 99F.20}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99D.15}}}{\*\bkmkstart stylerid1_2E24_2E2_2E2}{\*\bkmkend stylerid1_2E24_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Pari-mutuel wagering taxes \u8212\'3f rate \u8212\'3f credit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A tax of six percent is imposed on the gross sum wagered by the pari-mutuel method at each horse race meeting. The tax imposed by }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be paid by the licensee to the commission within ten days after the close of each horse race meeting and shall be distributed as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the racetrack is located in a city, five percent of the gross sum wagered shall be deposited with the commission. One-half of one percent of the gross sum wagered shall be remitted to the treasurer of the city in which the racetrack is located and shall be deposited in the general fund of the city. The remaining one-half of one percent of the gross sum wagered shall be remitted to the treasurer of the county in which the racetrack is located and shall be deposited in the general fund of the county.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the racetrack is located in an unincorporated part of a county, five and one-half percent of the gross sum wagered shall be deposited with the commission. The remaining one-half of one percent of the gross sum wagered shall be remitted to the treasurer of the county in which the racetrack is located and shall be deposited in the general fund of the county.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A tax credit of up to five percent of the gross sum wagered per year shall be granted to licensees licensed for horse races and paid into a special fund to be used for debt retirement or operating expenses. However, the tax credit is equal to six percent of the gross sum wagered in a year when the gross sum wagered is less than ninety million dollars. Any portion of the credit not used in a particular year shall be retained by the commission. A tax credit shall first be assessed against any share going to a city, then to the share going to a county, and then to the share going to the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A tax is imposed on the gross sum wagered by the pari-mutuel method at each track licensed for dog races. The tax imposed by }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be paid by the licensee to the commission within ten days after the close of the track\u8217\'3fs racing season. The rate of tax on each track is as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Six percent, if the gross sum wagered in the racing season is fifty-five million dollars or more.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Five percent, if the gross sum wagered in the racing season is thirty million dollars or more but less than fifty-five million dollars.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Four percent, if the gross sum wagered in the racing season is less than thirty million dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The tax revenue shall be distributed as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the racetrack is located in a city, one-half of one percent of the gross sum wagered shall be remitted to the treasurer of the city in which the racetrack is located and shall be deposited in the general fund of the city. One-half of one percent of the gross sum wagered shall be remitted to the treasurer of the county in which the racetrack is located and shall be deposited in the general fund of the county. The remaining amount shall be deposited with the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the racetrack is located in an unincorporated part of a county, one-half of one percent of the gross sum wagered shall be remitted to the treasurer of the county in which the racetrack is located and shall be deposited in the general fund of the county. The remaining amount shall be deposited with the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the rate of tax imposed under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ is six percent, five percent, or four percent, a licensee shall set aside for retiring any debt of the licensee, for capital improvement to the facilities of the licensee, for funding of possible future operating losses, or for charitable giving, the following amount:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the rate of tax paid by the licensee is six percent, one-sixth of the tax liability by the licensee during the racing season shall be set aside.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the rate of tax paid by the licensee is five percent, one percent of the gross sum wagered in the racing season shall be set aside.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the rate of tax paid by the licensee is four percent, two percent of the gross sum wagered in the racing season shall be set aside.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A tax is imposed on the gross sum wagered by the pari-mutuel method on horse races and dog races which are simultaneously telecast, in lieu of the taxes imposed pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 1 or 3}}}{{\f5\fs18\hyphpar0\qj{. The rate of tax is determined as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If wagering on simultaneously telecast horse races and dog races is not conducted by a licensee under }}}{{\f5\fs18\hyphpar0\qj{section 99D.9D}}}{{\f5\fs18\hyphpar0\qj{, a tax of two percent is imposed on the gross sum wagered by the pari-mutuel method on horse races and dog races which are simultaneously telecast. The tax revenue from simulcast horse races under this paragraph shall be distributed as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ and the tax revenue from simulcast dog races under this paragraph shall be distributed as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If wagering on simultaneously telecast horse races and dog races is conducted by a licensee under }}}{{\f5\fs18\hyphpar0\qj{section 99D.9D}}}{{\f5\fs18\hyphpar0\qj{, a tax of two percent is imposed on the gross sum wagered by the pari-mutuel method on horse races and dog races which are simultaneously telecast in excess of twenty-five million dollars in a calendar year. The tax revenue from simulcast horse races under this paragraph shall be deposited in the Iowa horse racing fund created in }}}{{\f5\fs18\hyphpar0\qj{section 99D.27B}}}{{\f5\fs18\hyphpar0\qj{. The remaining amount of tax revenue shall be deposited with the commission.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 187, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1266, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 216, \'a77 \u8211\'3f 9}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1261, \'a733}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 166, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 268, \'a7427}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1203, \'a78 \u8211\'3f 10}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1207, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1107, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1136, \'a715, 16}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 182, \'a7102}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1143, \'a721}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 159, \'a735}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a799D.9}}}{{\f5\fs12\hyphpar0\qj{, 99D.10}}}{{\f5\fs12\hyphpar0\qj{, 99D.14}}}{{\f5\fs12\hyphpar0\qj{, 99D.17}}}{{\f5\fs12\hyphpar0\qj{, 99D.27B}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Alternative tax imposed on certain pari-mutuel advance deposit wagers, see \'a799D.27B(6)}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 4, paragraph b amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99D.16}}}{\*\bkmkstart stylerid1_2E25_2E2_2E2}{\*\bkmkend stylerid1_2E25_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Withholding tax on winnings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{All winnings provided in }{{\f5\fs18\hyphpar0\qj{section 99D.11}}}{ are Iowa earned income and are subject to state and federal income tax laws. An amount deducted from winnings for payment of the state tax, pursuant to }{{\f5\fs18\hyphpar0\qj{section 422.16, subsection 2}}}{, shall be remitted to the department of revenue on behalf of the individual who won the wager.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{87 Acts, ch 214, \'a71}}}{; }\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/1992.2/CH1001.pdf" }{\fldrslt \f5 \fs18{{\f5\fs18\hyphpar0\qj\cf5{92 Acts, 2nd Ex, ch 1001, \'a7233}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{; }{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 145, \'a7286}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 115, \'a714}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a799D.9}}}{{\f5\fs12\hyphpar0\qj{, 99D.10}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99D.17}}}{\*\bkmkstart stylerid1_2E26_2E2_2E2}{\*\bkmkend stylerid1_2E26_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Use of moneys.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Unless otherwise provided by }{{\f5\fs18\hyphpar0\qj{section 99D.15}}}{ or another provision of law, moneys received pursuant to }{{\f5\fs18\hyphpar0\qj{sections 99D.14}}}{ and }{{\f5\fs18\hyphpar0\qj{99D.15}}}{ shall be deposited as provided in }{{\f5\fs18\hyphpar0\qj{section 8.57, subsection 3}}}{. These moneys shall first be used to the extent appropriated by the general assembly. The commission is subject to the budget requirements of }{{\f5\fs18\hyphpar0\qj{chapter 8}}}{ and the applicable auditing requirements and procedures of }{{\f5\fs18\hyphpar0\qj{chapter 11}}}{.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 187, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1261, \'a734}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 260, \'a71206}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1163, \'a724}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 131, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1107, \'a733}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 142, \'a735}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1185, \'a7122}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 159, \'a736}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a78.57}}}{{\f5\fs12\hyphpar0\qj{, 99D.7}}}{{\f5\fs12\hyphpar0\qj{, 99D.9}}}{{\f5\fs12\hyphpar0\qj{, 99D.10}}}{{\f5\fs12\hyphpar0\qj{, 99D.14}}}{{\f5\fs12\hyphpar0\qj{, 99G.39}}}{{\f5\fs12\hyphpar0\qj{, 123.17}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99D.18}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99D.19}}}{\*\bkmkstart stylerid1_2E28_2E2_2E2}{\*\bkmkend stylerid1_2E28_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Licensees \u8212\'3f records, reports, supervision \u8212\'3f confidentiality.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensee shall keep its books and records so as to clearly show the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The total number of admissions for each day of operation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The total amount of money wagered for each day of operation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The licensee shall furnish to the commission reports and information as the commission may require with respect to its activities. The commission may designate a representative to attend a licensed race meeting, who shall have full access to all places within the enclosure of the meeting and who shall supervise and check the admissions. The compensation of the representative shall be fixed by the commission but shall be paid by the licensee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The records of the commission shall be governed by the provisions of }}}{{\f5\fs18\hyphpar0\qj{chapter 22}}}{{\f5\fs18\hyphpar0\qj{, provided that, in addition to records that may be kept confidential pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 22.7}}}{{\f5\fs18\hyphpar0\qj{, the following records provided by a licensee to the commission shall be kept confidential, unless otherwise ordered by a court, by the lawful custodian of the records, or by another person duly authorized to release such information:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Promotional play receipts records.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Patron and customer records.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Surveillance records.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Security reports and network audits.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Internal control and compliance records.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Employee records. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Marketing expenses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Supplemental schedules to the certified audit, except for those books and records as described in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, that are obtained by the commission in connection with the annual audit under }}}{{\f5\fs18\hyphpar0\qj{section 99D.20}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any information specifically requested for inspection by the commission or a representative of the commission.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 187, \'a719}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1136, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 22, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a799D.9}}}{{\f5\fs12\hyphpar0\qj{, 99D.10}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99D.20}}}{\*\bkmkstart stylerid1_2E29_2E2_2E2}{\*\bkmkend stylerid1_2E29_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Audit of licensee operations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Within ninety days after the end of each calendar year, the licensee, including a licensee issued a license subject to the requirements of }{{\f5\fs18\hyphpar0\qj{section 99D.9C}}}{, shall transmit to the commission an audit of the financial transactions and condition of the licensee\u8217\'3fs operations conducted under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{. Additionally, within ninety days after the end of the licensee\u8217\'3fs fiscal year, the licensee shall transmit to the commission an audit of the licensee\u8217\'3fs total racing and gaming operations, including an itemization of all expenses and subsidies. All audits shall be conducted by certified public accountants authorized to practice in the state of Iowa under }{{\f5\fs18\hyphpar0\qj{chapter 542}}}{ who are selected by the board of supervisors of the county in which the licensee operates.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 187, \'a720}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 55, \'a721, 38}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1136, \'a718}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 3, \'a727}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 29, \'a71, 3}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1126, \'a77}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a799D.9}}}{{\f5\fs12\hyphpar0\qj{, 99D.10}}}{{\f5\fs12\hyphpar0\qj{, 99D.19}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99D.21}}}{\*\bkmkstart stylerid1_2E3_30_2E2_2E2}{\*\bkmkend stylerid1_2E3_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Annual report of commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The commission shall make an annual report to the governor, for the period ending December 31 of each year. Included in the report shall be an account of the commission\u8217\'3fs actions, its financial position and results of operation under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, the practical results attained under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, and any recommendations for legislation which the commission deems advisable.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 187, \'a721}}}{; }{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1266, \'a719}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a799D.9}}}{{\f5\fs12\hyphpar0\qj{, 99D.10}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99D.22}}}{\*\bkmkstart stylerid1_2E31_2E2_2E2}{\*\bkmkend stylerid1_2E31_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Native horses or dogs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensee shall hold at least one race on each racing day limited to Iowa-foaled horses or Iowa-whelped dogs as defined by the department of agriculture and land stewardship using standards consistent with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. However, if sufficient competition cannot be had among that class of horses or dogs on any day, another race for the day may be substituted.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If Iowa-foaled horses are in a race not limited to Iowa-foaled horses that is not a stakes race, the licensee shall allow any Iowa-foaled horse an additional three-pound weight allowance beyond the stated conditions of the race.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A sum equal to twelve percent of the purse won by an Iowa-foaled horse or Iowa-whelped dog shall be used to promote the horse and dog breeding industries. The twelve percent shall be withheld by the licensee from the breakage and shall be paid at the end of the race meeting to the state department of agriculture and land stewardship which in turn shall deposit it in a special fund to be known as the Iowa horse and dog breeders fund. The department shall pay the amount deposited in the fund that is withheld from the purse won by an Iowa-foaled horse to the breeder of the winning Iowa-foaled horse by December 31 of each calendar year. The department shall pay the amount deposited in the fund that is withheld from the purse won by an Iowa-whelped dog to the breeder of the winning Iowa-whelped dog by March 31 of each calendar year. For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the breeder of a horse shall be considered to be the owner of the brood mare at the time the foal is dropped.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{No less than twenty percent of all net purse moneys distributed to each breed, as described in }}}{{\f5\fs18\hyphpar0\qj{section 99D.7, subsection 5}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, shall be designated for registered Iowa-bred foals in the form of breeder\u8217\'3fs awards or purse supplement awards to enhance and foster the growth of the horse breeding industry.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, the following shall be considered in determining if a horse is an Iowa-foaled thoroughbred horse, quarter horse, or standardbred horse:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All thoroughbred horses, quarter horses, or standardbred horses foaled in Iowa which are registered by the jockey club, American quarter horse association, or United States trotting association as Iowa foaled shall be considered to be Iowa foaled.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{ Eligibility for brood mare residence shall be achieved by meeting at least one of the following rules:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Thirty days residency until the foal is inspected, if in foal to a registered Iowa stallion.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Thirty days residency until the foal is inspected for brood mares which are bred back to registered Iowa stallions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For a thoroughbred foal, continuous residency from December 15 until the foal is inspected if the mare was bred by other than an Iowa registered stallion and is not bred back to an Iowa registered stallion.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For a standardbred foal or quarter horse foal, continuous residency from January 31 until the foal is inspected if the mare was bred by other than an Iowa registered stallion and is not bred back to an Iowa registered stallion.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To be eligible for registration as an Iowa thoroughbred, quarter horse, or standardbred stallion, stallion residency from January 1 through July 31 for the year of registration shall be met. However, horses going to stud for the first year shall be eligible upon registration with residency to continue through July 31.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{State residency shall not be required for owners of brood mares.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To facilitate the implementation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the department of agriculture and land stewardship shall do all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Adopt standards to qualify thoroughbred, quarter horse, or standardbred stallions for Iowa breeding. A stallion shall stand for service in the state at the time of the foal\u8217\'3fs conception and shall not stand for service at any place outside the state during the calendar year in which the foal is conceived.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide for the registration of Iowa-foaled horses and that a horse shall not compete in a race limited to Iowa-foaled horses unless the horse is registered with the department of agriculture and land stewardship. The department may prescribe such forms as necessary to determine the eligibility of a horse.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The secretary of agriculture shall appoint investigators to determine the eligibility for registration of Iowa-foaled horses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Establish a registration fee imposed on each horse which is a thoroughbred, quarter horse, or standardbred which shall be paid by the breeder of the horse. The department shall not impose the registration fee more than once on each horse. The amount of the registration fee shall not exceed thirty dollars. The moneys paid to the department from registration fees shall be considered appropriated receipts as defined in }}}{{\f5\fs18\hyphpar0\qj{section 8.2}}}{{\f5\fs18\hyphpar0\qj{, and shall be used for the administration and enforcement of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of agriculture and land stewardship shall adopt rules establishing a schedule of registration fees to be imposed on owners of dogs that are whelped and raised for the first six months of their lives in Iowa for purposes of promoting native dogs as provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, including }}}{{\f5\fs18\hyphpar0\qj{section 99D.12}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The amount of the registration fees shall be imposed as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An owner of a dam registering the dam, twenty-five dollars.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An owner of a litter registering the litter, ten dollars.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An owner of a dog registering the dog, five dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The moneys paid to the department from registration fees as provided in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall be considered appropriated receipts as defined in }}}{{\f5\fs18\hyphpar0\qj{section 8.2}}}{{\f5\fs18\hyphpar0\qj{, and shall be used for the administration and enforcement of programs for the promotion of native dogs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To qualify for the Iowa horse and dog breeders fund, a dog shall have been whelped in Iowa and raised for the first six months of its life in Iowa in a state inspected licensed facility. In addition, the owner of the dog shall have been a resident of the state for at least two years prior to the whelping. The department of agriculture and land stewardship shall adopt rules and prescribe forms to bring Iowa breeders into compliance with residency requirements of dogs and breeders in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 187, \'a722}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1266, \'a720, 21}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 67, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 133, \'a71 \u8211\'3f 7}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 129, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 172, \'a719, 20}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 211, \'a735}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 111, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1057, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 103, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1088, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1177, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1185, \'a7123, 124}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a799D.9}}}{{\f5\fs12\hyphpar0\qj{, 99D.10}}}{{\f5\fs12\hyphpar0\qj{, 99D.12}}}{{\f5\fs12\hyphpar0\qj{, 99D.13}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99D.23}}}{\*\bkmkstart stylerid1_2E32_2E2_2E2}{\*\bkmkend stylerid1_2E32_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Commission veterinarian and chemist.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall employ one or more chemists or contract with a qualified chemical laboratory to determine by chemical testing and analysis of saliva, urine, blood, hair, or other excretions or body fluids whether a substance or drug has been introduced which may affect the outcome of a race or whether an action has been taken or a substance or drug has been introduced which may interfere with the testing procedure. The commission shall adopt rules under }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ concerning procedures and actions taken on positive drug reports. The commission may adopt by reference nationally recognized standards as determined by the commission or may adopt any other procedure or standard. The commission has the authority to retain and preserve by freezing, test samples for future analysis.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall employ or contract with one or more veterinarians to extract or procure the saliva, urine, blood, hair, or other excretions or body fluids of the horses or dogs for the chemical testing purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. A commission veterinarian shall be in attendance at every race meeting held in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A chemist or veterinarian who willfully or intentionally fails to perform the functions or duties of employment required by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be banned for life from employment at a race meeting held in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission veterinarian shall keep a continuing record of all horses determined to be sick, unsafe, unsound, or unfit to race by a commission veterinarian at a racetrack.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 187, \'a723}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1137, \'a73, 4}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1100, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1136, \'a719}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1088, \'a72}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a799D.9}}}{{\f5\fs12\hyphpar0\qj{, 99D.10}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99D.24}}}{\*\bkmkstart stylerid1_2E33_2E2_2E2}{\*\bkmkend stylerid1_2E33_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Prohibited activities \u8212\'3f penalty.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person is guilty of an aggravated misdemeanor for doing any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Holding or conducting a race or race meeting where the pari-mutuel system of wagering is used or to be used without a license issued by the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Holding or conducting a race or race meeting where wagering is permitted other than in the manner specified by }}}{{\f5\fs18\hyphpar0\qj{section 99D.11}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Committing any other corrupt or fraudulent practice as defined by the commission in relation to racing which affects or may affect the result of a race.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person knowingly permitting a person under the age of twenty-one years to make a pari-mutuel wager is guilty of a simple misdemeanor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person wagering or accepting a wager at any location outside the wagering area is subject to the penalties in }}}{{\f5\fs18\hyphpar0\qj{section 725.7}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person commits a class \u8220\'3fD\u8221\'3f felony and, in addition, shall be barred for life from racetracks under the jurisdiction of the commission, if the person does any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Offers, promises, or gives anything of value or benefit to a person who is connected with racing including, but not limited to, an officer or employee of a licensee, an owner of a horse, a jockey or driver, a trainer, or handler, pursuant to an agreement or arrangement or with the intent that the promise or thing of value or benefit will influence the actions of the person to whom the offer, promise, or gift was made in order to affect or attempt to affect the outcome of a race, or to influence official action of a member of the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Solicits or knowingly accepts or receives a promise of anything of value or benefit while the person is connected with racing including, but not limited to, an officer or employee of a licensee, an owner of a horse, a jockey or driver, a trainer, or handler, pursuant to an understanding or arrangement or with the intent that the promise or thing of value or benefit will influence the actions of the person to affect or attempt to affect the outcome of a race, or to influence official action of a member of the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Knowingly or intentionally passes a winning wager or share to another person or provides fraudulent identification in order to avoid the forfeiture of any money or thing of value as a voluntarily excluded person pursuant to the processes established under }}}{{\f5\fs18\hyphpar0\qj{section 99D.7, subsection 23}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Knowingly or intentionally passes a winning wager or share to another person or provides fraudulent identification in order to avoid the application of a setoff as provided in }}}{{\f5\fs18\hyphpar0\qj{section 99D.28}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person commits a class \u8220\'3fD\u8221\'3f felony and the commission shall suspend or revoke a license held by the person if the person:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Uses, possesses, or conspires to use or possess a device other than the ordinary whip or spur for the purpose of stimulating or depressing a horse or dog during a race or workout.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Sponges a horse\u8217\'3fs or dog\u8217\'3fs nostrils or windpipe or uses any method, injurious or otherwise, for the purpose of stimulating or depressing a horse or dog or affecting its speed in a race or a workout.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person commits a serious misdemeanor if the person has in the person\u8217\'3fs possession within the confines of a racetrack, stable, shed, building or grounds, or within the confines of a stable, shed, building or grounds where a horse or dog is kept which is eligible to race over a racetrack licensed under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, an appliance other than the ordinary whip or spur which can be used for the purpose of stimulating or depressing a horse or dog or affecting its speed at any time.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 187, \'a724}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1265, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 195, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1021, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1086, \'a724}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 19, \'a731}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1143, \'a74}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a799D.7}}}{{\f5\fs12\hyphpar0\qj{, 99D.9}}}{{\f5\fs12\hyphpar0\qj{, 99D.28}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99D.25}}}{\*\bkmkstart stylerid1_2E34_2E2_2E2}{\*\bkmkend stylerid1_2E34_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Drugging or numbing \u8212\'3f exception \u8212\'3f tests \u8212\'3f reports \u8212\'3f penalties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, unless the context otherwise requires:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDrugging\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means administering to a horse or dog any substance foreign to the natural horse or dog prior to the start of a race. However, in counties with a population of two hundred fifty thousand or more, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fdrugging\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include administering to a horse the drugs furosemide and phenylbutazone in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 99D.25A}}}{{\f5\fs18\hyphpar0\qj{ and rules adopted by the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fNumbing\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the applying of a freezing device or substance to the limbs of a horse or dog within two hours before the start of a race, or a surgical or other procedure which was, at any time, performed in which the nerves of a horse or dog were severed, destroyed, injected, or removed. For purposes of this paragraph, ice is not a freezing device or substance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fEntered\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means that a horse or dog has been registered as a participant in a specified race, and not withdrawn prior to presentation of the horse or dog for inspection and testing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The general assembly finds that the practice of drugging or numbing a horse or dog prior to a race:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Corrupts the integrity of the sport of racing and promotes criminal fraud in the sport;}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Misleads the wagering public and those desiring to purchase a horse or dog as to the condition and ability of the horse or dog;}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Poses an unreasonable risk of serious injury or death to the rider of a horse and to the riders of other horses competing in the same race; and}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is cruel and inhumane to the horse or dog so drugged or numbed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The following conduct is prohibited:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The entering of a horse or dog in a race by the trainer or owner of the horse or dog if the trainer or owner knows or if by the exercise of reasonable care the trainer or owner should know that the horse or dog is drugged or numbed;}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The drugging or numbing of a horse or dog with knowledge or with reason to believe that the horse or dog will compete in a race while so drugged or numbed. However, the commission may by rule establish permissible trace levels of substances foreign to the natural horse or dog that the commission determines to be innocuous;}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The willful failure by the operator of a racing facility to disqualify a horse or dog from competing in a race if the operator has been notified that the horse or dog is drugged or numbed, or was not properly made available for tests or inspections as required by the commission; and}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The willful failure by the operator of a racing facility to prohibit a horse or dog from racing if the operator has been notified that the horse or dog has been suspended from racing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The owners of a horse or dog and their agents and employees shall permit a member of the commission or a person employed or appointed by the commission to make tests as the commission deems proper in order to determine whether a horse or dog has been improperly drugged. The fact that purse money has been distributed prior to the issuance of a test report shall not be deemed a finding that no chemical substance has been administered unlawfully to the horse or dog earning the purse money. The findings of the commission that a horse or dog has been improperly drugged by a narcotic or other drug are prima facie evidence of the fact. The results of the tests shall be kept on file by the commission for at least one year following the tests.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Every horse which suffers a breakdown on the racetrack, in training, or in competition, and is destroyed, and every other horse which expires while stabled on the racetrack under the jurisdiction of the commission, shall undergo a postmortem examination by a veterinarian or a veterinary pathologist at a time and place acceptable to the commission veterinarian to determine the injury or sickness which resulted in euthanasia or natural death. Test samples may be obtained from the carcass upon which the postmortem examination is conducted and shall be sent to a laboratory approved by the commission for testing for foreign substances and natural substances at abnormal levels. When practical, blood and urine test samples should be procured prior to euthanasia. The owner of the deceased horse is responsible for payment of any charges due to conduct the postmortem examination. A record of every postmortem shall be filed with the commission by the veterinarian or veterinary pathologist who performed the postmortem within seventy-two hours of the death. Each owner and trainer accepts the responsibility for the postmortem examination provided herein as a requisite for maintaining the occupational license issued by the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any horse which in the opinion of the commission veterinarian has suffered a traumatic injury or disability such that a controlled program of phenylbutazone administration would not aid in restoring the racing soundness of the horse shall not be allowed to race while medicated with phenylbutazone or with phenylbutazone present in the horse\u8217\'3fs bodily systems.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person found within or in the immediate vicinity of a security stall who is in possession of unauthorized drugs or hypodermic needles or who is not authorized to possess drugs or hypodermic needles shall, in addition to any other penalties, be barred from entry into any racetrack in Iowa and any occupational license the person holds shall be revoked.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Before a horse is allowed to race using phenylbutazone, the veterinarian attending the horse shall certify to the commission the course of treatment followed in administering the phenylbutazone.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall conduct random tests of bodily substances of horses entered to race each day of a race meeting to aid in the detection of any unlawful drugging. The tests may be conducted both prior to and after a race. The commission may also test any horse that breaks down during a race and shall perform an autopsy on any horse that is killed or subsequently destroyed as a result of an accident during a race. When practical, blood and urine test samples should be procured prior to euthanasia.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Veterinarians must submit daily to the commission veterinarian on a prescribed form a report of all medications and other substances which the veterinarian prescribed, administered, or dispensed for horses registered at a current race meeting. A logbook detailing other professional services performed while on the grounds of a racetrack shall be kept by veterinarians and shall be made immediately available to the commission veterinarian or the stewards upon request.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who violates }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is guilty of a class \u8220\'3fD\u8221\'3f felony.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 187, \'a725}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1137, \'a75 \u8211\'3f 12}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1100, \'a73, 4}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1136, \'a720 \u8211\'3f 22, 65}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 48, \'a71, 7}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1032, \'a7189}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 73, \'a71, 4}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a799D.9}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99D.25A}}}{\*\bkmkstart stylerid1_2E35_2E2_2E2}{\*\bkmkend stylerid1_2E35_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Administration of furosemide or phenylbutazone.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ unless the context otherwise requires:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fBleeder\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means, according to its context, any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A horse which, during a race or exercise, is observed by the commission veterinarian or a licensed practicing veterinarian to be shedding blood from one or both nostrils and in which no upper airway injury is noted during an examination by the commission veterinarian or a licensed practicing veterinarian immediately following such a race or exercise.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A horse which, within one and one-half hours of such a race or exercise, is observed by the commission veterinarian or a licensed practicing veterinarian, through visual or endoscopic examination, to be shedding blood from the lower airway.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A horse which has been certified as a bleeder in another state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A horse which has furosemide listed on its most recent past performance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A horse which, by recommendation of a licensed practicing veterinarian, is prescribed furosemide to control or prevent bleeding from the lungs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fBleeder list\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a tabulation of all bleeders maintained by the commission veterinarian.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDetention barn\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a secured structure designated by the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Phenylbutazone may be administered to a horse in dosage amounts as set by rule by the commission. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a horse is to race with phenylbutazone in its system, the trainer, or trainer\u8217\'3fs designee, shall be responsible for marking the information on the entry blank for each race in which the horse shall use phenylbutazone. Changes made after the time of entry must be submitted on the prescribed form to the commission veterinarian no later than scratch time.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a test detects concentrations of phenylbutazone in the system of a horse in excess of the level permitted in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the commission shall assess a civil penalty against the trainer of at least two hundred dollars for the first offense and at least five hundred dollars for a second offense. The penalty for a third or subsequent offense shall be in the discretion of the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Furosemide may be administered to certified bleeders. Upon request, any horse placed on the bleeder list shall, in its next race, be permitted the use of furosemide. Once a horse has raced with furosemide, it must continue to race with furosemide in all subsequent races unless a request is made to discontinue the use. If the use of furosemide is discontinued, the horse shall be prohibited from again racing with furosemide unless it is later observed to be bleeding. Requests for the use of or discontinuance of furosemide must be made to the commission veterinarian by the horse\u8217\'3fs trainer or assistant trainer on a form prescribed by the commission on or before the day of entry into the race for which the request is made.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Once a horse has been permitted the use of furosemide, the horse must be treated with furosemide in the horse\u8217\'3fs stall, unless the commission provides that a horse must be brought to the detention barn for treatment. After the furosemide treatment, the commission, by rule, may authorize the release of the horse from the horse\u8217\'3fs stall or detention barn before the scheduled post time. If a horse is brought to the detention barn late, the commission shall assess a civil penalty of one hundred dollars against the trainer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A horse entered to race with furosemide must be treated at least four hours prior to post time. The furosemide shall be administered intravenously by a veterinarian issued a current occupational license by the commission. The commission shall adopt rules to ensure that furosemide is administered as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The commission shall require that the veterinarian deliver an affidavit signed by the veterinarian which certifies information regarding the treatment of the horse. The affidavit must be delivered to a commission veterinarian following the treatment. The affidavit must at least include the name of the veterinarian, the tattoo number of the horse, the location of the barn and stall where the treatment occurred, the race number of the horse, the name of the trainer, and the time that the furosemide was administered. Furosemide shall only be administered in a dose level of no less than one hundred fifty milligrams and no more than five hundred milligrams.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person found within or in the immediate vicinity of the detention barn or horse stall who is in possession of unauthorized drugs or hypodermic needles or who is not authorized to possess drugs or hypodermic needles shall, in addition to any other penalties, be barred from entry into any racetrack in Iowa and any occupational license the person holds shall be revoked.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1137, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1203, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1100, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 23, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1006, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1217, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1136, \'a723}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 48, \'a72 \u8211\'3f 5, 7}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1033, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 73, \'a72, 4}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a799D.25}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99D.26}}}{\*\bkmkstart stylerid1_2E36_2E2_2E2}{\*\bkmkend stylerid1_2E36_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Forfeiture of property.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Anything of value, including all traceable proceeds including but not limited to real and personal property, moneys, negotiable instruments, securities, and conveyances are subject to forfeiture to the state of Iowa if the item was used for any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In exchange for a bribe intended to affect the outcome of a race.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In exchange for or to facilitate a violation of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All moneys, coin, and currency found in close proximity of wagers, or of records of wagers are presumed forfeited. The burden of proof is upon the claimant of the property to rebut this presumption.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subsections 1 and 2}}}{{\f5\fs18\hyphpar0\qj{ do not apply if the act or omission which would give rise to the forfeiture was committed or omitted without the owner\u8217\'3fs knowledge or consent.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 187, \'a726}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99D.27}}}{\*\bkmkstart stylerid1_2E37_2E2_2E2}{\*\bkmkend stylerid1_2E37_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Racing dog adoption program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A track licensed to race dogs under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ shall maintain a racing dog adoption program. The track shall advertise the availability of adoptable dogs in the media, including but not limited to racing programs. The track shall compile a list of persons applying to adopt a dog. A dog\u8217\'3fs owner or dog\u8217\'3fs trainer acting with the consent of the owner may participate in the program by placing the dog for adoption. The ownership of the dog shall be transferred from the owner of the dog to the person who is adopting the dog. A dog shall not be transferred to a person for purposes related to racing, breeding, hunting, laboratory research, or scientific experimentation. A dog shall not be transferred unless the dog has been examined by a veterinarian and found to be free of disease requiring extensive medical treatment. A dog shall not be transferred, until a veterinarian has certified that the dog has been sterilized. The track may transfer a dog to a governmental agency or nonprofit organization without examination or certification. However, other requirements relating to the transfer of a dog to a person by a track under }{{\f5\fs18\hyphpar0\qj{this section}}}{ apply to the transfer of a dog to a person by the agency or organization. A person violating }{{\f5\fs18\hyphpar0\qj{this section}}}{ is guilty of a simple misdemeanor.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 216, \'a710}}}{; }{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1155, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a799D.13}}}{{\f5\fs12\hyphpar0\qj{, 162.20}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99D.27A}}}{\*\bkmkstart stylerid1_2E38_2E2_2E2}{\*\bkmkend stylerid1_2E38_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Iowa race horse aftercare organization assistance fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An Iowa race horse aftercare organization assistance fund is created in the state treasury under the control of the racing and gaming commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The fund shall consist of fines collected by the commission under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and such other moneys deposited in the fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Moneys in the fund shall be distributed, under the sole control of the commission, to organizations, exempt from federal income taxation under }}}{{\f5\fs18\hyphpar0\qj{section 501(c)(3) of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{, that are dedicated to race horse aftercare subject to the requirements of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall determine the method by which moneys in the fund shall be distributed, with priority given to organizations primarily involved in rehabilitation, retraining, and rehoming of former race horses that raced in the state of Iowa that have governing boards comprised of pari-mutuel industry occupational license holders. Moneys shall only be distributed to organizations shown to have been in existence for a minimum of three years. The distribution decisions of the commission shall be final.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Members of the commission, employees of the commission, and any individual that the commission had assist in the distribution determination shall be held harmless against any claim of liability made by any person or organization arising out of the distribution of the moneys from the fund by the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Section 8.33}}}{{\f5\fs18\hyphpar0\qj{ does not apply to moneys in the fund. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 12C.7, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, interest or earnings on moneys deposited in the fund shall be credited to the fund.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2022 Acts, ch 1054, \'a72}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99D.27B}}}{\*\bkmkstart stylerid1_2E39_2E2_2E2}{\*\bkmkend stylerid1_2E39_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Iowa horse racing fund }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ advance deposit wagering tax.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An Iowa horse racing fund is created in the state treasury under the control of the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The fund shall consist of tax revenue collected and deposited in the fund pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 6}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{section 99D.15, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, and such other moneys appropriated to, transferred to, or deposited in the fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Moneys in the fund are appropriated to the commission for distribution in a manner and in an amount as determined by the commission to individual entities or a recognized compact of entities tasked with the regulation of the horse racing industry in accordance with the federal }}}{{\f5\fs18\hyphpar0\qj{Horseracing Integrity and Safety Act of 2020}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{15 U.S.C. ch. 57A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In the event that the federal }}}{{\f5\fs18\hyphpar0\qj{Horseracing Integrity and Safety Act of 2020}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{15 U.S.C. ch. 57A}}}{{\f5\fs18\hyphpar0\qj{, is repealed, moneys in the fund shall be transferred to the rebuild Iowa infrastructure fund created in }}}{{\f5\fs18\hyphpar0\qj{section 8.57}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Members of the commission and those acting on behalf of the commission assisting in the distribution of the moneys in the fund shall be held harmless against any claim of liability made by an individual or entity arising out of the distribution of the moneys from the fund by the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Section 8.33}}}{{\f5\fs18\hyphpar0\qj{ does not apply to moneys in the fund. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 12C.7, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, interest or earnings on moneys deposited in the fund shall be credited to the fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A tax of two percent is imposed on the gross sum wagered by the pari-mutuel method as an advance deposit wager under }}}{{\f5\fs18\hyphpar0\qj{section 99D.11, subsection 6}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. The tax imposed under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ is in lieu of any tax imposed on such wagers under }}}{{\f5\fs18\hyphpar0\qj{section 99D.15}}}{{\f5\fs18\hyphpar0\qj{. The tax revenue generated under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be deposited in the fund.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2025 Acts, ch 159, \'a737}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a799D.15}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{NEW section}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99D.28}}}{\*\bkmkstart stylerid1_2E4_30_2E2_2E2}{\*\bkmkend stylerid1_2E4_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Setoff.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensee or a person acting on behalf of a licensee shall be provided electronic access to the names of the persons indebted to a claimant agency pursuant to the process established pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 99D.7, subsection 24}}}{{\f5\fs18\hyphpar0\qj{. The electronic access provided by the claimant agency shall include access to the names of the debtors, their social security numbers, and any other information that assists the licensee in identifying the debtors. If the name of a debtor provided to the licensee through electronic access is retrieved by the licensee and the winnings are required to be reported on internal revenue service form W-2G for gambling winnings, the retrieval of such a name shall constitute a valid lien upon and claim of lien against the winnings of the debtor whose name is electronically retrieved from the claimant agency. If a debtor\u8217\'3fs winnings are required to be reported on internal revenue service form W-2G for gambling winnings, the full amount of the debt shall be collectible from any winnings due the debtor without regard to limitations on the amounts that may be collectible in increments through setoff or other proceedings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The licensee is authorized and directed to withhold any winnings of a debtor which are paid out directly by the licensee subject to the lien created by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and provide notice of such withholding to the winner when the winner appears and claims winnings in person. The licensee shall pay the funds over to the collection entity which administers the setoff program pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 421.65}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any other provision of law to the contrary, the licensee may provide to a claimant agency all information necessary to accomplish and effectuate the intent of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, and likewise the claimant agency may provide all information necessary to accomplish and effectuate the intent of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The information obtained by a claimant agency from the licensee in accordance with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall retain its confidentiality and shall only be used by a claimant agency in the pursuit of its debt collection duties and practices. An employee or prior employee of a claimant agency who unlawfully discloses any such information for any other purpose, except as otherwise specifically authorized by law, shall be subject to the penalties specified by law for unauthorized disclosure of confidential information by an agent or employee of the claimant agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The information obtained by a licensee from a claimant agency in accordance with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall retain its confidentiality and only be used by the licensee in the pursuit of debt collection duties and practices. An employee or prior employee of a licensee who unlawfully discloses any such information for any other purpose, except as otherwise specifically authorized by law, shall be subject to the same penalties specified by law for unauthorized disclosure of confidential information by an agent or employee of the licensee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, attachments, setoffs, or executions authorized and issued pursuant to law shall be withheld if timely served upon the licensee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A claimant agency or licensee, acting in good faith, shall not be liable to any person for actions taken pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. In addition, the commission shall not initiate any administrative action or impose penalties on a licensee who voluntarily reports to the commission activity described in }}}{{\f5\fs18\hyphpar0\qj{section 99D.24, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3flicensee\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall also include an advance deposit wagering operator.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1172, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1031, \'a7171, 172}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 73, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1064, \'a75, 28}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1066, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1118, \'a773, 74}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1143, \'a75}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a799D.24}}}\par}}