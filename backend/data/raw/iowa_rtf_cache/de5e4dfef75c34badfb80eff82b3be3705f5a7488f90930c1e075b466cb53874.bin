\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F135}{\*\bkmkend codeChapter_5F135}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 135}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{DEPARTMENT OF HEALTH AND HUMAN SERVICES \u8212\'3f PUBLIC HEALTH}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a7135B.5}}}{{\f5\fs12\qc{, 163.3A}}}{{\f5\fs12\qc{, 195.10}}}\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER I}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E5_2E1_2E2}{GENERAL PROVISIONS}{\*\bkmkend stylerid1_2E5_2E1_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{135.1}}}{\*\bkmkstart stylerid1_2E5_2E2_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E2_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{For the purposes of }{{\f5\fs18\hyphpar0\qj{Title IV, subtitle 2}}}{, excluding }{{\f5\fs18\hyphpar0\qj{chapter 146}}}{, unless otherwise defined:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDirector\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the director of health and human services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fHealth officer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the physician, physician assistant, advanced registered nurse practitioner, or advanced practice registered nurse who is the health officer of the local board of health.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLocal board\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the local board of health.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPhysician\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person licensed to practice medicine and surgery, osteopathic medicine and surgery, chiropractic, podiatry, or optometry under the laws of this state; but a person licensed as a physician and surgeon shall be designated as a \u8220\'3fphysician\u8221\'3f or \u8220\'3fsurgeon\u8221\'3f, a person licensed as an osteopathic physician and surgeon shall be designated as an \u8220\'3fosteopathic physician\u8221\'3f or \u8220\'3fosteopathic surgeon\u8221\'3f, a person licensed as a chiropractor shall be designated as a \u8220\'3fchiropractor\u8221\'3f, a person licensed as a podiatrist shall be designated as a \u8220\'3fpodiatric physician\u8221\'3f, and a person licensed as an optometrist shall be designated as an \u8220\'3foptometrist\u8221\'3f. A definition or designation contained in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not be interpreted to expand the scope of practice of such licensees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fRules\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ include regulations and orders.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fState department\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fdepartment\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the department of health and human services.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a72583-b; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2181;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7135.1}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1245, \'a71101}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1199, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1023, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 108, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1036, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1212, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1058, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1084, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1088, \'a7141}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 133, \'a730}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1113, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1083, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7125}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1043, \'a752}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a710A.533}}}{{\f5\fs12\hyphpar0\qj{, 135C.1}}}{{\f5\fs12\hyphpar0\qj{, 144.26}}}{{\f5\fs12\hyphpar0\qj{, 237A.12}}}{{\f5\fs12\hyphpar0\qj{, 514.21}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{135.2}}}{\*\bkmkstart stylerid1_2E5_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Appointment of director and acting director.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2023 Acts, ch 19, \'a71357}}}{{\f5\fs18\hyphpar0\qj{.}}}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{135.3}}}{\*\bkmkstart stylerid1_2E5_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Disqualifications.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2023 Acts, ch 19, \'a71357}}}{{\f5\fs18\hyphpar0\qj{.}}}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{135.4 and 135.5}}}{Reserved. }{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{135.6 through 135.10}}}{Repealed by }{{\f5\fs18\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2023/CH0019.pdf" }{\fldrslt \f5 \fs18{{2023 Acts, ch 19, \'a71357}}}}}}{{\f5\fs18\qj{2023 Acts, ch 19, \'a71357}}}{.}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{135.11}}}{\*\bkmkstart stylerid1_2E5_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Public health duties of department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department shall:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Exercise general supervision over the public health, promote public hygiene and sanitation, prevent substance use disorder, and, unless otherwise provided, enforce the laws relating to the same.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Conduct campaigns for the education of the people in hygiene and sanitation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Issue health bulletins containing fundamental health principles and other health data deemed of public interest.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Make investigations and surveys in respect to the causes of disease and epidemics, and the effect of locality, employment, and living conditions upon the public health. For this purpose the department may use the services of the experts connected with the state hygienic laboratory.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Establish stations throughout the state for the distribution of antitoxins and vaccines to physicians, pharmacists, and other persons, at cost. All antitoxin and vaccine thus distributed shall be labeled \u8220\'3fIowa Department of Health and Human Services\u8221\'3f.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Exercise general supervision over the administration and enforcement of the sexually transmitted diseases and infections law, }}}{{\f5\fs18\hyphpar0\qj{chapter 139A, subchapter II}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Exercise sole jurisdiction over the disposal and transportation of the dead bodies of human beings and prescribe the methods to be used in preparing such bodies for disposal and transportation. However, the department may approve a request for an exception to the application of specific embalming and disposition rules adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ if such rules would otherwise conflict with tenets and practices of a recognized religious denomination to which the deceased individual adhered or of which denomination the deceased individual was a member. The department shall inform the board of mortuary science of any such approved exception which may affect services provided by a funeral director licensed pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 156}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Establish, publish, and enforce rules which require companies, corporations, and other entities to obtain a permit from the department prior to scattering cremated human remains.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Exercise general supervision over the administration and enforcement of the vital statistics law, }}}{{\f5\fs18\hyphpar0\qj{chapter 144}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Administer healthy aging and essential public health services by approving grants of state funds to the local boards of health for the purposes of promoting healthy aging throughout the lifespan and enhancing health promotion and disease prevention services, and by providing guidelines for the approval of the grants and allocation of the state funds. Guidelines, evaluation requirements, and formula allocation procedures for the services shall be established by the department by rule.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Administer }}}{{\f5\fs18\hyphpar0\qj{chapters 125}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{136A}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{136C}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{139A}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{142}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{144}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{147A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Consult with the office of statewide clinical education programs at the university of Iowa college of medicine and annually submit a report to the general assembly by January 15 verifying the number of physicians in active practice in Iowa by county who are engaged in providing obstetrical care. To the extent data are readily available, the report shall include information concerning the number of deliveries per year by specialty and county, the age of physicians performing deliveries, and the number of current year graduates of the university of Iowa college of medicine and the Des Moines university }}}{{\f5\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\fs18\hyphpar0\qj{ osteopathic medical center entering into residency programs in obstetrics, gynecology, and family practice. The report may include additional data relating to access to obstetrical services that may be available.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Administer the statewide maternal and child health program and the program for children with disabilities by conducting mobile and regional child health specialty clinics and conducting other activities to improve the health of low-income women and children and to promote the welfare of children with actual or potential conditions which may cause disabilities and children with chronic illnesses in accordance with the requirements of Tit. V of the federal }}}{{\f5\fs18\hyphpar0\qj{Social Security Act}}}{{\f5\fs18\hyphpar0\qj{. The department shall provide technical assistance to encourage the coordination and collaboration of state agencies in developing outreach centers which provide publicly supported services for pregnant women, infants, and children. The department shall also, through cooperation and collaborative agreements with the mobile and regional child health specialty clinics, establish common intake proceedings for maternal and child health services. The department shall work in cooperation with the legislative services agency in monitoring the effectiveness of the maternal and child health centers, including the provision of transportation for patient appointments and the keeping of scheduled appointments.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Establish, publish, and enforce rules requiring prompt reporting of methemoglobinemia, pesticide poisoning, and the reportable poisonings and illnesses established pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 139A.21}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Collect and maintain reports of pesticide poisonings and other poisonings, illnesses, or injuries caused by selected chemical or physical agents, including methemoglobinemia and pesticide and fertilizer hypersensitivity; and compile and publish, annually, a statewide and county-by-county profile based on the reports.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{16.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Adopt rules which require personnel of a licensed hospice, of a homemaker-home health aide provider agency which receives state homemaker-home health aide funds, or of an agency which provides respite care services and receives funds to complete training concerning blood-borne pathogens, including human immunodeficiency virus and viral hepatitis, consistent with standards from the federal occupational safety and health administration.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{17.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Adopt rules which require all emergency medical services personnel, fire fighters, and law enforcement personnel to complete training concerning blood-borne pathogens, including human immunodeficiency virus and viral hepatitis, consistent with standards from the federal occupational safety and health administration.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{18.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Adopt rules which provide for the testing of a convicted or alleged offender for the human immunodeficiency virus pursuant to }}}{{\f5\fs18\hyphpar0\qj{sections 915.40 through 915.43}}}{{\f5\fs18\hyphpar0\qj{. The rules shall provide for the provision of counseling, health care, and support services to the victim.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{19.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Establish ad hoc and advisory committees to the director in areas where technical expertise is not otherwise readily available. Members may be compensated for their actual and necessary expenses incurred in the performance of their duties. To encourage health consumer participation, public members may also receive a per diem as specified in }}}{{\f5\fs18\hyphpar0\qj{section 7E.6}}}{{\f5\fs18\hyphpar0\qj{ if funds are available and the per diem is determined to be appropriate by the director. Expense moneys paid to the members shall be paid from funds appropriated to the department. A majority of the members of such a committee constitutes a quorum.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{20.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Administer annual grants to county boards of health for the purpose of conducting programs for the testing of private water supply wells, the closing of abandoned private water supply wells, and the renovation or rehabilitation of private water supply wells. Grants shall be funded through moneys transferred to the department from the agriculture management account of the groundwater protection fund pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 455E.11, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (2), subparagraph division (b). The department shall adopt rules relating to the awarding of the grants.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{21.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Establish and administer, if sufficient funds are available to the department, a program to assess and forecast health workforce supply and demand in the state for the purpose of identifying current and projected workforce needs. The program may collect, analyze, and report data that furthers the purpose of the program. The program shall not release information that permits identification of individual respondents of program surveys.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{22.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Develop and maintain the statewide perinatal program based on the recommendations of the American academy of pediatrics and the American college of obstetricians and gynecologists contained in the most recent edition of the guidelines for perinatal care, and adopt rules in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ to implement those recommendations. Hospitals within the state shall determine whether to participate in the statewide perinatal program, and select the hospital\u8217\'3fs level of participation in the program. A hospital having determined to participate in the program shall comply with the guidelines appropriate to the level of participation selected by the hospital. Perinatal program surveys and reports are privileged and confidential and are not subject to discovery, subpoena, or other means of legal compulsion for their release to a person other than the affected hospital, and are not admissible in evidence in a judicial or administrative proceeding other than a proceeding involving verification of the participating hospital under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{23.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In consultation with the department of corrections, the antibiotic resistance task force, and the American federation of state, county and municipal employees, develop educational programs to increase awareness and utilization of infection control practices in institutions listed in }}}{{\f5\fs18\hyphpar0\qj{section 904.102}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{24.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Administer the Iowa youth survey, in collaboration with other state agencies, as appropriate, every two years to students in grades six, eight, and eleven in Iowa\u8217\'3fs public and nonpublic schools. Survey data shall be evaluated and reported, with aggregate data available online at the Iowa youth survey internet site.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{25.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Adopt rules requiring ambulatory surgical centers to report quality data to the department of health and human services that is consistent with the data required to be reported to the centers for Medicare and Medicaid services of the United States department of health and human services as authorized by the }}}{{\f5\fs18\hyphpar0\qj{Medicare Improvements and Extension Act of 2006}}}{{\f5\fs18\hyphpar0\qj{ under Tit. I of the }}}{{\f5\fs18\hyphpar0\qj{Tax Relief and Health Care Act of 2006}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{Pub. L. No. 109-432}}}{{\f5\fs18\hyphpar0\qj{, and the regulations adopted under such Acts. Notwithstanding any provision of law to the contrary, nothing in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall require an ambulatory surgical center to provide health data to the department of health and human services or any other public or private entity that is in addition to, different than, or exceeds the quality data required to be reported to the centers for Medicare and Medicaid services of the United States department of health and human services.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C97, \'a72565; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2191;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7135.11(1)}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{2, 3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2191;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7135.11(2, 3)}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C97, \'a72565; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2191;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7135.11(4)}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{5, 6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2191;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7135.11(8, 9); C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7135.11(7, 8)}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[S13, \'a72572-a, -b, -c; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2191;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7135.11(11); C73, \'a7135.11(10); C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7135.11(9)}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2191;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7135.11(12); C73, \'a7135.11(11); C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7135.11(10)}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[S13, \'a72575-a42; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2191;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7135.11(13); C73, \'a7135.11(12); C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7135.11(11)}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C97, \'a72565; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2191;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7135.11(14); C73, \'a7135.11(13); C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7135.11(12)}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{11, 12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2191;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7135.11(15, 16); C73, \'a7135.11(14, 15); C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7135.11(13, 14)}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C97, \'a72565; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2191;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7135.11(17); C73, \'a7135.11(16); C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7135.11(15)}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7135.11(16)}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[}{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1260, \'a755}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 27, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1245, \'a71104}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 8, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 115, \'a722}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 225, \'a7202}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1224, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 304, \'a7103}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1259, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 258, \'a729}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 140, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1023, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1132, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1036, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1128, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1129, \'a723}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 23, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 197, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1053, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1087, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1090, \'a760, 84}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1221, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 141, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1058, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1066, \'a737}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1223, \'a718}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 58, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 122, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 184, \'a76}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{; }{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts//CH0000.pdf" }{\fldrslt \f5 \fs18{{\f5\fs18\hyphpar0\qj\cf5{2001 Acts, 2nd Ex, ch 1, \'a725, 28}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1108, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 33, \'a78, 11}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 35, \'a745, 49}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 44, \'a736}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1167, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 89, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 10, \'a718}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 159, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1058, \'a71, 2, 15}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1084, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1088, \'a783}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1180, \'a720}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 41, \'a7263}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 151, \'a730}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1088, \'a74 \u8211\'3f 6}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 63, \'a733}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1113, \'a722}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 129, \'a749}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1106, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 148, \'a72, 20}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1041, \'a7127}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 91, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 16, \'a731}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7126}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1161, \'a721, 137}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1170, \'a7210}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7237.3}}}{{\f5\fs12\hyphpar0\qj{, 455E.11}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Laboratory tests, }{{\f5\fs12\hyphpar0\qj{\'a7263.7}