acts of votes for each of the following offices:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{President and vice president of the United States.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Senator in Congress.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Representative in Congress.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Governor and lieutenant governor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Senator or representative in the general assembly by districts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A state officer not otherwise specified above.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The abstracts for all offices except governor and lieutenant governor shall be enclosed in a securely sealed envelope.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7283, 284, 305; R60, \'a7517, 518, 539; C73, \'a7645, 662; C97, \'a71157; S13, \'a71157; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{869;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a750.30}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 129, \'a715}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1032, \'a7201}}}{; }{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 57, \'a741}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a750.48}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{50.30A}}}{\*\bkmkstart stylerid1_2E38_2E2_2E2}{\*\bkmkend stylerid1_2E38_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Election canvass summary forwarded to state commissioner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The commissioner shall, within thirteen days after each primary election, general election, and special election conducted pursuant to }{{\f5\fs18\hyphpar0\qj{section 69.14}}}{, forward to the state commissioner a true and exact copy of the election canvass summary report certified by the county board of canvassers.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 57, \'a742}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1033, \'a727}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{50.31}}}{\*\bkmkstart stylerid1_2E39_2E2_2E2}{\*\bkmkend stylerid1_2E39_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Abstracts for governor and lieutenant governor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The envelope containing the abstracts of votes for governor and lieutenant governor shall be endorsed substantially as follows:}}}\par}{}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\b0\fs18\hyphpar0\qj\ul0\strike0{\~\~\~}}}{\f5\fs18\hyphpar0\qj}{Abstract of votes for governor and lieutenant governor from }{{\f5\fs18\hyphpar0\qj{................}}}{ county.}{\f5\fs18\hyphpar0\qj}\par}{\pard\plain\f5\fs8\hyphpar0\qj\fi0\ri1084\li1084\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{After being so endorsed, the envelope shall be addressed as follows: }}}\par}{}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\b0\fs18\hyphpar0\qj\ul0\strike0{\~\~\~}}}{\f5\fs18\hyphpar0\qj}{To the Speaker of the House of Representatives.}{\f5\fs18\hyphpar0\qj}\par}{\pard\plain\f5\fs8\hyphpar0\qj\fi0\ri1084\li1084\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7283; R60, \'a7517; C73, \'a7645; C97, \'a71157; S13, \'a71157; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{870;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a750.31}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2019 Acts, ch 24, \'a710}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a750.32}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{50.32}}}{\*\bkmkstart stylerid1_2E4_30_2E2_2E2}{\*\bkmkend stylerid1_2E4_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Endorsement on other envelope.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The envelope for offices other than governor and lieutenant governor shall be endorsed substantially in the manner provided in }{{\f5\fs18\hyphpar0\qj{section 50.31}}}{, with changes necessary to indicate the particular offices, and shall be addressed as follows: }\par}{}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\b0\fs18\hyphpar0\qj\ul0\strike0{\~\~\~}}}{\f5\fs18\hyphpar0\qj}{To the State Commissioner of Elections.}{\f5\fs18\hyphpar0\qj}\par}{\pard\plain\f5\fs8\hyphpar0\qj\fi0\ri1084\li1084\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7283, 305; R60, \'a7517, 539; C73, \'a7645, 662; C97, \'a71157; S13, \'a71157; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{871;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a750.32}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 129, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 24, \'a711}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{50.33}}}{\*\bkmkstart stylerid1_2E41_2E2_2E2}{\*\bkmkend stylerid1_2E41_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Forwarding of envelopes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The envelopes, including the one addressed to the speaker, after being prepared, sealed, and endorsed as required by }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, shall be placed in one package and forwarded to the state commissioner.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7284, 305; R60, \'a7518, 539; C73, \'a7645, 662; C97, \'a71157; S13, \'a71157; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{872;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a750.33}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{93 Acts, ch 143, \'a723}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{50.34}}}{\*\bkmkstart stylerid1_2E42_2E2_2E2}{\*\bkmkend stylerid1_2E42_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Missing abstracts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If the abstracts from any county are not received at the office of the state commissioner within fifteen days after the day of election, the state commissioner shall send a messenger to the commissioner of such county, who shall furnish the messenger with them, or, if they have been sent, with a copy thereof, and the messenger shall return them to the state commissioner without delay.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7285; R60, \'a7519; C73, \'a7649; C97, \'a71158; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{873;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a750.34}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{50.35}}}{\*\bkmkstart stylerid1_2E43_2E2_2E2}{\*\bkmkend stylerid1_2E43_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Delivery of abstracts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The envelopes containing the abstracts of votes for governor and lieutenant governor shall not be opened by the state commissioner, but the state commissioner shall securely preserve the same and deliver them to the speaker of the house of representatives at the time said abstracts are canvassed as provided by law.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{874;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a750.35}}}{]}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Canvass by general assembly, }{{\f5\fs12\hyphpar0\qj{\'a72.27}}}{ et seq.; also }{{\f5\fs12\hyphpar0\qj{Iowa Constitution, Art. IV, \'a73}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{50.36}}}{\*\bkmkstart stylerid1_2E44_2E2_2E2}{\*\bkmkend stylerid1_2E44_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Envelopes containing other abstracts \u8212\'3f canvass.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The secretary of state, upon receipt of the envelopes containing the abstracts of votes, shall open and canvass the abstracts for all offices except governor and lieutenant governor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The secretary of state shall invite to attend the canvass one representative from each political party which, at the last three preceding general elections, cast for its candidate for president of the United States or for governor, as the case may be, at least two percent of the total vote cast for all candidates for that office at those elections, as determined by the secretary of state. The secretary of state shall notify the chairperson of each political party of the time of the canvass. However, the presence of a representative from a political party is not necessary for the canvass to proceed.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7286; R60, \'a7520; C73, \'a7650; C97, \'a71159; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{875;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a750.36}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{95 Acts, ch 189, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 123, \'a729}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 2 amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{50.37}}}{\*\bkmkstart stylerid1_2E45_2E2_2E2}{\*\bkmkend stylerid1_2E45_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{State canvassing board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The executive council shall constitute a board of canvassers of all abstracts of votes required to be filed with the state commissioner, except for the offices of governor and lieutenant governor. Any clerical error found by the secretary of state or state board of canvassers shall be corrected by the county commissioner in a letter addressed to the state board of canvassers.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7287; R60, \'a7521; C73, \'a7647, 651; C97, \'a71160, 1162; S13, \'a71162; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{876;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a750.37}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{95 Acts, ch 189, \'a712}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Canvass of constitutional amendments and public measures, }{{\f5\fs12\hyphpar0\qj{\'a749A.8}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{50.38}}}{\*\bkmkstart stylerid1_2E46_2E2_2E2}{\*\bkmkend stylerid1_2E46_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Time of state canvass.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Not later than twenty-seven days after the day of the election, the secretary of state shall present to the board of state canvassers abstracts of votes cast at the election showing the number of ballots cast for each office and a summary of the results for each office, showing the votes cast in each county. The state board of canvassers shall review the results compiled by the secretary of state and, if the results are accurately tabulated, the state board shall approve the canvass.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7288, 306; R60, \'a7522, 540; C73, \'a7647, 652, 663; C97, \'a71161, 1162; S13, \'a71162; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{877;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a750.38}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{95 Acts, ch 189, \'a713}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a750.48}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Canvass under special election, }{{\f5\fs12\hyphpar0\qj{\'a750.46}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{50.39}}}{\*\bkmkstart stylerid1_2E47_2E2_2E2}{\*\bkmkend stylerid1_2E47_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Abstract.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The state board of canvassers shall make an abstract stating the number of ballots cast for each office, the names of all the persons voted for, for what office, the number of votes each received, and whom the state board of canvassers declares to be elected, and if a public question has been submitted to the voters of the state, the number of ballots cast for and against the question and a declaration of the result as determined by the canvassers; which abstract shall be signed by the canvassers in their official capacity and as state canvassers, and have the seal of the state affixed.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7289, 306; R60, \'a7523, 540; C73, \'a7653, 663; C97, \'a71163; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{878;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a750.39}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 57, \'a743}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 34, \'a715}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{50.40}}}{\*\bkmkstart stylerid1_2E48_2E2_2E2}{\*\bkmkend stylerid1_2E48_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Record of canvass.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The state commissioner shall file the abstracts when received and shall have the same bound in book form to be kept by the state commissioner as a record of the result of said state election, to be known as the state election book.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7290; R60, \'a7524; C73, \'a7654; C97, \'a71164; S13, \'a71164; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{879;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a750.40}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{50.41}}}{\*\bkmkstart stylerid1_2E49_2E2_2E2}{\*\bkmkend stylerid1_2E49_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Certificate of election.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each person declared elected by the state board of canvassers shall receive a certificate, signed by the governor or, in the governor\u8217\'3fs absence, by the secretary of state, with the seal of state affixed, attested by the other canvassers, to be in substance as follows:}}}\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\sb80\ri1084\li1084{STATE OF IOWA:}\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~}}}{To }{{\f5\fs18\hyphpar0\qj{................................}}}{ (candidate\u8217\'3fs name): It is hereby certified that, at an election held on the }{{\f5\fs18\hyphpar0\qj{................}}}{ day of }{{\f5\fs18\hyphpar0\qj{........................}}}{ you were elected to the office of }{{\f5\fs18\hyphpar0\qj{........................}}}{ of Iowa, for the term of }{{\f5\fs18\hyphpar0\qj{............}}}{ years, from the }{{\f5\fs18\hyphpar0\qj{................}}}{ day of }{{\f5\fs18\hyphpar0\qj{........................}}}{ (or if to fill a vacancy, for the residue of the term, ending on the }{{\f5\fs18\hyphpar0\qj{................}}}{ day of }{{\f5\fs18\hyphpar0\qj{........................}}}{).}\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keep\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa80{{\f5\fs18\hyphpar0\qj{\~\~}}}{Given at the seat of government this }{{\f5\fs18\hyphpar0\qj{................}}}{ day of }{{\f5\fs18\hyphpar0\qj{........................}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the governor is absent, the certificate of the election of the secretary of state shall be signed by the auditor. The certificate to members of the legislature shall describe, by the number, the district from which the member is elected.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7288, 306; R60, \'a7522, 540; C73, \'a7652, 657, 663; C97, \'a71165; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{880;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a750.41}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{87 Acts, ch 115, \'a710}}}{; }{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1058, \'a710}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{50.42}}}{\*\bkmkstart stylerid1_2E5_30_2E2_2E2}{\*\bkmkend stylerid1_2E5_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Certificates mailed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The state commissioner shall prepare and deliver or mail certificates of election to the persons declared elected.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7292, 294; R60, \'a7526, 528; C73, \'a7648, 656, 658; C97, \'a71167; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{881;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a750.42}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{50.43}}}{\*\bkmkstart stylerid1_2E51_2E2_2E2}{\*\bkmkend stylerid1_2E51_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Senator or representative.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The certificate of the election of a senator or representative in Congress shall be signed by the governor, with the seal of the state affixed, and be countersigned by the secretary of state.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7294; R60, \'a7528; C73, \'a7658; C97, \'a71166; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{882;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a750.43}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{50.44}}}{\*\bkmkstart stylerid1_2E52_2E2_2E2}{\*\bkmkend stylerid1_2E52_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Tie vote.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If more than the requisite number of persons, including presidential electors, are found to have an equal and the highest number of votes, the election of one of them shall be determined by lot. The name of each of such candidates shall be written on separate pieces of paper, as nearly uniform in size and material as possible, and placed in a receptacle so that the names cannot be seen. In the presence of the board of canvassers, one of them shall publicly draw one of such names, and such person shall be declared elected. The result of such drawing shall be entered upon the abstract of votes and duly recorded, and a certificate of election issued to such person, as provided in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7281, 282, 307, 316; R60, \'a7515, 516, 541, 547; C73, \'a7632, 643, 644, 664; C97, \'a71169, 2754; S13, \'a72754; C24, \'a7883, 4204; C27, \'a7883, 4204, 4211-b8; C31, 35, \'a7883, 4216-c21; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{883, 4216.21;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a750.44, 277.21; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a750.44}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a762.18}}}{{\f5\fs12\hyphpar0\qj{, 331.383}}}{{\f5\fs12\hyphpar0\qj{, 376.11}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{50.45}}}{\*\bkmkstart stylerid1_2E53_2E2_2E2}{\*\bkmkend stylerid1_2E53_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Canvass public \u8212\'3f result determined.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{All canvasses of tally lists shall be public, and the persons having the greatest number of votes shall be declared elected. When a public measure has been submitted to the electors, the proposition shall be declared to have been adopted if the vote cast in favor of the question is greater than fifty percent of the total vote cast in favor and against the question, unless laws pertaining specifically to the public measure election establish a higher percentage of a favorable vote. All ballots cast and not counted as a vote in favor or against the proposition shall not be used in computing the total vote cast in favor and against the proposition.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7262, 273, 307; R60, \'a7497, 508, 541; C73, \'a7623, 638, 664; C97, \'a71170; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{884;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a750.45}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1119, \'a721}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.383}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{50.46}}}{\*\bkmkstart stylerid1_2E54_2E2_2E2}{\*\bkmkend stylerid1_2E54_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Special elections }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ canvass and certificate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{When a special election has been held to fill a vacancy, pursuant to }{{\f5\fs18\hyphpar0\qj{section 69.14}}}{, the board of county canvassers shall meet no earlier than 1:00 p.m. on the second day after the election, and canvass the votes cast at the election. If the second day after the election is a public holiday, }{{\f5\fs18\hyphpar0\qj{section 4.1, subsection 34}}}{, controls. The commissioner, as soon as the canvass is completed, shall transmit to the state commissioner an abstract of the votes so canvassed, and the state board, within five days after receiving such abstracts, shall canvass the tally lists. A certificate of election shall be issued by the county or state board of canvassers, as in other cases. All the provisions regulating elections, obtaining tally lists, and canvass of votes at general elections, except as to time, shall apply to special elections.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a7673; C73, \'a7791-793; C97, \'a71171; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{885;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a750.46}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1238, \'a727}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1033, \'a728}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.383}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{50.47}}}{\*\bkmkstart stylerid1_2E55_2E2_2E2}{\*\bkmkend stylerid1_2E55_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Messengers for election tally lists.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Messengers sent for the tally lists of elections shall be paid from the state or county treasury for necessary travel expense.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7295; R60, \'a7529; C73, \'a73827; C97, \'a71172; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{886;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a750.47}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a743.47}}}{{\f5\fs12\hyphpar0\qj{, 331.383}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{50.48}}}{\*\bkmkstart stylerid1_2E56_2E2_2E2}{\*\bkmkend stylerid1_2E56_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{General recount provisions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as provided in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the county board of canvassers shall order a recount of the votes cast for a particular office or nomination in each election precinct where a vote was cast for an office if a written request for a recount is made not later than 5:00 p.m. on the day following the county board\u8217\'3fs canvass of the election in question and the abstracts prepared pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 50.24}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{section 43.49}}}{{\f5\fs18\hyphpar0\qj{ in the case of a primary election, indicate that the difference between the total number of votes cast for the apparent winner and the total number of votes cast for the candidate requesting the recount is less than either one percent or fifty votes, whichever is lesser. For a city runoff election held pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 376.9}}}{{\f5\fs18\hyphpar0\qj{, the written request must be made not later than 5:00 p.m. on the day following the county board\u8217\'3fs canvass of the city runoff election. The request shall be filed with the commissioner of that county and shall be signed by either of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A candidate for that office or nomination whose name was printed on the ballot of the precinct or precincts where the recount is requested.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any other person who receives votes for that particular office or nomination in the precinct or precincts where the recount is requested and who is legally qualified to seek and to hold the office in question.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Immediately upon receipt of a request for a recount, the commissioner shall send a copy of the request to the apparent winner by certified mail. The commissioner shall also attempt to contact the apparent winner by telephone. If the apparent winner cannot be reached within four days, the chairperson of the political party or organization which nominated the apparent winner shall be contacted and shall act on behalf of the apparent winner, if necessary. For candidates for state or federal offices, the chairperson of the state party shall be contacted. For candidates for county offices, the county chairperson of the party shall be contacted.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state commissioner of elections shall order a recount of the votes cast for the election or nomination of a candidate for a statewide elected office, member of the general assembly, or federal office in each precinct where a vote was cast for the office if a written request for a recount is made not later than 5:00 p.m. on the day following the county board\u8217\'3fs canvass of the election in question and the abstracts prepared pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 50.24}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{section 43.49}}}{{\f5\fs18\hyphpar0\qj{ in the case of a primary election, indicate that the difference between the total number of votes cast for the apparent winner and the total number of votes cast for the candidate requesting the recount is less than fifteen hundredths of one percent for the election or nomination of a candidate for a statewide elected office or federal office, or less than either one percent or fifty votes, whichever is lesser, for all other elections or nominations. Immediately upon receipt of a request for a recount pursuant to this paragraph, the state commissioner of elections shall send a copy of the request to each commissioner of a county where a ballot for the office was cast, who shall conduct a recount as provided by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and on such date as the state commissioner of elections may direct. The state commissioner of elections shall order the start of a recount pursuant to this paragraph within seven days of receipt by the state commissioner of elections of the request for a recount. A candidate for an office filled by the electors of the entire state shall not be required to pay more than one bond for a recount.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Immediately upon receipt of a request for a recount for an office filled by the electors of more than one county, other than from the state commissioner of elections pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the commissioner shall send a copy of the request to each commissioner of a county where a ballot for the office was cast, who shall conduct a recount as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The recount shall be conducted by a board which shall consist of the commissioner and the commissioner\u8217\'3fs staff. The commissioner may assign persons employed by the commissioner to tally ballots during the election as members of the recount board. If the commissioner assigns persons employed by the commissioner to tally ballots during the election as members of the recount board to recount an election for a partisan office, the commissioner shall assign an equal number of persons from each political party.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commissioner shall convene the persons designated under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ not later than 9:00 a.m. on the seventh day following the receipt of a request for the recount of the election in question. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The candidate requesting the recount and the apparent winning candidate of the office subject to the recount may select not more than five persons to observe the conduct of the recount in each county where the recount is being conducted. A candidate may replace an observer appointed by the candidate at any time.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When all members of the recount board have been convened, the board shall undertake and complete the required recount as expeditiously as reasonably possible. The commissioner or the commissioner\u8217\'3fs designee shall supervise the handling of ballots to ensure that the ballots are protected from alteration or damage. The board shall recount all ballots which were voted and counted for the office in question, including any disputed ballots returned as required in }}}{{\f5\fs18\hyphpar0\qj{section 50.5}}}{{\f5\fs18\hyphpar0\qj{. The same program used for tabulating the votes on election day shall be used at the recount unless the program is believed or known to be flawed. A recount shall be conducted by the use of automatic tabulating equipment, except that the state commissioner, for an election for a member of the general assembly, or commissioner, for a local elective office, may direct that an election be conducted by hand due to extraordinary circumstances. The same method of conducting the recount shall be used in each precinct where the recount is conducted. The commissioner shall make all pieces of automatic tabulating equipment available for use in the recount. For purposes of this paragraph, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fextraordinary circumstances\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes but is not limited to a machine failure during an initial recount, a discrepancy between the results of the initial count and the results of the initial recount, and the number of overvotes for an office exceeding the difference between the number of votes received by the apparent winning candidate for that office and the votes received by the candidate who received the second highest number of votes for that office. }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The ballots shall be resealed by the recount board before adjournment and shall be preserved as required by }}}{{\f5\fs18\hyphpar0\qj{section 50.12}}}{{\f5\fs18\hyphpar0\qj{. At the conclusion of the recount, the recount board shall make and file with the commissioner a written report of its findings, which shall be signed by at least two-thirds of the members of the recount board. The recount board shall complete the recount and file its report not later than the eighteenth day following the commissioner\u8217\'3fs receipt of a request for the recount of the election in question.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At the conclusion of a recount, the recount board shall make and file with the commissioner a written report of its findings, signed by a majority of the recount board.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commissioner or commissioner\u8217\'3fs designee may assist in compiling the written report. The written report shall include a full tally and accounting of ballots reviewed by the recount board and shall be reported as required by }}}{{\f5\fs18\hyphpar0\qj{sections 50.24}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{53.20}}}{{\f5\fs18\hyphpar0\qj{. The written report must allow the commissioner to correct the canvass of voters in the manner required by law, if applicable.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the recount board\u8217\'3fs report is that the abstracts prepared pursuant to the county board\u8217\'3fs canvass were incorrect as to the number of votes cast for the candidates for the office or nomination in question, in that county or district, the commissioner shall at once so notify the county board. The county board shall reconvene within three days after being so notified, but no later than noon on the twenty-seventh day following the election in question for a recount of the offices of president and vice president, and shall correct its previous proceedings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commissioner shall promptly notify the state commissioner of any recount of votes for an office to which }}}{{\f5\fs18\hyphpar0\qj{section 50.30}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{section 43.60}}}{{\f5\fs18\hyphpar0\qj{ in the case of a primary election, is applicable. If necessary, the state canvass required by }}}{{\f5\fs18\hyphpar0\qj{section 50.38}}}{{\f5\fs18\hyphpar0\qj{, or by }}}{{\f5\fs18\hyphpar0\qj{section 43.63}}}{{\f5\fs18\hyphpar0\qj{, as the case may be, shall be delayed with respect to the office or the nomination to which the recount pertains. The commissioner shall subsequently inform the state commissioner at the earliest possible time whether any change in the outcome of the election in that county or district resulted from the recount.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the election is a city primary election held pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 376.7}}}{{\f5\fs18\hyphpar0\qj{, the recount shall progress according to the times provided by }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. If }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ applies the canvass shall be held by the second day after the election, the request for a recount must be made by the third day after the election, the board shall convene to conduct the recount by the sixth day after the election, and the report shall be filed by the eighth day after the election.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When a city council has chosen a runoff election pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 376.9}}}{{\f5\fs18\hyphpar0\qj{, the recount shall progress according to the times provided by }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. If }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ applies, the canvass shall be conducted pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 50.24}}}{{\f5\fs18\hyphpar0\qj{. The request for a recount must be made by the day after the canvass, and the board shall convene for the first time not later than the first Friday following the canvass. The report shall be filed not later than the fourteenth day after the election.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The recount board shall comply with all guidance issued by the state commissioner of elections pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 47.1}}}{{\f5\fs18\hyphpar0\qj{ during the conduct of a recount. The state commissioner may halt a recount in a county, take custody of all ballots and equipment used in the recount, and appoint staff to conduct a recount if the state commissioner believes that a recount is not being conducted as required by law.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the state commissioner believes that a commissioner is purposefully conducting a recount in violation of law, the state commissioner may impose a civil penalty on the commissioner not to exceed twenty-five thousand dollars, to be deposited in the general fund of the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Before a recount board has issued its final report, the candidate or person who requested the recount may reach an agreement with the apparent winner to accept the results of the original canvass by submitting the agreement in writing to each recount board that is conducting the recount. Upon receipt of the agreement, the recount boards shall cease their work and report to each county commissioner in a county where the recount is being conducted that the results of the original canvass are the official results.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71087-a18; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{584 \u8211\'3f 586;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a743.56}}}{ \u8211\'3f 43.58; }{{\f5\fs18\hyphpar0\qj{S81, \'a750.48}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 34, \'a734}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1224, \'a715, 16}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 143, \'a724, 25}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1180, \'a719}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 170, \'a758}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1134, \'a747, 115}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 190, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1032, \'a7153}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 57, \'a744}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 155, \'a729, 44}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 148, \'a751, 52}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 76, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1146, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 122, \'a77 \u8211\'3f 11}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a743.56}}}{{\f5\fs12\hyphpar0\qj{, 50.12}}}{{\f5\fs12\hyphpar0\qj{, 50.24}}}{{\f5\fs12\hyphpar0\qj{, 50.49}}}{{\f5\fs12\hyphpar0\qj{, 331.383}}}{{\f5\fs12\hyphpar0\qj{, 376.7}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section amended and editorially internally renumbered}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{50.49}}}{\*\bkmkstart stylerid1_2E57_2E2_2E2}{\*\bkmkend stylerid1_2E57_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Recounts for public measures.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A recount for any public measure shall be ordered by the board of canvassers if a petition requesting a recount is filed with the state commissioner for a public measure voted on by the electors of the entire state, or the county commissioner for all other public measures, not later than three days after the completion of the canvass of votes for the election at which the question appeared on the ballot and the abstracts prepared pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 50.24}}}{{\f5\fs18\hyphpar0\qj{ indicate that the difference between the affirmative and negative votes cast on the public measure is less than fifteen hundredths of one percent for a public measure voted on by the electors of the entire state, or less than either one percent or fifty votes, whichever is lesser, for all other public measures. The petition shall be signed by the greater of not less than ten eligible electors or a number of eligible electors equaling one percent of the total number of votes cast upon the public measure. Each petitioner must be a person who was entitled to vote on the public measure in question or would have been so entitled if registered to vote.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The recount shall be conducted by a board which shall consist of:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A designee named in the petition requesting the recount.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A designee named by the commissioner at or before the time the board is required to convene.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person chosen jointly by the members designated under paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commissioner shall convene the persons designated under }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, not later than 9:00 a.m. on the seventh day following the canvass of the election in question. If those two members cannot agree on the third member by 8:00 a.m. on the ninth day following the canvass, they shall immediately notify the chief judge of the judicial district in which the canvass is occurring, who shall appoint the third member not later than 5:00 p.m. on the eleventh day following the canvass.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The procedure for the recount shall follow the provisions of }}}{{\f5\fs18\hyphpar0\qj{section 50.48, subsections 3 through 6}}}{{\f5\fs18\hyphpar0\qj{, as far as possible.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{95 Acts, ch 189, \'a714}}}{; }{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1134, \'a748, 115}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1032, \'a7154}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1115, \'a7103}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 122, \'a712, 13}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a750.12}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 1 amended}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 4 stricken and former subsection 5 renumbered as 4}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{50.50}}}{\*\bkmkstart stylerid1_2E58_2E2_2E2}{\*\bkmkend stylerid1_2E58_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Administrative audits.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commissioner who was responsible for conducting an election may request an administrative audit when the commissioner is informed or suspects that voting equipment used in the election malfunctioned or that programming errors may have affected the outcome of the election, or if the precinct election officials report counting errors to the commissioner after the conclusion of the canvass of votes in the precinct. An administrative audit shall be conducted by the board of the special precinct established by }}}{{\f5\fs18\hyphpar0\qj{section 53.23}}}{{\f5\fs18\hyphpar0\qj{. The state commissioner may adopt rules for administrative audits.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each political party, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 43.2}}}{{\f5\fs18\hyphpar0\qj{, may appoint up to five observers to witness an audit conducted pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The observers shall be appointed by the county chairperson or, if the county chairperson fails to make an appointment, by the state chairperson. However, if either or both political parties fail to appoint an observer, the board may continue with the proceedings.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 170, \'a759}}}{; }{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1134, \'a749, 115}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 122, \'a714}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a750.12}}}{{\f5\fs12\hyphpar0\qj{, 50.51}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{50.51}}}{\*\bkmkstart stylerid1_2E59_2E2_2E2}{\*\bkmkend stylerid1_2E59_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Election audits.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{After each general election, the state commissioner shall, with the cooperation of the county commissioners, conduct an audit of the official canvass of votes from the preceding general election.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state commissioner shall determine the number of counties and precincts to be audited and shall select the precincts to be audited by lot. The absentee ballot and special voters precinct for each county, established pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 53.20}}}{{\f5\fs18\hyphpar0\qj{, shall be included with all other precincts of the county for selection by lot. In every precinct selected, the commissioner shall conduct a hand count of ballots cast in the preceding general election for president of the United States or governor, as the case may be. The hand count may be of less than all ballots cast, in accordance with rules adopted by the state commissioner.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A representative selected by each of the two political parties whose candidates received the highest number of votes statewide in the preceding general election shall be invited to observe the hand count. The commissioner shall notify the county chairperson of each political party a minimum of two days before the hand count of the time and place of the hand count.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If an invited representative does not appear at the hand count, the commissioner shall notify the state commissioner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commissioner may order an administrative recount pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 50.50}}}{{\f5\fs18\hyphpar0\qj{ if the commissioner determines the results of an audit require an administrative recount.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If selected to conduct an audit, the commissioner shall provide an audit report to the county board of supervisors and shall transmit the audit report to the state commissioner no later than twenty days following the election.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The results of an audit conducted pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not change the results, or invalidate the certification, of an election. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In advance of all other elections, the state commissioner shall order an audit of the election in the manner provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state commissioner shall adopt rules, pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{, to implement }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, which may include the establishment of pilot programs related to post-election audits.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2017 Acts, ch 110, \'a743}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1149, \'a78, 12}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 148, \'a729, 33}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 147, \'a738, 54}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a749.128}}}{{\f5\fs12\hyphpar0\qj{, 50.12}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{50.52}}}{\*\bkmkstart stylerid1_2E6_30_2E2_2E2}{\*\bkmkend stylerid1_2E6_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Enforcement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Members of local law enforcement agencies and the state patrol are authorized to take all reasonable actions to prevent violations of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2021 Acts, ch 12, \'a742, 73}}}\par}}