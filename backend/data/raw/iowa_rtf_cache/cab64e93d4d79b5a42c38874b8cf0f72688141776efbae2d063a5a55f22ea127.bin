\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fChild\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means either of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person twelve years of age or younger.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person thirteen years of age or older but younger than nineteen years of age who has a developmental disability as defined under the federal }}}{{\f5\fs18\hyphpar0\qj{Developmental Disabilities Assistance and Bill of Rights Act of 2000}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{Pub. L. No. 106-402}}}{{\f5\fs18\hyphpar0\qj{, as codified in }}}{{\f5\fs18\hyphpar0\qj{42 U.S.C. \'a715002(8)}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fChild care\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the care, supervision, and guidance of a child by a person other than the child\u8217\'3fs parent, guardian, or custodian for periods of less than twenty-four hours per day per child on a regular basis, but does not include care, supervision, and guidance of a child by any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An instructional program for children who are attending prekindergarten as defined by the state board of education under }}}{{\f5\fs18\hyphpar0\qj{section 256.11}}}{{\f5\fs18\hyphpar0\qj{ or a higher grade level and are at least four years of age, or are at least three years of age and eligible for special education under }}}{{\f5\fs18\hyphpar0\qj{chapter 256B}}}{{\f5\fs18\hyphpar0\qj{, administered by any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A public or nonpublic school system accredited by the department of education or the state board of regents.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A nonpublic school system which is not accredited by the department of education or the state board of regents.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any of the following church-related programs:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An instructional program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A youth program other than a preschool, before or after school child care program, or other child care program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A program providing care to children on church premises while the children\u8217\'3fs parents are attending church-related or church-sponsored activities on the church premises.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Short-term classes of less than two weeks\u8217\'3f duration held between school terms or during a break within a school term.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A child care center for sick children operated as part of a pediatrics unit in a hospital licensed by the department of inspections, appeals, and licensing pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 135B}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A program operated not more than one day per week by volunteers which meets all of the following conditions:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Not more than eleven children are served per volunteer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The program operates for less than four hours during any twenty-four-hour period.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The program is provided at no cost to the children\u8217\'3fs parent, guardian, or custodian.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A program administered by a political subdivision of the state which is primarily for recreational or social purposes and is limited to children who are five years of age or older and attending school.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An after school program continuously offered throughout the school year calendar to children who are at least five years of age and are enrolled in school, and attend the program intermittently or a summer-only program for such children. The program must be provided through a nominal membership fee or at no cost.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A special activity program which meets less than four hours per day for the sole purpose of the special activity. Special activity programs include but are not limited to music or dance classes, organized athletic or sports programs, recreational classes, scouting programs, and hobby or craft clubs or classes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A nationally accredited camp.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A structured program for the purpose of providing therapeutic, rehabilitative, or supervisory services to children under any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A purchase of service or managed care contract with the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A contract approved by a governance board of a decategorization of child welfare and juvenile justice funding project created under }}}{{\f5\fs18\hyphpar0\qj{section 232.188}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An arrangement approved by a juvenile court order.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{k.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Care provided on-site to children of parents residing in an emergency, homeless, or domestic violence shelter.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{l.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A child care facility providing respite care in a foster family home for a period of twenty-four hours or more to a child who is placed with an individual licensee under }}}{{\f5\fs18\hyphpar0\qj{chapter 237}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{m.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A program offered to a child whose parent, guardian, or custodian is engaged solely in a recreational or social activity, remains immediately available and accessible on the physical premises on which the child\u8217\'3fs care is provided, and does not engage in employment while the care is provided. However, if the recreational or social activity is provided in a fitness center or on the premises of a nonprofit organization, the parent, guardian, or custodian of the child may be employed to teach or lead the activity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fChild care center\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fcenter\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a facility providing child care or preschool services for seven or more children, except when the facility is registered as a child development home.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fChild care facility\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ffacility\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a child care center, preschool, or a registered child development home.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fChild care home\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person or program providing child care to any of the following children at any one time that is not registered to provide child care under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, as authorized under }}}{{\f5\fs18\hyphpar0\qj{section 237A.3}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Five or fewer children.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Six or fewer children, if at least one of the children is school-aged.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fChild development home\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person or program registered under }}}{{\f5\fs18\hyphpar0\qj{section 237A.3A}}}{{\f5\fs18\hyphpar0\qj{ that may provide child care to seven or more children at any one time.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fChildren needing special needs care\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fspecial needs child\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a child or children with one or more of the following conditions:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child has been diagnosed by a physician or by a person endorsed for service as a school psychologist by the department of education to have a developmental disability which substantially limits one or more major life activities, and the child requires professional treatment, assistance in self-care, or the purchase of special adaptive equipment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child has been determined by a qualified intellectual disability professional to have a condition which impairs the child\u8217\'3fs intellectual and social functioning.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child has been diagnosed by a mental health professional to have a behavioral or emotional disorder characterized by situationally inappropriate behavior which deviates substantially from behavior appropriate to the child\u8217\'3fs age, or which significantly interferes with the child\u8217\'3fs intellectual, social, or personal development.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDepartment\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the department of health and human services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDirector\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the director of health and human services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fInfant\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a child who is less than twenty-four months of age.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fInvolvement with child care\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means licensed or registered under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, employed in a child care facility, residing in a child care facility, receiving public funding for providing child care, or providing child care as a child care home provider, or residing in a child care home.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLicensed center\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a center issued a full or provisional license by the department under the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or a center for which a license is being processed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPoverty level\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the poverty level defined by the most recently revised poverty income guidelines published by the United States department of health and human services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPreschool\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a child care facility which provides to children ages three through five, for periods of time not exceeding three hours per day, programs designed to help the children to develop intellectual skills, social skills, and motor skills, and to extend their interest and understanding of the world about them.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSchool\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means kindergarten or a higher grade level.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7237A.1}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1213, \'a71 \u8211\'3f 3}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 96, \'a7157, 159}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 115, \'a734}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1097, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 206, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1005, \'a71 \u8211\'3f 3}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 151, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1083, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1109, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 54, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 76, \'a78, 9}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1129, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1175, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 151, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 192, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1067, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 105, \'a73, 4}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1142, \'a73 \u8211\'3f 8, 31}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 81, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 95, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1031, \'a7355, 361}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 129, \'a792, 156}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 88, \'a71, 5}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 103, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 40, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7738, 1951}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 89, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1170, \'a7418}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 135, \'a728}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7135.119}}}{{\f5\fs12\hyphpar0\qj{, 136A.5B}}}{{\f5\fs12\hyphpar0\qj{, 237.1}}}{{\f5\fs12\hyphpar0\qj{, 237.3}}}{{\f5\fs12\hyphpar0\qj{, 237A.2}}}{{\f5\fs12\hyphpar0\qj{, 237A.13}}}{{\f5\fs12\hyphpar0\qj{, 237A.26}}}{{\f5\fs12\hyphpar0\qj{, 237C.1}}}{{\f5\fs12\hyphpar0\qj{, 422.12C}}}{{\f5\fs12\hyphpar0\qj{, 692A.101}}}{{\f5\fs12\hyphpar0\qj{, 726.23}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 2, paragraph l amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{237A.2}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Licensing of child care centers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not establish or operate a child care center without obtaining a license under the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. A center may operate for a specified period of time, to be established by rule of the department, if application for a license has been made. If the department denies an application for an initial license, notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 17A.18}}}{{\f5\fs18\hyphpar0\qj{, the applicant center shall not continue to provide child care pending the outcome of an evidentiary hearing. The department shall issue a license if it determines that all of the following conditions have been met:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An application for a license or a renewal has been filed with the department on forms provided by the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The center is maintained to comply with state health and fire laws.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The center is maintained to comply with rules adopted under }}}{{\f5\fs18\hyphpar0\qj{section 237A.12}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person denied a license under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall receive written notice of the denial stating the reasons for denial and shall be provided with an opportunity for an evidentiary hearing.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A license issued under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall be valid for twenty-four months from the date of issuance. A license shall remain valid unless it is revoked or suspended in accordance with the provisions of }}}{{\f5\fs18\hyphpar0\qj{section 237A.8}}}{{\f5\fs18\hyphpar0\qj{ or is reduced to a provisional license under }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{. The department may inspect a licensed center at any time. A record of the license shall be kept by the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The license shall be posted in a conspicuous place in the center and shall state the particular premises in which child care may be offered and the number of individuals who may be received for care at any one time. A greater number of children than is authorized by the license shall not be kept in the center at any one time.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department may reduce a previously issued license to a provisional license or issue a provisional license for a period of time not to exceed one year if the center does not meet standards required under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. A provisional license shall not be renewable in regard to the same standards for more than two consecutive years. A provisional license shall be posted in a conspicuous place in the center as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. If written plans to bring the center up to standards, giving specific dates for completion of work, are submitted to and approved by the department, the provisional license shall be renewable as provided in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A program which is not a child care center by reason of the exceptions to the definition of child care in }}}{{\f5\fs18\hyphpar0\qj{section 237A.1, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, but which provides care, supervision, and guidance to a child may be issued a license if the program complies with all the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the department has denied or revoked a license because the applicant or person has continually or repeatedly failed to operate a licensed center in compliance with }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and rules adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, the person shall not own or operate a child care center for a period of twelve months from the date the license is denied or revoked. The department shall not act on an application for a license submitted by the applicant or person during the twelve-month period. The applicant or person shall be prohibited from involvement with child care unless the involvement is specifically permitted by the department.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, \'a7237A.2, 237A.3; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7237A.2}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1005, \'a74}}}{; }{{\f5\fs18\hyphpar0\qj{91 Acts, ch 232, \'a712}}}{; }{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1163, \'a754}}}{; }{{\f5\fs18\hyphpar0\qj{99 Acts, ch 192, \'a72}}}{; }{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1142, \'a79, 10, 31}}}{; }{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 44, \'a754}}}{; }{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 81, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7739, 740}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Child care provider minimum age and child care center staffing ratios, see }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2022/CH1135.pdf" }{\fldrslt \cf5 \f5 \fs12{{2022 Acts, ch 1135, \'a72, 3}}}}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{237A.3}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Child care homes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person or program providing child care in a child care home is not required to register under }}}{{\f5\fs18\hyphpar0\qj{section 237A.3A}}}{{\f5\fs18\hyphpar0\qj{ as a child development home. However, the person or program may register as a child development home.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a person or program has been prohibited by the department from involvement with child care, the person or program shall not provide child care as a child care home provider and is subject to penalty under }}}{{\f5\fs18\hyphpar0\qj{section 237A.19}}}{{\f5\fs18\hyphpar0\qj{ or injunction under }}}{{\f5\fs18\hyphpar0\qj{section 237A.20}}}{{\f5\fs18\hyphpar0\qj{ for doing so.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The location at which the child care is provided shall be a single-family residence that is owned, rented, or leased by the person or program providing the child care. For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, a }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fsingle-family residence\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes an apartment, condominium, townhouse, or other individual unit within a multiple unit residential dwelling, but does not include a commercial or industrial building that is primarily used for purposes other than a residence.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7237A.3}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1016, \'a73}}}{, }{{\f5\fs18\hyphpar0\qj{ch 1213, \'a74}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1005, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 151, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 232, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 267, \'a7142}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1163, \'a755}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 76, \'a710, 11}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1129, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 151, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 192, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 135, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1142, \'a711, 31}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 81, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1187, \'a7119}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 40, \'a72}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7237A.1}}}{{\f5\fs12\hyphpar0\qj{, 237A.19}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{237A.3A}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Child development homes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E8_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E8_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Registration.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not establish or operate a child development home unless the person obtains a certificate of registration. The department shall issue a certificate of registration upon receipt of a statement from the person or upon completion of an inspection conducted by the department or a designee of the department verifying that the person complies with applicable rules adopted by the department pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{section 237A.12}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The certificate of registration shall be posted in a conspicuous place in the child development home and shall state the name of the registrant, the registration category of the child development home, the maximum number of children who may be present for child care at any one time, and the address of the child development home. In addition, the certificate shall include a checklist of registration compliances.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The registration process for a child development home shall be repeated every twenty-four months as provided by rule.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensee or an approved kinship caregiver under }}}{{\f5\fs18\hyphpar0\qj{chapter 237}}}{{\f5\fs18\hyphpar0\qj{ shall register as a child development home provider in order to provide child care.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E8_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E8_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Revocation or denial of registration.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the department has denied or revoked a certificate of registration because a person has continually or repeatedly failed to operate a registered or licensed child care facility in compliance with }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and rules adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, the person shall not operate or establish a registered child development home for a period of twelve months from the date the registration or license was denied or revoked. The department shall not act on an application for registration submitted by the person during the twelve-month period. The applicant or person shall be prohibited from involvement with child care unless the involvement is specifically permitted by the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{\*\bkmkstart stylerid1_2E8_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E8_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Rules.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Three categories of standards shall be applicable to child development homes. The initial designations of the categories, which may be revised by the department, shall be \u8220\'3fA\u8221\'3f, \u8220\'3fB\u8221\'3f, and \u8220\'3fC\u8221\'3f, as ranked from less stringent standards and capacity to more stringent standards and capacity. The \u8220\'3fC\u8221\'3f registration category standards shall require the highest level of provider qualifications and allow the greatest capacity of the three categories. The department shall adopt rules applying standards to each category specifying provider qualifications and training, health and safety requirements, capacity, amount of space available per child, and other minimum requirements. The capacity requirements shall take into consideration the provider\u8217\'3fs own children, children who have a mild illness, children receiving part-time child care, and children served as a sibling group in overnight care.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The rules shall allow a child development home to be registered in a particular category for which the provider is qualified even though the amount of space required to be available for the maximum number of children authorized for that category exceeds the actual amount of space available in that home. However, the total number of children authorized for the child development home at that category of registration shall be limited by the amount of space available per child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In consultation with the director of the department of inspections, appeals, and licensing, the department shall adopt rules relating to the provision of fire extinguishers, smoke detectors, and two exits accessible to children in a child development home.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The rules shall require a child development home to be located in a single-family residence that is owned, rented, or leased by the person or, for dual registrations, at least one of the persons who is named on the child development home\u8217\'3fs certificate of registration. For purposes of this paragraph, a }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fsingle-family residence\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes an apartment, condominium, townhouse, or other individual unit within a multiple unit residential dwelling, but does not include a commercial or industrial building that is primarily used for purposes other than a residence.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the department adopts rules establishing a limitation on the number of hours for which substitute care may be utilized by the provider, such a limitation shall not apply to or incorporate substitute care utilized when the provider is engaged in jury duty or in official duties connected with the provider\u8217\'3fs membership on a state board, committee, or other policy-related body.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall adopt rules to allow registered child development homes providing care to school-aged children to exceed the child-to-staff ratio for school-aged children when a school-aged child\u8217\'3fs school starts late, is dismissed early, or is canceled due to inclement weather, a public health emergency, or structural damage regardless of whether the child development home provider is able to be assisted by a department-approved assistant or co-provider, provided the child is currently enrolled at the registered child development home and the registered child development home does not exceed the child development home\u8217\'3fs registration capacity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{\*\bkmkstart stylerid1_2E8_2E6_2E1_2E2}{\*\bkmkend stylerid1_2E8_2E6_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Number of children.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In determining the number of children present for child care at any one time in a child development home, each child present in the child development home shall be considered as being provided child care unless the child is described by one of the following exceptions:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child\u8217\'3fs parent, guardian, or custodian operates or established the child development home and the child is attending school or the child is provided child care full-time on a regular basis by another person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child has been present in the child development home for more than seventy-two consecutive hours and the child is attending school or the child is provided child care full-time on a regular basis by another person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of determining the number of children present for child care in a child development home, a child receiving foster care from a child development home provider shall be considered to be the child of the provider.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 151, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1127, \'a71, 2, 6}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 192, \'a74 \u8211\'3f 11, 37}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 135, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1142, \'a712, 31}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 81, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1084, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1187, \'a7120}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1192, \'a781}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1097, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7741, 1645}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 135, \'a729}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7237A.1}}}{{\f5\fs12\hyphpar0\qj{, 237A.3}}}{{\f5\fs12\hyphpar0\qj{, 237A.19}}}{{\f5\fs12\hyphpar0\qj{, 237A.20}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 1, paragraph d amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{237A.3B}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Smoking prohibited.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Smoking, as defined in }{{\f5\fs18\hyphpar0\qj{section 142D.2}}}{, shall not be permitted in a child care facility or child care home.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1084, \'a713}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{237A.3C}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Immunization information.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Each child care center, child care facility, child care home, and child development home shall include information regarding the exemptions and requirements for an exemption described in }{{\f5\fs18\hyphpar0\qj{section 139A.8, subsection 4}}}{, in any communication to the parent or guardian of a child that is related to the immunizations required under }{{\f5\fs18\hyphpar0\qj{section 139A.8}}}{.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2025 Acts, ch 106, \'a72}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{NEW section}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{237A.4}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Inspection and evaluation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department shall make periodic inspections of licensed centers to ensure compliance with licensing requirements provided in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, and the local boards of health may make periodic inspections of licensed centers to ensure compliance with health-related licensing requirements provided in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{. The department may inspect records maintained by a licensed center and may inquire into matters concerning these centers and the persons in charge. The department shall require that the center be inspected by the director of the department of inspections, appeals, and licensing or a designee for compliance with rules relating to fire safety before a license is granted or renewed. The department or a designee may periodically visit registered child development homes for the purpose of evaluation of an inquiry into matters concerning compliance with rules adopted under }{{\f5\fs18\hyphpar0\qj{section 237A.12}}}{. Evaluation of child development homes under }{{\f5\fs18\hyphpar0\qj{this section}}}{ may include consultative services provided pursuant to }{{\f5\fs18\hyphpar0\qj{section 237A.6}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7237A.4}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 173, \'a719}}}{; }{{\f5\fs18\hyphpar0\qj{99 Acts, ch 192, \'a712}}}{; }{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1142, \'a713, 31}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71646}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{237A.4A}}}{\*\bkmkstart stylerid1_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Child care regulatory fee \u8212\'3f child care facility fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall implement a regulatory fee for licensure of child care facilities. The fee requirements shall provide for tiered amounts based upon a child care facility\u8217\'3fs capacity and a child development home\u8217\'3fs regulatory category at the time of licensure.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The regulatory fee for centers shall not exceed one hundred fifty dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The regulatory fee for category \u8220\'3fA\u8221\'3f and \u8220\'3fB\u8221\'3f child development homes shall not exceed one hundred fifty dollars and the fee for category \u8220\'3fC\u8221\'3f child development homes shall not exceed one hundred eighty-seven dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall adopt rules for implementation of the fee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Regulatory fees collected shall augment existing funding for regulation of child care facilities in order to phase in annual inspections of child development homes and improve inspections of child care centers. The department shall not supplant existing funding for regulation of child care with funding derived from the regulatory fee. The department shall seek to meet the following target percentages of the total number of child development homes in the state inspected annually in phasing in the annual inspection of all child development homes:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the fiscal year beginning July 1, 2009, twenty percent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the fiscal year beginning July 1, 2010, forty percent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the fiscal year beginning July 1, 2011, sixty percent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the fiscal year beginning July 1, 2012, eighty percent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the fiscal year beginning July 1, 2013, and succeeding fiscal years, one hundred percent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In phasing in the inspection of child development homes, the department shall give priority to child development homes that have recently become licensed and have paid the regulatory fee implemented pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The results of an inspection of a child care facility shall be made publicly available on the internet page or site implemented by the department in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 237A.25}}}{{\f5\fs18\hyphpar0\qj{ and through other means.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The target time frame for the department\u8217\'3fs issuance of the report concerning an inspection or other regulatory visit to a child care facility is sixty calendar days.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A child care facility fund is created in the state treasury under the authority of the department. The fund is separate from the general fund of the state. Regulatory fees collected under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ shall be credited to the fund. Moneys credited to the fund shall not revert to any other fund and are not subject to transfer except as specifically provided by law. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 12C.7, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, interest or earnings on moneys deposited in the fund shall be credited to the fund. Moneys in the fund are annually appropriated to the department to be used for staffing dedicated to monitoring and regulation of child care facilities, contracting, related technology costs, record checks, grants and fee waivers, and other expenses for inspection and regulation of child care facilities. Any full-time equivalent positions paid for out of the fund shall be in addition to other such positions authorized for the department.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 179, \'a7208}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{237A.5}}}{\*\bkmkstart stylerid1_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Personnel.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All personnel in licensed or registered child care facilities shall have good health as evidenced by a report following a physical examination.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An individual shall have received an initial physical examination within the six months immediately preceding the date the individual begins employment, or within the six months immediately following the date the individual begins employment. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A physical examination shall include communicable disease tests performed by a licensed physician as defined in }}}{{\f5\fs18\hyphpar0\qj{section 135C.1}}}{{\f5\fs18\hyphpar0\qj{, or by a licensed physician assistant as defined in }}}{{\f5\fs18\hyphpar0\qj{section 148C.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Licensed or registered facility personnel shall receive a physical examination under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ at least once every three years after the date of the individual\u8217\'3fs initial physical examination under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Controlled medical conditions which would not affect the performance of the employee in the capacity employed shall not prohibit employment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, unless the context otherwise requires:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPerson subject to a record check\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person who is described by any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person is being considered for licensure or registration or is registered or licensed under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person is being considered by a child care facility for employment involving direct responsibility for a child or with access to a child when the child is alone or is employed with such responsibilities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person will reside or resides in a child care facility.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person has applied for or receives public funding for providing child care.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(e)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person will reside or resides in a child care home that is not registered under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ but that receives public funding for providing child care.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPerson subject to an evaluation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person subject to a record check whose record indicates that the person has committed a transgression.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fTransgression\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the existence of any of the following in a person\u8217\'3fs record:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Conviction of a crime.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A record of having committed founded child or dependent adult abuse.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Listing in the sex offender registry under }}}{{\f5\fs18\hyphpar0\qj{chapter 692A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A record of having committed a public or civil offense.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(e)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department has revoked a child care facility registration or license due to the person\u8217\'3fs continued or repeated failure to operate the child care facility in compliance with }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and rules adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If an individual person subject to a record check is being considered for employment by a child care facility or child care home provider, in lieu of requesting a record check in this state to be conducted by the record check evaluation system under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the child care facility or child care home may access the single contact repository established pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 135C.33}}}{{\f5\fs18\hyphpar0\qj{ as necessary to conduct a criminal and child abuse record check of the individual in this state. A copy of the results of the record check conducted through the single contact repository shall also be provided to the record check evaluation system. If the record check indicates the individual is a person subject to an evaluation, the child care facility or child care home may request that the record check evaluation system perform an evaluation as provided in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. Otherwise, the individual shall not be employed by the child care facility or child care home.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Unless a record check has already been conducted in accordance with paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the record check evaluation system shall conduct a criminal and child abuse record check in this state for a person who is subject to a record check and may conduct such a check in other states. In addition, the record check evaluation system may conduct a dependent adult abuse, sex offender registry, or other public or civil offense record check in this state or in other states for a person who is subject to a record check.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For a person subject to a record check, in addition to any other record check conducted pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, the person\u8217\'3fs fingerprints shall be provided to the department of public safety for submission through the state criminal history repository to the United States department of justice, federal bureau of investigation for a national criminal history check. The department may adopt rules specifying criteria in the public interest for requiring the national criminal history check of a person to be repeated.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as otherwise provided by law, the cost of a national criminal history check conducted in accordance with subparagraph (1) and the state record checks conducted in accordance with paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ that are conducted in connection with a person\u8217\'3fs involvement with a child care center are not the responsibility of the department. The department is responsible for the cost of such checks conducted in connection with a person\u8217\'3fs involvement with a child development home or child care home.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If record checks under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ have been conducted on a person subject to a record check and the results do not warrant prohibition of the person\u8217\'3fs involvement with child care or otherwise present protective concerns, the person may be involved with child care on a provisional basis until the record check under subparagraph (1) has been completed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a person subject to a record check refuses to consent to a record check or if the person makes what the person knows to be a false statement of material fact in connection with a record check, the person shall be prohibited from involvement with child care.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a record check performed pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ identifies an individual as a person subject to an evaluation, an evaluation shall be performed to determine whether prohibition of the person\u8217\'3fs involvement with child care is warranted. The evaluation shall be performed in accordance with procedures adopted for this purpose by the department.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prior to performing an evaluation, the record check evaluation system shall notify the affected person, licensee, registrant, or child care home applying for or receiving public funding for providing child care, that an evaluation will be conducted to determine whether prohibition of the person\u8217\'3fs involvement with child care is warranted.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a record check performed in accordance with paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ identifies that an individual is a person subject to an evaluation, the record check evaluation system shall perform the evaluation in accordance with }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, even if the application which made the person subject to the record check is withdrawn or the circumstances which made the person subject to the record check are no longer applicable. If the record check evaluation system\u8217\'3fs evaluation determines that prohibition of the person\u8217\'3fs involvement with child care is warranted, the provisions of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ regarding such a prohibition shall apply.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person subject to a record check who is or was employed by a child care facility or child care home provider and is hired by another child care facility or child care home provider shall be subject to a record check in accordance with }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. However, if the person was subject to an evaluation because of a transgression in the person\u8217\'3fs record and the evaluation determined that the transgression did not warrant prohibition of the person\u8217\'3fs involvement with child care and the latest record checks do not indicate there is a transgression that was committed subsequent to that evaluation, the person may commence employment with the other child care facility or provider in accordance with the evaluation and an exemption from any requirements for reevaluation of the latest record checks is authorized. Authorization of an exemption under this paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fg\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ from requirements for reevaluation of the latest record checks by the record check evaluation system is subject to all of the following provisions:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The position with the subsequent employer is substantially the same or has the same job responsibilities as the position for which the previous evaluation was performed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any restrictions placed on the person\u8217\'3fs employment in the previous evaluation by the record check evaluation system shall remain applicable in the person\u8217\'3fs subsequent employment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person subject to the record checks has maintained a copy of the previous evaluation and provides the evaluation to the subsequent employer or the previous employer provides the previous evaluation from the person\u8217\'3fs personnel file pursuant to the person\u8217\'3fs authorization. If a physical copy of the previous evaluation is not provided to the subsequent employer, the record checks shall be reevaluated.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Although an exemption under this paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fg\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ may be authorized, the subsequent employer may instead request a reevaluation of the record checks and may employ the person while the reevaluation is being performed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In an evaluation, the record check evaluation system shall consider the nature and seriousness of the transgression in relation to the position sought or held, the time elapsed since the commission of the transgression, the circumstances under which the transgression was committed, the degree of rehabilitation, the likelihood that the person will commit the transgression again, and the number of transgressions committed by the person involved. In addition to record check information, the record check evaluation system may utilize information from the record check evaluation system\u8217\'3fs case records in performing the evaluation. The record check evaluation system may permit a person who is evaluated to maintain involvement with child care, if the person complies with the record check evaluation system\u8217\'3fs conditions and corrective action plan relating to the person\u8217\'3fs involvement with child care. The record check evaluation system has final authority in determining whether prohibition of the person\u8217\'3fs involvement with child care is warranted and in developing any conditional requirements and corrective action plan under this paragraph.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person subject to an evaluation shall be prohibited from involvement with child care under any of the following circumstances:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person has a record of founded child abuse or dependent adult abuse that was determined to be sexual abuse.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person is listed or is required to be listed on any state sex offender registry or the national sex offender registry.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person has committed any of the following felony-level offenses:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Child endangerment or neglect or abandonment of a dependent person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Domestic abuse.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(iii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A crime against a child including but not limited to sexual exploitation of a minor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(iv)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A forcible felony.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(v)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Arson.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person has a record of a misdemeanor conviction against a child that constitutes one of the following offenses:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Child abuse.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Child endangerment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(iii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Sexual assault.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(iv)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Child pornography.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If, within five years prior to the date of application for registration or licensure under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, for employment or residence in a child care facility or child care home, or for receipt of public funding for providing child care, a person subject to an evaluation has been convicted of a controlled substance offense or has been found to have committed physical abuse, the person shall be prohibited from involvement with child care for a period of five years from the date of conviction or founded abuse. After the five-year prohibition period, the person may submit an application for registration or licensure under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, or to receive public funding for providing child care, or may request an evaluation, and the record check evaluation system shall perform an evaluation and, based upon the criteria in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fh\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, shall determine whether prohibition of the person\u8217\'3fs involvement with child care continues to be warranted.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the record check evaluation system determines, through an evaluation of a person\u8217\'3fs transgression, that the person\u8217\'3fs prohibition of involvement with child care is warranted, the person shall be prohibited from involvement with child care. The record check evaluation system may identify a period of time after which the person may request that another record check and evaluation be performed. A person who continues involvement with child care in violation of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ is subject to penalty under }}}{{\f5\fs18\hyphpar0\qj{section 237A.19}}}{{\f5\fs18\hyphpar0\qj{ or injunction under }}}{{\f5\fs18\hyphpar0\qj{section 237A.20}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{k.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If it has been determined that a child receiving child care from a child care facility or a child care home is the victim of founded child abuse committed by an employee, license or registration holder, child care home provider, or resident of the child care facility or child care home for which a report is placed in the central registry pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 232.71D}}}{{\f5\fs18\hyphpar0\qj{, the department shall provide notification at the time of the determination to the parents, guardians, and custodians of children receiving care from the child care facility or child care home. A notification made under this paragraph shall identify the type of abuse but shall not identify the victim or perpetrator or circumstances of the founded abuse.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensee or registrant shall inform all new applicants for employment of the possibility of the performance of a record check and shall obtain, from the applicant, a signed acknowledgment of the receipt of the information.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensee or registrant shall include the following inquiry in an application for employment:}}}\par}{\pard\plain\keep\f5\fs18\hyphpar0\qj\fi0\sb80\ri1084\li1084\sa80{{\f5\fs18\hyphpar0\qj{\~\~}}}{Do you have a record of founded child or dependent adult abuse or have you ever been convicted of a crime, in this state or any other state?}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who serves as an unpaid volunteer in a child care facility shall not be required to complete training as a mandatory reporter of child abuse under }}}{{\f5\fs18\hyphpar0\qj{section 232.69}}}{{\f5\fs18\hyphpar0\qj{ or under any other requirement.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7237A.5}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 153, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 184, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 153, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1134, \'a758}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1221, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 138, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1130, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 45, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1127, \'a73, 6}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 192, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 81, \'a75, 6}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1098, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1184, \'a7108 \u8211\'3f 111}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1187, \'a7121}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 41, \'a799}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 179, \'a7209}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1042, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1074, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1113, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 59, \'a773}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1066, \'a739}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7742}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 91, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7237A.19}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 1 amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{237A.6}}}{\*\bkmkstart stylerid1_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Consultative services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department shall provide consultative services to a person applying for a license or registration, or licensed or registered under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7237A.6}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2023 Acts, ch 19, \'a7743}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7237A.4}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{237A.7}}}{\*\bkmkstart stylerid1_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Confidential information.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Anyone who acquires through the administration of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ information relative to an individual in a child care facility or to a relative of the individual shall not, directly or indirectly, disclose the information except upon inquiry before a court of law or with the written consent of the individual or, in the case of a child, the written consent of the parent or guardian or as otherwise specifically required or allowed by law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ shall not prohibit the disclosure of information relative to the structure and operation of a facility nor shall it prohibit the statistical analysis by duly authorized persons of data collected by virtue of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, or the publication of the results of the analysis in a manner which does not disclose information identifying individual persons.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7237A.7}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{99 Acts, ch 192, \'a714}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{237A.8}}}{\*\bkmkstart stylerid1_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Violations }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ actions against license or registration.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department, after notice and opportunity for an evidentiary hearing before the department of inspections, appeals, and licensing, may suspend or revoke a license or certificate of registration issued under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ or may reduce a license to a provisional license if the person to whom a license or certificate is issued violates a provision of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ or if the person makes false reports regarding the operation of the child care facility to the department. The department shall notify the parent, guardian, or legal custodian of each child for whom the person provides child care at the time of action to suspend or revoke a license or certificate of registration.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7237A.8}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 153, \'a76}}}{; }{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1204, \'a754}}}{; }{{\f5\fs18\hyphpar0\qj{99 Acts, ch 192, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7744, 1952}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7237A.2}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{237A.9 through 237A.11}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{237A.12}}}{\*\bkmkstart stylerid1_2E18_2E2_2E2}{\*\bkmkend stylerid1_2E18_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Rules.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subject to the provisions of }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{, the department shall adopt rules setting minimum standards to provide quality child care in the operation and maintenance of child care centers and registered child development homes, relating to all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The number and qualifications of personnel necessary to assure the health, safety, and welfare of children in the facilities. Rules for facilities which are preschools shall be drawn so that any staff-to-children ratios which relate to the age of the children enrolled shall be based on the age of the majority of the children served by a particular class rather than on the age of the youngest child served.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Physical facilities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The adequacy of activity programs and food services available to the children. The department shall not restrict the use of or apply nutritional standards to a lunch or other meal which is brought to the center, child development home, or child care home by a school-age child for the child\u8217\'3fs consumption.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Policies established by the center for parental participation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Programs for education and in-service training of staff.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Records kept by the facilities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Administration.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Health, safety, and medical policies for children.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Rules adopted by the director of the department of inspections, appeals, and licensing for buildings, other than school buildings, used as child care centers as an adjunct to the primary purpose of the building shall take into consideration that children are received for temporary care only and shall not differ from rules adopted for these buildings when they are used by groups of persons congregating from time to time in the primary use and occupancy of the buildings. However, the rules may require a fire-rated separation from the remaining portion of the building if the director of the department of inspections, appeals, and licensing determines that the separation is necessary for the protection of children from a specific flammable hazard.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Rules relating to fire safety for child care centers shall be adopted under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ by the director of the department of inspections, appeals, and licensing in consultation with the department. Rules adopted by the director of the department of inspections, appeals, and licensing for a building which is owned or leased by a school district or accredited nonpublic school and used as a child care facility shall not differ from standards adopted by the director of the department of inspections, appeals, and licensing for school buildings under }}}{{\f5\fs18\hyphpar0\qj{chapter 10A, subchapter V, part 2}}}{{\f5\fs18\hyphpar0\qj{. Rules relating to sanitation shall be adopted by the department. The director of the department of inspections, appeals, and licensing shall inspect the facilities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a building is owned or leased by a school district or accredited nonpublic school and complies with standards adopted by the director of the department of inspections, appeals, and licensing for school buildings under }}}{{\f5\fs18\hyphpar0\qj{chapter 10A, subchapter V, part 2}}}{{\f5\fs18\hyphpar0\qj{, the building is considered appropriate for use by a child care facility. The rules adopted by the department under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not require the facility to comply with building requirements which differ from requirements for use of the building as a school.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Standards and requirements set by a city or county for a building which is owned or leased by a school district or accredited nonpublic school and used as a child care facility shall take into consideration that children are received for temporary care only and shall not differ from standards and requirements set for use of the building as a school.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Rules adopted relating to physical examination requirements for licensed or registered facility personnel and the children being provided child care by the licensed or registered facility shall allow for any licensed physician as defined in }}}{{\f5\fs18\hyphpar0\qj{section 135.1}}}{{\f5\fs18\hyphpar0\qj{ to perform the physical examination.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7237A.12}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 173, \'a720}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 151, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1083, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1129, \'a74, 5}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1175, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 192, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1142, \'a714 \u8211\'3f 16, 31}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1031, \'a7356, 361}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1153, \'a750}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7745, 1647}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1170, \'a7280}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7237A.2}}}{{\f5\fs12\hyphpar0\qj{, 237A.3A}}}{{\f5\fs12\hyphpar0\qj{, 237A.4}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{237A.13}}}{\*\bkmkstart stylerid1_2E19_2E2_2E2}{\*\bkmkend stylerid1_2E19_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{State child care assistance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A state child care assistance program is established in the department to assist children in families who meet eligibility guidelines and are described by any of the following circumstances:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child\u8217\'3fs parent, guardian, or custodian is participating in approved academic, vocational, or technical training.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child\u8217\'3fs parent, guardian, or custodian is seeking employment. Eligibility for assistance while seeking employment shall be limited to thirty days during a twelve-month period.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child\u8217\'3fs parent, guardian, or custodian is employed a minimum of thirty-two hours per week or an average of thirty-two hours per week during the month if the child requires basic care, or twenty-eight hours per week or an average of twenty-eight hours per week during the month if the child is a special needs child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child\u8217\'3fs parent, guardian, or custodian is absent due to hospitalization, physical illness, or mental illness, or is present but is unable to care for the child as verified by a physician or physician assistant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child needs protective services to prevent or alleviate child abuse or neglect.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person\u8217\'3fs family circumstances are described in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the person is thirteen years of age or older but younger than sixteen years of age, and state child care assistance is approved for the person by the director or the director\u8217\'3fs designee based on a request for an exception to policy made by the person\u8217\'3fs parent, guardian, or custodian because special family circumstances exist that would place the safety and well-being of the person at risk if the person is left home alone. The definition of child in }}}{{\f5\fs18\hyphpar0\qj{section 237A.1}}}{{\f5\fs18\hyphpar0\qj{ does not apply to child care supported by state child care assistance approved pursuant to this lettered paragraph.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A family shall only be initially eligible for state child care assistance if the family\u8217\'3fs gross monthly income does not exceed the lesser of:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{One hundred sixty percent of the federal poverty level applicable to the family size for children needing basic care.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Two hundred percent of the federal poverty level applicable to the family size for children needing special needs care.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Eighty-five percent of the state median gross monthly income.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Services under the program may be provided in a licensed child care center, a child development home, the home of a relative, the child\u8217\'3fs own home, a child care home, or in a facility exempt from licensing or registration.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall set reimbursement rates as authorized by appropriations enacted for payment of the reimbursements. The department shall conduct a statewide reimbursement rate survey to compile information on each county and the survey shall be conducted at least every two years. The department shall set rates in a manner so as to provide incentives for an unregistered provider to become registered.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall not modify reimbursement rates to the state child care assistance program or financial eligibility requirements for a family participating in the state child care assistance program without prior enabling legislation in this state passed on or after January 1, 2023.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department\u8217\'3fs billing and payment provisions for the program shall allow providers to elect either biweekly or monthly billing and payment for child care provided under the program. The department shall remit payment to a provider within ten business days of receiving a bill or claim for services provided. However, if the department determines that a bill has an error or omission, the department shall notify the provider of the error or omission and identify any correction needed before issuance of payment to the provider. The department shall provide the notice within five business days of receiving the billing from the provider and shall remit payment to the provider within ten business days of receiving the corrected billing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A child care provider shall be allowed to collect from a family participating in the state child care assistance program the difference between the state child care assistance reimbursement rate and the rate the provider would typically charge a private-pay family for child care, provided the child care provider and family agree in writing to such additional payments prior to the provision of the child care.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On or before July 1, 2007, the department shall implement a system for making program payments by electronic funds transfer or other electronic means.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall not apply waiting list requirements to any of the following persons:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Persons deemed to be eligible for benefits under the state child care assistance program in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 239B.24}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A family that is receiving state child care assistance at the time a child is born into the family. The newborn child shall be approved for services when the family reports the birth of the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Children who need protective services to prevent or alleviate child abuse or neglect.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A child in a family that is eligible for state child care assistance and that receives a state adoption subsidy for the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Based upon the availability of the funding appropriated for state child care assistance for a fiscal year, the department shall establish waiting lists for state child care assistance in descending order of prioritization as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Families with an income at or below one hundred percent of the federal poverty level whose members, for at least thirty-two hours per week in the aggregate, are employed or are participating at a satisfactory level in an approved training program or educational program, and parents with a family income at or below one hundred percent of the federal poverty level who are under the age of twenty-one years and are participating in an educational program leading to a high school diploma or the equivalent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Parents with a family income at or below one hundred percent of the federal poverty level who are under the age of twenty-one years and are participating, at a satisfactory level, in an approved training program or in an educational program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Families with an income of more than one hundred percent but not more than one hundred sixty percent of the federal poverty level whose members, for at least thirty-two hours per week in the aggregate, are employed or are participating at a satisfactory level in an approved training program or educational program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Families with an income at or below two hundred percent of the federal poverty level whose members are employed at least twenty-eight hours per week with a special needs child as a member of the family.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Nothing in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be construed as or is intended as, or shall imply, a grant of entitlement for services to persons who are eligible for assistance due to an income level or other eligibility circumstance addressed in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. Any state obligation to provide services pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is limited to the extent of the funds appropriated for the purposes of state child care assistance.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1067, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1142, \'a717, 18, 31}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 81, \'a77, 8}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1016, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1099, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 172, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 215, \'a799}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1187, \'a7122}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1140, \'a796, 97}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1108, \'a722}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 54, \'a735}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1066, \'a740}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1096, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1104, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 89, \'a72 \u8211\'3f 5}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7234.47}}}{{\f5\fs12\hyphpar0\qj{, 239B.24}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{237A.14}}}{\*\bkmkstart stylerid1_2E2_30_2E2_2E2}{\*\bkmkend stylerid1_2E2_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Child care assistance }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ graduated eligibility phase-out.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At the time of a twelve-month eligibility redetermination for a family receiving state child care assistance, the family shall remain eligible to receive child care assistance, subject to the graduated eligibility phase-out program as specified in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, if either of the following conditions are met:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The family\u8217\'3fs nonexempt gross monthly income is determined to be at least two hundred twenty-five percent but less than two hundred fifty percent of the federal poverty level applicable to the family size for children needing basic care.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The family\u8217\'3fs nonexempt gross monthly income is determined to be at least two hundred twenty-five percent but less than two hundred seventy-five percent of the federal poverty level applicable to the family size for children needing special needs care.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A family with an income at the following percentages of the federal poverty level applicable to the family size for children needing basic care shall be responsible for the following share of child care costs:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A family with an income above two hundred twenty-five percent of the federal poverty level but less than two hundred thirty-five percent of the federal poverty level shall pay for thirty-three percent of the family child care costs.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A family with an income at or above two hundred thirty-five percent of the federal poverty level but less than two hundred forty-five percent of the federal poverty level shall pay for forty-five percent of the family child care costs.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A family with an income at or above two hundred forty-five percent of the federal poverty level but at or less than two hundred fifty percent of the federal poverty level shall pay for sixty percent of the family child care costs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A family with an income at the following percentages of the federal poverty level applicable to the family size for children needing special needs care shall be responsible for the following share of child care costs:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A family with an income above two hundred twenty-five percent of the federal poverty level but less than two hundred forty-five percent of the federal poverty level shall pay for thirty-three percent of the family child care costs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A family with an income at or above two hundred forty-five percent of the federal poverty level but less than two hundred sixty-five percent of the federal poverty level shall pay for forty-five percent of the family child care costs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A family with an income at or above two hundred sixty-five percent of the federal poverty level but at or less than two hundred seventy-five percent of the federal poverty level shall pay for sixty percent of the family child care costs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The graduated eligibility phase-out as provided in paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall be implemented no later than July 1, 2022.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Child care provider reimbursement rates under the graduated eligibility phase-out program shall be the same rates as the child care provider reimbursement rates.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ in accordance with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2021 Acts, ch 174, \'a741}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 178, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7746}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{237A.15 through 237A.18}}}{Reserved.}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{237A.19}}}{\*\bkmkstart stylerid1_2E22_2E2_2E2}{\*\bkmkend stylerid1_2E22_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Penalty.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who establishes, conducts, manages, or operates a center without a license commits a serious misdemeanor. Each day of continuing violation after conviction, or notice from the department by certified mail of the violation, shall be considered a separate offense.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If registration is required under }}}{{\f5\fs18\hyphpar0\qj{section 237A.3A}}}{{\f5\fs18\hyphpar0\qj{, a person who establishes, conducts, manages, or operates a child development home without registering or a person who operates a child development home contrary to }}}{{\f5\fs18\hyphpar0\qj{section 237A.5}}}{{\f5\fs18\hyphpar0\qj{, commits a simple misdemeanor. Each day of continuing violation after conviction, or notice from the department by certified mail of the violation, is a separate offense. A single charge alleging continuing violation may be made in lieu of filing charges for each day of violation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who establishes, conducts, manages, or operates a child care home in violation of }}}{{\f5\fs18\hyphpar0\qj{section 237A.3, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, or a person or program that has been prohibited by the department from involvement with child care but continues that involvement commits a simple misdemeanor. Each day of continuing violation after conviction, or notice from the department by certified mail of the violation, is a separate offense. A single charge alleging continuing violation may be made in lieu of filing charges for each day of violation.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7237A.19}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1213, \'a75}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 184, \'a72}}}{; }{{\f5\fs18\hyphpar0\qj{99 Acts, ch 192, \'a717}}}{; }{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1142, \'a719, 31}}}{; }{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 81, \'a79}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7237A.3}}}{{\f5\fs12\hyphpar0\qj{, 237A.5}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{237A.20}}}{\*\bkmkstart stylerid1_2E23_2E2_2E2}{\*\bkmkend stylerid1_2E23_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Injunction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A person who establishes, conducts, manages, or operates a center without a license or a child development home without a certificate of registration, if registration is required under }{{\f5\fs18\hyphpar0\qj{section 237A.3A}}}{, may be restrained by temporary or permanent injunction. A person who has been convicted of a crime against a person, a person with a record of founded child abuse, or a person who has been prohibited by the department from involvement with child care may be restrained by temporary or permanent injunction from providing unregistered, registered, or licensed child care or from other involvement with child care. The action may be instituted by the state, the county attorney, a political subdivision of the state, or an interested person.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7237A.20}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 153, \'a77}}}{; }{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1248, \'a72}}}{; }{{\f5\fs18\hyphpar0\qj{99 Acts, ch 192, \'a718}}}{; }{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1142, \'a720, 31}}}{; }{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 81, \'a710}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7237A.3}}}{{\f5\fs12\hyphpar0\qj{, 237A.5}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{237A.21 and 237A.22}}}{Repealed by }{{\f5\fs18\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2010/CH1031.pdf" }{\fldrslt \f5 \fs18{{2010 Acts, ch 1031, \'a7360, 361}}}}}}{{\f5\fs18\qj{2010 Acts, ch 1031, \'a7360, 361}}}{.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{237A.23}}}{\*\bkmkstart stylerid1_2E25_2E2_2E2}{\*\bkmkend stylerid1_2E25_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Child care training and development system.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2024 Acts, ch 1170, \'a7368}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\sb0\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{237A.24}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{237A.25}}}{\*\bkmkstart stylerid1_2E27_2E2_2E2}{\*\bkmkend stylerid1_2E27_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Consumer information.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall develop consumer information material to assist parents in selecting a child care provider. In developing the material, the department shall consult with department staff, department of education staff, the early childhood Iowa state board, and child care resource and referral services. In addition, the department may consult with other entities at the local, state, and national level.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The consumer information material developed by the department for parents and other consumers of child care services shall include but is not limited to all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A pamphlet or other printed material containing consumer-oriented information on locating a quality child care provider.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Information explaining important considerations a consumer should take into account in selecting a licensed or registered child care provider.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Information explaining how a consumer can identify quality services, including what questions to ask of providers and what a consumer might expect or demand to know before selecting a provider.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An explanation of the applicable laws and regulations written in layperson\u8217\'3fs terms.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An explanation of what it means for a provider to be licensed, registered, or unregistered.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An explanation of the information considered in registry and record background checks.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Other information deemed relevant to consumers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall implement and publicize an internet page or site that provides all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The written information developed pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsections 1 and 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Regular informational updates, including when a child care provider was last subject to a state quality review or inspection and, based upon a final score or review, the results indicating whether the provider passed or failed the review or inspection.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Capability for a consumer to be able to access information concerning child care providers, such as informational updates, identification of provider location, name, and capacity, and identification of providers participating in the state child care assistance program and those participating in the child care food program, by sorting the information or employing other means that provide the information in a manner that is useful to the consumer. Information regarding provider location shall identify providers located in the vicinity of an address selected by a consumer and provide contact information without listing the specific addresses of the providers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Other information deemed appropriate by the department.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2003 Acts, 1st Ex, ch 2, \'a718, 209}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1031, \'a7357, 361}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 29, \'a757}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7748}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1170, \'a7281}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7237A.4A}}}{{\f5\fs12\hyphpar0\qj{, 237A.30}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{237A.26}}}{\*\bkmkstart stylerid1_2E28_2E2_2E2}{\*\bkmkend stylerid1_2E28_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Statewide resource and referral services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall administer the funding for a statewide grant program for child care resource and referral services. Grants shall only be awarded to community-based nonprofit incorporated agencies and public agencies. Grants shall be awarded to facilitate the establishment of regional resource and referral agencies throughout the state, based upon the distribution of the child population in the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall provide oversight of and annually evaluate an agency which is awarded a grant to provide resource and referral services to a region.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An agency which receives a grant to provide resource and referral services shall perform both of the following functions:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Organize assistance to child care homes and child care facilities utilizing training levels based upon the child care providers\u8217\'3f degrees of experience and interest.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Operate in partnership with both public and private interests and coordinate resource and referral services with existing community services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An agency may be required by the department to match the grant with financial resources of not more than twenty-five percent of the amount of the grant. The financial resources may include a private donation, an in-kind contribution, or a public funding source other than a separate state grant for child care service improvement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An agency, to be eligible to receive a grant to provide resource and referral services, must have a board of directors if the agency is an incorporated nonprofit agency or must have an advisory board if the agency is a public agency, to oversee the provision of resource and referral services. The board shall include providers, consumers, and other persons interested in the provision or delivery of child care services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An agency which receives a child care resource and referral grant may be awarded funding to provide various child care-related services, which may include but are not limited to any of the following services:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Assist families in selecting quality child care. The agency must provide referrals to registered and licensed child care facilities, and to persons providing care, supervision, and guidance of a child which is not defined as child care under }}}{{\f5\fs18\hyphpar0\qj{section 237A.1}}}{{\f5\fs18\hyphpar0\qj{ and may provide referrals to unregistered providers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Assist child care providers in adopting appropriate program and business practices to provide quality child care services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide information to the public regarding the availability of child care services in the communities within the agency\u8217\'3fs region.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Actively encourage the development of new and expansion of existing child care facilities in response to identified community needs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide specialized services to employers, including the provision of resource and referral services to employee groups identified by the employer and the provision of technical assistance to develop employer-supported child care programs. The specialized services may include but are not limited to working with employers to identify networks of recommended registered and licensed child care providers for employee groups and to implement employer-supported quality improvement initiatives among the network providers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Refer eligible child care facilities to the federal child care food programs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Loan toys, other equipment, and resource materials to child care facilities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department may contract with an agency receiving a child care resource and referral grant to perform any of the following functions relating to publicly funded services providing care, supervision, and guidance of a child:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Determine an individual\u8217\'3fs eligibility for the services in accordance with income requirements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Administer a voucher, certificate, or other system for reimbursing an eligible provider of the services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of improving the quality and consistency of data collection, consultation, and other support to child care home and child development home providers, a resource and referral services agency grantee shall coordinate and assist with publicly and privately funded efforts administered at the community level to provide the support. The support and efforts addressed by a grantee may include but are not limited to community-funded child care home and child development home consultants. Community members involved with the assistance may include but are not limited to the efforts of an early childhood Iowa area board under }}}{{\f5\fs18\hyphpar0\qj{chapter 256I}}}{{\f5\fs18\hyphpar0\qj{, and of community representatives of education, health, human services, business, faith, and public interests.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1248, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1083, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 192, \'a722}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1142, \'a723 \u8211\'3f 26, 31}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1031, \'a7301}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 98, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7237A.30}}}{{\f5\fs12\hyphpar0\qj{, 256C.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{237A.27}}}{\*\bkmkstart stylerid1_2E29_2E2_2E2}{\*\bkmkend stylerid1_2E29_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Crisis child care.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2002/CH1142.pdf" }{\fldrslt \cf5 \f5 \fs18{{2002 Acts, ch 1142, \'a729, 31}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{237A.28}}}{\*\bkmkstart stylerid1_2E3_30_2E2_2E2}{\*\bkmkend stylerid1_2E3_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Child care credit fund.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2009/CH0182.pdf" }{\fldrslt \cf5 \f5 \fs18{{2009 Acts, ch 182, \'a7138}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{237A.29}}}{\*\bkmkstart stylerid1_2E31_2E2_2E2}{\*\bkmkend stylerid1_2E31_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Public funding of child care \u8212\'3f sanctions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{State funds and federal funds provided to the state in accordance with federal requirements shall not be used to pay for the care, supervision, and guidance of a child for periods of less than twenty-four hours per day on a regular basis unless the care, supervision, and guidance is defined as child care as used in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ffraudulent means\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means knowingly making or causing to be made a false statement or a misrepresentation of a material fact, knowingly failing to disclose a material fact, or committing a fraudulent practice.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A child care provider that has been found by the department of inspections, appeals, and licensing in an administrative proceeding or in a judicial proceeding to have obtained, or has agreed to entry of a civil judgment or judgment by confession that includes a conclusion of law that the child care provider has obtained, by fraudulent means, public funding for provision of child care in an amount equal to or in excess of the minimum amount for a fraudulent practice in the second degree under }}}{{\f5\fs18\hyphpar0\qj{section 714.10, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, shall be subject to sanction in accordance with }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. Such child care provider shall be subject to a period during which receipt of public funding for provision of child care is conditioned upon no further violations and to one or more of the following sanctions as determined by the department:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Ineligibility to receive public funding for provision of child care.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Suspension from receipt of public funding for provision of child care.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Special review of the child care provider\u8217\'3fs claims for providing publicly funded child care.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The following factors shall be considered in determining the sanction or sanctions to be imposed under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraphs (1) through (3):}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Seriousness of the violation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Extent of the violation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{History of prior violations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prior imposition of sanctions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prior provision of provider education.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provider willingness to obey program rules.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(7)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Whether a lesser sanction will be sufficient to remedy the problem.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In determining the value of the public funding obtained by fraudulent means, if the public funding is obtained by two or more acts of fraudulent means by the same person or in the same location, or is obtained by different persons by two or more acts which occur in approximately the same location or time period so that the acts of fraudulent means used to obtain the public funding are attributable to a single scheme, plan, or conspiracy, these acts may be considered as a single instance of the use of fraudulent means and the value may be the total value of all moneys involved.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a child care provider is subject to sanctions under }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, within five business days of the date the sanctions are imposed, the provider shall submit to the department the names and addresses of children receiving child care from the provider. The department shall send information to the parents of the children regarding the provider\u8217\'3fs actions leading to the imposition of the sanctions and the nature of the sanctions imposed.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the child care provider fails to submit the names and addresses within the time period required by paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the department shall request that the attorney general file a petition with the district court of the county in which the provider is located for issuance of a temporary injunction enjoining the provider from providing child care until the names and addresses are submitted to the department. The attorney general may file the petition upon receiving the request from the department. Any temporary injunction may be granted without a bond being required from the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the sanctions imposed under }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ involve the provider\u8217\'3fs suspension or ineligibility for receiving public funding for provision of child care, the department shall not impose those sanctions before the parents of the affected children are informed, and upon request, shall provide assistance to the parents in locating replacement child care.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{93 Acts, ch 76, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 192, \'a725}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1104, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 44, \'a755}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 81, \'a711, 12}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1086, \'a744}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 30, \'a7241}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7749, 1953}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{237A.30}}}{\*\bkmkstart stylerid1_2E32_2E2_2E2}{\*\bkmkend stylerid1_2E32_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Voluntary child care quality rating system.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall work with the early childhood Iowa program established in }}}{{\f5\fs18\hyphpar0\qj{section 256I.5}}}{{\f5\fs18\hyphpar0\qj{ in designing and implementing a voluntary quality rating system for each provider type of child care facility.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The criteria utilized for the rating system may include but are not limited to any of the following:}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Facility type.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provider staff experience, education, training, and credentials. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Facility director education and training. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An environmental rating score or other direct assessment environmental methodology. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{National accreditation. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Facility history of compliance with law and rules.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Child-to-staff ratio.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Curriculum, including the extent to which the curriculum focuses on the stages of child development and on child outcomes. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Business practices.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Staff retention rates. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{k.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Evaluation of staff members and program practices. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{l.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Staff compensation and benefit practices. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{m.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provider and staff membership in professional early childhood organizations. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{n.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Parental involvement with the facility.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A facility\u8217\'3fs quality rating may be included on the internet site and in the consumer information provided by the department pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 237A.25}}}{{\f5\fs18\hyphpar0\qj{ and shall be identified in the child care provider referrals made by child care resource and referral service grantees under }}}{{\f5\fs18\hyphpar0\qj{section 237A.26}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{99 Acts, ch 192, \'a733}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 203, \'a749}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1142, \'a727, 28, 31}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 148, \'a720}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1010, \'a776}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1031, \'a7302, 358, 361}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 90, \'a7257}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 30, \'a785, 205, 208}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 24, \'a728}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7750}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1170, \'a7282}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{237A.31}}}{\*\bkmkstart stylerid1_2E33_2E2_2E2}{\*\bkmkend stylerid1_2E33_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Employer child care tax credit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The taxes imposed under }}}{{\f5\fs18\hyphpar0\qj{chapter 422, subchapter II or III}}}{{\f5\fs18\hyphpar0\qj{, the franchise tax imposed under }}}{{\f5\fs18\hyphpar0\qj{chapter 422, subchapter V}}}{{\f5\fs18\hyphpar0\qj{, the gross premiums tax under }}}{{\f5\fs18\hyphpar0\qj{chapter 432}}}{{\f5\fs18\hyphpar0\qj{, or the moneys and credits tax imposed under }}}{{\f5\fs18\hyphpar0\qj{section 533.329}}}{{\f5\fs18\hyphpar0\qj{ shall be reduced by an employer child care tax credit through the tax year beginning on or after January 1, 2025, but before January 1, 2026, equal to the proportion of the federal employer-provided child care tax credit provided in }}}{{\f5\fs18\hyphpar0\qj{section 45F of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{ the taxpayer was eligible for in the same tax year attributable to expenditures made in this state. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any credit in excess of the tax liability is not refundable but the excess for the tax year may be credited to the tax liability for the following five years or until depleted, whichever is earlier.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The aggregate amount of tax credits authorized pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not exceed an aggregate limit of two million dollars annually.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To receive a tax credit, a taxpayer must submit an application to the economic development authority in the form and manner prescribed by the authority by rule. The economic development authority shall issue certificates under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ on a first-come, first-served basis, which certificates may be redeemed for tax credits. The economic development authority shall issue such certificates so that not more than the amount authorized for such tax credits under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ may be claimed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of revenue, in consultation with the economic development authority, shall adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ to administer }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ is repealed January 1, 2031.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2022 Acts, ch 1148, \'a722, 28}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 5, \'a75 \u8211\'3f 7}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 136, \'a780, 81}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7422.12O}}}{{\f5\fs12\hyphpar0\qj{, 422.33}}}{{\f5\fs12\hyphpar0\qj{, 422.60}}}{{\f5\fs12\hyphpar0\qj{, 432.12O}}}{{\f5\fs12\hyphpar0\qj{, 533.329}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section applies to tax years beginning on or after January 1, 2023; }{{\f5\fs12\hyphpar0\qj{2022 Acts, ch 1148, \'a728}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2023 amendment to subsection 1 applies retroactively to January 1, 2023, for tax years beginning on or after that date; }{{\f5\fs12\hyphpar0\qj{2023 Acts, ch 5, \'a77}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 1 amended}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{NEW subsection 5}\par}}