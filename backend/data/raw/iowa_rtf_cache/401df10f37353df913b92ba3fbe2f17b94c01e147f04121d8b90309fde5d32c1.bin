.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(9)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The offense is a violation of }}}{{\f5\fs18\hyphpar0\qj{section 710A.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon a showing that the defendant is not fulfilling the conditions of probation, the court may revoke probation and impose any sentence authorized by law. Before taking such action, the court shall give the defendant an opportunity to be heard on any matter relevant to the proposed action. Upon violation of the conditions of probation, the court may proceed as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 908}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{By record entry at the time of or after sentencing, the court may suspend the sentence and place the defendant on probation upon such terms and conditions as it may require including commitment to an alternate jail facility or a community correctional residential treatment facility to be followed by a period of probation as specified in }}}{{\f5\fs18\hyphpar0\qj{section 907.7}}}{{\f5\fs18\hyphpar0\qj{, or commitment of the defendant to the judicial district department of correctional services for supervision or services under }}}{{\f5\fs18\hyphpar0\qj{section 901B.1}}}{{\f5\fs18\hyphpar0\qj{ at the level of sanctions which the district department determines to be appropriate and the payment of fees imposed under }}}{{\f5\fs18\hyphpar0\qj{section 904.912}}}{{\f5\fs18\hyphpar0\qj{. A person so committed who has probation revoked shall not be given credit for such time served. However, a person committed to an alternate jail facility or a community correctional residential treatment facility who has probation revoked shall be given credit for time served in the facility. The court shall not suspend any of the following sentences:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The minimum term of two days imposed pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 708.2A, subsection 7}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, or a sentence imposed under }}}{{\f5\fs18\hyphpar0\qj{section 708.2A, subsection 7}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A sentence imposed pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 664A.7}}}{{\f5\fs18\hyphpar0\qj{ for contempt.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A mandatory minimum sentence of incarceration imposed pursuant to a violation of }}}{{\f5\fs18\hyphpar0\qj{section 321J.2, subsection 1}}}{{\f5\fs18\hyphpar0\qj{; furthermore, the court shall not suspend any part of a sentence not involving incarceration imposed pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321J.2, subsection 3, 4, or 5}}}{{\f5\fs18\hyphpar0\qj{, beyond the mandatory minimum if any of the following apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the defendant\u8217\'3fs alcohol concentration established by the results of an analysis of a specimen of the defendant\u8217\'3fs blood, breath, or urine withdrawn in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapter 321J}}}{{\f5\fs18\hyphpar0\qj{ exceeds .15, regardless of whether or not the alcohol concentration indicated by the chemical test minus the established margin of error inherent in the device or method used to conduct the test equals an alcohol concentration of .15 or more.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the defendant has previously been convicted of a violation of }}}{{\f5\fs18\hyphpar0\qj{section 321J.2, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, or a violation of a statute in another state substantially corresponding to }}}{{\f5\fs18\hyphpar0\qj{section 321J.2, subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the defendant has previously received a deferred judgment or sentence for a violation of }}}{{\f5\fs18\hyphpar0\qj{section 321J.2, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, or for a violation of a statute in another state substantially corresponding to }}}{{\f5\fs18\hyphpar0\qj{section 321J.2, subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the defendant refused to consent to testing requested in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 321J.6}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the offense under }}}{{\f5\fs18\hyphpar0\qj{chapter 321J}}}{{\f5\fs18\hyphpar0\qj{ results in bodily injury to a person other than the defendant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A sentence imposed pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 707.6A, subsection 1}}}{{\f5\fs18\hyphpar0\qj{; or }}}{{\f5\fs18\hyphpar0\qj{section 707.6A, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, involving operation of a motor vehicle while intoxicated.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The offense is a violation of }}}{{\f5\fs18\hyphpar0\qj{section 124.401, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and the controlled substance is methamphetamine.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A mandatory minimum sentence or fine imposed for a violation of }}}{{\f5\fs18\hyphpar0\qj{section 462A.14}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The sentence imposed under }}}{{\f5\fs18\hyphpar0\qj{section 902.13}}}{{\f5\fs18\hyphpar0\qj{ for a violation referred to in }}}{{\f5\fs18\hyphpar0\qj{section 708.2A, subsection 4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A sentence imposed pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 710A.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a75447-a; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{3800;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7247.20; C75, 77, \'a7789A.1; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7907.3}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 206, \'a717}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1167, \'a728}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1220, \'a745}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1168, \'a73, 4}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 296, \'a793}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 218, \'a730}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 219, \'a725, 26}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 157, \'a711, 12}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 180, \'a716, 17}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1131, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1193, \'a717 \u8211\'3f 19}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 177, \'a731 \u8211\'3f 33}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 189, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 190, \'a78, 9}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1138, \'a76 \u8211\'3f 9, 29 \u8211\'3f 31, 37}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 182, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1099, \'a711 \u8211\'3f 13}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1201, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 165, \'a77 \u8211\'3f 9}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1050, \'a756, 57}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 156, \'a717 \u8211\'3f 19}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 143, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1101, \'a717 \u8211\'3f 19}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 119, \'a761, 62}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1193, \'a770, 81}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 34, \'a7155}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1138, \'a791 \u8211\'3f 93}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 90, \'a7214}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 83, \'a710 \u8211\'3f 12}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1028, \'a73, 4}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 42, \'a79, 10}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 74, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 87, \'a72 \u8211\'3f 4}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1020, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1182, \'a787, 88}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.218}}}{{\f5\fs12\hyphpar0\qj{, 321J.2}}}{{\f5\fs12\hyphpar0\qj{, 321J.4}}}{{\f5\fs12\hyphpar0\qj{, 462A.14}}}{{\f5\fs12\hyphpar0\qj{, 692A.111}}}{{\f5\fs12\hyphpar0\qj{, 707.6A}}}{{\f5\fs12\hyphpar0\qj{, 708.2A}}}{{\f5\fs12\hyphpar0\qj{, 708.2D}}}{{\f5\fs12\hyphpar0\qj{, 708.11}}}{{\f5\fs12\hyphpar0\qj{, 711.3B}}}{{\f5\fs12\hyphpar0\qj{, 726.24}}}{{\f5\fs12\hyphpar0\qj{, 726.25}}}{{\f5\fs12\hyphpar0\qj{, 901.5}}}{{\f5\fs12\hyphpar0\qj{, 901B.1}}}{{\f5\fs12\hyphpar0\qj{, 903A.5}}}{{\f5\fs12\hyphpar0\qj{, 907.3A}}}{{\f5\fs12\hyphpar0\qj{, 907.4}}}{{\f5\fs12\hyphpar0\qj{, 907.9}}}{{\f5\fs12\hyphpar0\qj{, 907.10}}}{{\f5\fs12\hyphpar0\qj{, 907.14}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Definition of forcible felony, }{{\f5\fs12\hyphpar0\qj{\'a7702.11}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For bail after deferred judgment, see }{{\f5\fs12\hyphpar0\qj{\'a7811.2}}}{, }{{\f5\fs12\hyphpar0\qj{811.11}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{907.3A}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Youthful offender status.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 907.3}}}{{\f5\fs18\hyphpar0\qj{ but subject to any conditions of the waiver order, the trial court shall, upon a plea of guilty or a verdict of guilty, place the juvenile over whom the juvenile court has waived jurisdiction pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 232.45, subsection 7}}}{{\f5\fs18\hyphpar0\qj{, on youthful offender status. The court shall transfer supervision of the youthful offender to the juvenile court for disposition in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 232.52}}}{{\f5\fs18\hyphpar0\qj{. An adjudication of delinquency entered by the juvenile court at disposition for a public offense shall not be deemed a conviction and shall not preclude the subsequent entry of a deferred judgment or sentence, conviction, or sentence by the district court. The court shall require supervision of the youthful offender in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 232.54, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fh\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court shall hold a hearing prior to a youthful offender\u8217\'3fs eighteenth birthday to determine whether the youthful offender shall continue on youthful offender status after the youthful offender\u8217\'3fs eighteenth birthday. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 901.2}}}{{\f5\fs18\hyphpar0\qj{, the court may order a presentence investigation report including a report for an offense classified as a class \u8220\'3fA\u8221\'3f felony. The court shall review the report of the juvenile court regarding the youthful offender prepared pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 232.56}}}{{\f5\fs18\hyphpar0\qj{, and any presentence investigation report, if ordered by the court. The court shall hear evidence by or on behalf of the youthful offender, by the county attorney, and by the person or agency to which custody of the youthful offender was transferred. The court shall make its decision, pursuant to the judgment and sentencing options available in }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{, after considering the services available to the youthful offender, the evidence presented, the juvenile court\u8217\'3fs report, the presentence investigation report if ordered by the court, the interests of the youthful offender, and interests of the community.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any provision of the Code which prescribes a mandatory minimum sentence for the offense committed by the youthful offender, following transfer of the youthful offender from the juvenile court back to the court having jurisdiction over the criminal proceedings involving the youthful offender, the court shall order one of the following sentencing options: }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Defer judgment and place the youthful offender on probation, upon the consent of the youthful offender.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Defer the sentence and place the youthful offender on probation upon such terms and conditions as the court may require.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Suspend the sentence and place the youthful offender on probation upon such terms and conditions as the court may require.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A term of confinement as prescribed by law for the offense.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Discharge the youthful offender from youthful offender status and terminate the sentence.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding anything in }}}{{\f5\fs18\hyphpar0\qj{section 907.7}}}{{\f5\fs18\hyphpar0\qj{ to the contrary, if the district court grants the youthful offender a deferred judgment, continues the youthful offender deferred sentence, or enters a sentence and suspends the sentence, and places the youthful offender on probation, the term of formal supervision shall commence upon entry of the order by the district court and may continue for a period not to exceed five years. If the district court enters a sentence of confinement, and the youthful offender was previously placed in secure confinement by the juvenile court under the terms of the initial disposition order or any modification to the initial disposition order, the person shall receive credit for any time spent in secure confinement. During any period of probation imposed by the district court, a youthful offender who violates the terms of probation is subject to }}}{{\f5\fs18\hyphpar0\qj{section 908.11}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 126, \'a751}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 41, \'a7262}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 42, \'a715}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.8}}}{{\f5\fs12\hyphpar0\qj{, 232.45}}}{{\f5\fs12\hyphpar0\qj{, 232.50}}}{{\f5\fs12\hyphpar0\qj{, 232.52}}}{{\f5\fs12\hyphpar0\qj{, 232.54}}}{{\f5\fs12\hyphpar0\qj{, 232.55}}}{{\f5\fs12\hyphpar0\qj{, 232.56}}}{{\f5\fs12\hyphpar0\qj{, 232.149B}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{907.4}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Deferred judgment docket.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A deferment of judgment under }}}{{\f5\fs18\hyphpar0\qj{section 907.3}}}{{\f5\fs18\hyphpar0\qj{ shall be entered promptly by the clerk of the district court, or the clerk\u8217\'3fs designee, into the deferred judgment database of the state, which shall serve as the deferred judgment docket. The deferred judgment docket shall be maintained by the state court administrator and shall not be destroyed. The docket shall contain a permanent record of the deferred judgment including the name and date of birth of the defendant, the district court docket number, the nature of the offense, and the date of the deferred judgment. Before granting deferred judgment in any case, the court shall search the deferred judgment docket and shall consider any prior record of a deferred judgment against the defendant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The permanent record provided for in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is a confidential record exempted from public access under }}}{{\f5\fs18\hyphpar0\qj{section 22.7}}}{{\f5\fs18\hyphpar0\qj{ and shall be available only to justices of the supreme court, judges of the court of appeals, district judges, district associate judges, judicial magistrates, clerks of the district court, judicial district departments of correctional services, county attorneys, the department of public safety, and the department of corrections requesting information pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, or the designee of a justice, judge, magistrate, clerk, judicial district department of correctional services, or county attorney, or departments.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, \'a7789A.1; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7907.4}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1292, \'a720}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 197, \'a744}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1168, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 128, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 151, \'a761}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{; }{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts//CH0000.pdf" }{\fldrslt \f5 \fs18{{\f5\fs18\hyphpar0\qj\cf5{2003 Acts, 1st Ex, ch 2, \'a760, 209}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 95, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1054, \'a72, 4}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7602.8102(135)}}}{{\f5\fs12\hyphpar0\qj{, 901C.2}}}{{\f5\fs12\hyphpar0\qj{, 907.9}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{907.5}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Standards for release on probation }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ written reasons.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Before deferring judgment, deferring sentence, or suspending sentence, the court first shall determine which option, if available, will provide maximum opportunity for the rehabilitation of the defendant and protection of the community from further offenses by the defendant and others. In making this determination, the court shall consider all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The age of the defendant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The defendant\u8217\'3fs prior record of convictions and prior record of deferments of judgment if any.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The defendant\u8217\'3fs employment circumstances.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The defendant\u8217\'3fs family circumstances.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The defendant\u8217\'3fs mental health and substance use disorder history and treatment options available in the community and the correctional system.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The nature of the offense committed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Such other factors as are appropriate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court shall file a specific written statement of its reasons for and the facts supporting its decision to defer judgment, to defer sentence, or to suspend sentence, and its decision on the length of probation.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, \'a7789A.1(2); C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7907.5}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2011 Acts, ch 7, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1021, \'a7118}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71342}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{907.6}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Conditions of probation \u8212\'3f regulations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Probationers are subject to the conditions established by the judicial district department of correctional services subject to the approval of the court, and any additional reasonable conditions which the court or district department may impose to promote rehabilitation of the defendant or protection of the community. Conditions may include but are not limited to adherence to regulations generally applicable to persons released on parole and including requiring unpaid community service as allowed pursuant to }{{\f5\fs18\hyphpar0\qj{section 907.13}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7907.6}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1069, \'a73}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 39, \'a72}}}{; }{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1193, \'a720}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321J.2}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{907.7}}}{\*\bkmkstart stylerid1_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Length of probation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The length of the probation shall be for a period as the court shall fix but not to exceed five years if the offense is a felony or not to exceed two years if the offense is a misdemeanor. The period of probation may be extended for up to one year including one year beyond the maximum period as provided in }}}{{\f5\fs18\hyphpar0\qj{section 908.11}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The length of the probation shall not be less than one year if the offense is a misdemeanor and shall not be less than two years if the offense is a felony.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court may subsequently reduce the length of the probation if the court determines that the purposes of probation have been fulfilled and the fees imposed under }}}{{\f5\fs18\hyphpar0\qj{section 904.912}}}{{\f5\fs18\hyphpar0\qj{ have been paid to or waived by the judicial district department of correctional services and that court debt collected pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 602.8107}}}{{\f5\fs18\hyphpar0\qj{ has been paid. The purposes of probation are to provide maximum opportunity for the rehabilitation of the defendant and to protect the community from further offenses by the defendant and others.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In determining the length of the probation, the court shall determine what period is most likely to provide maximum opportunity for the rehabilitation of the defendant, to allow enough time to determine whether or not rehabilitation has been successful, and to protect the community from further offenses by the defendant and others.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, \'a7247.20; C75, 77, \'a7789A.2; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7907.7}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 125, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 190, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1197, \'a75, 13}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1177, \'a74, 5}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1172, \'a727}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1175, \'a71, 4}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1182, \'a789}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7907.3}}}{{\f5\fs12\hyphpar0\qj{, 907.3A}}}{{\f5\fs12\hyphpar0\qj{, 908.11}}}{{\f5\fs12\hyphpar0\qj{, 910.4}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{907.8}}}{\*\bkmkstart stylerid1_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Supervision during probationary period.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person released on probation shall be assigned to a probation officer. Both the person and the person\u8217\'3fs probation officer shall be furnished with the conditions of the person\u8217\'3fs probation including a copy of the plan of restitution and the restitution plan of payment, if any, and the regulations which the person will be required to observe, in writing. The probation officer shall explain these conditions and regulations to the person and shall supervise, assist, and counsel the person during the term of the person\u8217\'3fs probation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When probation is granted, the court shall order said person committed to the custody, care, and supervision:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Of any suitable resident of this state; or}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Of the judicial district department of correctional services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Jurisdiction over these persons shall remain with the sentencing court.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In each case in which the court orders the person committed to the custody, care, and supervision of the judicial district department of correctional services, the clerk of the district court shall at once furnish the director of the judicial district department of correctional services with certified copies of the indictment or information, the minutes of testimony attached thereto, the judgment entry if judgment is not deferred, and the original mittimus. The county attorney shall at once advise the director, by letter, that the defendant has been placed under the supervision of the judicial district department of correctional services and give the director a detailed statement of the facts and circumstances surrounding the crime committed and the record and history of the defendant as may be known to the county attorney. If the defendant is confined in the county jail at the time of sentence, the court may order the defendant held until arrangements are made by the judicial district department of correctional services for the defendant\u8217\'3fs employment and the defendant has signed the necessary probation papers. If the defendant is not confined in the county jail at the time of sentence, the court may order the defendant to remain in the county wherein the defendant has been convicted and sentenced and report to the sheriff as to the defendant\u8217\'3fs whereabouts.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a75447-a; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{3801;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7247.21; C75, 77, \'a7789A.7; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7907.8}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1162, \'a712, 14}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 125, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1197, \'a76, 13}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1177, \'a74, 5}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 90, \'a7215}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.756(70)}}}{{\f5\fs12\hyphpar0\qj{, 602.8102(135)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{907.8A}}}{\*\bkmkstart stylerid1_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Sixth judicial district }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ determination of issues during probationary period.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/1998/CH1197.pdf" }{\fldrslt \cf5 \f5 \fs18{{98 Acts, ch 1197, \'a710, 13}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{; }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2000/CH1177.pdf" }{\fldrslt \cf5 \f5 \fs18{{2000 Acts, ch 1177, \'a74, 5}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{907.9}}}{\*\bkmkstart stylerid1_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Discharge from probation }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ procedure }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ expungement of deferred judgments.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At any time that the court determines that the purposes of probation have been fulfilled and fees imposed under }}}{{\f5\fs18\hyphpar0\qj{section 904.912}}}{{\f5\fs18\hyphpar0\qj{ and court debt collected pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 602.8107}}}{{\f5\fs18\hyphpar0\qj{ have been paid, the court may order the discharge of a person from probation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At any time that a probation officer determines that the purposes of probation have been fulfilled and fees imposed under }}}{{\f5\fs18\hyphpar0\qj{section 904.912}}}{{\f5\fs18\hyphpar0\qj{ and court debt collected pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 602.8107}}}{{\f5\fs18\hyphpar0\qj{ have been paid, the officer may order the discharge of a person from probation after approval of the district director and notification of the sentencing court and the county attorney who prosecuted the case.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The sentencing judge may order a hearing on its own motion, or shall order a hearing upon the request of the county attorney, for review of such discharge. If the sentencing judge is no longer serving or unable to order such hearing, the chief judge of the district or the chief judge\u8217\'3fs designee shall order any hearing pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. Following the hearing, the court shall approve or rescind such discharge. If a hearing is not ordered within thirty days after notification by the probation officer, the person shall be discharged and the probation officer shall notify the state court administrator of such discharge.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At the expiration of the period of probation if the fees imposed under }}}{{\f5\fs18\hyphpar0\qj{section 904.912}}}{{\f5\fs18\hyphpar0\qj{ and court debt collected pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 602.8107}}}{{\f5\fs18\hyphpar0\qj{ have been paid, the court shall order the discharge of the person from probation. If portions of the court debt remain unpaid, the person shall establish a payment plan with the clerk of the district court or the county attorney prior to the discharge. The court shall forward to the governor a recommendation for or against restoration of citizenship rights to that person upon discharge. A person who has been discharged from probation shall no longer be held to answer for the person\u8217\'3fs offense. }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon discharge from probation, if judgment has been deferred under }}}{{\f5\fs18\hyphpar0\qj{section 907.3}}}{{\f5\fs18\hyphpar0\qj{, the court\u8217\'3fs criminal record with reference to the deferred judgment, any counts dismissed by the court, which were contained in the indictment, information, or complaint that resulted in the deferred judgment, and any other related charges that were not contained in the indictment, information, or complaint but were dismissed, shall be expunged. However, the court\u8217\'3fs record shall not be expunged until the person has paid the restitution, civil penalties, court costs, fees, or other financial obligations ordered by the court or assessed by the clerk of the district court in the case that includes the deferred judgment. The expunged record is a confidential record exempt from public access under }}}{{\f5\fs18\hyphpar0\qj{section 22.7}}}{{\f5\fs18\hyphpar0\qj{ but shall be made available by the clerk of the district court, upon request and without court order, to an agency or person granted access to the deferred judgment docket under }}}{{\f5\fs18\hyphpar0\qj{section 907.4, subsection 2}}}{{\f5\fs18\hyphpar0\qj{. The court\u8217\'3fs record shall not be expunged in any other circumstances unless authorized by law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A dismissed count or related charge shall be expunged pursuant to the provisions of paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ in the following manner:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A count which was contained in the indictment, information, or complaint that resulted in the deferred judgment shall be expunged when the deferred judgment is expunged.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A related charge that was not contained in the indictment, information, or complaint that resulted in the deferred judgment shall only be expunged upon a court order that identifies the related charge to be expunged.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A count or related charge that was dismissed shall not be expunged pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ in any case in which a count or charge resulted in a conviction, not including a finding of contempt, that was not expunged.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The provisions of paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ apply whether the deferred judgment was expunged prior to July 1, 2012, or on or after July 1, 2012. The provisions of paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ apply whether the deferred judgment was expunged prior to July 1, 2016, or on or after July 1, 2016.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The provisions of paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ that require payment of financial obligations as a condition for expungement of a deferred judgment apply to any deferred judgment that has not been expunged prior to July 1, 2012.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, a charge or count is related to another charge or count if the charge or count arose from the same transaction or occurrence or from two or more transactions or occurrences constituting parts of a common scheme or plan.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A probation officer or the director of the judicial district department of correctional services who acts in compliance with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is acting in the course of the person\u8217\'3fs official duty and is not personally liable, either civilly or criminally, for the acts of a person discharged from probation by the officer after such discharge, unless the discharge constitutes willful disregard of the person\u8217\'3fs duty.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a75447-a; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{3800;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7247.20; C75, 77, \'a7789A.6; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7907.9}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1168, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1251, \'a772}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 219, \'a727}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 125, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 190, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1197, \'a77, 13}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1177, \'a74, 5}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{; }{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2003/CH0002.pdf" }{\fldrslt \f5 \fs18{{\f5\fs18\hyphpar0\qj\cf5{2003 Acts, 1st Ex, ch 2, \'a761, 209}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1175, \'a7205}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1172, \'a728}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1054, \'a73, 4}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1058, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1182, \'a790, 91}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7901C.2}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{907.10}}}{\*\bkmkstart stylerid1_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Release on probation after completing program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{When the court has determined that any person ordered to participate in a locally administered correctional program, pursuant to }{{\f5\fs18\hyphpar0\qj{section 907.3, subsection 1}}}{, has successfully completed such program, the court shall order such person to be released on probation.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7907.10}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{907.11}}}{\*\bkmkstart stylerid1_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Maximum period of confinement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{In no case shall the total time served in confinement and in any locally administered correctional program exceed the maximum period of confinement authorized for the public offense of which the defendant stands convicted.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7907.11}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{907.12}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{907.13}}}{\*\bkmkstart stylerid1_2E19_2E2_2E2}{\*\bkmkend stylerid1_2E19_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Community service sentencing \u8212\'3f liability \u8212\'3f workers\u8217\'3f compensation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court may establish as a condition of probation that the defendant perform unpaid community service for a time not to exceed the maximum period of confinement for the offense of which the defendant is convicted. If this condition is established, the defendant in cooperation with the probation officer assigned to the defendant and in cooperation with the judicial district department of correctional services, shall promptly prepare a plan to implement the community service condition. The plan shall include but shall not be limited to the suggested placement of the defendant and the suggested number of hours of services to be required.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The defendant\u8217\'3fs plan of community service, the comments of the defendant\u8217\'3fs probation officer, and the comments of the representative of the judicial district department of correctional services responsible for the unpaid community service program, shall be submitted promptly to the court. The court shall promptly enter an order approving the plan or modifying it. Compliance with the plan of community service as approved or modified by the court shall be a condition of the defendant\u8217\'3fs probation. The court thereafter may modify the plan at any time upon the defendant\u8217\'3fs request, upon the request of the judicial district department of correctional services, or upon the court\u8217\'3fs own motion. As an option for modification of a plan, the court may allow a defendant to complete some part or all of the defendant\u8217\'3fs community service obligation through the donation of property to a charitable organization other than a governmental subdivision. A donation of property to a charitable organization offered in satisfaction of some part or all of a community service obligation under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ is not a deductible contribution for the purposes of federal or state income taxes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At any time during the probation period the defendant may request and the court shall grant a hearing on any matter related to the plan of community service.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Failure of the defendant to comply with }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ or to comply with the plan of community service as approved or modified by the court shall constitute a violation of the conditions of probation. Without limitation, the court may modify the plan of community service or modify the required hours of service, but not beyond the maximum hours of service specified in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state of Iowa is exclusively liable, according to and under }}}{{\f5\fs18\hyphpar0\qj{chapter 669}}}{{\f5\fs18\hyphpar0\qj{, for a tortious act committed by a defendant while performing unpaid community service.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state of Iowa is exclusively liable for and shall pay any compensation becoming due any person under }}}{{\f5\fs18\hyphpar0\qj{section 85.59}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1069, \'a74}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1280, \'a73}}}{; }{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1168, \'a77}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7462A.14}}}{{\f5\fs12\hyphpar0\qj{, 901.3}}}{{\f5\fs12\hyphpar0\qj{, 907.6}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Community service as restitution; see }{{\f5\fs12\hyphpar0\qj{\'a7909.3A, 910.2}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{907.14}}}{\*\bkmkstart stylerid1_2E2_30_2E2_2E2}{\*\bkmkend stylerid1_2E2_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Deferred judgment \u8212\'3f civil penalty \u8212\'3f distribution.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon the entry of a deferred judgment pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 907.3}}}{{\f5\fs18\hyphpar0\qj{, a defendant shall be assessed a civil penalty of an amount not less than the amount of any criminal fine authorized by law for the offense under }}}{{\f5\fs18\hyphpar0\qj{section 902.9}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{section 903.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The clerk of the district court shall collect and remit the civil penalty to the state court administrator for deposit in the general fund of the state as provided in }}}{{\f5\fs18\hyphpar0\qj{section 602.8108}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 143, \'a75}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321J.2}}}{{\f5\fs12\hyphpar0\qj{, 907.1}}}{{\f5\fs12\hyphpar0\qj{, 907.3}}}{{\f5\fs12\hyphpar0\qj{, 908.11}}}\par}}