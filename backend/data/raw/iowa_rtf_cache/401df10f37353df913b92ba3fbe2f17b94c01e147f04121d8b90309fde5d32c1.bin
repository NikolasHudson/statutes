\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F9_307}{\*\bkmkend codeChapter_5F9_307}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 907}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{DEFERRED JUDGMENT, DEFERRED OR SUSPENDED}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\ri0\li0\sa0\par}{\pard\plain\keep\f5\fs18\qc\fi0\ri0\li0{ SENTENCE, AND PROBATION}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a7216A.136}}}{{\f5\fs12\qc{, 232.54}}}{{\f5\fs12\qc{, 422.7(6)(a)}}}{{\f5\fs12\qc{, 422.7(7)(a)}}}{{\f5\fs12\qc{, 422.35}}}{{\f5\fs12\qc{, 901.1}}}{{\f5\fs12\qc{, 901.5}}}{{\f5\fs12\qc{, 901A.2}}}\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{907.1}}}{\*\bkmkstart stylerid1_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{As used in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, unless the context otherwise requires:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDeferred judgment\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a sentencing option whereby both the adjudication of guilt and the imposition of a sentence are deferred by the court and whereby the court assesses a civil penalty as provided in }}}{{\f5\fs18\hyphpar0\qj{section 907.14}}}{{\f5\fs18\hyphpar0\qj{ upon the entry of the deferred judgment. The court retains the power to pronounce judgment and impose sentence subject to the defendant\u8217\'3fs compliance with conditions set by the court as a requirement of the deferred judgment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDeferred sentence\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a sentencing option whereby the court enters an adjudication of guilt but does not impose a sentence. The court retains the power to sentence the defendant to any sentence it originally could have imposed subject to the defendant\u8217\'3fs compliance with conditions set by the court as a requirement of the deferred sentence.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fExpunged\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the court\u8217\'3fs criminal record with reference to a deferred judgment or any other criminal record that has been segregated in a secure area or database which is exempted from public access. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSuspended sentence\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a sentencing option whereby the court pronounces judgment and imposes a sentence and then suspends execution of the sentence subject to the defendant\u8217\'3fs compliance with conditions set by the court as a requirement of the suspended sentence. Revocation of the suspended sentence results in the execution of sentence already pronounced.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fProbation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the procedure under which a defendant, against whom a judgment of conviction of a public offense has been or may be entered, is released by the court subject to supervision by a resident of this state or by the judicial district department of correctional services.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7907.1}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1168, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 143, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1054, \'a71, 4}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7901C.1}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{907.2}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Probation service \u8212\'3f probation officers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Pursuant to designation by the court, probation services shall be provided by the judicial district department of correctional services. Probation officers shall perform the duties assigned to them by law and by the director of the judicial district department of correctional services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Probation officers employed by the judicial district department of correctional services, while performing the duties prescribed by that department, are peace officers. Probation officers shall investigate all persons referred to them for investigation by the director of the judicial district department of correctional services which employs them. They shall furnish to each person released under their supervision or committed to a community corrections residential facility operated by the judicial district department of correctional services, a written statement of the conditions of probation or commitment. They shall keep informed of each person\u8217\'3fs conduct and condition and shall use all suitable methods prescribed by the judicial district department of correctional services to aid and encourage the person to bring about improvements in the person\u8217\'3fs conduct and condition. Probation officers shall keep records of their work and shall make reports to the court when alleged violations occur and within no less than thirty days before the period of probation will expire. Probation officers shall coordinate their work with other social welfare agencies which offer services of a corrective nature operating in the area to which they are assigned.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7907.2}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1019, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 125, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1197, \'a74, 13}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1177, \'a74, 5}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1041, \'a7127}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7801.4}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{907.3}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Deferred judgment, deferred sentence, or suspended sentence.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Pursuant to }{{\f5\fs18\hyphpar0\qj{section 901.5}}}{, the trial court may, upon a plea of guilty, a verdict of guilty, or a special verdict upon which a judgment of conviction may be rendered, exercise any of the options contained in }{{\f5\fs18\hyphpar0\qj{this section}}}{. However, }{{\f5\fs18\hyphpar0\qj{this section}}}{ does not apply to a forcible felony, to a violation of }{{\f5\fs18\hyphpar0\qj{chapter 709}}}{ committed by a person who is a mandatory reporter of child abuse under }{{\f5\fs18\hyphpar0\qj{section 232.69}}}{ in which the victim is a person who is under the age of eighteen, or to a violation of }{{\f5\fs18\hyphpar0\qj{section 718C.2}}}{ or }{{\f5\fs18\hyphpar0\qj{718C.5}}}{.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{With the consent of the defendant, the court may defer judgment and may place the defendant on probation upon conditions as it may require. A civil penalty shall be assessed as provided in }}}{{\f5\fs18\hyphpar0\qj{section 907.14}}}{{\f5\fs18\hyphpar0\qj{ upon the entry of a deferred judgment. However, the court shall not defer judgment if any of the following is true:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The defendant previously has been convicted of a felony. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fFelony\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a conviction in a court of this or any other state or of the United States, of an offense classified as a felony by the law under which the defendant was convicted at the time of the defendant\u8217\'3fs conviction.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prior to the commission of the offense the defendant had been granted a deferred judgment or similar relief, two or more times anywhere in the United States.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prior to the commission of the offense the defendant had been granted a deferred judgment or similar relief in a felony prosecution anywhere in the United States within the preceding five years, measured from the date of granting of deferment of judgment to the date of commission of the offense.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The defendant is a corporation.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The offense is a violation of }}}{{\f5\fs18\hyphpar0\qj{section 124.401, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and the controlled substance is methamphetamine.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The offense is a violation of }}}{{\f5\fs18\hyphpar0\qj{section 321J.2}}}{{\f5\fs18\hyphpar0\qj{ and the person has been convicted of a violation of that section or the person\u8217\'3fs driver\u8217\'3fs license has been revoked under }}}{{\f5\fs18\hyphpar0\qj{chapter 321J}}}{{\f5\fs18\hyphpar0\qj{, and any of the following apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the defendant\u8217\'3fs alcohol concentration established by the results of an analysis of a specimen of the defendant\u8217\'3fs blood, breath, or urine withdrawn in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapter 321J}}}{{\f5\fs18\hyphpar0\qj{ exceeds .15, regardless of whether or not the alcohol concentration indicated by the chemical test minus the established margin of error inherent in the device or method used to conduct the test equals an alcohol concentration of .15 or more.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the defendant has previously been convicted of a violation of }}}{{\f5\fs18\hyphpar0\qj{section 321J.2, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, or a violation of a statute in another state substantially corresponding to }}}{{\f5\fs18\hyphpar0\qj{section 321J.2, subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the defendant has previously received a deferred judgment or sentence for a violation of }}}{{\f5\fs18\hyphpar0\qj{section 321J.2, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, or for a violation of a statute in another state substantially corresponding to }}}{{\f5\fs18\hyphpar0\qj{section 321J.2, subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the defendant refused to consent to testing requested in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 321J.6}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(e)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the offense under }}}{{\f5\fs18\hyphpar0\qj{chapter 321J}}}{{\f5\fs18\hyphpar0\qj{ results in bodily injury to a person other than the defendant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(f)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the offense was committed while also in violation of }}}{{\f5\fs18\hyphpar0\qj{section 321.279, subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(7)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The offense is a violation of }}}{{\f5\fs18\hyphpar0\qj{section 462A.14}}}{{\f5\fs18\hyphpar0\qj{, and a mandatory minimum sentence must be served or mandatory minimum fine must be paid by the defendant.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(8)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The offense is a conviction for or plea of guilty to a violation of }}}{{\f5\fs18\hyphpar0\qj{section 664A.7}}}{{\f5\fs18\hyphpar0\qj{ or a finding of contempt pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 664A.7}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(9)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The offense is a violation of }}}{{\f5\fs18\hyphpar0\qj{chapter 692A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(10)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The offense is a violation of }}}{{\f5\fs18\hyphpar0\qj{section 707.6A, subsection 1}}}{{\f5\fs18\hyphpar0\qj{; or a violation of }}}{{\f5\fs18\hyphpar0\qj{section 707.6A, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, involving operation of a motor vehicle while intoxicated.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(11)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The defendant committed an assault as defined in }}}{{\f5\fs18\hyphpar0\qj{section 708.1}}}{{\f5\fs18\hyphpar0\qj{, against a peace officer in the performance of the peace officer\u8217\'3fs duty.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(12)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prior to the commission of the offense the defendant had been granted a deferred judgment or deferred sentence for a violation of }}}{{\f5\fs18\hyphpar0\qj{section 708.2}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{708.2A}}}{{\f5\fs18\hyphpar0\qj{ which was issued on a domestic abuse assault, or was granted similar relief anywhere in the United States concerning that jurisdiction\u8217\'3fs statutes which substantially correspond to domestic abuse assault as provided in }}}{{\f5\fs18\hyphpar0\qj{section 708.2A}}}{{\f5\fs18\hyphpar0\qj{, and the current offense is a violation of }}}{{\f5\fs18\hyphpar0\qj{section 708.2A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(13)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The offense is a violation referred to in }}}{{\f5\fs18\hyphpar0\qj{section 708.2A, subsection 4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(14)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The offense is a violation of }}}{{\f5\fs18\hyphpar0\qj{section 709.8}}}{{\f5\fs18\hyphpar0\qj{ and the child is twelve years of age or under.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(15)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The offense is a violation of }}}{{\f5\fs18\hyphpar0\qj{section 710A.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(16)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The offense is a violation of }}}{{\f5\fs18\hyphpar0\qj{section 728.12}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon a showing that the defendant is not cooperating with the program of probation or is not responding to it, the court may withdraw the defendant from the program, pronounce judgment, and impose any sentence authorized by law. Before taking such action, the court shall give the defendant an opportunity to be heard on any matter relevant to the proposed action. Upon violation of the conditions of probation, the court may proceed as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 908}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon fulfillment of the conditions of probation and the payment of fees imposed and not waived by the judicial district department of correctional services under }}}{{\f5\fs18\hyphpar0\qj{section 904.912}}}{{\f5\fs18\hyphpar0\qj{, the defendant shall be discharged without entry of judgment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At the time of or after pronouncing judgment and with the consent of the defendant, the court may defer the sentence and assign the defendant to the judicial district department of correctional services. The court may assign the defendant to supervision or services under }}}{{\f5\fs18\hyphpar0\qj{section 901B.1}}}{{\f5\fs18\hyphpar0\qj{ at the level of sanctions which the district department determines to be appropriate. However, the court shall not defer the sentence for a violation of any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The offense is a violation of }}}{{\f5\fs18\hyphpar0\qj{section 124.401, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and the controlled substance is methamphetamine.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Section 321J.2, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, if any of the following apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the defendant\u8217\'3fs alcohol concentration established by the results of an analysis of a specimen of the defendant\u8217\'3fs blood, breath, or urine withdrawn in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapter 321J}}}{{\f5\fs18\hyphpar0\qj{ exceeds .15, regardless of whether or not the alcohol concentration indicated by the chemical test minus the established margin of error inherent in the device or method used to conduct the test equals an alcohol concentration of .15 or more.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the defendant has previously been convicted of a violation of }}}{{\f5\fs18\hyphpar0\qj{section 321J.2, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, or a violation of a statute in another state substantially corresponding to }}}{{\f5\fs18\hyphpar0\qj{section 321J.2, subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the defendant has previously received a deferred judgment or sentence for a violation of }}}{{\f5\fs18\hyphpar0\qj{section 321J.2, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, or for a violation of a statute in another state substantially corresponding to }}}{{\f5\fs18\hyphpar0\qj{section 321J.2, subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the defendant refused to consent to testing requested in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 321J.6}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(e)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the offense under }}}{{\f5\fs18\hyphpar0\qj{chapter 321J}}}{{\f5\fs18\hyphpar0\qj{ results in bodily injury to a person other than the defendant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(f)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The offense was committed while also in violation of }}}{{\f5\fs18\hyphpar0\qj{section 321.279, subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The offense is a violation of }}}{{\f5\fs18\hyphpar0\qj{section 462A.14}}}{{\f5\fs18\hyphpar0\qj{, and a mandatory minimum sentence must be served or mandatory minimum fine must be paid by the defendant.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}