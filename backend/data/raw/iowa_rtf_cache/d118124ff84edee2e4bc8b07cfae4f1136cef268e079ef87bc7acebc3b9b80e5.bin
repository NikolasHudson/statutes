\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F135Q}{\*\bkmkend codeChapter_5F135Q}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 135Q}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{HEALTH CARE EMPLOYMENT AGENCIES AND WORKERS}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{135Q.1}}}{\*\bkmkstart stylerid1_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{As used in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, unless the context otherwise requires:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAffiliate\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an entity that directly or indirectly is controlled with or by, or is under the common control with, a health care entity. For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fcontrol\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as defined in }}}{{\f5\fs18\hyphpar0\qj{section 423.3, subsection 92}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDepartment\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the department of inspections, appeals, and licensing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fHealth care employment agency\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fagency\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an agency that contracts with a health care entity in this state to provide agency workers for temporary or temporary-to-hire employee placements.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fHealth care employment agency\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include a health care entity or an affiliate of a health care entity when acting as a health care employment agency for the sole purpose of providing agency workers to the health care entity itself or to an affiliate of the health care entity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fHealth care employment agency\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include a health care technology platform.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fHealth care employment agency worker\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fagency worker\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an individual who contracts with or is employed by a health care employment agency to provide nursing services to health care entity consumers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fHealth care entity\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a facility, agency, or program licensed or certified by the department or by the centers for Medicare and Medicaid services of the United States department of health and human services. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fHealth care technology platform\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fplatform\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes an individual, a trust, a partnership, a corporation, a limited liability partnership or company, or any other business entity that develops and operates, offers, or maintains a system or technology that provides an internet-based or application-based marketplace through which an independent nursing services professional bids on open shifts posted by a health care entity to provide nursing services for the health care entity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fIndependent nursing services professional\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person engaged as an independent contractor through a health care technology platform to provide nursing services for a health care entity. An independent nursing services professional shall be considered an independent contractor provided the independent nursing services professional in the independent nursing services professional\u8217\'3fs sole discretion bids on open shifts and chooses where, when, and how often to work. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fIndividual agency worker category\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes registered nurses, licensed practical nurses, certified nurse aides, certified medication aides, home health aides, medication managers, and noncertified or nonlicensed staff providing personal care as defined in }}}{{\f5\fs18\hyphpar0\qj{section 231C.2}}}{{\f5\fs18\hyphpar0\qj{ who are health care employment agency workers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fManaging entity\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a business entity, owner, ownership group, chief executive officer, program administrator, director, or other decision maker whose responsibilities include directing the management or policies of a health care employment agency or a health care technology platform. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fManaging entity\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes an individual who, directly or indirectly, holds a beneficial interest in a corporation, partnership, or other business entity that constitutes a managing entity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fNursing services\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means those services which may be provided only by or under the supervision of a nurse. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fNursing services\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes services performed by a registered nurse, a licensed practical nurse, a certified nurse aide, a certified medication aide, a home health aide, a medication manager, or by noncertified or nonlicensed staff providing personal care as defined in }}}{{\f5\fs18\hyphpar0\qj{section 231C.2}}}{{\f5\fs18\hyphpar0\qj{. }}}{{\i\f5\fs18\hyphpar0\qj{ \u8220\'3fNursing services\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include the practice of nursing by an advanced registered nurse practitioner or an advanced practice registered nurse licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 152}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{152E}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fNursing services professionals\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes registered nurses, licensed practical nurses, certified nurse aides, certified medication aides, home health aides, medication managers, and noncertified or nonlicensed staff providing personal care as defined in }}}{{\f5\fs18\hyphpar0\qj{section 231C.2}}}{{\f5\fs18\hyphpar0\qj{, who are not health care employment agency workers but instead are employed directly by or contract directly with a health care entity.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2022 Acts, ch 1069, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1153, \'a749}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71905}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 131, \'a71, 3}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1157, \'a763, 68}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{135Q.2}}}{\*\bkmkstart stylerid1_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Health care employment agency requirements }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ registration }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ liability.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A health care employment agency operating in the state shall register annually with the department. Each separate location of a health care employment agency shall register annually with and pay an annual registration fee of five hundred dollars to the department. The department shall issue each location a separate certification of registration upon approval of registration and payment of the fee. The annual registration fees shall be retained by the department as appropriated receipts as defined in }}}{{\f5\fs18\hyphpar0\qj{section 8.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A health care employment agency that fails to register with the department as required under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be prohibited from contracting with any health care entity in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A health care employment agency shall do all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Ensure that agency workers comply with all applicable requirements relating to the health requirements and qualifications of personnel in health care entity settings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Document that each agency worker meets the minimum licensing, certification, training, and health requirements and the continuing education standards for the agency worker\u8217\'3fs position in the health care entity setting.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Maintain records for each agency worker and report, file, or otherwise provide any required documentation to external parties or regulators which would otherwise be the responsibility of the health care entity if the agency worker was directly employed by the health care entity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Maintain professional and general liability insurance coverage with minimum per occurrence coverage of one million dollars and aggregate coverage of three million dollars to insure against loss, damage, or expense incident to a claim arising out of the death or injury of any person as the result of negligence or malpractice in the provision of services by the agency or an agency worker.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A health care employment agency shall not do any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Restrict in any manner the employment opportunities of an agency worker by including a noncompete clause in any contract with an agency worker or health care entity.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In any contract with an agency worker or health care entity, require payment of liquidated damages, employment fees, or other compensation if the agency worker is subsequently hired as a permanent employee of the health care entity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not apply to a contract between a health care employment agency and an agency worker or a health care entity if the contract meets all of the following criteria:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The contract is entered into for the purpose of placing an agency worker the health care employment agency assisted in obtaining authorization to work in the United States.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The contract contains an initial duration term of not less than twenty-four months and a total duration term, including any renewals or extensions, of not more than thirty-six months.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The contract requires the agency worker to work for a single health care entity for the entire duration of the contract.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any contract that violates }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be unenforceable in court.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A health care employment agency shall submit a report to the department on a quarterly basis for each health care entity participating in Medicare or Medicaid with whom the agency contracts that includes all of the following by provider type:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A detailed list of the average amount charged to the health care entity for each individual agency worker category.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A detailed list of the average amount paid by the agency to agency workers in each individual agency worker category.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall establish a system for members of the public to report complaints against an agency or agency worker. The department shall investigate any complaint received and shall report the department\u8217\'3fs findings to the complaining party and the agency involved.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2022 Acts, ch 1069, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1153, \'a749}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 131, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1157, \'a764, 68}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1185, \'a7140}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7135Q.4}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{135Q.3}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Health care technology platform requirements }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ registration }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ liability.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A health care technology platform operating in the state shall register annually with the department and pay an annual registration fee of five hundred dollars to the department. The department shall issue each health care technology platform a certificate of registration upon approval of registration and payment of the fee. The annual registration fees shall be retained by the department as appropriated receipts as defined in }}}{{\f5\fs18\hyphpar0\qj{section 8.2}}}{{\f5\fs18\hyphpar0\qj{. }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A health care technology platform that fails to register with the department as required under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be prohibited from contracting with any health care entity in this state. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A health care technology platform that allows independent nursing services professionals to utilize the platform to bid on open shifts is an authorized agency for purposes of access to the single contact repository. A health care technology platform shall rerun background checks for an independent nursing services professional following two consecutive years of inactivity on the platform by the independent nursing services professional. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A health care technology platform shall verify that an independent nursing services professional utilizing the platform does all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Supplies documentation demonstrating that the independent nursing services professional meets all applicable state requirements and qualifications of personnel in a health care entity setting.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Meets all applicable minimum state licensing and certification requirements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Maintains professional liability insurance coverage with the minimum per occurrence coverage of one million dollars and aggregate coverage of three million dollars to insure against loss, damage, or expense incident to a claim arising out of the death or injury of any person as the result of negligence or malpractice in the provision of services by the independent nursing services professional.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A health care technology platform shall not do any of the following: }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Restrict in any manner the employment opportunities of an independent nursing services professional by including a noncompete clause in any contract with an independent nursing services professional or health care entity.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In any contract with an independent nursing services professional or health care entity, require payment of liquidated damages, employment fees, or other compensation if the independent nursing services professional is subsequently hired as a permanent employee or is engaged directly as a contractor of the health care entity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any contract that violates this subsection shall be unenforceable in court. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall establish a system for members of the public to report complaints against a health care technology platform or an independent nursing services professional. The department shall investigate any complaint received and shall report the department\u8217\'3fs findings to the complaining party and the health care technology platform involved.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2024 Acts, ch 1157, \'a765, 68}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1185, \'a784}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7135Q.4}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{135Q.4}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Penalties }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ enforcement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A health care employment agency that violates }}}{{\f5\fs18\hyphpar0\qj{section 135Q.2, subsection 1 or 4}}}{{\f5\fs18\hyphpar0\qj{, is subject to an initial monetary penalty of five thousand dollars and shall be provided notification by the department and given a thirty-day grace period in which to comply.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A health care employment agency that fails to comply following the notification and within the thirty-day grace period under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall be subject to a monetary penalty of twenty-five thousand dollars. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a health care employment agency fails to comply with paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the health care employment agency shall be subject to an additional monetary penalty of twenty-five thousand dollars, revocation of registration, and denial of subsequent registration for up to three years.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A health care employment agency that violates }}}{{\f5\fs18\hyphpar0\qj{section 135Q.2, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, or that knowingly provides an agency worker who has an illegally or fraudulently obtained or issued diploma, registration, license, certification, or background check to a health care entity is subject to a monetary penalty of five thousand dollars for each violation.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a health care employment agency commits a second or subsequent violation of }}}{{\f5\fs18\hyphpar0\qj{section 135Q.2, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, within any three-year period, the health care employment agency shall be subject to immediate revocation of registration. The department shall notify the agency thirty days in advance of the date of such revocation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A health care employment agency that violates }}}{{\f5\fs18\hyphpar0\qj{section 135Q.2, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, is subject to a monetary penalty of twenty-five thousand dollars for the first violation. If a health care employment agency violates }}}{{\f5\fs18\hyphpar0\qj{section 135Q.2, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, a second or subsequent time, the health care employment agency shall be subject to immediate revocation of registration, and shall not be eligible to apply for or be granted registration for the three-year period immediately following the date of revocation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A health care technology platform that violates }}}{{\f5\fs18\hyphpar0\qj{section 135Q.3, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, is subject to an initial monetary penalty of five thousand dollars and shall be provided notification by the department and given a thirty-day grace period in which to comply.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A health care technology platform that fails to comply with the notification and within the thirty-day grace period under subparagraph (1) shall be subject to a monetary penalty of twenty-five thousand dollars. }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a health care technology platform knowingly fails to comply with subparagraph (2), the health care technology platform shall be subject to an additional monetary penalty of twenty-five thousand dollars, revocation of registration, and denial of subsequent registration for up to three years. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A health care technology platform that violates }}}{{\f5\fs18\hyphpar0\qj{section 135Q.3, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, or that knowingly allows an independent nursing services professional who has an illegally obtained or issued diploma, registration, license, certification, or background check to utilize the platform to bid on a shift for a health care entity is subject to a monetary penalty of five thousand dollars for each violation.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a health care technology platform commits a second or subsequent violation of }}}{{\f5\fs18\hyphpar0\qj{section 135Q.3, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, within any three-year period, the health care technology platform shall be subject to immediate revocation of registration. The department shall notify the health care technology platform thirty days in advance of the date of such revocation. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A health care technology platform that violates }}}{{\f5\fs18\hyphpar0\qj{section 135Q.3, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, is subject to a monetary penalty of twenty-five thousand dollars for the first violation.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a health care technology platform violates }}}{{\f5\fs18\hyphpar0\qj{section 135Q.3, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, a second or subsequent time, the health care technology platform shall be subject to immediate revocation of registration, and shall not be eligible to apply for or be granted registration for the three-year period immediately following the date of revocation. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The managing entity of an agency for which registration has been denied or revoked under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not be eligible to apply for or be granted registration for another agency during the three-year period following the date of the denial or revocation.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall not approve a new registration or renew an existing registration for any agency for which the managing entity is also the managing entity of an agency for which registration has been denied or revoked during the three-year period in which registration of the violating agency is denied or revoked.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The managing entity of a health care technology platform for which registration has been denied or revoked under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not be eligible to apply for or be granted registration for another health care technology platform during the two-year period following the date of the denial or revocation. }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall not approve a new registration or renew an existing registration for any health care technology platform for which the managing entity is also the managing entity of a health care technology platform for which registration has been denied or revoked during the two-year period in which registration of the violating health care technology platform is denied or revoked. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any monetary penalties collected under this section shall be retained by the department as appropriated receipts as defined in }}}{{\f5\fs18\hyphpar0\qj{section 8.2}}}{{\f5\fs18\hyphpar0\qj{. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The attorney general shall enforce }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2024 Acts, ch 1157, \'a766, 68}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1185, \'a784}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{135Q.5}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Department annual report.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department shall submit an annual report to the general assembly by January 15, for the immediately preceding fiscal year, that includes a summary of the number of registrations issued and the amount of registration fees collected, the violations of this chapter, the amount of monetary penalties collected, the number of health care employment agencies, health care technology platforms, and managing entities for whom a registration was revoked or denied, and any recommendations for changes to the chapter.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2024 Acts, ch 1157, \'a767, 68}}}\par}}