\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F13B}{\*\bkmkend codeChapter_5F13B}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 13B}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{PUBLIC DEFENDERS}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a723B.5}}}{{\f5\fs12\qc{, 600A.6B}}}{{\f5\fs12\qc{, 600A.6C}}}{{\f5\fs12\qc{, 815.9}}}\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{13B.1}}}{\*\bkmkstart stylerid1_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{As used in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ unless the context otherwise requires:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAppointed attorney\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an attorney appointed by the court and compensated by the state to represent an indigent defendant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fClaimant\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an attorney or other person seeking reimbursement of costs or fees payable from the appropriations under }}}{{\f5\fs18\hyphpar0\qj{section 815.11}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDepartment\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the department of inspections, appeals, and licensing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fFinancial statement\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a full written disclosure of all assets, liabilities, current income, dependents, and other information required to determine if a client qualifies for legal assistance by an appointed attorney.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fState public defender\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the state public defender appointed pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{81 Acts, ch 23, \'a71, 8}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1161, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{91 Acts, ch 268, \'a7408, 439}}}{; }{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1040, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1193, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1041, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71725}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{13B.2}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Position established.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The position of state public defender is established within the department of inspections, appeals, and licensing. The governor shall appoint the state public defender, who shall serve at the pleasure of the governor, subject to confirmation by the senate, no less frequently than once every four years, whether or not there has been a new state public defender appointed during that time, and shall establish the state public defender\u8217\'3fs salary.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{81 Acts, ch 23, \'a72, 8}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1245, \'a7516}}}{; }{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1161, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71726}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Confirmation, see }{{\f5\fs12\hyphpar0\qj{\'a72.32}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{13B.2A}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Indigent defense }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ report }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ court-appointed counsel fees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state public defender shall file a written report every three years with the governor and the general assembly by January 1 of a year in which a report is due relating to the recommendations and activities of the state public defender relating to the state indigent defense system. The first such report shall be due on January 1, 2012.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The report shall contain recommendations to the general assembly regarding the hourly rates paid to court-appointed counsel and per case fee limitations. These recommendations shall be consistent with the constitutional requirement to provide effective assistance of counsel to those indigent persons for whom the state is required to provide counsel.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{99 Acts, ch 135, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1156, \'a715, 58}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1031, \'a7414}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{13B.3}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Qualifications of state public defender.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Only persons admitted to practice law in this state shall be appointed state public defender or assistant state public defender.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{81 Acts, ch 23, \'a73, 8}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1161, \'a73}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{13B.4}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Duties and powers of state public defender.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state public defender shall coordinate the provision of legal representation to all indigents under arrest or charged with a crime who face the possibility of imprisonment under the applicable criminal statute or ordinance. }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state public defender shall also coordinate the provision of legal representation to all indigents seeking postconviction relief, against whom a contempt action is pending, in proceedings under }}}{{\f5\fs18\hyphpar0\qj{section 811.1A}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{chapter 229A}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{812}}}{{\f5\fs18\hyphpar0\qj{, in juvenile proceedings, on appeal in criminal cases, and on appeal in proceedings to obtain postconviction relief when ordered to do so by the district court in which the judgment or order was issued, and may provide for the representation of indigents in proceedings instituted pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 908}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state public defender shall not engage in the private practice of law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state public defender shall file a notice with the clerk of the district court in each county served by a public defender designating which public defender office shall receive notice of appointment of cases. The state public defender may also designate a person admitted to practice law in this state or a nonprofit organization employing persons admitted to practice law in this state to be appointed by the court as a designee of the state public defender. In each county in which the state public defender files a designation, the state public defender\u8217\'3fs designee shall be appointed by the court to represent all eligible persons or to serve as guardian ad litem for eligible children in juvenile court in all cases and proceedings specified in the designation. The appointment shall not be made if the state public defender or the state public defender\u8217\'3fs designee notifies the court that the state public defender\u8217\'3fs designee will not provide services in certain cases as identified in the designation by the state public defender.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state public defender may contract with persons admitted to practice law in this state and nonprofit legal organizations for the provision of legal services to indigent persons. The contract may incorporate administrative rules into the terms of the contract or expressly provide that payments may be paid that are other than on an hourly rate basis for legal services provided, including but not limited to a fixed rate per case or per month.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state public defender shall establish fee limitations for particular categories of cases. The fee limitations shall be reviewed at least every three years. In establishing and reviewing the fee limitations, the state public defender shall consider public input during the establishment and review process, and any available information regarding ordinary and customary charges for like services; the number of cases in which legal services to indigents are anticipated; the seriousness of the charge; an appropriate allocation of resources among the types of cases; experience with existing hourly rates, claims, and fee limitations; and any other factors determined to be relevant.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state public defender shall establish a procedure for the submission of all claims for payment of indigent defense costs, including the submission of interim claims in appropriate cases.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state public defender may review any claim for payment of indigent defense costs and may take any of the following actions:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the charges are appropriate and reasonable, approve the claim for payment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Deny the claim under any of the following circumstances:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If it is not timely.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If it is not payable as an indigent defense claim under }}}{{\f5\fs18\hyphpar0\qj{chapter 815}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If it is not payable under the contract between the claimant and the state public defender.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the claimant was appointed contrary to }}}{{\f5\fs18\hyphpar0\qj{section 814.11}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{815.10}}}{{\f5\fs18\hyphpar0\qj{, or the claimant failed to comply with }}}{{\f5\fs18\hyphpar0\qj{section 814.11, subsection 7}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{section 815.10, subsection 5}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Request additional information or return the claim to the claimant, if the claim is incomplete.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If any portion of the claim is excessive, notify the claimant that the claim is excessive and will be reduced to an amount which is not excessive, and reduce and approve the balance of the claim.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If any portion of the claim is not payable within the scope of appointment of the claimant, notify the claimant that a portion of the claim is not within the scope of appointment and is not payable, deny those portions of the claim that are not payable, and approve the balance of the claim.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{, the claimant may seek review of any action or intended action denying or reducing any claim by filing a motion with the court with jurisdiction over the original appointment for review.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The motion must be filed within twenty days of any action taken by the state public defender.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The motion shall be set for hearing by the court and the state public defender shall be provided with at least ten days\u8217\'3f notice of the hearing. The state public defender shall not be required to file a resistance to the motion filed under this paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state public defender or the claimant may participate by telephone. If the state public defender participates by telephone, the state public defender shall be responsible for initiating and paying for all telephone charges.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The filing of a motion shall not delay the payment of the amount approved by the state public defender.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a claim or portion of the claim is denied, the action of the state public defender shall be affirmed unless the action conflicts with a statute or an administrative rule.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the claim is reduced for being excessive, the claimant shall have the burden to establish by a preponderance of the evidence that the amount of compensation and expenses is reasonable and necessary.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(7)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The decision of the court following a hearing on the motion is a final judgment appealable by the state public defender or the claimant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(8)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the state public defender is not first notified and given an opportunity to be heard, any court order entered after the state public defender has taken action on a claim, which affects that claim, is void.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In reviewing a claim for compensation submitted by an attorney who had been retained or agreed to represent an indigent person prior to appointment, the state public defender may consider any moneys earned or paid to the attorney prior to the appointment in determining whether the claim is reasonable and necessary or excessive. The attorney shall provide the state public defender with a copy of any representation agreement, and information on any moneys earned or paid to the attorney prior to the appointment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state public defender is authorized to contract with county attorneys to provide collection services related to court-ordered indigent defense restitution.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state public defender shall not revise the allocations to the office of the state public defender and the allocations for indigent defense of adults and juveniles, unless prior notice of the revisions is given to the legislative services agency, the co-chairpersons and ranking members of the joint appropriations subcommittee on the justice system, and the co-chairpersons and ranking members of the house and senate committees on appropriations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state public defender shall adopt rules, as necessary, pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ to administer }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{chapter 815}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Executing the duties of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not be deemed a violation of }}}{{\f5\fs18\hyphpar0\qj{section 68B.6}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{81 Acts, ch 23, \'a74, 8}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 36, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1161, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 51, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 268, \'a7411, 439}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1242, \'a718}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 175, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1107, \'a720}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1187, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1040, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 12, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 135, \'a73 \u8211\'3f 6}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 208, \'a746}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1154, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1067, \'a71 \u8211\'3f 5}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1119, \'a7116}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 35, \'a746, 49}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 51, \'a71 \u8211\'3f 3}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1040, \'a71 \u8211\'3f 3}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1084, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1091, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1175, \'a7195}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 107, \'a71, 14}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1041, \'a72 \u8211\'3f 4}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 22, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1061, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 178, \'a723, 24}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1063, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 88, \'a71, 2}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a713B.4A}}}{{\f5\fs12\hyphpar0\qj{, 13B.9}}}{{\f5\fs12\hyphpar0\qj{, 22.7(44)}}}{{\f5\fs12\hyphpar0\qj{, 814.11}}}{{\f5\fs12\hyphpar0\qj{, 815.7}}}{{\f5\fs12\hyphpar0\qj{, 815.10}}}{{\f5\fs12\hyphpar0\qj{, 815.10A}}}{{\f5\fs12\hyphpar0\qj{, 815.14}}}{{\f5\fs12\hyphpar0\qj{, 908.2A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{13B.4A}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Confidentiality of indigent defense claim records.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A claim for compensation and reimbursement for legal assistance and supporting documents submitted to the state public defender for payment of costs incurred in the legal representation of an indigent person from the indigent defense fund established in }}}{{\f5\fs18\hyphpar0\qj{section 815.11}}}{{\f5\fs18\hyphpar0\qj{ shall be kept confidential by the state public defender except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The claim and supporting documents shall be released to the client on whose behalf the costs were incurred, or the client\u8217\'3fs designee, upon written request by the client.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Summary claims data may be released if the data does not contain information that is required to be kept confidential pursuant to an attorney\u8217\'3fs obligations under the Iowa rules of professional conduct. Such summary data may include:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The name of the attorney or vendor who provided the legal services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The name of the county in which legal services were provided.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The case number and name of the client unless the information is a confidential juvenile record under }}}{{\f5\fs18\hyphpar0\qj{section 232.147}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The type of claim and the type of cases for which legal services were provided.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The number of hours and expenses claimed, and the total amount paid.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state public defender may in the state public defender\u8217\'3fs sole discretion release claims and supporting documents, including any information that would otherwise be confidential under }}}{{\f5\fs18\hyphpar0\qj{sections 232.147 through 232.150}}}{{\f5\fs18\hyphpar0\qj{, to the auditor of state, the Iowa supreme court attorney disciplinary board, the grievance commission of the supreme court of Iowa, or to other state or local agencies to the extent necessary to investigate fraud or other criminal activity against the attorney or vendor submitting the claim.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state public defender may release the claim and supporting documents to the court with respect to a hearing held under }}}{{\f5\fs18\hyphpar0\qj{section 13B.4, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2013 Acts, ch 116, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1026, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1038, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 29, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1041, \'a7127}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2019, \'a713B.4A}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a722.7(10)}}}{{\f5\fs12\hyphpar0\qj{, 232.151}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{13B.4B}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Confidentiality of indigent defense claim records.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Transferred to }}}{{\f5\fs18\hyphpar0\qj{\'a713B.4A}}}{{\f5\fs18\hyphpar0\qj{; }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2018/CH1041.pdf" }{\fldrslt \cf5 \f5 \fs18{{2018 Acts, ch 1041, \'a7127}}}}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{13B.5}}}{\*\bkmkstart stylerid1_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Staff.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The state public defender may appoint assistant state public defenders who, subject to the direction of the state public defender, shall have the same duties as the state public defender and shall not engage in the private practice of law. The salaries of the staff shall be fixed by the state public defender. The state public defender and the state public defender\u8217\'3fs staff shall receive actual and necessary expenses, including travel at the state rate set forth in }{{\f5\fs18\hyphpar0\qj{section 8A.363}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{81 Acts, ch 23, \'a75, 8}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1161, \'a75}}}{; }{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 145, \'a7136}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{13B.6}}}{\*\bkmkstart stylerid1_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Account established.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{There is established in the state general fund an account to be known as the state public defender operating account. The state public defender may bill a county for services rendered to the county by the office of the state public defender. Receipts shall be deposited in the operating account established under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. There is appropriated from the state general fund all amounts deposited in the state public defender operating account for use in maintaining the operations of the office of state public defender.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of inspections, appeals, and licensing shall provide internal accounting and related fiscal services for the state public defender.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{81 Acts, ch 23, \'a76, 8}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 200, \'a710}}}{; }{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1245, \'a7517}}}{; }{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1161, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71727}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{13B.7}}}{\*\bkmkstart stylerid1_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Legal services to inmates.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The state public defender may supervise the provision of legal services, funded by an appropriation to the Iowa department of corrections, to inmates of adult correctional institutions in civil cases involving prison litigation.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 96, \'a7160}}}{; }{{\f5\fs18\hyphpar0\qj{83 Acts, ch 203, \'a712}}}{; }{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1161, \'a77}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{13B.8}}}{\*\bkmkstart stylerid1_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Office of local public defender.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state public defender may establish or abolish local public defender offices. In determining whether to establish or abolish a local public defender office, the state public defender shall consider the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The number of cases or potential cases where a local public defender is or would be involved.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The population of the area served or to be served.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The willingness of the local private bar to participate in cases where a public defender is or would be involved.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Other factors which the state public defender deems to be important.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state public defender may appoint and may, for cause, remove the local public defender, assistant local public defenders, clerks, investigators, secretaries, or other employees. Each local public defender, and any assistant local public defender, must be an attorney admitted to the practice of law before the Iowa supreme court.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The compensation of the local public defender and staff of the local public defender offices shall be fixed by the state public defender.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state public defender shall provide separate and suitable office space, furniture, equipment, computers, support staff, and supplies for each office of the local public defender out of funds appropriated to the state public defender for this purpose.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state public defender may enter into agreements with the department of management to provide or procure suitable computer networks and other information technology services to or for each office of the state public defender, including the central administrative office and the office of the state appellate defender, and to each office of the local public defender.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An employee of a local public defender office shall not have access to any confidential client information in any other local public defender office, and the state public defender shall not have access to such confidential information.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1161, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 268, \'a7412, 439}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 67, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 135, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1115, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1154, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1067, \'a76 \u8211\'3f 8}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1119, \'a7117}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 88, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1185, \'a7103}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{13B.8A}}}{\*\bkmkstart stylerid1_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Public defender property.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2007/CH0126.pdf" }{\fldrslt \cf5 \f5 \fs18{{2007 Acts, ch 126, \'a7113}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{13B.9}}}{\*\bkmkstart stylerid1_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Powers and duties of local public defenders \u8212\'3f referrals to outside counsel.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The local public defender shall do all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Represent an indigent person who is under arrest or charged with a crime if the indigent person requests representation or the court orders representation when the type of case, the county, and the court have been designated for such representation by the state public defender. The local public defender shall counsel and defend an indigent defendant at every stage of the criminal proceedings and prosecute before or after conviction any appeals or other remedies which the local public defender considers to be in the interest of justice unless other counsel is appointed to the case.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Represent an indigent party, upon order of the court, in child in need of assistance, family in need of assistance, delinquency, and termination of parental rights proceedings pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 232}}}{{\f5\fs18\hyphpar0\qj{ when designated by the state public defender to represent the indigent party in the type of case for that county. The local public defender shall counsel and represent an indigent party in all proceedings pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 232}}}{{\f5\fs18\hyphpar0\qj{ to which the local public defender is appointed and prosecute before or after judgment any appeals or other remedies which the local public defender considers to be in the interest of justice unless other counsel is appointed to the case. A local public defender office or designee shall represent in a subsequent adoption proceeding a party including a nonindigent party who files an adoption petition pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 600.3}}}{{\f5\fs18\hyphpar0\qj{ to adopt a child who was the subject of a termination of parental rights proceeding pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 232}}}{{\f5\fs18\hyphpar0\qj{ in which the local public defender office was involved as provided under this paragraph. If a conflict of interest arises, the representation shall be provided through referral of the party to outside counsel with whom the state public defender has contracted, subject to the fees for legal services incorporated in the contract.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Serve as guardian ad litem for each child in all cases in which the local public defender office is the state public defender\u8217\'3fs designee. The local public defender shall be responsible for determining who shall perform the duties of the guardian ad litem as defined in }}}{{\f5\fs18\hyphpar0\qj{section 232.2}}}{{\f5\fs18\hyphpar0\qj{ and shall be responsible for assuring the court that the duties of the guardian ad litem have been fulfilled. A local public defender office or designee shall serve as guardian ad litem for each child in a subsequent adoption proceeding pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 600.3}}}{{\f5\fs18\hyphpar0\qj{ to adopt a child who was the subject of a termination of parental rights proceeding pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 232}}}{{\f5\fs18\hyphpar0\qj{ in which the local public defender office was involved as provided under this paragraph. If a conflict of interest arises, the guardian ad litem for the child shall be provided through retention of outside counsel with whom the state public defender has contracted, subject to the fees for guardian ad litem services incorporated in the contract.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An attorney appointed under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is not liable to a person represented by the attorney for damages as a result of a conviction in a criminal case unless the court determines in a postconviction proceeding or on direct appeal that the person\u8217\'3fs conviction resulted from ineffective assistance of counsel, and the ineffective assistance of counsel is the proximate cause of the damage. In juvenile or civil proceedings, an attorney appointed under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is not liable to a person represented by the attorney for damages unless it has been determined that the attorney has provided ineffective assistance of counsel and the ineffective assistance of counsel is the proximate cause of the damage.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The local public defender shall handle every case to which the local public defender is appointed if the local public defender can reasonably handle the case. The local public defender shall be responsible for assigning cases to individual attorneys within the local public defender office and for making decisions concerning cases in which the local public defender has been appointed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a conflict of interest arises or if the local public defender is unable to handle a case because of a temporary overload of cases, the local public defender shall return the case to the court. If the case is returned and the state public defender has filed a successor designation, the court shall appoint the successor designee. If there is no successor designee on file, the court shall make the appointment pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 815.10}}}{{\f5\fs18\hyphpar0\qj{. As used in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fsuccessor designee\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ may include another local public defender office, or a nonprofit organization or a person admitted to practice law in this state that has contracted with the state public defender under }}}{{\f5\fs18\hyphpar0\qj{section 13B.4, subsection 3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a conflict of interest arises in any case, }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ does not affect the local public defender\u8217\'3fs obligation to withdraw as counsel or as guardian ad litem.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1161, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 83, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 268, \'a7413, 439}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1187, \'a718, 19}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{; }{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts//CH0000.pdf" }{\fldrslt \f5 \fs18{{\f5\fs18\hyphpar0\qj\cf5{96 Acts, ch 1040, \'a73, 4}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 135, \'a78 \u8211\'3f 10}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1067, \'a79 \u8211\'3f 12}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 51, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1017, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1040, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 19, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1061, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1063, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 161, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 134, \'a71}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{13B.10}}}{\*\bkmkstart stylerid1_2E18_2E2_2E2}{\*\bkmkend stylerid1_2E18_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Determination of indigence.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{For purposes of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, a determination of indigence shall be made pursuant to }{{\f5\fs18\hyphpar0\qj{section 815.9}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1161, \'a710}}}{; }{{\f5\fs18\hyphpar0\qj{89 Acts, ch 83, \'a75}}}{; }{{\f5\fs18\hyphpar0\qj{93 Acts, ch 175, \'a716}}}{; }{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1193, \'a72}}}{; }{{\f5\fs18\hyphpar0\qj{99 Acts, ch 135, \'a711}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{13B.11}}}{\*\bkmkstart stylerid1_2E19_2E2_2E2}{\*\bkmkend stylerid1_2E19_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{State appellate defender.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The state public defender shall appoint a state appellate defender who shall represent indigents on appeal in criminal cases and on appeal in proceedings to obtain postconviction relief when appointed to do so by the district court in which the judgment or order was issued, and may represent indigents in proceedings instituted pursuant to }{{\f5\fs18\hyphpar0\qj{chapter 908}}}{ when required to do so by the state public defender, and shall not engage in the private practice of law.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 51, \'a72}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{13B.12}}}{\*\bkmkstart stylerid1_2E2_30_2E2_2E2}{\*\bkmkend stylerid1_2E2_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Gideon fellowship.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The state public defender may establish a Gideon fellowship program for the entry level hiring and training of public defender attorneys. The state public defender may appoint up to four Gideon fellows for a term of up to two years and may assign each fellow to a local public defender office or appellate defender office. Each fellow shall be a licensed attorney admitted to practice law in this state prior to commencement of the fellowship.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2014 Acts, ch 1071, \'a71}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{13B.13}}}{\*\bkmkstart stylerid1_2E21_2E2_2E2}{\*\bkmkend stylerid1_2E21_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{State public defender pilot project }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ child welfare legal representation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Notwithstanding any other provision of the law to the contrary, for each fiscal year for the period beginning July 1, 2020, and ending June 30, 2025, the state public defender may establish a pilot project to implement innovative models of legal representation in order to assist families involved in the child welfare system. The state public defender shall have sole discretion to establish and implement the pilot project. The state public defender may implement the new pilot project in up to sixteen counties throughout the state. The purpose of the pilot project is to implement and study innovative ways, through a team approach or through other methods, to achieve positive outcomes for families, reduce trauma to young children, and deliver financial benefits to families and their communities. The state public defender may coordinate with other agencies and organizations to implement the pilot project, seek grant funding, and measure the results. The state public defender may appoint an attorney to represent an indigent person prior to initiation of formal proceedings, without court order, if such representation is deemed appropriate by the state public defender and relates to the purposes of the pilot project.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2020 Acts, ch 1040, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 10, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7815.11}}}\par}}