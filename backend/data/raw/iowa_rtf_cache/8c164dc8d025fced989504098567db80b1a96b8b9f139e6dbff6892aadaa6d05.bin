\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F5_309}{\*\bkmkend codeChapter_5F5_309}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 509}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{GROUP INSURANCE}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a787.4}}}{{\f5\fs12\qc{, 296.7}}}{{\f5\fs12\qc{, 331.301}}}{{\f5\fs12\qc{, 364.4}}}{{\f5\fs12\qc{, 505.28}}}{{\f5\fs12\qc{, 505.29}}}{{\f5\fs12\qc{, 507B.4A}}}{{\f5\fs12\qc{, 508A.5}}}{{\f5\fs12\qc{, 509B.1}}}{{\f5\fs12\qc{, 510.11}}}{{\f5\fs12\qc{, 513C.10}}}{{\f5\fs12\qc{, 514C.1}}}{{\f5\fs12\qc{, 514C.2}}}{{\f5\fs12\qc{, 514C.3A}}}{{\f5\fs12\qc{, 514C.4}}}{{\f5\fs12\qc{, 514C.4A}}}{{\f5\fs12\qc{, 514C.6}}}{{\f5\fs12\qc{, 514C.10}}}{{\f5\fs12\qc{, 514C.11}}}{{\f5\fs12\qc{, 514C.12}}}{{\f5\fs12\qc{, 514C.12A}}}{{\f5\fs12\qc{, 514C.18}}}{{\f5\fs12\qc{, 514C.19}}}{{\f5\fs12\qc{, 514C.20}}}{{\f5\fs12\qc{, 514C.21}}}{{\f5\fs12\qc{, 514C.23}}}{{\f5\fs12\qc{, 514C.24}}}{{\f5\fs12\qc{, 514C.25}}}{{\f5\fs12\qc{, 514C.26}}}{{\f5\fs12\qc{, 514C.29}}}{{\f5\fs12\qc{, 514C.30}}}{{\f5\fs12\qc{, 514C.32}}}{{\f5\fs12\qc{, 514C.33}}}{{\f5\fs12\qc{, 514C.34}}}{{\f5\fs12\qc{, 514C.36}}}{{\f5\fs12\qc{, 514E.1}}}{{\f5\fs12\qc{, 514E.2}}}{{\f5\fs12\qc{, 514F.4}}}{{\f5\fs12\qc{, 514L.1}}}{{\f5\fs12\qc{, 669.14}}}{{\f5\fs12\qc{, 670.7}}}\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{509.1}}}{\*\bkmkstart stylerid1_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Form of policy.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{No policy of group life, accident or health insurance shall be delivered in this state unless it conforms to one of the following descriptions:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A policy issued to an employer, or to the trustees of a fund established by an employer, which employer or trustee shall be deemed the policyholder, to insure employees of the employer for the benefit of persons other than the employer, subject to the following requirements:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The employees eligible for insurance under the policy shall be all of the employees of the employer, or all of any class or classes thereof determined by conditions pertaining to their employment. The policy may provide that the term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3femployees\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall include the employees of one or more subsidiary corporations, and the employees, individual proprietors, and partners of one or more affiliated corporations, proprietors or partnerships if the business of the employer and of such affiliated corporations, proprietors or partnerships is under common control through stock ownership, contract, or otherwise. The policy may provide that the term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3femployees\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall include the individual proprietor or partners if the employer is an individual proprietor or a partnership. The policy may provide that the term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3femployees\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall include retired employees. The policy may also provide that the term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3femployees\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall include the board of directors if the employer is a corporation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The premium for the group policy shall be paid by the policyholder, either from the employer\u8217\'3fs funds or funds contributed by the insured employees, or from both. A policy of group accident and health insurance on which part of the premium is to be derived from funds contributed by the insured employees may be placed in force only if at least seventy-five percent of the then eligible employees, excluding any as to whom evidence of individual insurability is not satisfactory to the insurer, elect to make the required contributions. A policy on which no part of the premium is to be derived from funds contributed by the insured employees must insure all eligible employees, or all except any as to whom evidence of individual insurability is not satisfactory to the insurer. As used in this paragraph, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3faccident and health insurance\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include disability income insurance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amounts of insurance under the policy must be based upon some plan precluding individual selection either by the employees or by the employer or trustees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Group policies may include dependents of the employee, including the spouse.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The policy shall not exclude from coverage an employee or an employee\u8217\'3fs spouse or dependents on the basis of the eligibility of the employee or the employee\u8217\'3fs spouse or dependents for medical assistance under }}}{{\f5\fs18\hyphpar0\qj{chapter 249A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A policy issued to any one of the following to be considered the policyholder:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An advisory, supervisory, or governing body or bodies of a regularly organized religious denomination to insure its clergy, priests, or ministers of the gospel.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A teachers\u8217\'3f association, to insure its members.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A lawyers\u8217\'3f association, to insure its members.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A volunteer fire company, to insure all of its members.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A fraternal society or association, or any subordinate lodge or branch thereof, to insure its members.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A common principal of any group of persons similarly engaged between whom there exists a contractual relationship, to insure the members of such group.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(7)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An association, the members of which are students, teachers, administrators or officials of any elementary or secondary school or of any college, to insure the members thereof. For the purpose of this subparagraph, the students, teachers, administrators or officials of or for any such school or college shall constitute an association.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{ The provisions and requirements of }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ shall apply to the policy and the policyholder and insured in the same manner as }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ applies to employers and employees, except that if a policy is issued to a volunteer fire company or an association, the members of which are students, teachers, administrators or officials of any elementary or secondary school or of any college, the requirement for twenty-five members shall not apply, and, if issued to a teachers\u8217\'3f association or lawyers\u8217\'3f association, not less than sixty-five percent of the members thereof may be insured.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A policy issued to a creditor, who shall be deemed the policyholder, to insure debtors of the creditor, subject to the following requirements:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The debtors eligible for insurance under the policy shall be all of the debtors of the creditor, or all of any class or classes thereof determined by conditions pertaining to the indebtedness or to the purchase giving rise to the indebtedness. The policy may provide that the term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fdebtors\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall include the debtors of one or more subsidiary corporations, and the debtors of one or more affiliated corporations, proprietors or partnerships if the business of the policyholder and of such affiliated corporations, proprietors or partnerships is under common control through stock ownership, contract, or otherwise.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The premium for the policy shall be paid by the policyholder, either from the creditor\u8217\'3fs funds, or from charges collected from the insured debtors, or from both. A policy on which part or all of the premium is to be derived from the collection from the insured debtors of identifiable charges not required of uninsured debtors shall not include, in the class or classes of debtors eligible for insurance, debtors under obligations outstanding at its date of issue without evidence of individual insurability unless at least seventy-five percent of the then eligible debtors elect to pay the required charges. A policy on which no part of the premium is to be derived from the collection of such identifiable charges must insure all eligible debtors, or all except any as to whom evidence of individual insurability is not satisfactory to the insurer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The policy may be issued only if the group of eligible debtors is then receiving new entrants at the rate of at least one hundred persons yearly, or may reasonably be expected to receive at least one hundred new entrants during the first policy year, and only if the policy reserves to the insurer the right to require evidence of individual insurability if less than seventy-five percent of the new entrants become insured.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amount of insurance on the life of a debtor shall not exceed the amount owed by the debtor to the creditor, or the face amount of a totally or partially executed loan or loan commitment creating personal liability and made in good faith for general agricultural or horticultural purposes to a debtor with seasonal income. However, in no event shall the amount of insurance exceed two hundred thousand dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The insurance shall be payable to the policyholder. Such payment shall reduce or extinguish the unpaid indebtedness of the debtor to the extent of such payment. Provided that in the case of a debtor for agricultural or horticultural purposes of the type described in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f,}}}{{\f5\fs18\hyphpar0\qj{ the insurance in excess of indebtedness to the creditor, if any, shall be payable to a named beneficiary, to the estate of the debtor or under the provision of a facility of payment clause.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A policy issued to a labor union, which shall be deemed the policyholder, to insure members of such union for the benefit of persons other than the union or any of its officials, representatives, or agents, subject to the following requirements:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The members eligible for insurance under the policy shall be all of the members of the union or all of any class or classes thereof determined by conditions pertaining to their employment, or to membership in the union, or both.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The premium for the group life policy shall be paid by the policyholder, either wholly from the union\u8217\'3fs funds, or partly from such funds and partly from funds contributed by the insured members specifically for their insurance. No policy, except accident and health, may be issued on which the entire premium is to be derived from funds contributed by the insured members specifically for their insurance. A policy on which part of the premium is to be derived from funds contributed by the insured members specifically for their insurance may be placed in force only if at least sixty-five percent of the then eligible members, excluding any as to whom evidence of individual insurability is not satisfactory to the insurer, elect to make the required contributions. A policy on which no part of the premium is to be derived from funds contributed by the insured members specifically for their insurance must insure all eligible members, or all except any as to whom evidence of individual insurability is not satisfactory to the insurer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The policy must cover at least ten members at date of issue.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amounts of insurance under the policy must be based upon some plan precluding individual selection either by the members or by the union.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Policies may include dependents of the insured, including the spouse.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The policy shall not exclude from coverage a member or a member\u8217\'3fs spouse or dependents on the basis of the eligibility of the member or the member\u8217\'3fs spouse or dependents for medical assistance under }}}{{\f5\fs18\hyphpar0\qj{chapter 249A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A policy issued to the trustees of a fund established by two or more employers in the same industry or by two or more labor unions or by one or more employers and by one or more labor unions which trustees shall be deemed the policyholder, to insure employees of the employers or members of the unions for the benefit of persons other than the employers or the unions, subject to the following requirements:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The persons eligible for insurance shall be all of the employees of the employers or all of the members of the unions, or all of any class or classes thereof determined by conditions pertaining to their employment, or to membership in the unions, or both. The policy may provide that the term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3femployees\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall include the individual proprietor or partners if an employer is an individual proprietor or a partnership. The policy may provide that the term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3femployees\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall include the trustees or their employees, or both, if their duties are principally connected with such trusteeship. The policy may provide that the term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3femployees\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall include retired employees. The policy may also provide that the term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3femployees\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall include the board of directors if the employer is a corporation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The premium for the policy shall be paid by the trustees wholly from funds established by the employers of the insured persons. The policy must insure all eligible persons, or all except any as to whom evidence of individual insurability is not satisfactory to the insurer, if the funds are contributed wholly by the employer or unions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The policy must cover at least one hundred persons at date of issue.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amounts of insurance under the policy must be based upon some plan precluding individual selection either by the insured persons or by the policyholder, employers, or unions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Policies may include dependents of the insured, including the spouse.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The policy shall not exclude from coverage an employee or member or an employee\u8217\'3fs or member\u8217\'3fs spouse or dependents on the basis of the eligibility of the employee or member or employee\u8217\'3fs or member\u8217\'3fs spouse or dependents for medical assistance under }}}{{\f5\fs18\hyphpar0\qj{chapter 249A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A policy issued to any nonprofit industrial association, which shall be deemed the policyholder, incorporated for a period of at least ten years and organized for purposes other than obtaining insurance, subject to the following requirements:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If two or more members of the association, or any class or classes of members thereof determined by conditions pertaining to insurance, elect to insure their employees or any class or classes of employees determined by conditions pertaining to employment; and}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The total number of insured employees must not be less than one thousand, and of these not less than seventy-five percent must be employees of members with at least twenty insured employees each, and further, not more than ten percent may be employees of members with less than ten insured employees each; and}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The insurance premiums are paid by such members to the association; each member, insofar as applicable to the member\u8217\'3fs own employees, may collect part of the premium from insured employees, and the method of apportionment of the premium payment between the member and the member\u8217\'3fs employees may be varied as among individual members; and}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Not less than seventy-five percent of the eligible employees of each participating member may be insured where the employees pay a part of the premium. The word \u8220\'3femployees\u8221\'3f as used in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall also include the individual members and employees of such association.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Policies may include dependents of the employees, including the spouse.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The policy shall not exclude from coverage an employee or an employee\u8217\'3fs spouse or dependents on the basis of the eligibility of the employee or the employee\u8217\'3fs spouse or dependents for medical assistance under }}}{{\f5\fs18\hyphpar0\qj{chapter 249A}}}{{\f5\fs18\hyphpar0\qj{. This paragraph shall also apply to corporations operating within the state who provide insurance coverage for their employees directly, and the commissioner shall have the authority to enforce the provisions of this paragraph.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A policy issued to the department of health and human services, which shall be deemed the policyholder, to insure eligible persons for medical assistance, or for both mandatory medical assistance and optional medical assistance, as defined by }}}{{\f5\fs18\hyphpar0\qj{chapter 249A}}}{{\f5\fs18\hyphpar0\qj{ as hereafter amended.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A policy of group health insurance coverage, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 513B.2}}}{{\f5\fs18\hyphpar0\qj{, issued by a small employer carrier, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 513B.2}}}{{\f5\fs18\hyphpar0\qj{, to a bona fide association, subject to the following requirements:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The policy provides group health insurance coverage to eligible employees of members of a bona fide association that are small employers as defined in }}}{{\f5\fs18\hyphpar0\qj{section 513B.2}}}{{\f5\fs18\hyphpar0\qj{, and to the spouses and dependents of such employees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The policy is issued to a bona fide association. For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, a bona fide association is an association which meets all of the following requirements:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The association is a trade, industry, or professional association which is organized in good faith as a nonprofit corporation under }}}{{\f5\fs18\hyphpar0\qj{chapter 504}}}{{\f5\fs18\hyphpar0\qj{ for purposes other than obtaining insurance and has been in existence and actively maintained for at least five continuous years at the time the policy is issued.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The association does not condition membership in the association on the health status of employees of its members or the health status of the spouses and dependents of such employees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Group health insurance coverage offered by the association is available to all eligible employees of its members that are small employers as defined in }}}{{\f5\fs18\hyphpar0\qj{section 513B.2}}}{{\f5\fs18\hyphpar0\qj{ who choose to participate in the health insurance coverage offered, and to the spouses and dependents of such employees, regardless of the health status of such employees or their spouses and dependents.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Group health insurance coverage offered by the association is available only to persons who are eligible employees of a small employer as defined in }}}{{\f5\fs18\hyphpar0\qj{section 513B.2}}}{{\f5\fs18\hyphpar0\qj{ that is a member of the association, or to the spouses or dependents of such employees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A policy of group health insurance coverage issued to a multiple employer welfare arrangement pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 513D}}}{{\f5\fs18\hyphpar0\qj{ that is subject to regulation by the commissioner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A policy issued to a resident of this state under a group life, accident, or health insurance policy issued to a group other than one described in }}}{{\f5\fs18\hyphpar0\qj{subsections 1 through 9}}}{{\f5\fs18\hyphpar0\qj{, subject to the following requirements:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commissioner determines that all of the following apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The issuance of the group policy is not contrary to the best interest of the public.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The issuance of the group policy will result in economies of acquisition or administration.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The benefits under the group policy are reasonable in relation to the premium charged.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commissioner need not make a determination under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ if the commissioner determines that the group insurance coverage offered in this state by an insurer or other person is offered under a policy issued in another state and that state or another state in which the policy is offered, having requirements substantially similar to those in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, has determined that the policy meets those requirements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The premium for the policy shall be paid either from the policyholder\u8217\'3fs funds, or from funds contributed by the covered person, or both.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The insurer may exclude or limit the coverage on any person as to whom evidence of individual insurability is not satisfactory to the insurer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If compensation of any kind will or may be paid to the policyholder in connection with the group policy, the insurer shall provide to the prospective insured written notice that compensation will or may be paid. Notice shall be provided whether the compensation is direct or indirect, and whether the compensation is paid to or retained by the policyholder, or paid to or retained by a third party at the direction of the policyholder or any entity affiliated with the policyholder by ownership, contract, or employment. The notice shall be placed on or accompany any document designed for the enrollment of prospective insureds.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, \'a78675, 8676; C35, \'a78684-e1 \u8211\'3f 8684-e3; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{8684.01 \u8211\'3f 8684.03;}}}{ C46, \'a7509.1 \u8211\'3f 509.3; C50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7509.1}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 96, \'a7157, 159}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 69, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 63, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 244, \'a725}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1162, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1117, \'a733}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 57, \'a71, 2, 8}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1023, \'a7108}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 138, \'a775}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 29, \'a7145}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1063, \'a73, 4}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 181, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71186}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7513B.2}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{509.2}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Provisions as part of group life policy.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{No policy of group life insurance shall be delivered in this state unless it contains in substance the following provisions, or provisions which in the opinion of the commissioner are more favorable to the persons insured or at least as favorable to the persons insured, and more favorable to the policyholder, provided, however, that provisions of }{{\f5\fs18\hyphpar0\qj{subsections 6 through 10}}}{ shall not apply to policies issued to a creditor to insure debtors of such creditor; that the standard provisions required for individual life insurance policies shall not apply to group life insurance policies; and that if the group life insurance policy is on a plan of insurance other than the term plan, it shall contain a nonforfeiture provision or provisions which in the opinion of the commissioner is or are equitable to the insured persons and to the policyholder, but nothing herein shall be construed to require that group life insurance policies contain the same nonforfeiture provisions as are required for individual life insurance policies:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A provision that the policyholder is entitled to a grace period of thirty-one days for the payment of any premium due except that first, during which grace period the death benefit coverage shall continue in force, unless the policyholder shall have given the insurer written notice of discontinuance in advance of the date of discontinuance and in accordance with the terms of the policy. The policy may provide that the policyholder shall be liable to the insurer for the payment of a pro rata premium for the time the policy was in force during such grace period.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A provision that the validity of the policy shall not be contested, except for nonpayment of premiums, after it has been in force for two years from its date of issue; and that no statement made by any person insured under the policy relating to the person\u8217\'3fs insurability shall be used in contesting the validity of the insurance with respect to which such statement was made after such insurance has been in force prior to the contest for a period of two years during such person\u8217\'3fs lifetime, nor unless it is contained in a written instrument signed by the person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A provision that a copy of the application, if any, of the policyholder shall be attached to the policy when issued, that all statements made by the policyholder or by the persons insured shall be deemed representations and not warranties, and that no statement made by any person insured shall be used in any contest unless a copy of the instrument containing the statement is or has been furnished to such person or to the person\u8217\'3fs beneficiary.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A provision setting forth the conditions, if any, under which the insurer reserves the right to require a person eligible for insurance to furnish evidence of individual insurability satisfactory to the insurer as a condition to part or all of the person\u8217\'3fs coverage.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A provision specifying an equitable adjustment of premiums or benefits or of both to be made in the event the age of a person insured has been misstated, such provision to contain a clear statement of the method of adjustment to be used.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A provision that any sum becoming due by reason of the death of the person insured shall be payable to the beneficiary designated by the person insured, subject to the provisions of the policy in the event there is no designated beneficiary, as to all or any part of such sum, living at the death of the person insured, and subject to any right reserved by the insurer in the policy and set forth in the certificate to pay at its option a part of such sum, not exceeding five hundred dollars, to any person appearing to the insurer to be equitably entitled thereto by reason of having incurred funeral or other expenses incident to the last illness or death of the person insured.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A provision that the insurer will issue to the policyholder for delivery to each person insured an individual certificate setting forth a statement as to the insurance protection to which the person is entitled, to whom the insurance benefits are payable, and the rights and conditions set forth in }}}{{\f5\fs18\hyphpar0\qj{subsections 8 through 10}}}{{\f5\fs18\hyphpar0\qj{ if applicable.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A provision that if the insurance, or any portion of it, on a person covered under the policy ceases because of termination of employment or of membership in the class or classes eligible for coverage under the policy, such person shall be entitled to have issued to the person by the insurer, without evidence of insurability, an individual policy of life insurance without disability or other supplementary benefits, provided application for the individual policy shall be made, and the first premium paid to the insurer, within thirty-one days after such termination, and provided further that,}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The individual policy shall, at the option of such person, be on any one of the forms, except term insurance, then customarily issued by the insurer at the age and for the amount applied for;}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The individual policy shall be in an amount not in excess of the amount of life insurance which ceases because of such termination, provided that any amount of insurance which matures on the date of such termination, or has matured prior thereto as an endowment payable to the person insured, whether in one sum or in installments or in the form of an annuity, shall not, for the purposes of this provision, be included in the amount which is considered to cease because of such termination, and}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The premium on the individual policy shall be at the insurer\u8217\'3fs then customary rate applicable to the form and amount of the individual policy, to the class of risk to which such person then belongs, and to the person\u8217\'3fs age attained on the effective date of the individual policy.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A provision that if the group policy terminates or is amended so as to terminate the insurance of any class of insured persons, every person insured thereunder at the date of such termination whose insurance terminates and who has been so insured for at least five years prior to such termination date shall be entitled to have issued to the person by the insurer an individual policy of life insurance, subject to the same conditions and limitations as are provided by }}}{{\f5\fs18\hyphpar0\qj{subsection 8}}}{{\f5\fs18\hyphpar0\qj{, except that the group policy may provide that the amount of such individual policy shall not exceed the smaller of the amount of the person\u8217\'3fs life insurance protection ceasing because of the termination or amendment of the group policy, less the amount of any life insurance for which the person is or becomes eligible under any group policy issued or reinstated by the same or another insurer within thirty-one days after such termination, and two thousand dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A provision that if a person insured under the group policy dies during the period within which the person would have been entitled to have an individual policy issued to the person in accordance with }}}{{\f5\fs18\hyphpar0\qj{subsection 8 or 9}}}{{\f5\fs18\hyphpar0\qj{ and before such an individual policy shall have become effective, the amount of life insurance which the person would have been entitled to have issued to the person under such individual policy shall be payable as a claim under the group policy, whether or not application for the individual policy or the payment of the first premium therefor has been made.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, \'a78677, 8678; C35, \'a78684-e4, -e5; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{8684.04, 8684.05;}}}{ C46, \'a7509.4, 509.5; C50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7509.2}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2021 Acts, ch 76, \'a7125, 126}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1032, \'a786}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1043, \'a796}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7508A.5}}}{{\f5\fs12\hyphpar0\qj{, 509.4}}}{{\f5\fs12\hyphpar0\qj{, 509.10}}}{{\f5\fs12\hyphpar0\qj{, 509.14}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{509.3}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Provisions as part of accident or health policy.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All policies of group accident or health insurance or combination thereof issued in this state shall contain in substance the following provisions:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The policy shall have a provision that a copy of the application, if any, of the policyholder shall be attached to the policy when issued or shall be furnished to the policyholder within thirty days after the policy is issued, that all statements made by the policyholder or by the persons insured shall be deemed representations and not warranties, and that no statement made by any person insured shall be used in any contest unless a copy of the instrument containing the statement is or has been furnished to such person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A provision that the company will issue to the policyholder for delivery to each person insured under such policy an individual certificate setting forth a statement as to the insurance protection to which the person is entitled, to whom the insurance benefits are payable, and such provisions of the policy as are, in the opinion of the commissioner of insurance, necessary to inform the holder thereof as to the holder\u8217\'3fs rights under the policy.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A provision that to the group or class thereof originally insured shall be added, from time to time, all new persons eligible to insurance in such group or class.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A provision that if the insurance on a person or insurance on a person and the person\u8217\'3fs dependents covered by the policy ceases because of termination of employment or of membership in the class, the person and the person\u8217\'3fs dependents may continue their accident or health insurance under the group policy.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A provision shall be made available to policyholders, under group policies covering vision care services or procedures, for payment of necessary medical or surgical care and treatment provided by an optometrist licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 154}}}{{\f5\fs18\hyphpar0\qj{ if the care and treatment are provided within the scope of the optometrist\u8217\'3fs license and if the policy would pay for the care and treatment if the care and treatment were provided by a person engaged in the practice of medicine or surgery or osteopathic medicine and surgery as licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 148}}}{{\f5\fs18\hyphpar0\qj{. The policy shall provide that the policyholder may reject the coverage or provision if the coverage or provision for services which may be provided by an optometrist is rejected for all providers of similar vision care services as licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 148}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{154}}}{{\f5\fs18\hyphpar0\qj{. This paragraph applies to group policies delivered or issued for delivery after July 1, 1983, and to existing group policies on their next anniversary or renewal date, or upon expiration of the applicable collective bargaining contract, if any, whichever is later. This paragraph does not apply to blanket, short-term travel, accident-only, limited or specified disease, or individual or group conversion policies, or policies designed only for issuance to persons for coverage under Tit. XVIII of the Social Security Act, or any other similar coverage under a state or federal government plan.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A provision shall be made available to policyholders under group policies covering diagnosis and treatment of human ailments for payment or reimbursement for necessary diagnosis or treatment provided by a chiropractor licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 151}}}{{\f5\fs18\hyphpar0\qj{, if the diagnosis or treatment is provided within the scope of the chiropractor\u8217\'3fs license and if the policy would pay or reimburse for the diagnosis or treatment by a person licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 148}}}{{\f5\fs18\hyphpar0\qj{ of the human ailment, irrespective of and disregarding variances in terminology employed by the various licensed professions in describing the human ailment or its diagnosis or its treatment. The policy shall provide that the policyholder may reject the coverage or provision if the coverage or provision for diagnosis or treatment of a human ailment by a chiropractor is rejected for all providers of diagnosis or treatment for similar human ailments licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 148}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{151}}}{{\f5\fs18\hyphpar0\qj{. A policy of group health insurance may limit or make optional the payment or reimbursement for lawful diagnostic or treatment service by all licensees under }}}{{\f5\fs18\hyphpar0\qj{chapters 148}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{151}}}{{\f5\fs18\hyphpar0\qj{ on any rational basis which is not solely related to the license under or the practices authorized by }}}{{\f5\fs18\hyphpar0\qj{chapter 151}}}{{\f5\fs18\hyphpar0\qj{ or is not dependent upon a method of classification, categorization, or description based directly or indirectly upon differences in terminology used by different licensees in describing human ailments or their diagnosis or treatment. This paragraph applies to group policies delivered or issued for delivery after July 1, 1986, and to existing group policies on their next anniversary or renewal date, or upon expiration of the applicable collective bargaining contract, if any, whichever is later. This paragraph does not apply to blanket, short-term travel, accident-only, limited or specified disease, or individual or group conversion policies, or policies under Tit. XVIII of the Social Security Act, or any other similar coverage under a state or federal government plan.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A provision shall be made available to policyholders, under group policies covering hospital, medical, or surgical expenses, for payment of covered services determined to be medically necessary provided by registered nurses certified by a national certifying organization, which organization shall be identified by the Iowa board of nursing pursuant to rules adopted by the board, if the services are within the practice of the profession of a registered nurse as that practice is defined in }}}{{\f5\fs18\hyphpar0\qj{section 152.1}}}{{\f5\fs18\hyphpar0\qj{, under terms and conditions agreed upon between the insurer and the policyholder, subject to utilization controls. This paragraph shall not require payment for nursing services provided by a certified nurse practicing in a hospital, nursing facility, health care institution, physician\u8217\'3fs office, or other noninstitutional setting if the certified nurse is an employee of the hospital, nursing facility, health care institution, physician, or other health care facility or health care provider. This paragraph applies to group policies delivered or issued for delivery in this state on or after July 1, 1989, and to existing group policies on their next anniversary or renewal dates, or upon expiration of the applicable collective bargaining contract, if any, whichever is later. This paragraph does not apply to blanket, short-term travel, accident-only, limited or specified disease, or individual or group conversion policies, policies rated on a community basis, or policies designed only for issuance to persons for eligible coverage under Tit. XVIII of the federal Social Security Act, or any other similar coverage under a state or federal government plan.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A provision that the insurer will permit continuation of existing coverage or reenrollment in previously existing coverage for an individual who meets the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 513B.2, subsection 14}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and who is an unmarried child of an insured or enrollee who so elects, at least through the policy anniversary date on or after the date the child marries, ceases to be a resident of this state, or attains the age of twenty-five years old, whichever occurs first, or so long as the unmarried child maintains full-time status as a student in an accredited institution of postsecondary education.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to the provisions required in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ through }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fh\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the commissioner shall require provisions through the adoption of rules implementing the federal Health Insurance Portability and Accountability Act, Pub. L. No. 104-191.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, \'a78677, 8678; C35, \'a78684-e4, -e6; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{8684.04, 8684.06;}}}{ C46, \'a7509.4, 509.6; C50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7509.3}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 166, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1290, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1124, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1180, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 164, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 103, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 75, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 70, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1088, \'a7125}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1188, \'a738, 43}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 118, \'a77, 11}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1021, \'a798}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7509.10}}}{{\f5\fs12\hyphpar0\qj{, 509.14}}}{{\f5\fs12\hyphpar0\qj{, 514.21}}}{{\f5\fs12\hyphpar0\qj{, 514.23}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{509.3A}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Creditable coverage.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{For the purposes of any policies of group accident or health insurance or combination of such policies issued in this state, }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fcreditable coverage\u8221\'3f}}}{ means health benefits or coverage provided to an individual under any of the following:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A group health plan.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Health insurance coverage.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Part A or Part B Medicare pursuant to Tit. XVIII of the federal Social Security Act.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Medicaid pursuant to Tit. XIX of the federal Social Security Act, other than coverage consisting solely of benefits under section 1928 of that Act.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10 U.S.C. ch. 55.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A health or medical care program provided through the Indian health service or a tribal organization.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A state health benefits risk pool.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A health plan offered under 5 U.S.C. ch. 89.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphp