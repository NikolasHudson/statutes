nce with other law.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Compliance with the requirements of a statute, regulation, or treaty described in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ for obtaining priority over the rights of a lien creditor is equivalent to the filing of a financing statement under }}}{{\f5\fs18\hyphpar0\qj{this Article}}}{{\f5\fs18\hyphpar0\qj{. Except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{sections 554.9313}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{554.9316, subsections 4 and 5}}}{{\f5\fs18\hyphpar0\qj{, for goods covered by a certificate of title, a security interest in property subject to a statute, regulation, or treaty described in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ may be perfected only by compliance with those requirements, and a security interest so perfected remains perfected notwithstanding a change in the use or transfer of possession of the collateral.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{\*\bkmkstart stylerid1_2E15_2E6_2E3_2E5_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E6_2E3_2E5_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Duration and renewal of perfection.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{section 554.9316, subsections 4 and 5}}}{{\f5\fs18\hyphpar0\qj{, duration and renewal of perfection of a security interest perfected by compliance with the requirements prescribed by a statute, regulation, or treaty described in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ are governed by the statute, regulation, or treaty. In other respects, the security interest is subject to }}}{{\f5\fs18\hyphpar0\qj{this Article}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{\*\bkmkstart stylerid1_2E15_2E6_2E3_2E5_2E6_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E6_2E3_2E5_2E6_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Inapplicability to certain inventory.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{During any period in which collateral subject to a statute specified in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ is inventory held for sale or lease by a person or leased by that person as lessor and that person is in the business of selling goods of that kind, }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ does not apply to a security interest in that collateral created by that person.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1149, \'a731, 185, 187}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1052, \'a76, 37}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7554.9308}}}{{\f5\fs12\hyphpar0\qj{, 554.9309}}}{{\f5\fs12\hyphpar0\qj{, 554.9310}}}{{\f5\fs12\hyphpar0\qj{, 554.9316}}}{{\f5\fs12\hyphpar0\qj{, 554.9334}}}{{\f5\fs12\hyphpar0\qj{, 554.9335}}}{{\f5\fs12\hyphpar0\qj{, 554.9337}}}{{\f5\fs12\hyphpar0\qj{, 554.9505}}}{{\f5\fs12\hyphpar0\qj{, 554.9611}}}{{\f5\fs12\hyphpar0\qj{, 554.9621}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18