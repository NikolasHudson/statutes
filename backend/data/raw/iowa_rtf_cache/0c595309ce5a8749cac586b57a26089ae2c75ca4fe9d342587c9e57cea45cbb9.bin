5\fs18\hyphpar0\qj{, a secured party shall use reasonable care in the custody and preservation of collateral in the secured party\u8217\'3fs possession. In the case of chattel paper or an instrument, reasonable care includes taking necessary steps to preserve rights against prior parties unless otherwise agreed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E15_2E5_2E3_2E2_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E5_2E3_2E2_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Expenses, risks, duties, and rights when secured party in possession.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{, if a secured party has possession of collateral:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{reasonable expenses, including the cost of insurance and payment of taxes or other charges, incurred in the custody, preservation, use, or operation of the collateral are chargeable to the debtor and are secured by the collateral;}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{the risk of accidental loss or damage is on the debtor to the extent of a deficiency in any effective insurance coverage;}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{the secured party shall keep the collateral identifiable, but fungible collateral may be commingled; and}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{the secured party may use or operate the collateral:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{for the purpose of preserving the collateral or its value;}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{as permitted by an order of a court having competent jurisdiction; or}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{except in the case of consumer goods, in the manner and to the extent agreed by the debtor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{\*\bkmkstart stylerid1_2E15_2E5_2E3_2E2_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E5_2E3_2E2_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Duties and rights when secured party in possession or control.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{, a secured party having possession of collateral or control of collateral under }}}{{\f5\fs18\hyphpar0\qj{section 554.7106}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{554.9104}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{554.9105}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{554.9105A}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{554.9106}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{554.9107}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{554.9107A}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{may hold as additional security any proceeds, except money or funds, received from the collateral;}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{shall apply money or funds received from the collateral to reduce the secured obligation, unless remitted to the debtor; and}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{may create a security interest in the collateral.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{\*\bkmkstart stylerid1_2E15_2E5_2E3_2E2_2E6_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E5_2E3_2E2_2E6_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Buyer of certain rights to payment.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the secured party is a buyer of accounts, chattel paper, payment intangibles, or promissory notes or a consignor:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ does not apply unless the secured party is entitled under an agreement:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{to charge back uncollected collateral; or}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{otherwise to full or limited recourse against the debtor or a secondary obligor based on the nonpayment or other default of an account debtor or other obligor on the collateral; and}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{subsections 2 and 3}}}{{\f5\fs18\hyphpar0\qj{ do not apply.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1149, \'a717, 185, 187}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 30, \'a745, 46, 67}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1117, \'a720}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7554.9601}}}{{\f5\fs12\hyphpar0\qj{, 554.9602}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{554.9208}}}{\*\bkmkstart stylerid1_2E15_2E5_2E3_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E5_2E3_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Additional duties of secured party having control of collateral.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E15_2E5_2E3_2E3_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E5_2E3_2E3_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Applicability of section.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ applies to cases in which there is no outstanding secured obligation and the secured party is not committed to make advances, incur obligations, or otherwise give value.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E15_2E5_2E3_2E3_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E5_2E3_2E3_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Duties of secured party after receiving demand from debtor.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Within ten days after receiving a signed demand by the debtor:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{a secured party having control of a deposit account under }}}{{\f5\fs18\hyphpar0\qj{section 554.9104, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, shall send to the bank with which the deposit account is maintained a signed record that releases the bank from any further obligation to comply with instructions originated by the secured party;}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{a secured party having control of a deposit account under }}}{{\f5\fs18\hyphpar0\qj{section 554.9104, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, shall:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{pay the debtor the balance on deposit in the deposit account; or}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{transfer the balance on deposit into a deposit account in the debtor\u8217\'3fs name;}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{a secured party, other than a buyer, having control under }}}{{\f5\fs18\hyphpar0\qj{section 554.9105}}}{{\f5\fs18\hyphpar0\qj{ of an authoritative electronic copy of a record evidencing chattel paper shall transfer control of the electronic copy to the debtor or a person designated by the debtor;}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{a secured party having control of investment property under }}}{{\f5\fs18\hyphpar0\qj{section 554.8106, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{section 554.9106, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, shall send to the securities intermediary or commodity intermediary with which the security entitlement or commodity contract is maintained a signed record that releases the securities intermediary or commodity intermediary from any further obligation to comply with entitlement orders or directions originated by the secured party;}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{a secured party having control of a letter-of-credit right under }}}{{\f5\fs18\hyphpar0\qj{section 554.9107}}}{{\f5\fs18\hyphpar0\qj{ shall send to each person having an unfulfilled obligation to pay or deliver proceeds of the letter of credit to the secured party a signed release from any further obligation to pay or deliver proceeds of the letter of credit to the secured party; }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{a secured party having control under }}}{{\f5\fs18\hyphpar0\qj{section 554.7106}}}{{\f5\fs18\hyphpar0\qj{ of an authoritative electronic copy of an electronic document shall transfer control of the electronic copy to the debtor or a person designated by the debtor;}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{a secured party having control under }}}{{\f5\fs18\hyphpar0\qj{section 554.9105A}}}{{\f5\fs18\hyphpar0\qj{ of electronic money shall transfer control of the electronic money to the debtor or a person designated by the debtor; and}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{a secured party having control under }}}{{\f5\fs18\hyphpar0\qj{section 554.14105}}}{{\f5\fs18\hyphpar0\qj{ of a controllable electronic record, other than a buyer of a controllable account or controllable payment intangible evidenced by the controllable electronic record, shall transfer control of the controllable electronic record to the debtor or a person designated by the debtor.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1149, \'a718, 185, 187}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 30, \'a745, 46, 68}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1117, \'a721, 22}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 64, \'a793}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1023, \'a750}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7554.9625}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{554.9209}}}{\*\bkmkstart stylerid1_2E15_2E5_2E3_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E5_2E3_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Duties of secured party if account debtor has been notified of assignment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E15_2E5_2E3_2E4_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E5_2E3_2E4_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Applicability of section.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ applies if:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{there is no outstanding secured obligation; and}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{the secured party is not committed to make advances, incur obligations, or otherwise give value.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E15_2E5_2E3_2E4_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E5_2E3_2E4_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Duties of secured party after receiving demand from debtor.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Within ten days after receiving a signed demand by the debtor, a secured party shall send to an account debtor that has received notification under }}}{{\f5\fs18\hyphpar0\qj{section 554.9406, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{section 554.14106, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, of an assignment to the secured party as assignee a signed record that releases the account debtor from any further obligation to the secured party.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{\*\bkmkstart stylerid1_2E15_2E5_2E3_2E4_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E5_2E3_2E4_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Inapplicability to sales.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not apply to an assignment constituting the sale of an account, chattel paper, or payment intangible.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1149, \'a719, 187}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1023, \'a751}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7554.9625}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{554.9210}}}{\*\bkmkstart stylerid1_2E15_2E5_2E3_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E5_2E3_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Request for accounting \u8212\'3f request regarding list of collateral or statement of account.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E15_2E5_2E3_2E5_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E5_2E3_2E5_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Definitions.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fRequest\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a record of a type described in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fRequest for an accounting\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a record signed by a debtor requesting that the recipient provide an accounting of the unpaid obligations secured by collateral and reasonably identifying the transaction or relationship that is the subject of the request.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fRequest regarding a list of collateral\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a record signed by a debtor requesting that the recipient approve or correct a list of what the debtor believes to be the collateral securing an obligation and reasonably identifying the transaction or relationship that is the subject of the request.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fRequest regarding a statement of account\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a record signed by a debtor requesting that the recipient approve or correct a statement indicating what the debtor believes to be the aggregate amount of unpaid obligations secured by collateral as of a specified date and reasonably identifying the transaction or relationship that is the subject of the request.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E15_2E5_2E3_2E5_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E5_2E3_2E5_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Duty to respond to requests.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subject to }}}{{\f5\fs18\hyphpar0\qj{subsections 3, 4, 5, and 6}}}{{\f5\fs18\hyphpar0\qj{, a secured party, other than a buyer of accounts, chattel paper, payment intangibles, or promissory notes or a consignor, shall comply with a request within fourteen days after receipt:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{in the case of a request for an accounting, by signing and sending to the debtor an accounting; and}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{in the case of a request regarding a list of collateral or a request regarding a statement of account, by signing and sending to the debtor an approval or correction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{\*\bkmkstart stylerid1_2E15_2E5_2E3_2E5_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E5_2E3_2E5_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Request regarding list of collateral }}}{{\i\f5\fs18\hyphpar0\qj{\u8212\'3f}}}{{\i\f5\fs18\hyphpar0\qj{ statement concerning type of collateral.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A secured party that claims a security interest in all of a particular type of collateral owned by the debtor may comply with a request regarding a list of collateral by sending to the debtor a signed record including a statement to that effect within fourteen days after receipt.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{\*\bkmkstart stylerid1_2E15_2E5_2E3_2E5_2E6_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E5_2E3_2E5_2E6_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Request regarding list of collateral }}}{{\i\f5\fs18\hyphpar0\qj{\u8212\'3f}}}{{\i\f5\fs18\hyphpar0\qj{ no interest claimed.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person that receives a request regarding a list of collateral, claims no interest in the collateral when it receives the request, and claimed an interest in the collateral at an earlier time shall comply with the request within fourteen days after receipt by sending to the debtor a signed record:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{disclaiming any interest in the collateral; and}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{if known to the recipient, providing the name and mailing address of any assignee of or successor to the recipient\u8217\'3fs interest in the collateral.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{\*\bkmkstart stylerid1_2E15_2E5_2E3_2E5_2E7_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E5_2E3_2E5_2E7_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Request for accounting or regarding statement of account }}}{{\i\f5\fs18\hyphpar0\qj{\u8212\'3f}}}{{\i\f5\fs18\hyphpar0\qj{ no interest in obligation claimed.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person that receives a request for an accounting or a request regarding a statement of account, claims no interest in the obligations when it receives the request, and claimed an interest in the obligations at an earlier time shall comply with the request within fourteen days after receipt by sending to the debtor a signed record:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{disclaiming any interest in the obligations; and}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{if known to the recipient, providing the name and mailing address of any assignee of or successor to the recipient\u8217\'3fs interest in the obligations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{\*\bkmkstart stylerid1_2E15_2E5_2E3_2E5_2E8_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E5_2E3_2E5_2E8_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Charges for responses.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A debtor is entitled without charge to one response to a request under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ during any six-month period. The secured party may require payment of a charge not exceeding twenty-five dollars for each additional response.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1149, \'a720, 187}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1023, \'a752}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7554.9602}}}{{\f5\fs12\hyphpar0\qj{, 554.9625}}}\par}{}{}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{PART 3}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E15_2E6_2E1_2E2}{PERFECTION AND PRIORITY}{\*\bkmkend stylerid1_2E15_2E6_2E1_2E2}\par}{}{}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBPART A}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E15_2E6_2E2_2E1_2E2}{LAW GOVERNING PERFECTION AND PRIORITY}{\*\bkmkend stylerid1_2E15_2E6_2E2_2E1_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{554.9301}}}{\*\bkmkstart stylerid1_2E15_2E6_2E2_2E2_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E6_2E2_2E2_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Law governing perfection and priority of security interests.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Except as otherwise provided in }{{\f5\fs18\hyphpar0\qj{sections 554.9303 through 554.9306B}}}{, the following rules determine the law governing perfection, the effect of perfection or nonperfection, and the priority of a security interest in collateral:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, while a debtor is located in a jurisdiction, the local law of that jurisdiction governs perfection, the effect of perfection or nonperfection, and the priority of a security interest in collateral.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{While collateral is located in a jurisdiction, the local law of that jurisdiction governs perfection, the effect of perfection or nonperfection, and the priority of a possessory security interest in that collateral.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{, while negotiable tangible documents, goods, instruments, or tangible money is located in a jurisdiction, the local law of that jurisdiction governs:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{perfection of a security interest in the goods by filing a fixture filing;}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{perfection of a security interest in timber to be cut; and}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{the effect of perfection or nonperfection and the priority of a nonpossessory security interest in the collateral.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The local law of the jurisdiction in which the wellhead or minehead is located governs perfection, the effect of perfection or nonperfection, and the priority of a security interest in as-extracted collateral.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1149, \'a721, 185, 187}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 30, \'a745, 46, 69}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1117, \'a723}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1023, \'a753, 54}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7554.1301}}}{{\f5\fs12\hyphpar0\qj{, 554.9316}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{554.9302}}}{\*\bkmkstart stylerid1_2E15_2E6_2E2_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E6_2E2_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Law governing perfection and priority of agricultural liens.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{While farm products are located in a jurisdiction, the local law of that jurisdiction governs perfection, the effect of perfection or nonperfection, and the priority of an agricultural lien on the farm products.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1149, \'a722, 185, 187}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7554.1301}}}{{\f5\fs12\hyphpar0\qj{, 579A.2}}}{{\f5\fs12\hyphpar0\qj{, 579B.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{554.9303}}}{\*\bkmkstart stylerid1_2E15_2E6_2E2_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E6_2E2_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Law governing perfection and priority of security interests in goods covered by a certificate of title.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E15_2E6_2E2_2E4_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E6_2E2_2E4_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Applicability of section.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ applies to goods covered by a certificate of title, even if there is no other relationship between the jurisdiction under whose certificate of title the goods are covered and the goods or the debtor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E15_2E6_2E2_2E4_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E6_2E2_2E4_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{When goods covered by certificate of title.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Goods become covered by a certificate of title when a valid application for the certificate of title and the applicable fee are delivered to the appropriate authority. Goods cease to be covered by a certificate of title at the earlier of the time the certificate of title ceases to be effective under the law of the issuing jurisdiction or the time the goods become covered subsequently by a certificate of title issued by another jurisdiction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{\*\bkmkstart stylerid1_2E15_2E6_2E2_2E4_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E6_2E2_2E4_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Applicable law.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The local law of the jurisdiction under whose certificate of title the goods are covered governs perfection, the effect of perfection or nonperfection, and the priority of a security interest in goods covered by a certificate of title from the time the goods become covered by the certificate of title until the goods cease to be covered by the certificate of title.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1149, \'a723, 185, 187}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.50}}}{{\f5\fs12\hyphpar0\qj{, 554.1301}}}{{\f5\fs12\hyphpar0\qj{, 554.9301}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{554.9304}}}{\*\bkmkstart stylerid1_2E15_2E6_2E2_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E6_2E2_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Law governing perfection and priority of security interests in deposit accounts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E15_2E6_2E2_2E5_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E6_2E2_2E5_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Law of bank\u8217\'3fs jurisdiction governs.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The local law of a bank\u8217\'3fs jurisdiction governs perfection, the effect of perfection or nonperfection, and the priority of a security interest in a deposit account maintained with that bank even if the transaction does not bear any relation to the bank\u8217\'3fs jurisdiction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E15_2E6_2E2_2E5_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E6_2E2_2E5_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Bank\u8217\'3fs jurisdiction.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The following rules determine a bank\u8217\'3fs jurisdiction for purposes of this part:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If an agreement between the bank and the debtor governing the deposit account expressly provides that a particular jurisdiction is the bank\u8217\'3fs jurisdiction for purposes of this part, }}}{{\f5\fs18\hyphpar0\qj{this Article}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, that jurisdiction is the bank\u8217\'3fs jurisdiction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not apply and an agreement between the bank and its customer governing the deposit account expressly provides that the agreement is governed by the law of a particular jurisdiction, that jurisdiction is the bank\u8217\'3fs jurisdiction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If neither paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ nor paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ applies and an agreement between the bank and its customer governing the deposit account expressly provides that the deposit account is maintained at an office in a particular jurisdiction, that jurisdiction is the bank\u8217\'3fs jurisdiction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If none of the preceding paragraphs applies, the bank\u8217\'3fs jurisdiction is the jurisdiction in which the office identified in an account statement as the office serving the customer\u8217\'3fs account is located.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If none of the preceding paragraphs applies, the bank\u8217\'3fs jurisdiction is the jurisdiction in which the chief executive office of the bank is located.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1149, \'a724, 185, 187}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1023, \'a755}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7554.1301}}}{{\f5\fs12\hyphpar0\qj{, 554.9301}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{554.9305}}}{\*\bkmkstart stylerid1_2E15_2E6_2E2_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E6_2E2_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Law governing perfection and priority of security interests in investment property.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E15_2E6_2E2_2E6_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E6_2E2_2E6_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Governing law \u8212\'3f general rules.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{, the following rules apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{While a security certificate is located in a jurisdiction, the local law of that jurisdiction governs perfection, the effect of perfection or nonperfection, and the priority of a security interest in the certificated security represented thereby.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The local law of the issuer\u8217\'3fs jurisdiction as specified in }}}{{\f5\fs18\hyphpar0\qj{section 554.8110, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, governs perfection, the effect of perfection or nonperfection, and the priority of a security interest in an uncertificated security.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The local law of the securities intermediary\u8217\'3fs jurisdiction as specified in }}}{{\f5\fs18\hyphpar0\qj{section 554.8110, subsection 5}}}{{\f5\fs18\hyphpar0\qj{, governs perfection, the effect of perfection or nonperfection, and the priority of a security interest in a security entitlement or securities account.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The local law of the commodity intermediary\u8217\'3fs jurisdiction governs perfection, the effect of perfection or nonperfection, and the priority of a security interest in a commodity contract or commodity account.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ apply even if the transaction does not bear any relation to the jurisdiction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E15_2E6_2E2_2E6_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E6_2E2_2E6_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Commodity intermediary\u8217\'3fs jurisdiction.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The following rules determine a commodity intermediary\u8217\'3fs jurisdiction for purposes of this part:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If an agreement between the commodity intermediary and commodity customer governing the commodity account expressly provides that a particular jurisdiction is the commodity intermediary\u8217\'3fs jurisdiction for purposes of this part, }}}{{\f5\fs18\hyphpar0\qj{this Article}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, that jurisdiction is the commodity intermediary\u8217\'3fs jurisdiction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not apply and an agreement between the commodity intermediary and commodity customer governing the commodity account expressly provides that the agreement is governed by the law of a particular jurisdiction, that jurisdiction is the commodity intermediary\u8217\'3fs jurisdiction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If neither paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ nor paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ applies and an agreement between the commodity intermediary and commodity customer governing the commodity account expressly provides that the commodity account is maintained at an office in a particular jurisdiction, that jurisdiction is the commodity intermediary\u8217\'3fs jurisdiction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If none of the preceding paragraphs applies, the commodity intermediary\u8217\'3fs jurisdiction is the jurisdiction in which the office identified in an account statement as the office serving the commodity customer\u8217\'3fs account is located.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If none of the preceding paragraphs applies, the commodity intermediary\u8217\'3fs jurisdiction is the jurisdiction in which the chief executive office of the commodity intermediary is located.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{\*\bkmkstart stylerid1_2E15_2E6_2E2_2E6_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E6_2E2_2E6_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{When perfection governed by law of jurisdiction where debtor located.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The local law of the jurisdiction in which the debtor is located governs:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{perfection of a security interest in investment property by filing;}}}\par}{}{\par