8\hyphpar0\qj{states that the debtor is entitled to an accounting of the unpaid indebtedness and states the charge, if any, for an accounting; and}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{states the time and place of a public disposition or the time after which any other disposition is to be made.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Whether the contents of a notification that lacks any of the information specified in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ are nevertheless sufficient is a question of fact.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The contents of a notification providing substantially the information specified in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ are sufficient, even if the notification includes:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{information not specified by that paragraph; or}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{minor errors that are not seriously misleading.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A particular phrasing of the notification is not required.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The following form of notification and the form appearing in }}}{{\f5\fs18\hyphpar0\qj{section 554.9614, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, when completed in accordance with the instructions in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{section 554.9614, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, each provides sufficient information:}}}\par}{}{\pard\plain\keepn\f5\fs18\hyphpar0\qc\fi0\ri1084\li1084{\f5\fs18\hyphpar0\qc}{NOTIFICATION OF DISPOSITION}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qc\fi0\ri1084\li1084\sa0\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qc\fi0\ri1084\li1084{ OF COLLATERAL}{\f5\fs18\hyphpar0\qc}\par}{}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~}}}{To:}{{\f5\fs18\hyphpar0\qj{\~\~}}}{(Name of debtor, obligor, or other person to which the notification is sent)}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~}}}{From:}{{\f5\fs18\hyphpar0\qj{\~\~}}}{(Name, address, and telephone number of secured party)}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~}}}{\{1\}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{Name of any debtor that is not an addressee: (Name of each debtor)}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~}}}{\{2\}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{We will sell (describe collateral) (to the highest qualified bidder) at public sale. A sale could include a lease or license. The sale will be held as follows:}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~}}}{(Date)}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~}}}{(Time)}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~}}}{(Place)}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~}}}{\{3\}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{We will sell (describe collateral) at private sale sometime after (date). A sale could include a lease or license.}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~}}}{\{4\}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{You are entitled to an accounting of the unpaid indebtedness secured by the property that we intend to sell or, as applicable, lease or license.}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~}}}{\{5\}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{If you request an accounting you must pay a charge of $(amount).}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~}}}{\{6\}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{You may request an accounting by calling us at (telephone number).}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qc\fi0\ri1084\li1084{\f5\fs18\hyphpar0\qc}{[End of Form]}{\f5\fs18\hyphpar0\qc}\par}{\pard\plain\f5\fs8\hyphpar0\qj\fi0\ri1084\li1084\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E15_2E9_2E3_2E14_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E9_2E3_2E14_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18