\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F181}{\*\bkmkend codeChapter_5F181}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 181}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{BEEF CATTLE PRODUCERS ASSOCIATION}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a78A.502}}}{{\f5\fs12\qc{, 97B.1A}}}{{\f5\fs12\qc{, 159.6}}}{{\f5\fs12\qc{, 173.3}}}{{\f5\fs12\qc{, 179.5A}}}\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{181.1}}}{\*\bkmkstart stylerid1_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{As used in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, unless the context requires otherwise:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAssociation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the Iowa beef cattle producers association.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCattle\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any live domesticated bovine animal regardless of age.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fExecutive committee\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the executive committee of the association as created in }}}{{\f5\fs18\hyphpar0\qj{section 181.3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fFederal Act\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the federal Beef Promotion and Research Act of 1985, 7 U.S.C. \'a72901 et seq.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fFederal assessment\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an excise tax on the sale of bovine animals imposed pursuant to the federal Act.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fProducer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any person who owns or acquires ownership of cattle. However, a person shall not be considered a producer if any of the following apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person\u8217\'3fs only share in the proceeds of a sale of cattle or beef is a sales commission, handling fee, or other service fee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person acquired ownership of cattle to facilitate the transfer of ownership of such cattle from the seller to a third party; resold such cattle no later than ten days from the date on which the person acquired ownership; and certified as required by rules adopted by the executive committee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fQualified financial institution\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a bank or credit union as defined in }}}{{\f5\fs18\hyphpar0\qj{section 12C.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fRecords\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means books, papers, documents, accounts, agreements, memoranda, electronic records of accounts, or correspondence relating to a matter regulated under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSecretary\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the secretary of agriculture.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fState assessment\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an excise tax on the sale of cattle imposed pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7181.6}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1100, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1146, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 30, \'a72, 9}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{CS97, \'a7181.1}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1037, \'a71, 19}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1017, \'a748}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1043, \'a71, 2, 21}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{181.1A}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Recognition of organization.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The Iowa beef cattle producers association now existing in and incorporated under the laws of this state is entitled to the benefits of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ by filing, each year, with the department of agriculture and land stewardship, verified proof of the names of its president, vice president, secretary, and treasurer, together with other information required by the department of agriculture and land stewardship.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2949;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7181.1}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1100, \'a72}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{CS97, \'a7181.1A}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7181.17}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{181.2}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Duties and objects of association.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The Iowa beef cattle producers association shall do all of the following:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Aid in the marketing and promotion of the cattle industry of the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Conduct research on beef production and evaluate Iowa beef production needs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide educational materials and opportunities to consumers, producers, and youth regarding the benefits of Iowa\u8217\'3fs beef cattle industry.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prepare an annual report of the proceedings and expenditures of the executive committee as provided in }}}{{\f5\fs18\hyphpar0\qj{section 181.18B}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2950;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7181.2}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1146, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1037, \'a72, 19}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1043, \'a73, 21}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{181.3}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Executive committee }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ creation and operation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An executive committee of the Iowa beef cattle producers association is created. The executive committee consists of ten members, including all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Five producers elected by the Iowa beef cattle producers association pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 181.6A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Two producers appointed by the Iowa cattlemen\u8217\'3fs association.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{One livestock market representative appointed pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The secretary of agriculture or a designee, who shall serve as an ex officio, voting member.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The dean of the college of agriculture and life sciences of Iowa state university of science and technology or a designee, who shall serve as an ex officio, voting member.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The Iowa livestock auction market association shall nominate two livestock market representatives. The secretary of agriculture shall appoint one of the nominees or another livestock market representative of the secretary\u8217\'3fs choice, who shall serve at the pleasure of the secretary.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The executive committee shall elect a chairperson, secretary, and other officers it deems necessary.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A member who is a producer or livestock market representative described in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ through }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, shall serve a three-year term. The member shall not serve more than two consecutive full terms.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except for an ex officio member, a vacancy in the executive committee resulting from death, inability or refusal to serve, or failure to meet the qualifications of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall be filled by the executive committee. If the executive committee fails to fill a vacancy, the secretary shall appoint a person to fill the vacancy. A vacancy appointment shall be filled only for the remainder of the unexpired term.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2951;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7181.3}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1100, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 30, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1037, \'a73, 4, 19}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1032, \'a730}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1043, \'a74, 21}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 29, \'a750}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7181.1}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{181.4}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Executive committee }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ employees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The executive committee may employ two or more competent persons who shall devote their entire time, under the direction of the executive committee, in carrying out the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{. The salary of persons so employed shall be set by the executive committee, and the persons shall hold office at the pleasure of the executive committee.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2952;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7181.4}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1100, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1037, \'a75, 19}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1043, \'a75, 21}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{181.5}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Expenses of officers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The officers of the association shall serve without compensation, but shall receive their necessary expenses while engaged in the business of the association.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2953;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7181.5}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{181.6}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{181.6A}}}{\*\bkmkstart stylerid1_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Executive committee }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ election.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The Iowa beef cattle producers association shall hold an annual meeting of producers. An election shall be held at the annual meeting, as necessary, for election of producers to the executive committee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prior to the annual meeting, the association shall appoint a nominating committee. At least sixty days prior to the annual meeting of the association, the nominating committee shall nominate two producers as candidates for each position on the executive committee for which an election is to be held. At least forty-five days prior to the annual meeting of the association, additional candidates may be nominated by a written petition of fifty producers. Procedures governing the place of filing and the contents of the petition shall be promulgated and publicized by the executive committee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Producers attending the annual meeting of the association may vote for one nominee for each position on the executive committee for which an election is held. Producers not attending the annual meeting of the association may vote by absentee ballot if the ballot is requested and mailed, with proper postage, to the executive committee prior to the annual meeting of the association. For each position for which an election is held, the candidate receiving the highest number of votes shall be elected.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notice of election for executive committee membership shall be given by the executive committee by publication in a newspaper of general circulation in the state and in any other reasonable manner as determined by the executive committee, and shall set forth the date, time, and place of the annual meeting of the association. The executive committee shall administer the elections, with the assistance of the secretary.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1100, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1037, \'a76, 19}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1043, \'a76, 21}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7181.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{181.7}}}{\*\bkmkstart stylerid1_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Executive committee }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ research and education programs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The executive committee shall initiate, administer, or participate in research and education programs directed toward the better and more efficient production, promotion, and utilization of cattle and the marketing of products made from cattle. The executive committee shall provide for the methods and means that it determines are necessary to further the purposes of }{{\f5\fs18\hyphpar0\qj{this section}}}{, including but not limited to any of the following:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Providing public relations and other promotion techniques for the maintenance of present markets.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Making donations to nonprofit organizations furthering the purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Assisting in the development of new or larger domestic markets for products made from cattle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Assisting in the development of new or larger foreign markets for cattle and products made from cattle.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7181.7}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1037, \'a77, 19}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1043, \'a77, 21}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7181.13}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{181.7A}}}{\*\bkmkstart stylerid1_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Commencement of federal assessment }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ suspension and recommencement of state assessment }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ rate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prior to the commencement of the collection of the federal assessment, the executive committee may seek certification as a qualified state beef council within the meaning of the federal Act.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The executive committee shall suspend the state assessment upon collection of the federal assessment. The state assessment shall recommence upon the earlier of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The noncollection of the federal assessment. The recommenced state assessment shall be imposed for a four-year period. Its effective date shall be the first date for which the federal assessment is not collected.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The passage of a special referendum pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 181.19}}}{{\f5\fs18\hyphpar0\qj{ regardless of whether a federal assessment is being collected.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The rate of the recommenced state assessment shall be the same as the rate that was last in effect under }}}{{\f5\fs18\hyphpar0\qj{section 181.19}}}{{\f5\fs18\hyphpar0\qj{ immediately prior to the suspension of the state assessment.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1100, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1037, \'a78, 19}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1043, \'a78, 21}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7181.13}}}{{\f5\fs12\hyphpar0\qj{, 181.19}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{181.8}}}{\*\bkmkstart stylerid1_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Executive committee }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ entering premises }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ examining records.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The executive committee may authorize its agents to enter at a reasonable time upon the premises of any purchaser charged by }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ with remitting the state assessment to the executive committee, and to examine records and other instruments relating to the collection of the state assessment. However, the executive committee must first have reasonable grounds to believe that the state assessment has not been remitted or fully accounted for.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7181.8}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1037, \'a79, 19}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1043, \'a79, 21}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{181.9 and 181.10}}}{Repealed by }{{\f5\fs18\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2004/CH1037.pdf" }{\fldrslt \f5 \fs18{{2004 Acts, ch 1037, \'a718, 19}}}}}}{{\f5\fs18\qj{2004 Acts, ch 1037, \'a718, 19}}}{. }{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{181.11}}}{\*\bkmkstart stylerid1_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Collection of state assessment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A state assessment imposed as provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall be levied and collected from the purchaser on each sale of cattle at a rate provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. The state assessment shall be imposed on any person selling cattle and shall be deducted by the purchaser from the price paid to the seller. The purchaser, at the time of the sale, shall make and deliver to the seller a separate invoice for each sale showing the names and addresses of the seller and the purchaser, the number of cattle sold, and the date of sale. The purchaser shall forward the state assessment to the executive committee at a time prescribed by the executive committee, but not later than the last day of the month following the end of the prior reporting period in which the cattle are sold.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The executive committee may enter into arrangements with persons purchasing cattle outside of this state for remitting the state assessment by such purchasers.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1037, \'a710, 19}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1043, \'a710, 21}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7181.15}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{181.12}}}{\*\bkmkstart stylerid1_2E18_2E2_2E2}{\*\bkmkend stylerid1_2E18_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Remission of state assessment on application.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A person from whom a state assessment is collected may, by written application filed with the executive committee within ninety days after its collection, have the amount remitted to the person by the executive committee. The information that the state assessment is refundable and the address of the executive committee to which application for a refund may be made shall appear on the invoice of sale form supplied by the purchaser to the producer near the area on the form which shows the amount of the state assessment paid. The executive committee shall furnish uniform application for refund forms and make the refund forms readily available to all producers. A purchaser charged by }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ with remitting the state assessment shall make the forms readily available to all producers.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7181.12}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 71, \'a71}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1037, \'a711, 19}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1043, \'a711, 21}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Right to refund not subject to execution or transfer; }{{\f5\fs12\hyphpar0\qj{\'a7179.5A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{181.13}}}{\*\bkmkstart stylerid1_2E19_2E2_2E2}{\*\bkmkend stylerid1_2E19_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Administration of moneys originating from state assessment }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ appropriation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All state assessments imposed under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall be paid to and collected by the executive committee and deposited with the treasurer of state in a separate cattle promotion fund which shall be created by the treasurer of state. The department of administrative services shall transfer moneys from the fund to the executive committee for deposit into an account established by the executive committee in a qualified financial institution. The department shall transfer the moneys as provided in a resolution adopted by the executive committee. However, the department is only required to transfer moneys once during each day and only during hours when the offices of the state are open. From the moneys collected, deposited, and transferred to the executive committee, in accordance with the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, the executive committee shall first pay the costs of referendums held pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, the costs of collection of such state assessments, and the expenses of its agents. At least ten percent of the remaining moneys shall be remitted to the association in proportions determined by the executive committee, for use in a manner not inconsistent with }}}{{\f5\fs18\hyphpar0\qj{section 181.7}}}{{\f5\fs18\hyphpar0\qj{. The remaining moneys, with approval of a majority of the executive committee, shall be expended as the executive committee finds necessary to carry out the provisions and purposes of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. However, in no event shall the total expenses exceed the total amount transferred from the fund for use by the executive committee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All moneys deposited in the cattle promotion fund and transferred to the executive committee pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ are appropriated and shall be used for the administration of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and for the payment of claims based upon obligations incurred in the performance of activities and functions set forth in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the state assessment is suspended as provided in }}}{{\f5\fs18\hyphpar0\qj{section 181.7A}}}{{\f5\fs18\hyphpar0\qj{ or a continuance referendum fails to pass as provided in }}}{{\f5\fs18\hyphpar0\qj{section 181.19A}}}{{\f5\fs18\hyphpar0\qj{, moneys remaining in the cattle promotion fund and transferred to the executive committee shall continue to be transferred and expended in accordance with the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ until exhausted.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7181.13}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1100, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1146, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 30, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 145, \'a7286}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1037, \'a712, 19}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1030, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1043, \'a712, 21}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{181.14}}}{\*\bkmkstart stylerid1_2E2_30_2E2_2E2}{\*\bkmkend stylerid1_2E2_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Notice.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2004/CH1037.pdf" }{\fldrslt \cf5 \f5 \fs18{{2004 Acts, ch 1037, \'a718, 19}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{181.15}}}{\*\bkmkstart stylerid1_2E21_2E2_2E2}{\*\bkmkend stylerid1_2E21_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Referendum \u8212\'3f procedures.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Upon receiving a petition to conduct a referendum as provided in }{{\f5\fs18\hyphpar0\qj{section 181.19}}}{ or }{{\f5\fs18\hyphpar0\qj{181.19A}}}{, the secretary shall conduct the referendum as follows:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The secretary shall provide for the publication of a notice of the referendum for a period of not less than five days in a newspaper of general circulation in the state and in such other newspapers as the secretary may prescribe. The notice of referendum shall set forth the period for voting and the voting places for the referendum and the amount of the state assessment. A referendum shall not be commenced prior to fourteen days after the last day of such period of publication.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each producer upon signing a statement certifying that the person is a bona fide producer shall be entitled to one vote. At the close of the referendum period, the secretary shall count and tabulate the ballots filed during the referendum period. The ballots cast in the referendum shall constitute complete and conclusive evidence for use in any determination made by the secretary under the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The secretary shall tabulate the ballots to determine whether the referendum has passed. If from such tabulation the secretary determines that a majority of the total number of producers voting approves the imposition of a state assessment, the state assessment shall be imposed as provided in }}}{{\f5\fs18\hyphpar0\qj{section 181.11}}}{{\f5\fs18\hyphpar0\qj{ at a rate provided for in }}}{{\f5\fs18\hyphpar0\qj{section 181.19}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The secretary may prescribe such additional procedures as may be necessary to conduct a referendum.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7181.15}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1195, \'a73}}}{; }{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1037, \'a713, 19}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{181.16}}}{\*\bkmkstart stylerid1_2E22_2E2_2E2}{\*\bkmkend stylerid1_2E22_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Moneys remaining in fund.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2004/CH1037.pdf" }{\fldrslt \cf5 \f5 \fs18{{2004 Acts, ch 1037, \'a718, 19}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{181.17}}}{\*\bkmkstart stylerid1_2E23_2E2_2E2}{\*\bkmkend stylerid1_2E23_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Executive committee }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ election }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ voting by nonmember producers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A producer who is not a member of the Iowa beef cattle producers association shall be entitled to vote in elections of persons to be members of the executive committee in the same manner as if the producer were a member. The members elected to the executive committee shall elect from their number the officers referred to in }{{\f5\fs18\hyphpar0\qj{section 181.1A}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7181.17}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 30, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 3, \'a746}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1043, \'a713, 21}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{181.18}}}{\*\bkmkstart stylerid1_2E24_2E2_2E2}{\*\bkmkend stylerid1_2E24_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Rules.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{All rules adopted by the executive committee shall be subject to the provisions of }{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7181.18}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 3, \'a747}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1043, \'a714, 21}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{181.18A}}}{\*\bkmkstart stylerid1_2E25_2E2_2E2}{\*\bkmkend stylerid1_2E25_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Not a state agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The Iowa beef cattle producers association is not an agency of state government.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{93 Acts, ch 102, \'a71}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{181.18B}}}{\*\bkmkstart stylerid1_2E26_2E2_2E2}{\*\bkmkend stylerid1_2E26_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Report.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Each year, the executive committee shall prepare and submit a report summarizing the activities of the executive committee under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ to the auditor of state and the secretary of agriculture. The report shall show all income, expenses, and other relevant information concerning fees collected and expended under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1146, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1037, \'a714, 19}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1043, \'a715, 21}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7181.2}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{181.19}}}{\*\bkmkstart stylerid1_2E27_2E2_2E2}{\*\bkmkend stylerid1_2E27_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Initial and special referendums.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The secretary shall, upon the petition of five hundred producers, conduct an initial referendum to determine whether a state assessment is to be imposed, at a rate established by the executive committee not to exceed one dollar per head on all cattle sold for any purpose.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The secretary shall, upon the petition of five hundred producers, conduct a special referendum to do any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Determine whether a state assessment already imposed shall be increased to a rate, established by the executive committee, not to exceed one dollar per head on all cattle sold for any purpose.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Determine whether a state assessment suspended pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 181.7A}}}{{\f5\fs18\hyphpar0\qj{ is to be in addition to a federal assessment. The state assessment shall be imposed at a rate not to exceed one dollar per head on all cattle sold for whatever purpose.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a referendum passes, the secretary shall establish an effective date to commence the state assessment. However, the state assessment must be commenced within ninety days from the date that the secretary determines that the referendum has passed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a special referendum to increase the rate of the state assessment does not pass, the result of the special referendum shall not affect the existence or length of the state assessment in effect on the date that the special referendum was conducted.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7181.19}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 71, \'a72}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1195, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 30, \'a76, 7}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1037, \'a715, 19}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1043, \'a716, 21}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7181.7A}}}{{\f5\fs12\hyphpar0\qj{, 181.15}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{181.19A}}}{\*\bkmkstart stylerid1_2E28_2E2_2E2}{\*\bkmkend stylerid1_2E28_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Continuance referendum.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The secretary shall, upon the petition of producers, conduct a continuance referendum to determine whether a state assessment should be renewed. The secretary must receive the petition not less than one hundred fifty and not more than two hundred forty days before the four-year anniversary of a state assessment\u8217\'3fs effective date. The petition must be signed within that period by a number of producers equal to or greater than two percent of the number of producers in this state reported in the most recent United States census of agriculture, requesting a referendum to determine whether to continue the state assessment. The referendum shall be conducted not earlier than thirty days before the four-year anniversary date of the state assessment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the secretary determines that a continuance referendum has passed, the state assessment shall continue in effect for four additional years from the anniversary of its effective date.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the secretary determines that the referendum has not passed, the secretary and the executive committee shall terminate the assessment in an orderly manner as soon as practicable after the determination. Another referendum shall not be held for at least one hundred eighty days from the date that the assessment is terminated.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If no valid petition for a continuance referendum is received by the secretary within the time period provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the state assessment shall continue in effect for four additional years from the anniversary of its effective date.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1037, \'a716, 19}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1043, \'a717, 21}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7181.13}}}{{\f5\fs12\hyphpar0\qj{, 181.15}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{181.20}}}{\*\bkmkstart stylerid1_2E29_2E2_2E2}{\*\bkmkend stylerid1_2E29_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Misdemeanors.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Any person who shall violate or assist in the violation of any of the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ shall be deemed guilty of a simple misdemeanor.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, \'a7181.19; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7181.20}}}{]}\par}}