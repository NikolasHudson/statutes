\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F8_305}{\*\bkmkend codeChapter_5F8_305}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 805}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{CITATIONS IN LIEU OF ARREST}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a7100.41}}}{{\f5\fs12\qc{, 664A.3}}}{{\f5\fs12\qc{, 801.1}}}{{\f5\fs12\qc{, 804.22}}}\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E5_2E1_2E1}{POLICE CITATIONS}{\*\bkmkend stylerid1_2E5_2E1_2E1}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{805.1}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Issuance of citation \u8212\'3f release.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except for an offense for which an accused would not be eligible for bail under }}}{{\f5\fs18\hyphpar0\qj{section 811.1}}}{{\f5\fs18\hyphpar0\qj{ or a violation of }}}{{\f5\fs18\hyphpar0\qj{section 708.11}}}{{\f5\fs18\hyphpar0\qj{, a peace officer having grounds to make an arrest may issue a citation in lieu of making an arrest without a warrant or, if a warrantless arrest has been made, a citation may be issued in lieu of continued custody.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The citation procedure for traffic and other violations designated as scheduled violations is governed by }}}{{\f5\fs18\hyphpar0\qj{sections 805.6 through 805.15}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{State and local law enforcement agencies in the state of Iowa may cooperate to formulate uniform guidelines that will provide for the maximum possible use of citations in lieu of arrest and in lieu of continued custody for offenses for which citations are authorized. These guidelines shall be submitted to the Iowa law enforcement academy council for review. The Iowa law enforcement academy council shall then submit recommendations to the general assembly no later than January 1, 1984.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Factors to be considered by the agencies in formulating the guidelines relating to the issuance of citations for simple misdemeanors not governed by }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, shall include but shall not be limited to all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Whether a person refuses or fails to produce means for a satisfactory identification.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Whether a person refuses to sign the citation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Whether detention appears reasonably necessary in order to halt a continuing offense or disturbance or to prevent harm to a person or persons.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Whether a person appears to be under the influence of intoxicants or drugs and no one is available to take custody of the person and be responsible for the person\u8217\'3fs safety.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Whether a person has insufficient ties to the jurisdiction to assure that the person will appear or it reasonably appears that there is a substantial likelihood that the person will refuse to appear in response to a citation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Whether a person has previously failed to appear in response to a citation or after release on pretrial release guidelines.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Additional factors to be considered in the formulation of guidelines relating to the issuance of citations for other offenses for which citations are authorized shall include but shall not be limited to all of the following concerning the person:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Place and length of residence.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Family relationships.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{References.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Present and past employment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Criminal record.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Nature and circumstances of the alleged offense.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(7)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Other facts relevant to the likelihood of the person\u8217\'3fs response to a citation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The issuance of a citation in lieu of arrest or in lieu of continued custody does not affect the officer\u8217\'3fs authority to conduct an otherwise lawful search. The issuance of a citation in lieu of arrest shall be deemed an arrest for the purpose of the speedy indictment requirements of rule of }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/ACO/CourtRulesChapter/2.pdf" }{\fldrslt \f5 \fs18{{\f5\b\fs18\hyphpar0\qj\cf5{criminal procedure 2.33(2)(a)}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{, Iowa court rules.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Even if a citation is issued, the officer may take the cited person to an appropriate medical facility if it reasonably appears that the person needs care.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When a citation is not issued for an offense for which a citation is authorized, the arrested person may be released pending initial appearance on bail or on other conditions determined by pretrial release guidelines. When an arrested person furnishes bail, the officer then in charge of the place of detention shall secure it in safekeeping and shall see that it is forwarded to the office of the clerk of court during the clerk\u8217\'3fs next regular business day.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When the offense is one for which a citation is not authorized, the person does not qualify for release under pretrial release guidelines and the person cannot be released under a bond schedule, the person may be released on bail or otherwise only after initial appearance before a magistrate as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 804}}}{{\f5\fs18\hyphpar0\qj{ and the rules of criminal procedure.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, 75, 77, \'a7753.5; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7805.1}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 51, \'a76, 9}}}{; }{{\f5\fs18\hyphpar0\qj{87 Acts, ch 149, \'a76}}}{; }{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1158, \'a799}}}{; }{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1167, \'a76}}}{; }{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1093, \'a75}}}{; }{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 24, \'a760}}}{; }{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1119, \'a7109}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7364.17}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Arrest, see }{{\f5\fs12\hyphpar0\qj{\'a7804.1}}}{, }{{\f5\fs12\hyphpar0\qj{804.7}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Uniform citation, see }{{\f5\fs12\hyphpar0\qj{\'a7805.6}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Persons under eighteen years; see }{{\f5\fs12\hyphpar0\qj{\'a7805.16}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{805.2}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Form.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The citation shall include the name and address of the person, the nature of the offense, the time and place at which the person is to appear in court, and the penalty for nonappearance.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, 75, 77, \'a7753.6; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7805.2}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7364.17}}}{{\f5\fs12\hyphpar0\qj{, 805.6}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{805.3}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Procedure.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Before the cited person is released, the person shall sign the citation, either in a paper or electronic format, under penalty of providing false identification information under }{{\f5\fs18\hyphpar0\qj{section 719.1A}}}{, properly identifying the person cited. The person\u8217\'3fs signature shall also serve as a written promise to appear in court at the time and place specified. A copy of the citation shall be given to the person.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, 75, 77, \'a7753.7; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7805.3}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{95 Acts, ch 81, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 118, \'a734}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1078, \'a73}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7364.17}}}{{\f5\fs12\hyphpar0\qj{, 805.6}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{805.4}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Complaint.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The law enforcement officer issuing the citation shall cause to be filed a complaint in the court in which the cited person is required to appear, as soon as practicable, charging the crime stated in said notice.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, 75, 77, \'a7753.8; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7805.4}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7364.17}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Contents and procedures, see }{{\f5\fs12\hyphpar0\qj{\'a7804.1}}}{; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0{{\f5\fs12\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/ACO/CourtRulesChapter/2.pdf" }{\fldrslt \f5 \fs12{{\f5\b\fs12\hyphpar0\qj\cf5{R.Cr.P. 2.54 \u8211\'3f 2.56 }}}}}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{805.5}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Failure to appear.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Any person who willfully fails to appear in court as specified by the citation shall be guilty of a simple misdemeanor. Where a defendant fails to make a required court appearance, the court shall issue an arrest warrant for the offense of failure to appear, and shall forward the warrant and the original or electronically produced citation to the clerk. The clerk shall enter a transfer to the issuing agency on the docket, and shall return the warrant with the original or electronically produced citation attached to the law enforcement agency which issued the citation for enforcement of the warrant. Upon arrest of the defendant, the warrant and the original or electronically produced citation shall be returned to the court, and the offenses shall be heard and disposed of simultaneously.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, 75, 77, \'a7753.9; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7805.5}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{95 Acts, ch 118, \'a735}}}{; }{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1034, \'a765}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7364.17}}}{{\f5\fs12\hyphpar0\qj{, 602.8102(126)}}}\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E11_2E1_2E1}{TRAFFIC AND SCHEDULED VIOLATIONS}{\*\bkmkend stylerid1_2E11_2E1_2E1}\par}{}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\ri1445\li1445{\f5\fs12\qc}{Surcharge on penalty, }{{\f5\fs12\qc{chapter 911}}}\par}{\pard\plain\keep\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{805.6}}}{\*\bkmkstart stylerid1_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Uniform citation and complaint.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commissioner of public safety, the director of transportation, and the director of the department of natural resources, acting jointly, shall adopt a uniform, combined citation and complaint which shall be used for charging all traffic violations in Iowa under state law or local regulation or ordinance, and which shall be used for charging all other violations which are designated by }}}{{\f5\fs18\hyphpar0\qj{sections 805.8A}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{805.8B}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{805.8C}}}{{\f5\fs18\hyphpar0\qj{ to be scheduled violations. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ does not prevent the charging of any of those violations by information, by private complaint filed under }}}{{\f5\fs18\hyphpar0\qj{chapter 804}}}{{\f5\fs18\hyphpar0\qj{, or by a simple notice of fine where permitted by }}}{{\f5\fs18\hyphpar0\qj{section 321.236, subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to those violations which are required by paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ to be charged upon a uniform citation and complaint, a violation of }}}{{\f5\fs18\hyphpar0\qj{chapter 321}}}{{\f5\fs18\hyphpar0\qj{ which is punishable as a simple, serious, or aggravated misdemeanor may be charged upon a uniform citation and complaint, whether or not the alleged offender is arrested by the officer making the charge.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each uniform citation and complaint shall be serially numbered and shall be in quintuplicate, and the officer shall deliver the original and a copy to the court where the defendant is to appear, two copies to the defendant, and a copy to the law enforcement agency of the officer. Notwithstanding other contrary requirements of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, a uniform citation and complaint may be originated from a computerized device. The officer issuing the citation through a computerized device shall electronically sign and date the citation or complaint and shall obtain electronically the signature of the person cited as provided in }}}{{\f5\fs18\hyphpar0\qj{section 805.3}}}{{\f5\fs18\hyphpar0\qj{ and shall give two copies of the citation to the person cited and shall provide a record of the citation to the court where the person cited is to appear and to the law enforcement agency of the officer by an electronic process which accurately reproduces or forms a durable medium for accurately and legibly reproducing an unaltered image or copy of the citation. If the uniform citation and complaint is created electronically, the issuing agency shall cause the uniform citation and complaint to be transmitted to the court, and the officer shall deliver a document to the defendant which contains a section for the defendant and a section which may be sent to the court. The court shall forward an abstract of the uniform citation and complaint in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 321.491}}}{{\f5\fs18\hyphpar0\qj{ when applicable.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The uniform citation and complaint shall contain spaces for the following: }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The parties\u8217\'3f names. }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The address of the alleged offender. }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The registration number of the offender\u8217\'3fs vehicle. }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The information required by }}}{{\f5\fs18\hyphpar0\qj{section 805.2}}}{{\f5\fs18\hyphpar0\qj{. }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(e)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A warning which states: }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb80\ri1084\li1084\sa80{{\f5\fs18\hyphpar0\qj{\~\~}}}{ I hereby swear and affirm that the information provided by me on this citation is true under penalty of providing false information.}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(f)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A statement that providing false identification information is a violation of }}}{{\f5\fs18\hyphpar0\qj{section 719.1A}}}{{\f5\fs18\hyphpar0\qj{. }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(g)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A list of the scheduled fines prescribed by }}}{{\f5\fs18\hyphpar0\qj{sections 805.8A}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{805.8B}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{805.8C}}}{{\f5\fs18\hyphpar0\qj{, either separately or by group, and a statement of the court costs payable in scheduled violation cases, whether or not a court appearance is required or is demanded. }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(h)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A brief explanation of }}}{{\f5\fs18\hyphpar0\qj{sections 805.9}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{805.10}}}{{\f5\fs18\hyphpar0\qj{. }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A space where the defendant may sign an admission of the violation when permitted by }}}{{\f5\fs18\hyphpar0\qj{section 805.9}}}{{\f5\fs18\hyphpar0\qj{. }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The uniform citation and complaint shall require that the defendant appear before a court at a specified time and place.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The uniform citation and complaint also may contain a space for the imprint of a credit card, and may contain any other information which the commissioner of public safety, the director of transportation, and the director of the department of natural resources may determine.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The uniform citation and complaint shall also contain the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A promise to appear as provided in }}}{{\f5\fs18\hyphpar0\qj{section 805.3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The following statement:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb80\ri1084\li1084\sa80{{\f5\fs18\hyphpar0\qj{\~\~}}}{I hereby give my unsecured appearance bond in the amount of }{{\f5\fs18\hyphpar0\qj{................}}}{ dollars and enter my written appearance. I agree that if I fail to appear in person or by counsel to defend against the offense charged in this citation the court is authorized to enter a conviction and render judgment against me for the amount of my appearance bond in satisfaction of the penalty plus court costs.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A space immediately below the items in subparagraphs (1) and (2) for the signature of the person being charged which shall serve for each of the items in subparagraphs (1) and (2).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A place for citing a person in violation of }}}{{\f5\fs18\hyphpar0\qj{section 453A.2, subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The uniform citation and complaint shall contain a place for the verification of the officer issuing the complaint. The complaint may be verified before the chief officer of the law enforcement agency, or the chief officer\u8217\'3fs designee. The chief officer of each law enforcement agency of the state may designate specific individuals to administer oaths and certify verifications.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Unless the officer issuing the citation arrests the alleged offender, or permits admission or requires submission of bail as provided in }}}{{\f5\fs18\hyphpar0\qj{section 805.9, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, the officer shall enter in the blank contained in the statement required by }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, one of the following amounts and shall require the person to sign the written appearance:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the offense is one to which an assessment of a minimum fine is applicable and the entry is otherwise not prohibited by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, an amount equal to one and one-half times the minimum fine and applicable surcharge assessed pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 911}}}{{\f5\fs18\hyphpar0\qj{, plus court costs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the offense is one to which a scheduled fine is applicable, an amount equal to one and one-half times the scheduled fine and applicable surcharge assessed pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 911}}}{{\f5\fs18\hyphpar0\qj{, plus court costs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the violation is for any offense for which a court appearance is mandatory, and an assessment of a minimum fine is not applicable, the amount of one hundred dollars and applicable surcharge assessed pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 911}}}{{\f5\fs18\hyphpar0\qj{, plus court costs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The written appearance defined in }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, shall not be used for any offense other than a simple misdemeanor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The filing fees and court costs in cases of parking meter and overtime parking violations which are denied are as stated in }}}{{\f5\fs18\hyphpar0\qj{section 602.8106, subsection 1}}}{{\f5\fs18\hyphpar0\qj{. The court costs in scheduled violation cases where a court appearance is not required are as stated in }}}{{\f5\fs18\hyphpar0\qj{section 602.8106, subsection 1}}}{{\f5\fs18\hyphpar0\qj{. The court costs in scheduled violation cases where a court appearance is required are as stated in }}}{{\f5\fs18\hyphpar0\qj{section 602.8106, subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Supplies of the uniform citation and complaint for municipal corporations and county agencies shall be paid for out of the budget of the municipal corporation or county receiving the fine resulting from use of the citation and complaint. Supplies of the uniform citation and complaint form used by other agencies shall be paid for out of the budget of the agency concerned and not out of the budget of the judicial branch.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commissioner of public safety and the director of the department of natural resources, acting jointly, shall design and publish a compendium of scheduled violations and scheduled fines, containing other information which they deem appropriate, and shall distribute copies to all courts and law enforcement officers and agencies of the state upon request. The cost of the publication shall be paid out of the budget of the department of public safety and out of the budget of the department of natural resources, each budget being liable for half of those costs. Copies shall be made available to individuals upon request, and a charge may be collected which does not exceed the cost of printing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Supplies of uniform citation and complaint forms existing or on order on July 1, 2010, may be used until exhausted.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, 75, 77, \'a7753.13; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7805.6}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 123, \'a7201, 209}}}{{\f5\fs18\hyphpar0\qj{; 83 Acts, ch 204, \'a78, 9}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 197, \'a740, 41}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1237, \'a744}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1238, \'a731}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 167, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 296, \'a790}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1170, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1230, \'a793}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 116, \'a721}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1074, \'a715, 16}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 81, \'a72 \u8211\'3f 5}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 118, \'a736}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1047, \'a766}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1178, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1105, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1131, \'a71 \u8211\'3f 3}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 6, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 137, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 6, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 33, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 215, \'a7259}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 130, \'a716, 42}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1069, \'a763}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1078, \'a74, 5}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1193, \'a766, 67, 79}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 30, \'a7168}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 167, \'a723}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a79B.17}}}{{\f5\fs12\hyphpar0\qj{, 321.236}}}{{\f5\fs12\hyphpar0\qj{, 321.485}}}{{\f5\fs12\hyphpar0\qj{, 331.424}}}{{\f5\fs12\hyphpar0\qj{, 602.8102(126A)}}}{{\f5\fs12\hyphpar0\qj{, 805.1}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(1)(a)}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(12)(e)}}}{{\f5\fs12\hyphpar0\qj{, 805.15}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{805.7}}}{\*\bkmkstart stylerid1_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Traffic and scheduled violations offices \u8212\'3f fine collection boxes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E13_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E13_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Offices.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each district court clerk\u8217\'3fs office shall constitute a traffic and scheduled violations office of the district court. Additional offices may be established at other locations, as needed, if authorized by the chief judge of the district.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E13_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E13_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Collection boxes.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The chief judge of the district may permit the maintenance of locked collection boxes to be used at weigh stations and other locations where vehicles are inspected and weighed with portable scales. The boxes shall be used solely for the deposit of fines, costs, and guaranteed arrest bond certificates received for scheduled violations applicable to commercial carriers. The collection boxes shall remain locked at all times and shall be opened only by the clerk of the district court or the clerk\u8217\'3fs designee. The chief judge of the district may prescribe procedures for the system and may discontinue its use if necessary.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, 75, 77, \'a7753.14; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7805.7}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 296, \'a791}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7602.8102(127)}}}{{\f5\fs12\hyphpar0\qj{, 805.1}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(12)(e)}}}{{\f5\fs12\hyphpar0\qj{, 805.15}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{805.8}}}{\*\bkmkstart stylerid1_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Scheduled violations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E14_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E14_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Application.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as otherwise indicated, violations of sections of the Code specified in }}}{{\f5\fs18\hyphpar0\qj{sections 805.8A}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{805.8B}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{805.8C}}}{{\f5\fs18\hyphpar0\qj{ are scheduled violations, and the scheduled fine for each of those violations is as provided in those sections, whether the violation is of state law or of a county or city ordinance. The crime services surcharge required by }}}{{\f5\fs18\hyphpar0\qj{section 911.1}}}{{\f5\fs18\hyphpar0\qj{ shall be added to the scheduled fine.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E14_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E14_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Description of violations.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The descriptions of offenses used in }}}{{\f5\fs18\hyphpar0\qj{sections 805.8A}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{805.8B}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{805.8C}}}{{\f5\fs18\hyphpar0\qj{ are for convenience only and shall not be construed to define any offense or to include or exclude any offense other than those specifically included or excluded by reference to the Code. A reference to a section or subsection of the Code without further limitation includes every offense defined by that section or subsection.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, 75, 77, \'a7753.15; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7805.8}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 49, \'a714}}}{, }{{\f5\fs18\hyphpar0\qj{ch 103, \'a79}}}{, }{{\f5\fs18\hyphpar0\qj{ch 109, \'a72}}}{, }{{\f5\fs18\hyphpar0\qj{ch 110, \'a74}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1028, \'a737 \u8211\'3f 39}}}{, }{{\f5\fs18\hyphpar0\qj{ch 1104, \'a726}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1062, \'a733, 38}}}{{\f5\fs18\hyphpar0\qj{; 83 Acts, ch 58, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 83 Acts, ch 125, \'a76 \u8211\'3f 8}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1016, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1174, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1219, \'a737}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 40, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 195, \'a762}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1007, \'a741}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1116, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1221, \'a73}}}{{\f5\fs18\hy