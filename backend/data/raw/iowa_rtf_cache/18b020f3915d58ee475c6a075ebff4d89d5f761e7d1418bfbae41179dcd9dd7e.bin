j{section 461A.38}}}{{\f5\fs18\hyphpar0\qj{, the scheduled fine is ten dollars. For a parking violation under }}}{{\f5\fs18\hyphpar0\qj{section 321.362}}}{{\f5\fs18\hyphpar0\qj{, the scheduled fine is twenty dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For a parking violation under }}}{{\f5\fs18\hyphpar0\qj{section 321L.2A, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, the scheduled fine is twenty dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For violations under }}}{{\f5\fs18\hyphpar0\qj{section 321L.2A, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{sections 321L.3}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{321L.4, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{section 321L.7}}}{{\f5\fs18\hyphpar0\qj{, the scheduled fine is two hundred dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E15_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Title and registration violations.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For title or registration violations under the following sections, the scheduled fine is as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Section 321.17}}}{\f5\fs18\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{ $}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{70.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Section 321.24}}}{\f5\fs18\hyphpar0\qj}{{\f5\