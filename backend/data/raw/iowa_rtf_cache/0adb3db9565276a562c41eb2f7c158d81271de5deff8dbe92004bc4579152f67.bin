\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F423F}{\*\bkmkend codeChapter_5F423F}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 423F}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{STATEWIDE SCHOOL INFRASTRUCTURE FUNDING}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a776.4}}}{{\f5\fs12\qc{, 256.9}}}{{\f5\fs12\qc{, 291.10}}}\par}{}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\ri1445\li1445{\f5\fs12\qc}{Chapter to be repealed January 1, 2051; see }{{\f5\fs12\qc{\'a7423F.6}}}\par}{\pard\plain\keep\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{423F.1}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Legislative intent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{It is the intent of the general assembly that the increase in the state sales, services, and use taxes under }{{\f5\fs18\hyphpar0\qj{chapter 423, subchapters II and III}}}{, from five percent to six percent on July 1, 2008, shall be used solely for purposes of providing revenues to local school districts under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ to be used solely for school infrastructure purposes or school district property tax relief.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1134, \'a727}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{423F.2}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Secure an advanced vision for education fund creation and distribution \u8212\'3f repeal of local sales and services taxes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{After July 1, 2008, all local sales and services taxes for school infrastructure purposes imposed under }}}{{\f5\fs18\hyphpar0\qj{chapter 423E}}}{{\f5\fs18\hyphpar0\qj{, Code 2023, are repealed. After July 1, 2008, a county no longer has the authority under }}}{{\f5\fs18\hyphpar0\qj{chapter 423E}}}{{\f5\fs18\hyphpar0\qj{, Code 2023, or any other provision of law to impose or to extend an existing local sales and services tax for school infrastructure purposes.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The increase in the state sales, services, and use taxes under }}}{{\f5\fs18\hyphpar0\qj{chapter 423, subchapters II and III}}}{{\f5\fs18\hyphpar0\qj{, from five percent to six percent shall replace the repeal of the county\u8217\'3fs local sales and services tax for school infrastructure purposes. The distribution of moneys in the secure an advanced vision for education fund and the use of the moneys for infrastructure purposes or property tax relief shall be as provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To the extent that any school district has issued bonds anticipating the proceeds of a local sales and services tax for school infrastructure purposes prior to July 1, 2008, the pledge of such tax receipts for the payment of principal and interest on such bonds shall be replaced by a pledge of its share of the revenues the school district receives under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A secure an advanced vision for education fund is created as a separate and distinct fund in the state treasury under the control of the department of revenue. Moneys in the fund include revenues credited to the fund pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, appropriations made to the fund, and other moneys deposited into the fund. Subject to }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{, any amounts disbursed from the fund shall be utilized for school infrastructure purposes or property tax relief.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The moneys available in a fiscal year in the secure an advanced vision for education fund shall be distributed by the department of revenue to each school district on a per pupil basis calculated using each school district\u8217\'3fs budget enrollment, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 257.6}}}{{\f5\fs18\hyphpar0\qj{, for that fiscal year.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prior to distribution of moneys in the secure an advanced vision for education fund to school districts, an amount equal to the equity transfer amount for the fiscal year minus the foundation base transfer amount for the fiscal year shall be distributed and credited to the property tax equity and relief fund created in }}}{{\f5\fs18\hyphpar0\qj{section 257.16A}}}{{\f5\fs18\hyphpar0\qj{, an amount equal to the foundation base transfer amount shall be distributed and credited to the foundation base supplement fund created in }}}{{\f5\fs18\hyphpar0\qj{section 257.16D}}}{{\f5\fs18\hyphpar0\qj{, and an amount equal to the career academy transfer amount for the fiscal year shall be distributed and credited to the career academy fund created in }}}{{\f5\fs18\hyphpar0\qj{section 257.51}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, the equity transfer amount is determined by multiplying the equity transfer percentage by the amount of moneys available in the secure an advanced vision for education fund in the fiscal year. }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the fiscal year beginning July 1, 2018, the equity transfer percentage is two and one-tenth percent. For the fiscal year beginning July 1, 2019, the equity transfer percentage is three and one-tenth percent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For each fiscal year beginning on or after July 1, 2020, the equity transfer percentage is equal to the equity transfer percentage for the immediately preceding fiscal year, unless the amount of moneys available in the secure an advanced vision for education fund in the immediately preceding fiscal year equals or exceeds one hundred two percent of the amount of moneys available in the fund for the fiscal year prior to the immediately preceding fiscal year, in which case the equity transfer percentage shall be the equity transfer percentage for the immediately preceding fiscal year plus one percent subject to the limitation in subparagraph division (c).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the equity transfer percentage calculated under subparagraph division (b) exceeds thirty percent, the equity transfer percentage for that fiscal year shall be thirty percent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, the foundation base transfer amount for the fiscal year beginning July 1, 2019, is zero, and for each fiscal year beginning on or after July 1, 2020, the foundation base transfer amount equals the equity transfer amount for the fiscal year under subparagraph (2) minus the sum of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Three and one-tenth percent of the amount of the moneys available in the secure an advanced vision for education fund in the fiscal year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{One-half of the product of the equity transfer percentage for the fiscal year minus three and one-tenth percent multiplied by the moneys available in the secure an advanced vision for education fund in the fiscal year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, the career academy transfer amount for the fiscal year beginning July 1, 2019, is one million dollars.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For each fiscal year beginning on or after July 1, 2020, the career academy transfer amount is equal to the lesser of five million dollars or the amount of the career academy transfer amount for the immediately preceding fiscal year, unless the amount of moneys available in the secure an advanced vision for education fund in the immediately preceding fiscal year equals or exceeds one hundred two and one-half percent of the amount of moneys available in the fund for the fiscal year prior to the immediately preceding fiscal year, in which case the career academy transfer amount equals the lesser of five million dollars or the sum of the amount of the career academy transfer amount for the immediately preceding fiscal year plus one-half percent of the amount of moneys available in the secure an advanced vision for education fund in the fiscal year following the deposit of revenues in the property tax equity and relief fund and the foundation base supplement fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director of revenue by the last day of each month shall transfer to each school district the amount of tax moneys remitted to the department attributable to each school district from the preceding month. }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On or before August 15 of each fiscal year the director of revenue shall provide to each school district an estimate of the amount of tax moneys to be distributed to each school district for the current fiscal year.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1134, \'a728}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1191, \'a772}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 140, \'a7134 \u8211\'3f 136}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 166, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1138, \'a748 \u8211\'3f 50}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7257.51}}}{{\f5\fs12\hyphpar0\qj{, 275.12}}}{{\f5\fs12\hyphpar0\qj{, 275.29}}}{{\f5\fs12\hyphpar0\qj{, 275.30}}}{{\f5\fs12\hyphpar0\qj{, 292.1}}}{{\f5\fs12\hyphpar0\qj{, 292.2}}}{{\f5\fs12\hyphpar0\qj{, 423.2A}}}{{\f5\fs12\hyphpar0\qj{, 423.43}}}{{\f5\fs12\hyphpar0\qj{, 423F.4}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{423F.3}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Use of revenues.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A school district receiving revenues from the secure an advanced vision for education fund under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ without a valid revenue purpose statement shall expend the revenues subject to }}}{{\f5\fs18\hyphpar0\qj{subsections 2 and 3}}}{{\f5\fs18\hyphpar0\qj{ for the following purposes:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reduction of bond levies under }}}{{\f5\fs18\hyphpar0\qj{sections 298.18}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{298.18A}}}{{\f5\fs18\hyphpar0\qj{ and all other debt levies.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reduction of the regular and voter-approved physical plant and equipment levy under }}}{{\f5\fs18\hyphpar0\qj{section 298.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reduction of the public educational and recreational levy under }}}{{\f5\fs18\hyphpar0\qj{section 300.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For any authorized infrastructure purpose of the school district as defined in }}}{{\f5\fs18\hyphpar0\qj{subsection 6}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the payment of principal and interest on bonds issued under }}}{{\f5\fs18\hyphpar0\qj{sections 423E.5}}}{{\f5\fs18\hyphpar0\qj{* and }}}{{\f5\fs18\hyphpar0\qj{423F.4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A revenue purpose statement in existence for the expenditure of local sales and services tax for school infrastructure purposes imposed by a county pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 423E.2}}}{{\f5\fs18\hyphpar0\qj{, Code Supplement 2007, prior to July 1, 2008, shall remain in effect until amended or extended. The board of directors of a school district may take action to adopt or amend a revenue purpose statement specifying the specific purposes for which the revenues received from the secure an advanced vision for education fund will be expended. If a school district is located in a county which has imposed a local sales and services tax for school infrastructure purposes prior to July 1, 2008, this action shall be taken before expending or anticipating revenues to be received after the unextended term of the tax unless the school district elects to adopt a revenue purpose statement as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the board of directors adopts a resolution to use funds received under the operation of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ solely for providing property tax relief by reducing indebtedness from the levies specified under }}}{{\f5\fs18\hyphpar0\qj{section 298.2}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{298.18}}}{{\f5\fs18\hyphpar0\qj{, or for radon testing pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 280.32}}}{{\f5\fs18\hyphpar0\qj{, the board of directors may approve a revenue purpose statement for that purpose without submitting the revenue purpose statement to a vote of the electors.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the board of directors intends to use funds for purposes other than those listed in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, or change the use of funds to purposes other than those listed in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the board shall adopt a revenue purpose statement or amend an existing revenue purpose statement, subject to approval of the electors, listing the proposed use of the funds. }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any provision of law to the contrary, for each school district with an existing revenue purpose statement for the use of revenues from the secure an advanced vision for education fund adopted under this paragraph or adopted under another provision of law before July 1, 2019, such revenue purpose statement shall terminate and be of no further force and effect on January 1, 2031, or the expiration date of the revenue purpose statement, whichever is earlier. If such a school district intends to use funds for purposes other than those listed in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and does not intend to operate without a revenue purpose statement on or after January 1, 2031, or the expiration date of the revenue purpose statement, whichever is earlier, the board of directors shall submit a revenue purpose statement for approval by the electors under subparagraph (1) on or after July 1, 2019, and such revenue purpose statement submitted to the electors shall include all proposed uses including those previously approved by the electors, if applicable. The following, in substantially the following form, shall be included in the notice of the election published under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and published on the school district\u8217\'3fs internet site:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb80\ri1084\li1084\sa80{If a majority of eligible electors voting on the question fail to approve this revenue purpose statement, revenues received by the school district from the secure an advanced vision for education fund shall first be expended for . . . . (State the purposes in the order listed in }{{\f5\fs18\hyphpar0\qj{subsection 1}}}{ and as required by }{{\f5\fs18\hyphpar0\qj{subsection 4}}}{ of }{{\f5\fs18\hyphpar0\qj{this section}}}{ for which the revenues received by the school district under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ will be expended.)}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Unless a new revenue purpose statement is adopted by the electors, the existing revenue purpose statement remains in effect until January 1, 2031, or the expiration date of the revenue purpose statement, whichever is earlier. If a revenue purpose statement is terminated under the provisions of this subparagraph, such termination shall not affect the validity of or a first lien on bonds issued under }}}{{\f5\fs18\hyphpar0\qj{section 423E.5}}}{{\f5\fs18\hyphpar0\qj{, Code 2019, or }}}{{\f5\fs18\hyphpar0\qj{section 423F.5}}}{{\f5\fs18\hyphpar0\qj{ prior to the date the revenue purpose statement is terminated under subparagraph division (a), or the validity of a contract or other obligation of the school district secured in whole or in part by or requiring the payment of funds received under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ in effect prior to the date the revenue purpose statement is terminated under subparagraph division (a).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of directors may use funds received under the operation of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ for a joint infrastructure project with one or more school districts or one or more school districts and a community college established under }}}{{\f5\fs18\hyphpar0\qj{chapter 260C}}}{{\f5\fs18\hyphpar0\qj{, for which buildings or facilities are constructed or leased for the purpose of offering classes under a district-to-community college sharing agreement or concurrent enrollment program that meets the requirements for funding under }}}{{\f5\fs18\hyphpar0\qj{section 257.11, subsection 3}}}{{\f5\fs18\hyphpar0\qj{. If the board intends to use funds received under the operation of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ for such a joint infrastructure project, the board shall adopt a revenue purpose statement or amend an existing revenue purpose statement, subject to approval of the electors, stating the proposed use of the funds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board secretary shall notify the county commissioner of elections of the intent to take an issue to the voters pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. The county commissioner of elections shall publish the notices required by law for special or general elections, and the election shall be held on a date specified in }}}{{\f5\fs18\hyphpar0\qj{section 39.2, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. A majority of those voting on the question must favor approval of the revenue purpose statement. If the proposal is not approved, the school district shall not submit the same or new revenue purpose statement to the electors for a period of six months from the date of the previous election.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The revenues received pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall be expended for the purposes specified in the revenue purpose statement. If a board of directors has not approved a revenue purpose statement, the revenues shall be expended in the order listed in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ except that the payment of bonds for which the revenues have been pledged shall be paid first. Once approved, a revenue purpose statement is effective until amended or repealed by the foregoing procedures. A revenue purpose statement shall not be amended or repealed to reduce the amount of revenue pledged to the payment of principal and interest on bonds as long as any bonds authorized by }}}{{\f5\fs18\hyphpar0\qj{sections 423E.5}}}{{\f5\fs18\hyphpar0\qj{* and }}}{{\f5\fs18\hyphpar0\qj{423F.4}}}{{\f5\fs18\hyphpar0\qj{ are outstanding unless funds sufficient to pay principal, interest, and premium, if any, on the outstanding obligations at or prior to maturity have been properly set aside and pledged for that purpose.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A school district with a certified enrollment of fewer than two hundred fifty pupils in the entire district or certified enrollment of fewer than one hundred pupils in high school shall not expend the amount received for new construction without prior application to the department of education and receipt of a certificate of need pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. A certificate of need is not required for repairing schoolhouses or buildings, equipment, technology, or transportation equipment for transporting students as provided in }}}{{\f5\fs18\hyphpar0\qj{section 298.3}}}{{\f5\fs18\hyphpar0\qj{, or for construction necessary for compliance with the federal Americans With Disabilities Act pursuant to 42 U.S.C. \'a712101 \u8211\'3f 12117. In determining whether a certificate of need shall be issued or denied, the department shall consider all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Enrollment trends in the grades that will be served at the new construction site.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The cost-benefit analysis of remodeling, reconstructing, or repairing existing buildings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The fire and health safety needs of the school district.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The distance, convenience, cost of transportation, and accessibility of the new construction site to the students to be served at the new construction site.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Availability of alternative, less costly, or more effective means of serving the needs of the students.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The financial condition of the district, including the effect of the decline of the budget guarantee and unspent balance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Broad and long-term ability of the district to support the facility and the quality of the academic program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Cooperation with other educational entities including other school districts, area education agencies, postsecondary institutions, and local communities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Benefits and effects of the new construction on student learning.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fschool infrastructure\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means those activities authorized in }}}{{\f5\fs18\hyphpar0\qj{section 423E.1, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, Code 2007.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Additionally, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fschool infrastructure\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes the payment or retirement of outstanding bonds previously issued for school infrastructure purposes as defined in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, and the payment or retirement of bonds issued under }}}{{\f5\fs18\hyphpar0\qj{sections 423E.5}}}{{\f5\fs18\hyphpar0\qj{* and }}}{{\f5\fs18\hyphpar0\qj{423F.4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Additionally, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fschool infrastructure\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes the acquisition or installation of information technology infrastructure. For purposes of this subparagraph, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3finformation technology infrastructure\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the basic, underlying physical framework or system necessary to deliver technology connectivity to a school district and to network school buildings within a school district.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Additionally, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fschool infrastructure\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes school safety and security infrastructure. For purposes of this subparagraph, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fschool safety and security infrastructure\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes but is not limited to safe rooms, remote entry technology and equipment, security camera systems, card access systems, and communication systems with access to fire and police emergency frequencies. For purposes of this subparagraph, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fschool safety and security infrastructure\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include the cost of personnel, development of safety and security plans, or training related to the implementation of safety and security plans.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Additionally, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fschool infrastructure\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes software or other innovative technology, and the cost of subscription and monitoring fees associated with such software or other innovative technology, that meets all of the following requirements:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is designed to detect and alert school district employees and first responders if there is a visible, unholstered firearm on property owned by the school district.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is capable of integrating with local public safety answering point technology.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(iii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is designed to integrate with a school district\u8217\'3fs existing security camera infrastructure.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(iv)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Was developed in the United States without the use of any third-party data or open-source data.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(v)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Was developed in the United States by an organization in which a majority interest and a controlling interest is owned by shareholders who are citizens of the United States.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(vi)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is not associated with any company that is owned or controlled by the People\u8217\'3fs Republic of China.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(vii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All of the video processing, data processing, and data storage occurs on school district property or on servers located within the United States that follow data retention policies that are consistent with rules adopted by the department of homeland security and emergency management. The department of homeland security and emergency management shall adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ to administer this subparagraph subdivision. The rules adopted by the department of homeland security and emergency management shall do all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(A)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Establish security standards related to the transmission and storage of video and data.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(B)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Establish model data retention policies related to the storage of video and data. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(C)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Establish a list of organizations that satisfy the standards established by the department of homeland security and emergency management pursuant to this subparagraph subdivision. An organization may submit a request to the department of homeland security and emergency management to be included on this list.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(viii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Was developed by an organization that is on the list established by the department of homeland security and emergency management pursuant to subparagraph subdivision (vii), subparagraph part (C).}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ix)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Beginning July 1, 2025, is designated by the secretary of homeland security as qualified anti-terrorism technology under }}}{{\f5\fs18\hyphpar0\qj{6 U.S.C. \'a7441 et seq.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of this subparagraph, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fschool infrastructure\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include the cost of personnel.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It is the intent of the general assembly that each school district prioritize the use of revenues under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ for secure entries for the district\u8217\'3fs attendance centers before expending such revenues for athletic facility infrastructure projects.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A school district that uses secure an advanced vision for education fund moneys for school infrastructure shall comply with the state building code in the absence of a local building code.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prior to approving the use of revenues received under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ for an athletic facility infrastructure project within the scope of the school district\u8217\'3fs approved revenue purpose statement or pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{ for a school district without an approved revenue statement, the board of directors shall adopt a resolution setting forth the proposal for the athletic facility infrastructure project and hold an additional public hearing on the issue of construction of the athletic facility. Notice of the time and place of the public hearing shall be published not less than ten nor more than twenty days before the public hearing in a newspaper which is a newspaper of general circulation in the school district. If at any time prior to the fifteenth day following the hearing, the secretary of the board of directors receives a petition containing the required number of signatures and asking that the question of the approval of the use of revenues for the athletic facility infrastructure project be submitted to the voters of the school district, the board of directors shall either rescind the board\u8217\'3fs resolution for the use of revenues for the athletic facility infrastructure project or direct the county commissioner of elections to submit the question to the registered voters of the school district at an election held on a date specified in }}}{{\f5\fs18\hyphpar0\qj{section 39.2, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. The petition must be signed by eligible electors equal in number to not less than one hundred or thirty percent of the number of voters at the last preceding election of school officials under }}}{{\f5\fs18\hyphpar0\qj{section 277.1}}}{{\f5\fs18\hyphpar0\qj{, whichever is greater. If a majority of those voting on the question favors the use of the revenues for the athletic facility infrastructure project, the board shall be authorized to approve such use by resolution of the board. If a majority of those voting on the question does not favor the use of the revenues for the athletic facility infrastructure project, the board of directors shall rescind the board\u8217\'3fs resolution for the use of revenues for the athletic facility infrastructure project. If a petition is not received by the board of directors within the prescribed time period, the board of directors may approve the use of revenues for the athletic facility infrastructure project without voter approval.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{After fourteen days from the date of the hearing under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or fourteen days after the date of the election held under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, if applicable, whichever is later, an action shall not be brought questioning the board of directors\u8217\'3f authority to use funds for the athletic facility infrastructure project or questioning the legality of any proceedings in connection with the authorization of such use.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAthletic facility\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a building or structure, or portion thereof, that is not physically attached to a student attendance center.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAthletic facility infrastructure project\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a school infrastructure project that includes in whole or in part the construction of an athletic facility.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fConstruction\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include repair or maintenance of an existing facility.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The general assembly shall not alter the purposes for which the revenues received under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ may be used from infrastructure and property tax relief purposes to any other purpose unless the bill is approved by a vote of at least two-thirds of the members of both chambers of the general assembly and is signed by the governor.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1134, \'a729}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1191, \'a773}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 88, \'a736}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 141, \'a750, 51}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 120, \'a746}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 166, \'a712 \u8211\'3f 16}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1063, \'a7229}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1097, \'a72, 4}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1179, \'a75, 13}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a776.4}}}{{\f5\fs12\hyphpar0\qj{, 275.12}}}{{\f5\fs12\hyphpar0\qj{, 279.86}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 8 does not apply to the 2022 amendment to subsection 3, paragraph a; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2022/CH1097.pdf" }{\fldrslt \cf5 \f5 \fs12{{2022 Acts, ch. 1097, \'a74}}}}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{*}{{\f5\fs12\hyphpar0\qj{Chapter 423E}}}{ repealed effective June 30, 2023, pursuant to terms of former }{{\f5\fs12\hyphpar0\qj{\'a7423E.7}}}{; corrective legislation is pending}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{423F.4}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Borrowing authority for school districts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subject to the conditions established under }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, a school district may anticipate its share of the revenues under }}}{{\f5\fs18\hyphpar0\qj{section 423F.2}}}{{\f5\fs18\hyphpar0\qj{ by issuing bonds in the manner provided in }}}{{\f5\fs18\hyphpar0\qj{section 423E.5}}}{{\f5\fs18\hyphpar0\qj{, Code 2019. However, to the extent any school district has issued bonds anticipating the proceeds of an extended local sales and services tax for school infrastructure purposes imposed by a county pursuant to former }}}{{\f5\fs18\hyphpar0\qj{chapter 423E}}}{{\f5\fs18\hyphpar0\qj{, Code and Code Supplement 2007, prior to July 1, 2008, the pledge of such revenues for the payment of principal and interest on such bonds shall be replaced by a pledge of its share of the revenues under }}}{{\f5\fs18\hyphpar0\qj{section 423F.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Bonds issued on or after July 1, 2019, shall not be sold at public sale as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 75}}}{{\f5\fs18\hyphpar0\qj{, or at a private sale, without notice and hearing. Notice of the time and place of the public hearing shall be published not less than ten nor more than twenty days before the public hearing in a newspaper which is a newspaper of general circulation in the school district.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For bonds subject to the requirements of paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, if at any time prior to the fifteenth day following the hearing, the secretary of the board of directors receives a petition containing the required number of signatures and asking that the question of the issuance of such bonds be submitted to the voters of the school district, the board shall either rescind its adoption of the resolution or direct the county commissioner of elections to submit the question to the registered voters of the school district at an election held on the date specified in }}}{{\f5\fs18\hyphpar0\qj{section 39.2, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. The petition must be signed by eligible electors equal in number to not less than one hundred or thirty percent of the number of voters at the last preceding election of school officials under }}}{{\f5\fs18\hyphpar0\qj{section 277.1}}}{{\f5\fs18\hyphpar0\qj{, whichever is greater. If the board submits the question at an election and a majority of those voting on the question favors issuance of the bonds, the board shall be authorized to issue the bonds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{After fourteen days from the date of the hearing under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or fourteen days after the date of the election held under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, if applicable, whichever is later, an action shall not be brought questioning the legality of any bonds or the power of the authority to issue any bonds or to the legality of any proceedings in connection with the authorization or issuance of the bonds.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1134, \'a730}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 166, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 71, \'a7134, 136}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7275.12}}}{{\f5\fs12\hyphpar0\qj{, 275.29}}}{{\f5\fs12\hyphpar0\qj{, 275.30}}}{{\f5\fs12\hyphpar0\qj{, 275.53}}}{{\f5\fs12\hyphpar0\qj{, 275.54}}}{{\f5\fs12\hyphpar0\qj{, 275.55}}}{{\f5\fs12\hyphpar0\qj{, 279.85}}}{{\f5\fs12\hyphpar0\qj{, 423F.3}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2023 amendment to subsection 2, paragraph b applies July 1, 2023, for elections on propositions relating to the issuing of bonds or other indebtedness occurring on or after that date; }{{\f5\fs12\hyphpar0\qj{2023 Acts, ch 71, \'a7136}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{423F.5}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Contents of financial audit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A school district shall include as part of its financial audit for the budget year beginning July 1, 2007, and for each subsequent budget year the amount received during the year pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 423E}}}{{\f5\fs18\hyphpar0\qj{* or }}}{{\f5\fs18\hyphpar0\qj{ this chapter}}}{{\f5\fs18\hyphpar0\qj{, as applicable. In addition, the financial audit shall include the amount of bond levies, physical plant and equipment levy, and public educational and recreational levy reduced as a result of the moneys received under }}}{{\f5\fs18\hyphpar0\qj{chapter 423E}}}{{\f5\fs18\hyphpar0\qj{* or }}}{{\f5\fs18\hyphpar0\qj{ this chapter}}}{{\f5\fs18\hyphpar0\qj{, as applicable. The amount of the reductions shall be stated in terms of dollars and cents per one thousand dollars of valuation and in total amount of property tax dollars. Also included shall be an accounting of the amount of moneys received which were spent for infrastructure purposes pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 423E}}}{{\f5\fs18\hyphpar0\qj{* or }}}{{\f5\fs18\hyphpar0\qj{ this chapter}}}{{\f5\fs18\hyphpar0\qj{, as applicable.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The auditor of state may prescribe necessary forms and procedures for the consistent collection of the information required by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1134, \'a731}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 25, \'a743}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7291.10}}}{{\f5\fs12\hyphpar0\qj{, 423F.3}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{*}{{\f5\fs12\hyphpar0\qj{Chapter 423E}}}{ repealed effective June 30, 2023, pursuant to terms of former }{{\f5\fs12\hyphpar0\qj{\'a7423E.7}}}{; corrective legislation is pending}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{423F.6}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Repeal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This chapter}}}{ is repealed January 1, 2051.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1134, \'a732}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 166, \'a718}}}\par}}