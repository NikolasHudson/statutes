18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{522C.5A}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Individual applicants }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ resident adjuster.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Prior to approving an individual\u8217\'3fs application for a resident adjuster license, the commissioner shall find that the applicant meets all of the following requirements:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This state is the applicant\u8217\'3fs home state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant has not committed any act that is a ground for denial, suspension, or revocation of a license under }}}{{\f5\fs18\hyphpar0\qj{section 522C.13}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant has the requisite character and competence to be licensed as an adjuster, as may be determined by the commissioner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant is financially responsible pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 522C.7}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant has paid all fees required under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. An applicant who concurrently applies for both an adjuster license, and a license as an appraiser under }}}{{\f5\fs18\hyphpar0\qj{chapter 522F}}}{{\f5\fs18\hyphpar0\qj{, shall only be required to pay the fee required under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or the fee required under }}}{{\f5\fs18\hyphpar0\qj{chapter 522F}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant maintains an office in the applicant\u8217\'3fs home state that is available by reasonable appointment or regular business hours.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant is at least eighteen years of age.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant successfully passed the adjuster examination pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 522C.8}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant for a public adjuster license has submitted contracts and any subsequent contract modification to the commissioner for review and approval prior to use. A contract that has been filed is deemed to be approved unless disapproved or additional information is requested by the commissioner within thirty calendar days of receipt of the filing by the commissioner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant has obtained any necessary authority from the secretary of state to transact business in this state.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2025 Acts, ch 28, \'a736, 52}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7522C.7}}}{{\f5\fs12\hyphpar0\qj{, 522C.9}}}{{\f5\fs12\hyphpar0\qj{, 522C.10}}}{{\f5\fs12\hyphpar0\qj{, 522C.15}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section applies beginning July 22, 2025, to a person currently doing business in this state as an independent adjuster or a staff adjuster as of January 1, 2025; }{{\f5\fs12\hyphpar0\qj{2025 Acts, ch 28, \'a752}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{NEW section}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{522C.5B}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Individual applicants }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ nonresident adjuster.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Before approving a nonresident applicant\u8217\'3fs application for a nonresident adjuster license, the commissioner shall find that the nonresident applicant meets all of the following requirements:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The nonresident applicant has not committed any act that is a ground for denial, suspension, or revocation of a license under }}}{{\f5\fs18\hyphpar0\qj{section 522C.13}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The nonresident applicant is licensed as a resident adjuster and in good standing in the nonresident applicant\u8217\'3fs home state. If the nonresident applicant\u8217\'3fs resident license in the nonresident applicant\u8217\'3fs home state terminates for any reason, a license issued to a nonresident applicant under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall become inactive, unless the termination is due to the nonresident applicant being issued a new resident adjuster license in the nonresident applicant\u8217\'3fs home state and the home state has reciprocity with this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The nonresident applicant has submitted a request for licensure to the division in a form and manner prescribed by the commissioner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The nonresident applicant has the requisite character and competence to be licensed as an adjuster, as may be determined by the commissioner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The nonresident applicant is financially responsible pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 522C.7}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The nonresident applicant has paid all fees required under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. An applicant who concurrently applies for both an adjuster license, and a license as an appraiser under }}}{{\f5\fs18\hyphpar0\qj{chapter 522F}}}{{\f5\fs18\hyphpar0\qj{, shall only be required to pay the fee required under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or the fee required under }}}{{\f5\fs18\hyphpar0\qj{chapter 522F}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The nonresident applicant has obtained any necessary authority from the Iowa secretary of state to transact business in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The nonresident applicant for a public adjuster license has filed contracts with the commissioner for review and approval prior to use. A contract that has been filed is deemed to be approved unless disapproved or additional information is requested by the commissioner within thirty calendar days of receipt of the filing by the commissioner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The nonresident applicant successfully passed the adjuster examination pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 522C.8}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The nonresident applicant is at least eighteen years of age.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The nonresident applicant maintains an office in the nonresident applicant\u8217\'3fs home state that is available by reasonable appointment or regular business hours.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2025 Acts, ch 28, \'a737, 52}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7522C.7}}}{{\f5\fs12\hyphpar0\qj{, 522C.10}}}{{\f5\fs12\hyphpar0\qj{, 522C.15}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section applies beginning July 22, 2025, to a person currently doing business in this state as an independent adjuster or a staff adjuster as of January 1, 2025; }{{\f5\fs12\hyphpar0\qj{2025 Acts, ch 28, \'a752}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{NEW section}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{522C.5C}}}{\*\bkmkstart stylerid1_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Business entity applicants }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ resident public adjuster or independent adjuster.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Prior to approving a business entity\u8217\'3fs application for a license for a resident public adjuster or resident independent adjuster, the commissioner shall find that the business entity meets all of the following requirements:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The business entity has designated an individual adjuster licensed in this state to be responsible for the business entity\u8217\'3fs compliance with the insurance laws and administrative rules of this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The business entity has not committed any act that is a ground for denial, suspension, or revocation of a license under }}}{{\f5\fs18\hyphpar0\qj{section 522C.13}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The business entity has the requisite character and competence to be licensed as an adjuster, as may be determined by the commissioner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The business entity is financially responsible pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 522C.7}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The business entity has paid all fees required under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. An applicant who concurrently applies for both an adjuster license, and a license as an appraiser under }}}{{\f5\fs18\hyphpar0\qj{chapter 522F}}}{{\f5\fs18\hyphpar0\qj{, shall only be required to pay the fee required under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or the fee required under }}}{{\f5\fs18\hyphpar0\qj{chapter 522F}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The business entity maintains an office in the business entity\u8217\'3fs home state that is available by reasonable appointment or regular business hours.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The business entity applying for a public adjuster license has submitted contracts and any subsequent contract modification to the commissioner for review and approval prior to use. A contract that has been filed is deemed to be approved unless disapproved or additional information is requested by the commissioner within thirty calendar days of receipt of the filing by the commissioner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The business entity has obtained any necessary authority from the Iowa secretary of state to transact business in this state.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2025 Acts, ch 28, \'a738, 52}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7522C.7}}}{{\f5\fs12\hyphpar0\qj{, 522C.10}}}{{\f5\fs12\hyphpar0\qj{, 522C.15}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section applies beginning July 22, 2025, to a person currently doing business in this state as an independent adjuster or a staff adjuster as of January 1, 2025; }{{\f5\fs12\hyphpar0\qj{2025 Acts, ch 28, \'a752}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{NEW section}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{522C.5D}}}{\*\bkmkstart stylerid1_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Business applicants }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ nonresident business entity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Before approving a nonresident business entity\u8217\'3fs application for a nonresident public adjuster license or a nonresident independent adjuster license, the commissioner shall find that the nonresident business entity meets all of the following requirements:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The nonresident business applicant has designated an individual adjuster licensed in this state to be responsible for the nonresident business applicant\u8217\'3fs compliance with the insurance laws and administrative rules of this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The nonresident business applicant has not committed any act that is a ground for denial, suspension, or revocation of a license under }}}{{\f5\fs18\hyphpar0\qj{section 522C.13}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The nonresident business applicant has the requisite character and competence to be licensed as an adjuster, as may be determined by the commissioner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The nonresident business applicant is financially responsible pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 522C.7}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The nonresident business applicant has paid all fees required under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The nonresident business applicant maintains an office in the nonresident business applicant\u8217\'3fs home state that is available by reasonable appointment or regular business hours.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The nonresident business applicant applying for a public adjuster license has submitted contracts and any subsequent contract modification to the commissioner for review and approval prior to use. A contract that has been filed is deemed to be approved unless disapproved or additional information is requested by the commissioner within thirty calendar days of receipt of the filing by the commissioner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The nonresident business applicant has obtained any necessary authority from the Iowa secretary of state to transact business in this state.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2025 Acts, ch 28, \'a739, 52}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7522C.7}}}{{\f5\fs12\hyphpar0\qj{, 522C.10}}}{{\f5\fs12\hyphpar0\qj{, 522C.15}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section applies beginning July 22, 2025, to a person currently doing business in this state as an independent adjuster or a staff adjuster as of January 1, 2025; }{{\f5\fs12\hyphpar0\qj{2025 Acts, ch 28, \'a752}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{NEW section}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{522C.6}}}{\*\bkmkstart stylerid1_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Fees }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ license issuance, renewal, or reinstatement, and examination.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Fees for a license as an adjuster shall be as follows:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any applicable fee for a criminal history check pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 522B.5A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The fee for issuance or renewal of an adjuster license is fifty dollars for a consecutive twenty-four-month period.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The fee for reinstatement of an adjuster license is fifty dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The fee for a reinstatement or reissuance of an adjuster license due to a disciplinary action under }}}{{\f5\fs18\hyphpar0\qj{section 522C.15}}}{{\f5\fs18\hyphpar0\qj{ is one hundred dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commissioner may charge a reasonable fee for the compilation and production of adjuster licensing records.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The fee for an examination under }}}{{\f5\fs18\hyphpar0\qj{section 522C.8}}}{{\f5\fs18\hyphpar0\qj{ may be set by a third-party testing service under contract with the division to administer the examination. The fee must be approved by the division.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Fees shall be paid electronically through the NIPR gateway.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 137, \'a729}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 124, \'a729}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 28, \'a740, 52}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7522C.8}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2025 amendment applies beginning July 22, 2025, to a person currently doing business in this state as an independent adjuster or a staff adjuster as of January 1, 2025; }{{\f5\fs12\hyphpar0\qj{2025 Acts, ch 28, \'a752}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section stricken and rewritten}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{522C.7}}}{\*\bkmkstart stylerid1_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Financial responsibility.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prior to issuance of a license under }}}{{\f5\fs18\hyphpar0\qj{section 522C.5A}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{522C.5B}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{522C.5C}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{522C.5D}}}{{\f5\fs18\hyphpar0\qj{, an applicant shall secure evidence of financial responsibility through a surety bond as prescribed by the commissioner. The surety bond shall be executed and issued by an insurer authorized to issue surety bonds in this state and meet the following requirements:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The surety bond shall be a minimum of fifty thousand dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The surety bond shall be in favor of the state and specifically authorize recovery by the commissioner on behalf of any person in this state who sustains damages as the result of an adjuster\u8217\'3fs erroneous act, failure to act, fraud, or unfair or deceptive act or practice under }}}{{\f5\fs18\hyphpar0\qj{chapter 507B}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The surety bond shall not be terminated without prior written notice filed with the division a minimum of thirty calendar days prior to termination.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The division may request that an adjuster provide evidence of financial responsibility at any time the division deems relevant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An adjuster shall immediately notify the division if the adjuster\u8217\'3fs evidence of financial responsibility terminates in violation of }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, or becomes impaired, and the adjuster\u8217\'3fs license shall become inactive until the adjuster provides the division with evidence of financial responsibility.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2025 Acts, ch 28, \'a741, 52}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7522C.4}}}{{\f5\fs12\hyphpar0\qj{, 522C.5A}}}{{\f5\fs12\hyphpar0\qj{, 522C.5B}}}{{\f5\fs12\hyphpar0\qj{, 522C.5C}}}{{\f5\fs12\hyphpar0\qj{, 522C.5D}}}{{\f5\fs12\hyphpar0\qj{, 522C.10}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section applies beginning July 22, 2025, to a person currently doing business in this state as an independent adjuster or a staff adjuster as of January 1, 2025; }{{\f5\fs12\hyphpar0\qj{2025 Acts, ch 28, \'a752}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{NEW section}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{522C.8}}}{\*\bkmkstart stylerid1_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Examination.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An individual applying for a license under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall pass a written examination, unless exempt pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 522C.9}}}{{\f5\fs18\hyphpar0\qj{. The examination shall test the knowledge of the individual concerning the duties and responsibilities of an adjuster and the insurance laws and administrative rules of this state, and shall be conducted as prescribed by the division.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An individual who concurrently applies for an adjuster license, and a license as an appraiser under }}}{{\f5\fs18\hyphpar0\qj{chapter 522F}}}{{\f5\fs18\hyphpar0\qj{, may choose to take a joint examination conducted as prescribed by the division. The joint examination shall test the knowledge of the individual concerning the duties and responsibilities of an adjuster and of an appraiser, and the insurance laws and administrative rules of this state. An individual who successfully passes a joint examination, and who meets all other requirements for licensure as an adjuster, and as an appraiser under }}}{{\f5\fs18\hyphpar0\qj{chapter 522F}}}{{\f5\fs18\hyphpar0\qj{, shall be licensed as both an adjuster and as an appraiser.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each individual applying for examination shall remit the examination fee under }}}{{\f5\fs18\hyphpar0\qj{section 522C.6}}}{{\f5\fs18\hyphpar0\qj{. An individual applying for a joint examination under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, shall pay one examination fee for the joint examination.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An individual who fails to appear for a scheduled examination, or who fails to pass the examination, may reapply for examination and must remit the required fee to be scheduled for another examination.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The results of an examination shall be valid to submit for licensure for ninety calendar days after the date of the examination.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2025 Acts, ch 28, \'a742, 52}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7522C.5A}}}{{\f5\fs12\hyphpar0\qj{, 522C.5B}}}{{\f5\fs12\hyphpar0\qj{, 522C.6}}}{{\f5\fs12\hyphpar0\qj{, 522C.9}}}{{\f5\fs12\hyphpar0\qj{, 522C.15}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section applies beginning July 22, 2025, to a person currently doing business in this state as an independent adjuster or a staff adjuster as of January 1, 2025; }{{\f5\fs12\hyphpar0\qj{2025 Acts, ch 28, \'a752}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{NEW section}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{522C.9}}}{\*\bkmkstart stylerid1_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Examination }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ exemption.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An individual who applies for a nonresident license under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and who was previously a licensed adjuster in another state that required an examination that included Iowa-specific statutes and administrative rules shall not be required to apply for examination under }}}{{\f5\fs18\hyphpar0\qj{section 522C.8}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An individual who relocates to this state and who was a licensed adjuster in another state that required an examination that included Iowa-specific statutes and administrative rules shall not be required to apply for examination under }}}{{\f5\fs18\hyphpar0\qj{section 522C.8}}}{{\f5\fs18\hyphpar0\qj{ if the individual submits an application for a resident adjuster license under }}}{{\f5\fs18\hyphpar0\qj{section 522C.5A}}}{{\f5\fs18\hyphpar0\qj{ within ninety calendar days of establishing legal residency, and all of the following apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The individual is currently a licensed adjuster in the state from which the applicant relocated.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state from which the applicant relocated issues a certification that the applicant is licensed and in good standing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The producer database records of the state from which the applicant relocated, or records maintained by the NAIC or a NAIC affiliate or subsidiary, indicate that the adjuster is currently licensed or had been licensed, and is in good standing.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2025 Acts, ch 28, \'a743, 52}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7522C.8}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section applies beginning July 22, 2025, to a person currently doing business in this state as an independent adjuster or a staff adjuster as of January 1, 2025; }{{\f5\fs12\hyphpar0\qj{2025 Acts, ch 28, \'a752}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{NEW section}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{522C.10}}}{\*\bkmkstart stylerid1_2E18_2E2_2E2}{\*\bkmkend stylerid1_2E18_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Public adjuster and insured }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ contract for services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A public adjuster shall not provide services to an insured until a written contract with the insured has been executed on a form filed with and approved by the commissioner pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 522C.5A, subsection 9}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{section 522C.5B, subsection 8}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{section 522C.5C, subsection 7}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{section 522C.5D, subsection 7}}}{{\f5\fs18\hyphpar0\qj{. The contract must have a heading that indicates the contract is a public adjuster contract and must contain all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The full name, address, telephone number, and license number of the public adjuster presenting and negotiating the contract and, if applicable, the full name, address, telephone number, and license number of the business entity the public adjuster is associated with.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The insured\u8217\'3fs full name, street address, insurance company name, and, if known or upon notification, the insurance policy number and claim number.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A description of the insured\u8217\'3fs loss claim and the address at which the loss is located, if applicable.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A description of services to be provided by the public adjuster on behalf of the insured.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A signature of the public adjuster and of the insured, and the date the public adjuster and the insured each signed the contract.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An attestation that the public adjuster has a surety bond pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 522C.7}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(7)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An explanation of the amount payable to the public adjuster, and how the amount is calculated, which may include any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If an hourly rate, the contract shall state the hourly rate and how the rate is applied to the hours of service provided by the public adjuster to calculate the amount payable.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a flat fee, the contract must state the exact amount payable to the public adjuster.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a percentage of settlement, the contract must state the exact percentage applied to the settlement on the claim.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If any other consideration, the contract must detail how the amount payable is calculated or determined.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(8)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A public adjuster may charge a reasonable fee that shall not exceed any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Fifteen percent of all claim payments approved by the insurer for any noncatastrophic disaster insurance claim settlement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Ten percent of all claim payments approved by the insurer for any catastrophic disaster insurance claim settlement.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(9)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That compensation for any reopened or supplemental claim may not exceed the limitations set forth in the contract.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(10)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the insured has the right to agree to or reject a loss settlement even if the public adjuster objects to the insured\u8217\'3fs decision.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(11)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The initial expenses of the public adjuster that will be reimbursed from the proceeds of the claim payment shall be specified by expense type, with reimbursement estimates set forth in the contract. Any additional expenses for which the public adjuster requests reimbursement shall be disclosed in writing to the insured, and must be approved by the insured prior to reimbursement.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(12)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A statement that the public adjuster shall not render services or perform acts that constitute the practice of law.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(13)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A statement that the public adjuster shall not act on behalf of or aid any person in negotiation or settlement of a claim related to bodily injury, death, or noneconomic damages.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(14)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The process for rescinding the contract, including the date by which rescission of the contract by the public adjuster or the insured must occur. The public adjuster shall provide notice of the insured\u8217\'3fs rights under }}}{{\f5\fs18\hyphpar0\qj{chapter 555A}}}{{\f5\fs18\hyphpar0\qj{, and the insured may rescind the contract as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 555A}}}{{\f5\fs18\hyphpar0\qj{. A contract shall not be construed to prevent an insured from pursuing a civil remedy after the revocation or cancellation period. If the insured rescinds the contract, anything of value given by the insured shall be returned to the insured within fifteen business days following receipt of the cancellation notice by the public adjuster.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A contract provision shall not be redacted in a copy of the contract submitted to the commissioner. Such redaction shall constitute a violation of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, and shall be subject to penalties under }}}{{\f5\fs18\hyphpar0\qj{sections 522C.13}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{522C.14}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the insurer, no later than five calendar days after the date on which the insured\u8217\'3fs loss is reported to the insurer, either pays or commits in writing to pay to the insured the policy limit of the insured\u8217\'3fs insurance policy, the public adjuster shall:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Inform the insured that the total amount of loss claimed by the insured may not be agreed to by the insurer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Only be entitled to reasonable compensation from the insured for services provided on behalf of the insured based on the time spent on the claim, and the expenses incurred by the public adjuster, until the date the insurer pays the claim or provides the insured with a written commitment that the insurer will pay the claim.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A public adjuster contract shall not contain a provision that does any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Allows the public adjuster\u8217\'3fs percentage of a settlement to be collected if money is still due from an insurer, or that allows the public adjuster to collect the entire percentage of a settlement from any single payment issued by an insurer rather than as a percentage of each payment issued by the insurer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Requires or permits the insured to authorize an insurer to issue a check only in the name of the public adjuster.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Imposes collection costs or late fees prior to an insurance claim payment by an insurer to an insured.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Allows the public adjuster\u8217\'3fs compensation to be increased based on the fact that a claim is litigated.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Precludes either an insured or the public adjuster from pursuing civil remedies.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Restricts an insured\u8217\'3fs right to initiate or maintain direct communication with the insured\u8217\'3fs attorney or insurer, with the insurer\u8217\'3fs adjuster or attorney, or any other person regarding settlement of the insured\u8217\'3fs claim.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Grants the public adjuster power of attorney for the insured. However, a public adjuster may obtain a limited power of attorney for an insured for the sole purpose of depositing claim payments in the insured\u8217\'3fs name into a fiduciary trust account pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 522C.11, subsection 26}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Requires the insured to use a particular business entity or individual for the reconstruction, repair, or restoration of the insured\u8217\'3fs damaged property.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prior to execution of the contract, the public adjuster shall review the terms of the contract with the insured and provide the insured with a separate disclosure document regarding the claim process that shall include the following:}}}\par}{}{\pard\plain\keepn\f5\fs18\hyphpar0\qc\fi0\ri1084\li1084{\f5\fs18\hyphpar0\qc}{DISCLOSURE DOCUMENT}{\f5\fs18\hyphpar0\qc}\par}{}{\pard\plain\keepn\f5\fs18\hyphpar0\qc\fi0\ri1084\li1084{\f5\fs18\hyphpar0\qc}{REGARDING THE CLAIM PROCESS}{\f5\fs18\hyphpar0\qc}\par}{}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\b0\fs18\hyphpar0\qj\ul0\strike0{\~\~\~}}}{\f5\fs18\hyphpar0\qj}{1.}{{\f5\fs18\hyphpar0\qj{\~\~}}}{PROPERTY INSURANCE POLICIES OBLIGATE THE INSURED TO PRESENT A CLAIM TO THE INSURED\u8217\'3fS INSURER FOR CONSIDERATION. THERE ARE THREE TYPES OF ADJUSTERS THAT MAY BE INVOLVED IN THAT PROCESS. THE THREE TYPES ARE AS FOLLOWS:}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\b0\fs18\hyphpar0\qj\ul0\strike0{\~\~\~}}}{\f5\fs18\hyphpar0\qj}{(A)}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSTAFF ADJUSTER\u8221\'3f}}}{ IS DEFINED IN IOWA CODE }{{\f5\fs18\hyphpar0\qj{SECTION 522C.2}}}{. A STAFF ADJUSTER IS EMPLOYED BY THE INSURER. THEY WILL NOT CHARGE THE INSURED A FEE.}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\b0\fs18\hyphpar0\qj\ul0\strike0{\~\~\~}}}{\f5\fs18\hyphpar0\qj}{(B)}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fINDEPENDENT ADJUSTER\u8221\'3f}}}{ IS DEFINED IN IOWA CODE }{{\f5\fs18\hyphpar0\qj{SECTION 522C.2}}}{. AN INDEPENDENT ADJUSTER IS CONTRACTED BY THE INSURER TO REPRESENT THE INSURER. THEY WILL NOT CHARGE THE INSURED A FEE.}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\b0\fs18\hyphpar0\qj\ul0\strike0{\~\~\~}}}{\f5\fs18\hyphpar0\qj}{(C)}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPUBLIC ADJUSTER\u8221\'3f}}}{ IS DEFINED IN IOWA CODE }{{\f5\fs18\hyphpar0\qj{SECTION 522C.2}}}{. A PUBLIC ADJUSTER IS NOT AN EMPLOYEE OR REPRESENTATIVE OF THE INSURER. THEY ARE HIRED BY THE INSURED TO ASSIST IN THE PREPARATION, PRESENTATION, AND SETTLEMENT OF A CLAIM.}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\b0\fs18\hyphpar0\qj\ul0\strike0{\~\~\~}}}{\f5\fs18\hyphpar0\qj}{2.}{{\f5\fs18\hyphpar0\qj{\~\~}}}{THE INSURED IS NOT REQUIRED TO HIRE A PUBLIC ADJUSTER TO HELP THE INSURED MEET THE INSURED\u8217\'3fS OBLIGATIONS UNDER THE INSURED\u8217\'3fS POLICY, BUT HAS THE RIGHT TO DO SO.}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\b0\fs18\hyphpar0\qj\ul0\strike0{\~\~\~}}}{\f5\fs18\hyphpar0\qj}{3.}{{\f5\fs18\hyphpar0\qj{\~\~}}}{THE INSURED HAS THE RIGHT TO INITIATE DIRECT COMMUNICATIONS WITH THE INSURED\u8217\'3fS ATTORNEY, THE INSURED\u8217\'3fS INSURANCE COMPANY, THE INSURANCE COMPANY\u8217\'3fS STAFF ADJUSTER OR INDEPENDENT ADJUSTER, THE INSURANCE COMPANY\u8217\'3fS ATTORNEY, OR ANY OTHER PERSON REGARDING THE SETTLEMENT OF THE INSURED\u8217\'3fS CLAIM.}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\b0\fs18\hyphpar0\qj\ul0\strike0{\~\~\~}}}{\f5\fs18\hyphpar0\qj}{4.}{{\f5\fs18\hyphpar0\qj{\~\~}}}{THE INSURED MAY BE RESPONSIBLE FOR ANY AMOUNT PAYABLE TO A PUBLIC ADJUSTER RELATED TO ANY PORTION OF A CLAIM THAT WAS PREVIOUSLY PAID IN PART, IN FULL, OR SETTLED BY THE INSURER PRIOR TO A CONTRACT BEING ENTERED INTO BETWEEN THE PUBLIC ADJUSTER AND THE INSURED.}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\b0\fs18\hyphpar0\qj\ul0\strike0{\~\~\~}}}{\f5\fs18\hyphpar0\qj}{5.}{{\f5\fs18\hyphpar0\qj{\~\~}}}{THE AMOUNT PAYABLE TO A PUBLIC ADJUSTER, WHICH CAN INCLUDE A SALARY, FEE, COMMISSION, OR OTHER CONSIDERATION AS OUTLINED IN THE CONTRACT, IS THE OBLIGATION OF THE INSURED, NOT THE INSURER.}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\b0\fs18\hyphpar0\qj\ul0\strike0{\~\~\~}}}{\f5\fs18\hyphpar0\qj}{6.}{{\f5\fs18\hyphpar0\qj{\~\~}}}{THE INSURED MAY FILE A COMPLAINT WITH THE IOWA INSURANCE DIVISION BY CALLING (877) 955-1212 OR VISITING IID.IOWA.GOV. }{\f5\fs18\hyphpar0\qj}\par}{\pard\plain\f5\fs8\hyphpar0\qj\fi0\ri1084\li1084\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An original copy of a completed contract shall be provided to the public adjuster and to the insured. The commissioner may inspect the original contract in possession of the public adjuster at any time without prior notice. A contract may be executed electronically if done so in compliance with }}}{{\f5\fs18\hyphpar0\qj{chapter 554D}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Within seventy-two hours of executing a contract with an insured under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the public adjuster shall provide the insured\u8217\'3fs insurer a notification letter, which has been signed by the insured, authorizing the public adjuster to represent the insured\u8217\'3fs interest. The insurer shall verify that the public adjuster is currently licensed with the division.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A contract between a public adjuster and an insured executed on a form in violation of }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, shall not be enforceable in this state.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2025 Acts, ch 28, \'a744, 52}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7522C.11}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section applies beginning July 22, 2025, to a person currently doing business in this state as an independent adjuster or a staff adjuster as of January 1, 2025; }{{\f5\fs12\hyphpar0\qj{2025 Acts, ch 28, \'a752}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{NEW section}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{522C.11}}}{\*\bkmkstart stylerid1_2E19_2E2_2E2}{\*\bkmkend stylerid1_2E19_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Adjusters }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ standards of conduct.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A public adjuster shall serve with objectivity and complete loyalty to the interest of the insured. A public adjuster shall render to the insured in good faith information, counsel, and service, that in the opinion of the public adjuster will best serve the insured\u8217\'3fs insurance claim needs and interest. These duties extend to the claims process and include providing timely responses to both the insurer and the insured.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For a minimum of seventy-two hours following a catastrophic disaster, to allow time for the commissioner to safely deploy consumer protection resources, a public adjuster shall not, in person or by telephone, directly offer to contract, attempt to offer to contract, or enter into an adjuster contract with an insured unless the offer to contract, the attempt to offer to contract, or entering into a contract is initiated by a consumer. If the commissioner deems the severity of the catastrophic disaster to have placed people under duress, the commissioner shall immediately dispatch the consumer advocate and other personnel to the disaster area to provide consumer guidance. If, after a public hearing, the commissioner determines that, due to the scope and severity of the catastrophic disaster, additional time is necessary to safely deploy additional consumer protection resources, the commissioner may extend the time period that a public adjuster shall not offer to contract, attempt to offer to contract, or enter into a contract for an additional seventy-two hours. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A public adjuster shall not solicit between the hours of 8:00 p.m. and 9:00 a.m. Solicitation shall include but is not limited to a door-to-door sale as that term is defined in }}}{{\f5\fs18\hyphpar0\qj{section 555A.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A public adjuster, or an independent adjuster, shall not permit an unlicensed employee or representative of the public adjuster or independent adjuster, nor any person associated with a claim, to conduct business for which a license is required under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An adjuster shall not have a direct or indirect financial interest in any aspect of a claim other than the amount payable pursuant to the written contract with an insured under }}}{{\f5\fs18\hyphpar0\qj{section 522C.10}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An adjuster shall not acquire any interest in salvage of property.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An adjuster shall not undertake the adjustment of any claim if the adjuster is not competent and knowledgeable as to the terms and conditions of the insurance coverage, or if the loss or coverage otherwise exceeds the adjuster\u8217\'3fs current expertise.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An adjuster shall maintain all documentation relating to all estimates and coverage determinations for a minimum of five years from the date of completion of a settlement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An adjuster shall not knowingly make any false oral or written material statements regarding any person engaged in the business of insurance, or any other adjuster, to an insured who is a client or potential client.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An adjuster shall not reasonably act, or fail to act, in any manner that obstructs or prevents an insurer or adjuster from timely conducting an inspection of any part of an insured\u8217\'3fs property for which there is a claim for loss or damage.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a public adjuster is unavailable after reasonable request by an insurer, resulting in delay of the insurer\u8217\'3fs timely inspection of the property, the insured shall allow the insurer to have access to the property without the participation or presence of the public adjuster to facilitate the insurer\u8217\'3fs prompt inspection of the loss or damage.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An adjuster shall respond to an inquiry from an insurer or an insured regarding a claim within fifteen business days of the date of the inquiry unless good cause exists for delay. The adjuster shall reply within fifteen business days to all pertinent communications from the insured, the insurer, or a representative of the insured or the insurer that reasonably suggest that a response is expected.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon receiving notification of a claim, an insurer shall provide necessary claim forms, instructions, and reasonable assistance within fifteen business days of notification of the claim so that first-party claimants can comply with the policy conditions and the insurer\u8217\'3fs reasonable requirements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An adjuster shall not act as an appraiser and as an adjuster on the same claim.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An adjuster shall not act as an umpire and as an adjuster on the same claim.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A public adjuster shall not enter into a contract that accepts a power of attorney or limited power of attorney for an insured.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{16.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An independent adjuster shall not act as an independent adjuster and a public adjuster on the same claim.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A public adjuster shall not act as a public adjuster and an independent adjuster on the same claim.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{17.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A staff adjuster may be licensed as a public adjuster or as an independent adjuster, but shall be prohibited from providing services as an independent adjuster or a public adjuster while employed as a staff adjuster.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{18.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A public adjuster shall not agree to, or reject, any loss settlement without the insured\u8217\'3fs express knowledge and written consent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{19.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An adjuster shall not engage in any act or practice that is a conflict of interest. A conflict of interest shall include but is not limited to the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A direct or indirect financial interest with a person responsible for the reconstruction, repair, or restoration of damaged property that is the subject of a claim, or with a person involved in resolving a claim valuation dispute.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A direct or indirect financial interest, or other valuable consideration regardless of form or amount paid to an adjuster in exchange for referring an insured to an appraiser, umpire, construction company, contractor, salvage company, or attorney.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Being an owner, employee, agent, investor, or having other financial interest in a business entity responsible for the reconstruction, repair, or restoration of damaged property that is the subject of a claim, or having an immediate family member who is an owner, employee, agent, or investor in a business entity responsible for the reconstruction, repair, or restoration of a damaged property that is the subject of a claim.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Entering into a written or verbal contract, or formal or informal agreement, with any person that compromises the adjuster\u8217\'3fs duty of loyalty to the insured.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Using claim information obtained in the course of a claim investigation for commercial purposes including marketing or advertising for the benefit of the adjuster.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{20.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A public adjuster shall not file a complaint with the division on behalf of an insured without the insured\u8217\'3fs knowledge and written consent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{21.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An adjuster shall not represent, directly or indirectly, that damage has occurred at a property unless the adjuster has inspected the damaged areas of the property.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{22.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An adjuster shall produce a detailed written estimate to repair or replace covered damages and provide a copy to both the insured and the insurer in a timely manner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{23.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A public adjuster shall not offer to pay an insured\u8217\'3fs deductible, or claim that the insured\u8217\'3fs deductible will be waived, as an inducement to use the services of the public adjuster.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{24.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An adjuster shall respond reasonably promptly to inquiries by the division.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{25.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A public adjuster shall provide a detailed invoice for completed services to an insured prior to requesting payment for services pursuant to a contract under }}}{{\f5\fs18\hyphpar0\qj{section 522C.10}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{26.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Funds received or held by a public adjuster on behalf of an insured toward the settlement of a claim shall be:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Held in a fiduciary capacity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Deposited by the adjuster into one or more separate noninterest-bearing fiduciary trust accounts in a financial institution licensed to do business in this state no later than the close of the fifth business day from the date the public adjuster received the funds, and either deposited in the insured\u8217\'3fs name or in the name of the public adjuster as trustee for the insured, to be held and administered as a trust account for the benefit and protection of the insured.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Held separately from personal or nonbusiness funds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Held separately from other business funds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Listed specifically and separately, by the insured\u8217\'3fs name and the amount in trust in the book of accounts and records of the public adjuster. The book of accounts and records must indicate the fiduciary nature of the account and any amounts deposited or withdrawn.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Disbursed within thirty calendar days of receipt of an invoice by the public adjuster from a contractor that completed work, if the public adjuster receives approval of the insured that the work was satisfactorily completed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{27.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A public adjuster shall comply with all applicable local ordinances.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{28.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An adjuster who fails to comply with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be subject to penalties under }}}{{\f5\fs18\hyphpar0\qj{sections 522C.13}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{522C.14}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2025 Acts, ch 28, \'a745, 52}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7522C.10}}}{{\f5\fs12\hyphpar0\qj{, 522C.14}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section applies beginning July 22, 2025, to a person currently doing business in this state as an independent adjuster or a staff adjuster as of January 1, 2025; }{{\f5\fs12\hyphpar0\qj{2025 Acts, ch 28, \'a752}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{NEW section}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{522C.12}}}{\*\bkmkstart stylerid1_2E2_30_2E2_2E2}{\*\bkmkend stylerid1_2E2_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Adjusters }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ records.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An adjuster shall have a continuing duty to keep, at the adjuster\u8217\'3fs place of business, usual and customary records pertaining to transactions undertaken by the adjuster. All such records shall be kept available and open for inspection by the division at any time during regular business hours; however, the division is not entitled to inspect any records prepared in anticipation of litigation or that are subject to any privilege recognized in }}}{{\f5\fs18\hyphpar0\qj{chapter 622}}}{{\f5\fs18\hyphpar0\qj{. The records shall be maintained for a minimum of five years from the date of the adjuster transaction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An adjuster who fails to comply with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be subject to penalties under }}}{{\f5\fs18\hyphpar0\qj{sections 522C.13}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{522C.14}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2025 Acts, ch 28, \'a746, 52}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section applies beginning July 22, 2025, to a person currently doing business in this state as an independent adjuster or a staff adjuster as of January 1, 2025; }{{\f5\fs12\hyphpar0\qj{2025 Acts, ch 28, \'a752}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{NEW section}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{522C.13}}}{\*\bkmkstart stylerid1_2E21_2E2_2E2}{\*\bkmkend stylerid1_2E21_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{License denial, nonrenewal, suspension, or revocation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The division may place on probation, suspend, revoke, or refuse to issue or renew an adjuster\u8217\'3fs license, and may levy a civil penalty as provided in }}}{{\f5\fs18\hyphpar0\qj{section 522C.14}}}{{\f5\fs18\hyphpar0\qj{, for one or more of the following causes:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The adjuster provided incorrect, misleading, incomplete, or materially untrue information in a license application.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The adjuster violated an insurance law, regulation, subpoena, or order of the commissioner or of a commissioner of another state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The adjuster obtained or attempted to obtain a license through misrepresentation or fraud.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The adjuster improperly withheld, misappropriated, or converted money or property received in the course of doing business.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The adjuster was convicted of a felony.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The adjuster admitted to, or was found to have committed, any unfair trade practice or fraud.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The adjuster used fraudulent, coercive, or dishonest practices, or demonstrated incompetence, untrustworthiness, or financial irresponsibility, or was a source of injury or loss in the conduct of business in this state or elsewhere.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The adjuster had any professional license, or its equivalent, denied, suspended, or revoked in this state or any other state, province, district, or territory.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The adjuster forged another\u8217\'3fs name to any document related to the adjuster\u8217\'3fs work as an adjuster.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The adjuster improperly used notes or any other reference material to complete an examination for an adjuster license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{k.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The adjuster knowingly negotiated as an adjuster with an individual or business entity who is not, but is required to be, licensed as an adjuster, appraiser, or umpire.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{l.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The adjuster failed to comply with an administrative or court order imposing a child support obligation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{m.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The adjuster failed to comply with an administrative or court order related to repayment of loans to the college student aid commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{n.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The adjuster failed to pay state income tax or to comply with any administrative or court order directing payment of state income tax.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{o.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The adjuster failed or refused to cooperate in an investigation conducted by the commissioner or the commissioner\u8217\'3fs designee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{p.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The adjuster intentionally misrepresented the terms of an actual or proposed contract for services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the commissioner does not renew an adjuster\u8217\'3fs license or denies an application for a license, the commissioner shall notify the adjuster or applicant and advise, in writing, of the reason for the nonrenewal of the license or denial of the application for a license. The adjuster or applicant may request a hearing on the nonrenewal or denial by filing a written request for a hearing within thirty calendar days from the date of notice of the nonrenewal or denial. A hearing shall be conducted according to }}}{{\f5\fs18\hyphpar0\qj{section 522C.15}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The license of a business entity may be suspended, revoked, placed on probation, or refused if the commissioner finds, after hearing, that an individual adjuster\u8217\'3fs violation was known or should have been known by a licensed partner, officer, or manager of the business entity and the violation was not reported to the commissioner and corrective action was not taken.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The license of a nonresident adjuster shall be immediately inactive if the nonresident adjuster is placed on probation, suspended, revoked, refused, or denied licensure in any other state. The nonresident adjuster shall have seven calendar days to alert the commissioner that the nonresident adjuster has been placed on probation, suspended, revoked, refused, nonrenewed, or denied licensure in another state. Failure to meet the reporting deadline shall be a violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to, or in lieu of, denial, probation, suspension, or revocation of a license under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, an adjuster, after hearing, may be subject to a civil penalty as provided in }}}{{\f5\fs18\hyphpar0\qj{section 522C.14}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commissioner may enforce }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, may conduct an investigation of any suspected violation of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, and may impose any penalty or remedy authorized by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ against any person who is under investigation for, or charged with, a violation of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ even if the person\u8217\'3fs license has been surrendered or has lapsed by operation of law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All complaint files, investigation files, investigation reports, and other investigative information in the possession of the commissioner or the commissioner\u8217\'3fs agents that relates to adjuster discipline shall be privileged and confidential, and shall not be subject to discovery, subpoena, or other means of legal compulsion for release to a person other than the adjuster, and shall not be admissible in evidence in a judicial or administrative proceeding other than a proceeding involving adjuster discipline. A final written decision of the commissioner in a disciplinary proceeding shall be a public record.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Investigative information in the possession of the commissioner or the commissioner\u8217\'3fs agents that relates to adjuster discipline may be disclosed, at the commissioner\u8217\'3fs discretion. The commissioner may share documents, materials, or other information, including confidential and privileged documents and materials subject to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, with other state, federal, and international regulatory agencies, with NAIC, its affiliates or subsidiaries, and with state, federal, and international law enforcement authorities, provided that the recipient agrees to maintain the confidentiality and privileged status of the document, material, or other information.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the investigative information in the possession of the commissioner or the commissioner\u8217\'3fs agents indicates a crime has been committed, the information shall be reported to the proper law enforcement agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 17A.19, subsection 6}}}{{\f5\fs18\hyphpar0\qj{, upon an appeal by the adjuster, the commissioner shall transmit the entire record of the contested case to the reviewing court.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 17A.19, subsection 6}}}{{\f5\fs18\hyphpar0\qj{, if a waiver of privilege has been involuntary and evidence has been received at a disciplinary hearing, the court shall issue an order to withhold the identity of the individual whose privilege was waived.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2025 Acts, ch 28, \'a747, 52}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7522B.5A}}}{{\f5\fs12\hyphpar0\qj{, 522C.5A}}}{{\f5\fs12\hyphpar0\qj{, 522C.5B}}}{{\f5\fs12\hyphpar0\qj{, 522C.5C}}}{{\f5\fs12\hyphpar0\qj{, 522C.5D}}}{{\f5\fs12\hyphpar0\qj{, 522C.10}}}{{\f5\fs12\hyphpar0\qj{, 522C.11}}}{{\f5\fs12\hyphpar0\qj{, 522C.12}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section applies beginning July 22, 2025, to a person currently doing business in this state as an independent adjuster or a staff adjuster as of January 1, 2025; }{{\f5\fs12\hyphpar0\qj{2025 Acts, ch 28, \'a752}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{NEW section}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{522C.14}}}{\*\bkmkstart stylerid1_2E22_2E2_2E2}{\*\bkmkend stylerid1_2E22_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Civil and criminal penalties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon a determination by the commissioner after a hearing conducted pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ that an adjuster has violated a provision of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, the commissioner shall reduce the findings of the hearing to writing and deliver a copy of the findings to the adjuster.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon a determination by the commissioner that an adjuster has engaged, is engaging, or is about to engage in any act or practice constituting a violation of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or a rule adopted or order issued under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, the commissioner may take the following actions:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Issue an order requiring the adjuster to cease and desist from engaging in the conduct resulting in the violation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Assess a civil penalty against the adjuster of not more than one thousand dollars for each violation of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, not to exceed an aggregate of ten thousand dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the adjuster knew or reasonably should have known the adjuster was in violation of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, assess a civil penalty of not more than five thousand dollars for each violation of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, not to exceed an aggregate penalty of fifty thousand dollars in any one six-month period.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Issue a summary order, including a brief statement of findings of fact, conclusions of law, and policy reasons for the decision, and directing the adjuster to cease and desist from engaging in the act or practice or to take affirmative action as is necessary in the judgment of the commissioner to comply with the requirements of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An adjuster may contest a summary order by filing, within thirty calendar days from the date of the issuance of the summary order, a written request for a contested case proceeding and hearing as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ and in accordance with rules adopted by the commissioner. }}}{{\f5\fs18\hyphpar0\qj{Section 17A.18A}}}{{\f5\fs18\hyphpar0\qj{ shall be inapplicable to a summary order issued under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. If a hearing is not requested within thirty calendar days from the date of issuance of the summary order, the summary order shall become final by operation of law. A summary order shall remain effective from the date of issuance until the date the order becomes final by operation of law, or is modified or overturned by a presiding officer or court following a request for hearing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An adjuster violating a summary order issued under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be deemed in contempt of the summary order. The commissioner may petition the district court to enforce the order as certified by the commissioner. The district court shall find the adjuster in contempt of the order if the court finds, after conducting a hearing, that the adjuster is not in compliance with the order. The court may assess a civil penalty against the adjuster and may issue further orders as the court deems appropriate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to any other penalty under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, if the commissioner finds that a violation of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ was directed, encouraged, condoned, ignored, or ratified by the employer of the adjuster, the commissioner shall assess a penalty to the employer. Penalties under this paragraph may be retained by the commissioner under }}}{{\f5\fs18\hyphpar0\qj{section 505.7, subsection 9}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person acting as an adjuster without proper licensure, or an adjuster who willfully violates any provision of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or an order issued under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, is guilty of a class \u8220\'3fD\u8221\'3f felony. If the violation results in a loss of more than ten thousand dollars, the person or adjuster is guilty of a class \u8220\'3fC\u8221\'3f felony.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An adjuster who steals, converts, or misappropriates funds that should be held in trust under }}}{{\f5\fs18\hyphpar0\qj{section 522C.11}}}{{\f5\fs18\hyphpar0\qj{, is guilty of a class \u8220\'3fD\u8221\'3f felony. If the violation results in a loss of more than ten thousand dollars, the adjuster is guilty of a class \u8220\'3fC\u8221\'3f felony.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commissioner may refer such evidence as is available concerning a violation of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, or of any rule adopted or order issued under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, or of the failure of a person to comply with the licensing requirements of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, to the attorney general or the proper county attorney who may institute the appropriate criminal proceedings under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This chapter}}}{{\f5\fs18\hyphpar0\qj{ does not limit the power of the state to punish any person for conduct that constitutes a crime under any other statute.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any contract regulated by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ that is entered into by an insured with a person who is not a licensed public adjuster in this state shall be void. If a contract is void, the insured is not liable for the payment for any past services rendered, or future services to be rendered, by that person.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2025 Acts, ch 28, \'a748, 52}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7522C.10}}}{{\f5\fs12\hyphpar0\qj{, 522C.11}}}{{\f5\fs12\hyphpar0\qj{, 522C.12}}}{{\f5\fs12\hyphpar0\qj{, 522C.13}}}{{\f5\fs12\hyphpar0\qj{, 522C.15}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section applies beginning July 22, 2025, to a person currently doing business in this state as an independent adjuster or a staff adjuster as of January 1, 2025; }{{\f5\fs12\hyphpar0\qj{2025 Acts, ch 28, \'a752}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{NEW section}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{522C.15}}}{\*\bkmkstart stylerid1_2E23_2E2_2E2}{\*\bkmkend stylerid1_2E23_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Reinstatement or reissuance of license after disciplinary matters }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ forfeiture in lieu of compliance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person licensed as an adjuster under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ whose license has been revoked or suspended by order, or who forfeited a license in connection with a disciplinary matter, may apply to the commissioner for reinstatement or reissuance in accordance with the terms of the order of revocation or suspension, or the order accepting the forfeiture, and submit to a criminal history check under }}}{{\f5\fs18\hyphpar0\qj{section 522B.5A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Proceedings for reinstatement or reissuance shall be initiated by the applicant who shall file with the commissioner an application for reinstatement or reissuance after disciplinary action. An applicant shall not be eligible for reinstatement or reissuance until the applicant satisfies the requirements under }}}{{\f5\fs18\hyphpar0\qj{section 522C.5}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{522C.5A}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{522C.5B}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{522C.5C}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{522C.5D}}}{{\f5\fs18\hyphpar0\qj{, as applicable, and the examination requirements under }}}{{\f5\fs18\hyphpar0\qj{section 522C.8}}}{{\f5\fs18\hyphpar0\qj{. An applicant may also be required to submit a new or renewal adjuster application under }}}{{\f5\fs18\hyphpar0\qj{section 522C.5A}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{522C.5B}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{522C.5C}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{522C.5D}}}{{\f5\fs18\hyphpar0\qj{, as applicable.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An application for reinstatement or reissuance shall allege facts which, if established, are sufficient to enable the commissioner to determine that the basis of revocation, suspension, or forfeiture of the applicant\u8217\'3fs license no longer exists, and must disclose if the applicant has engaged in any conduct listed as a cause for licensing action that was not included in the order for suspension, revocation, or forfeiture.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An application for reinstatement or reissuance shall allege facts which, if established, are sufficient to enable the commissioner to determine that it is in the public interest for the application to be granted. The commissioner may determine that it is not in the public interest if the applicant has engaged in any conduct listed as a cause for licensing action that was not included in the order for suspension, revocation, or forfeiture, or if the applicant does not have the character and fitness to be a licensed adjuster in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The burden of proof to establish facts identified in paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall be on the applicant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An adjuster may request reinstatement of a suspended license prior to the end of the suspension term.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Unless otherwise provided by law, if an order of revocation or suspension did not establish terms on which reinstatement or reissuance may occur, or if the license was forfeited, an initial application for reinstatement or reissuance shall not be made until at least one year from the date of the order of the suspension, revocation, or acceptance of the forfeiture of a license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All proceedings on an application for reinstatement or reissuance, including preliminary and ancillary matters, shall be held in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{. The application shall be docketed in the original case in which the original license was suspended, revoked, or forfeited, if the case exists.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An order of reinstatement or reissuance shall be based on a written decision which incorporates findings of fact and conclusions of law. An order granting an application for reinstatement or reissuance may impose such terms and conditions as the commissioner or the commissioner\u8217\'3fs designee deems appropriate, and may include one or more penalties provided under }}}{{\f5\fs18\hyphpar0\qj{section 522C.14}}}{{\f5\fs18\hyphpar0\qj{. The order shall be a public record and may be disseminated in compliance with }}}{{\f5\fs18\hyphpar0\qj{chapter 22}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If an adjuster\u8217\'3fs ordered suspension period ends prior to the adjuster\u8217\'3fs license expiration date and the adjuster applies for reinstatement prior to the license expiration date and meets all applicable requirements, the division shall reinstate the license as soon as practicable but no earlier than the end of the suspension period if the division, after a complete review, determines the license should be reinstated.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If an adjuster\u8217\'3fs license is suspended beyond the adjuster\u8217\'3fs license expiration date, whether due to an ordered suspension time period or failure to apply for reinstatement prior to expiration, the adjuster must apply for reissuance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A submission of voluntary forfeiture of a license shall be made in writing to the commissioner. Forfeiture of a license is effective on the date of submission unless a contested case proceeding is pending on the date of submission. If a contested case proceeding is pending, the forfeiture shall become effective upon conditions as ordered by the commissioner. A forfeiture made during the pendency of a contested case proceeding shall be considered a disciplinary action and shall be published in the same manner as is applicable to any other form of disciplinary order.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commissioner shall not be prohibited from denying an application for reinstatement or reissuance, or from bringing an additional immediate action, if an adjuster has engaged in an additional violation of }}}{{\f5\fs18\hyphpar0\qj{chapter 507B}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, or otherwise failed to meet all applicable requirements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ shall not apply to reinstatement of an expired license or issuance of a new license that is not in connection with a disciplinary matter.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2025 Acts, ch 28, \'a749, 52}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7522C.6}}}{{\f5\fs12\hyphpar0\qj{, 522C.13}}}{{\f5\fs12\hyphpar0\qj{, 522C.16}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section applies beginning July 22, 2025, to a person currently doing business in this state as an independent adjuster or a staff adjuster as of January 1, 2025; }{{\f5\fs12\hyphpar0\qj{2025 Acts, ch 28, \'a752}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{NEW section}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{522C.16}}}{\*\bkmkstart stylerid1_2E24_2E2_2E2}{\*\bkmkend stylerid1_2E24_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Suspension for failure to pay child support or state debt.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commissioner shall deny an adjuster\u8217\'3fs application for license issuance, renewal, reinstatement, or reissuance; suspend a current license; or revoke a currently suspended license, upon receipt of a certificate of noncompliance from the child support recovery unit pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 252J}}}{{\f5\fs18\hyphpar0\qj{, or upon receipt of a certificate of noncompliance from the centralized collection unit of the department of revenue pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 272D}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon receipt of a certificate of noncompliance under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, the commissioner shall issue a notice to the adjuster that the division will, unless the certificate of noncompliance is withdrawn, deny the adjuster\u8217\'3fs application for license issuance, renewal, reinstatement, or reissuance, suspend the adjuster\u8217\'3fs current license, or revoke the adjuster\u8217\'3fs currently suspended license, thirty calendar days after the date the notice is mailed. Notice shall be sent to the adjuster\u8217\'3fs last known address by restricted certified mail, return receipt requested, or in accordance with the division\u8217\'3fs rules for service. The notice shall contain all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A statement that the commissioner intends to deny the adjuster\u8217\'3fs application for license issuance, renewal, reinstatement, or reissuance; suspend the adjuster\u8217\'3fs current license; or revoke the adjuster\u8217\'3fs currently suspended license in thirty calendar days unless the certificate of noncompliance is withdrawn.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A statement that the adjuster must contact the agency that issued the certificate of noncompliance to request a withdrawal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A statement that the adjuster does not have a right to a hearing before the division, but that the adjuster may file an application for a hearing in district court pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 252J.9}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{272D.9}}}{{\f5\fs18\hyphpar0\qj{, as applicable, and that the filing of an application by the adjuster will stay the proceedings of the division.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A copy of the certificate of noncompliance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An adjuster shall keep the commissioner informed of all actions taken by the district court or the issuing agency in connection with a certificate of noncompliance. Within seven calendar days of filing or issuance, an adjuster shall provide to the commissioner a copy of all applications filed with the district court pursuant to an application or hearing, all court orders entered in such action, and all withdrawals of a certificate of noncompliance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If an applicant or licensed adjuster timely files an application for hearing in district court and the division is notified of the filing, the commissioner\u8217\'3fs denial, suspension, or revocation proceedings shall be stayed until the division is notified by the district court, the issuing agency, the licensee, or the applicant of the resolution of the application. Upon receipt of a court order lifting the stay or otherwise directing the commissioner to proceed, the commissioner shall continue with the intended action described in the notice.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the commissioner does not receive a withdrawal of the certificate of noncompliance from the issuing agency, or a notice from a clerk of court, the issuing agency, the licensee, or the applicant that an application for hearing has been filed within thirty calendar days after the notice is issued, the commissioner shall deny the adjuster\u8217\'3fs application for license issuance, renewal, reinstatement, or reissuance; suspend a current license; or revoke a currently suspended license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon receipt of a withdrawal of a certificate of noncompliance from the issuing agency, suspension or revocation proceedings shall halt and the named adjuster shall be notified that the proceedings have halted. If the adjuster\u8217\'3fs license has already been suspended, the adjuster must apply for reinstatement in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 522C.15}}}{{\f5\fs18\hyphpar0\qj{, and the license shall be reinstated if the adjuster is otherwise in compliance with }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. If the adjuster\u8217\'3fs application for licensure was stayed, application processing shall resume. All fees required for license renewal, reinstatement, or reissuance must be paid by the adjuster, and all continuing education requirements shall be satisfied, before the adjuster\u8217\'3fs license is renewed or reinstated after a license suspension or revocation under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commissioner shall notify an adjuster in writing through regular first class mail, or such other means as the commissioner deems appropriate under the circumstances, within ten calendar days of the effective date of the suspension or revocation of the adjuster\u8217\'3fs license, and shall also notify the adjuster when the adjuster\u8217\'3fs license is reinstated following the commissioner\u8217\'3fs receipt of a withdrawal of the certificate of noncompliance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any provision of law to the contrary, the division may share information with the child support recovery unit or the centralized collection unit of the department of revenue for the sole purpose of identifying adjusters subject to enforcement under }}}{{\f5\fs18\hyphpar0\qj{chapter 252J}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{272D}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2025 Acts, ch 28, \'a750, 52}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section applies beginning July 22, 2025, to a person currently doing business in this state as an independent adjuster or a staff adjuster as of January 1, 2025; }{{\f5\fs12\hyphpar0\qj{2025 Acts, ch 28, \'a752}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{NEW section}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{522C.17}}}{\*\bkmkstart stylerid1_2E25_2E2_2E2}{\*\bkmkend stylerid1_2E25_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Severability.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If any provision of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ or the application thereof to any person or circumstance is held invalid, the invalidity does not affect other provisions or applications of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ which can be given effect without the invalid provision or application, and to this end the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ are severable.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2025 Acts, ch 28, \'a751, 52}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section applies beginning July 22, 2025, to a person currently doing business in this state as an independent adjuster or a staff adjuster as of January 1, 2025; }{{\f5\fs12\hyphpar0\qj{2025 Acts, ch 28, \'a752}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{NEW section}\par}}