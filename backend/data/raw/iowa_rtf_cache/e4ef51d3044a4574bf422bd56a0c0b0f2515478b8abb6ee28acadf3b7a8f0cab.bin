5\fs18\hyphpar0\qj{chapters 446}}}{, }{{\f5\fs18\hyphpar0\qj{447}}}{, and }{{\f5\fs18\hyphpar0\qj{448}}}{, }{{\f5\fs18\hyphpar0\qj{section 331.553, subsection 3}}}{, and }{{\f5\fs18\hyphpar0\qj{sections 427.8 through 427.12}}}{ and }{{\f5\fs18\hyphpar0\qj{569.8}}}{:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAbate\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means to cancel in their entirety all applicable amounts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCompromise\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means to enter into a contractual agreement for the payment of taxes, interest, fees, and costs in amounts different from those specified by law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCounty system\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a method of data storage and retrieval as approved by the auditor of state including, but not limited to, tax lists, books, records, indexes, registers, or schedules.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLegal representative\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a parent, guardian, or conservator of a person with a legal disability, a person appointed by a court to act on behalf of a person with a legal disability, or a person acting on behalf of a person with a legal disability pursuant to a power of attorney.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fParcel\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means each separate item shown on the tax list, manufactured or mobile home tax list, schedule of assessment, or schedule of rate or charge.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPerson with a legal disability\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a minor or a person of unsound mind.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fRate or charge\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an item, including rentals, legally certified to the county treasurer for collection as provided in }}}{{\f5\fs18\hyphpar0\qj{sections 169C.6,}}}{{\f5\fs18\hyphpar0\qj{ }}}{{\f5\fs18\hyphpar0\qj{331.465}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{331.489}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{358.20}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{359A.6}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{364.11}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{364.12}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{468.589}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{section 384.84, subsection 4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fTaxes\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an annual ad valorem tax, a special assessment, a drainage tax, a rate or charge, and taxes on homes pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 435}}}{{\f5\fs18\hyphpar0\qj{ which are collectible by the county treasurer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fTotal amount due\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the aggregate total of all taxes, penalties, interest, costs, and fees due on a parcel.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a7751; C73, \'a7846; C97, \'a71390; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7184;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7445.1}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1139, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 191, \'a726}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1163, \'a785}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 73, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 57, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 153, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 176, \'a780}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1118, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1039, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a76B.1}}}{{\f5\fs12\hyphpar0\qj{, 11.1}}}{{\f5\fs12\hyphpar0\qj{, 12B.1}}}{{\f5\fs12\hyphpar0\qj{, 24.2}}}{{\f5\fs12\hyphpar0\qj{, 35B.1}}}{{\f5\fs12\hyphpar0\qj{, 43.2}}}{{\f5\fs12\hyphpar0\qj{, 50.1}}}{{\f5\fs12\hyphpar0\qj{, 62.1}}}{{\f5\fs12\hyphpar0\qj{, 64.1}}}{{\f5\fs12\hyphpar0\qj{, 65.1}}}{{\f5\fs12\hyphpar0\qj{, 66.1}}}{{\f5\fs12\hyphpar0\qj{, 69.1}}}{{\f5\fs12\hyphpar0\qj{, 96.1B}}}{{\f5\fs12\hyphpar0\qj{, 99.1}}}{{\f5\fs12\hyphpar0\qj{, 144.1}}}{{\f5\fs12\hyphpar0\qj{, 161A.3}}}{{\f5\fs12\hyphpar0\qj{, 169C.1}}}{{\f5\fs12\hyphpar0\qj{, 177A.2}}}{{\f5\fs12\hyphpar0\qj{, 230.1}}}{{\f5\fs12\hyphpar0\qj{, 257B.1}}}{{\f5\fs12\hyphpar0\qj{, 306.2}}}{{\f5\fs12\hyphpar0\qj{, 309.1}}}{{\f5\fs12\hyphpar0\qj{, 311.1}}}{{\f5\fs12\hyphpar0\qj{, 317.1}}}{{\f5\fs12\hyphpar0\qj{, 321A.1}}}{{\f5\fs12\hyphpar0\qj{, 331.552}}}{{\f5\fs12\hyphpar0\qj{, 331.559}}}{{\f5\fs12\hyphpar0\qj{, 353.1}}}{{\f5\fs12\hyphpar0\qj{, 354.2}}}{{\f5\fs12\hyphpar0\qj{, 357.1}}}{{\f5\fs12\hyphpar0\