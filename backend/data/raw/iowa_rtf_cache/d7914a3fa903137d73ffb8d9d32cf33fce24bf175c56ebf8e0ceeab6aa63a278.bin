{SUBCHAPTER I}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E6_2E2_2E2}{GENERAL PROVISIONS}{\*\bkmkend stylerid1_2E6_2E2_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{483A.1}}}{\*\bkmkstart stylerid1_2E6_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Licenses }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ fees }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ rules.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, a person shall not fish, trap, hunt, pursue, catch, kill, take in any manner, use, have possession of, sell, or transport all or a part of any wild animal, bird, game, turtle, or fish, the protection and regulation of which is desirable for the conservation of resources of the state, without first obtaining a license for that purpose, and the payment of a fee as established by rules adopted by the commission pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The fees established by rule pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ shall be periodically evaluated by the department, but not less often than once every three years, to ensure that the fees paid are sufficient to meet the needs of natural resource management and the public.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{By December 15 of each year on and after December 15, 2019, that an evaluation of the license fees is completed, the department shall file a written report with the commission and the general assembly which shall include the evaluation and recommendations for changes, if any. Any fee increase proposed in such a report shall not take effect until on or after December 15 of the year succeeding the report and an individual license fee shall not be increased in any calendar year in an amount that exceeds five percent.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a72563-a2, -o, -p; SS15, \'a72547-a, 2562-b, 2563-a1; C24, \'a71706, 1718, 1719, 1748, 1752, 1756, 1779; C27, \'a71706, 1718, 1719, 1719-a1, 1748, 1752, 1756, 1779; C31, \'a71706, 1718, 1718-c1, 1719, 1719-a1, 1748, 1752, 1756, 1766-c3, 1779; C35, \'a71794-e1; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1794.082;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7110.1}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1199, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1260, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1114, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1141, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1240, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 90, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 237, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 238, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 237, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1216, \'a710, 11}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7483A.1}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{95 Acts, ch 12, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 46, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1199, \'a75, 27}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1223, \'a730}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 137, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 148, \'a71 \u8211\'3f 3, 9}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1141, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 120, \'a71 \u8211\'3f 4, 6}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 152, \'a71 \u8211\'3f 3, 6}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 139, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 194, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 144, \'a732, 33}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 179, \'a7147, 214, 215, 217}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1096, \'a75, 23}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1118, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 62, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1058, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1159, \'a71, 28}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.605}}}{{\f5\fs12\hyphpar0\qj{, 481A.93}}}{{\f5\fs12\hyphpar0\qj{, 483A.1A}}}{{\f5\fs12\hyphpar0\qj{, 483A.3}}}{{\f5\fs12\hyphpar0\qj{, 483A.7}}}{{\f5\fs12\hyphpar0\qj{, 483A.8}}}{{\f5\fs12\hyphpar0\qj{, 483A.9A}}}{{\f5\fs12\hyphpar0\qj{, 483A.17}}}{{\f5\fs12\hyphpar0\qj{, 483A.24}}}{{\f5\fs12\hyphpar0\qj{, 483A.28}}}{{\f5\fs12\hyphpar0\qj{, 717F.7}}}{{\f5\fs12\hyphpar0\qj{, 805.8B(3)(o)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Commercial fishing licenses, see }{{\f5\fs12\hyphpar0\qj{\'a7482.4}}}{ }\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fines, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8B, subsection 3}}}{, paragraph o }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{483A.1A}}}{\*\bkmkstart stylerid1_2E6_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{As used in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ unless the context otherwise requires:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fBoundary waters\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the waters of the Mississippi, Missouri, and Big Sioux rivers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCommission\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the natural resource commission created under }}}{{\f5\fs18\hyphpar0\qj{section 455A.5}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDepartment\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the department of natural resources created under }}}{{\f5\fs18\hyphpar0\qj{section 455A.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDirector\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the director of the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLicense\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a privilege granted by the commission to fish, hunt, fur harvest, pursue, catch, kill, take in any manner, use, have possession of, sell, or transport all or part of a wild animal, bird, game, or fish, including any privilege related to a license granted by issuance of a stamp or a payment of a fee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLicense agent\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an individual, business, or governmental agency authorized to sell a license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLicense document\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an authorization, certificate, or permit issued by the department or a license agent that lists and confers one or more license privileges.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fNonresident\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person who is not a resident as defined in }}}{{\f5\fs18\hyphpar0\qj{subsection 10}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPrincipal and primary residence or domicile\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the one and only place where a person has a true, fixed, and permanent home, and to where, whenever the person is briefly and temporarily absent, the person intends to return. Relevant factors in determining a person\u8217\'3fs principal and primary residence or domicile include but are not limited to proof of place of employment, mailing address, utility records, land ownership records, vehicle registration, and address listed on the person\u8217\'3fs state and federal income tax returns. A person shall submit documentation to establish the person\u8217\'3fs principal and primary residence or domicile to the department or its designee upon request. The department or its designee shall keep confidential any document received pursuant to such a request if the document is required to be kept confidential by state or federal law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fResident\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a natural person who meets any of the following criteria during each year in which the person claims status as a resident:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Has physically resided in this state as the person\u8217\'3fs principal and primary residence or domicile for a period of not less than ninety consecutive days immediately before applying for or purchasing a resident license, tag, or permit under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and has been issued an Iowa driver\u8217\'3fs license or an Iowa nonoperator\u8217\'3fs identification card. A person is not considered a resident under this paragraph if the person is residing in the state only for a special or temporary purpose including but not limited to engaging in hunting, fishing, or trapping.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is a full-time student at either of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An accredited educational institution located in this state and resides in this state while attending the educational institution.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An accredited educational institution located outside of this state, if the person is under the age of twenty-five and has at least one parent or legal guardian who maintains a principal and primary residence or domicile in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is a student who qualifies as a resident pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ only for the purpose of purchasing any resident license specified in rules adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 483A.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is a nonresident under eighteen years of age whose parent is a resident of this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is a member of the armed forces of the United States who is serving on active duty and meets any of the following qualifications:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Claims residency in this state and has filed a state individual income tax return as a resident pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 422, subchapter II}}}{{\f5\fs18\hyphpar0\qj{, for the preceding tax year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is stationed at a federal military installation in this state, or at a federal military installation contiguous to a county in this state, and is domiciled within this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is stationed at and resides or is domiciled within a federal military installation located contiguous to a county in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is the spouse of a person included in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1245, \'a71858}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C87, \'a7110.1A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7483A.1A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{95 Acts, ch 76, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1116, \'a73 \u8211\'3f 5}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1175, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 134, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 37, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 144, \'a734, 35}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 34, \'a7112}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1159, \'a715, 28}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1062, \'a794}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1073, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 76, \'a7122}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321G.1}}}{{\f5\fs12\hyphpar0\qj{, 321I.1}}}{{\f5\fs12\hyphpar0\qj{, 482.2}}}{{\f5\fs12\hyphpar0\qj{, 483A.2}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{483A.2}}}{\*\bkmkstart stylerid1_2E6_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Dual residency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A resident license shall be limited to persons who do not claim any resident privileges, except as defined in }{{\f5\fs18\hyphpar0\qj{section 483A.1A, subsection 10}}}{, paragraphs }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{, }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{, }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{, and }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{, in another state or country. A person shall not purchase or apply for any resident license or permit if that person has claimed residency in any other state or country.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1116, \'a76}}}{; }{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 144, \'a736}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{483A.3}}}{\*\bkmkstart stylerid1_2E6_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Wildlife habitat fee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A resident or nonresident person required to have a hunting or fur harvester license shall not hunt or trap unless the person purchases a hunting or fur harvester license that includes the wildlife habitat fee, in an amount established by rules adopted by the commission pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 483A.1}}}{{\f5\fs18\hyphpar0\qj{. }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Residents who have permanent disabilities or who are younger than sixteen or older than sixty-five years of age may purchase a hunting or fur harvester license that does not include the wildlife habitat fee. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All wildlife habitat fees shall be administered in the same manner as hunting and fur harvester licenses except all revenue derived from wildlife habitat fees shall be used within the state of Iowa for habitat development and shall be deposited in the state fish and game protection fund, except as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{. The revenue may be used for the matching of federal funds. The revenues and any matched federal funds shall be used for acquisition of land, leasing of land, or obtaining of easements from willing sellers for use as wildlife habitats. Notwithstanding the exemption provided by }}}{{\f5\fs18\hyphpar0\qj{section 427.1}}}{{\f5\fs18\hyphpar0\qj{, any land acquired with the revenues and matched federal funds shall be subject to the full consolidated levy of property taxes, which shall be paid from the income generated from those lands or, if no such income is generated, from the wildlife habitat fee revenues. In addition the revenue may be used for the development and enhancement of wildlife lands and habitat areas.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Not less than three dollars from each wildlife habitat fee shall be allocated as specified in }}}{{\f5\fs18\hyphpar0\qj{section 483A.3B}}}{{\f5\fs18\hyphpar0\qj{ and not less than fifty percent of the balance of each fee shall be used by the commission to enter into agreements with county conservation boards or other public agencies in order to carry out the purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. However, the state share of funding of those agreements provided by the revenue from wildlife habitat fees shall not exceed seventy-five percent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Up to sixty percent of the revenues from wildlife habitat fees which are not required under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ to be used by the commission to enter into agreements with county conservation boards or other public agencies may be credited to the wildlife habitat bond fund as provided in }}}{{\f5\fs18\hyphpar0\qj{section 483A.53}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{subsections 1 and 2}}}{{\f5\fs18\hyphpar0\qj{, any increase in wildlife habitat fee revenues collected on or after December 15, 2018, pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ as a result of wildlife habitat fee increases established by rules adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 483A.1}}}{{\f5\fs18\hyphpar0\qj{, shall be used by the commission for any of the purposes set forth in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ or in }}}{{\f5\fs18\hyphpar0\qj{section 483A.3B}}}{{\f5\fs18\hyphpar0\qj{, except that such increases in revenues collected shall not be used by the commission for the purpose of land acquisition. The commission shall not reduce on an annual basis for these purposes the amount of other funds being expended as of December 15, 2018.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A multi-year hunting license purchased pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 483A.9A}}}{{\f5\fs18\hyphpar0\qj{, includes the payment of a wildlife habitat fee for each of the years for which the license is valid and those fees shall be used as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7110.3}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1260, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1114, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1231, \'a71}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7483A.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1129, \'a798}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1199, \'a76, 27}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1223, \'a730}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 194, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1096, \'a76, 23}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1159, \'a72 \u8211\'3f 5, 28}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7427.1(24)(a)}}}{{\f5\fs12\hyphpar0\qj{, 483A.3B}}}{{\f5\fs12\hyphpar0\qj{, 805.8B(3)(b)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8B}}}{, subsection 3, paragraph b }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{483A.3A}}}{\*\bkmkstart stylerid1_2E6_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Fish habitat development funding.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Three dollars from each resident and nonresident annual and seven-day fishing license and nine dollars from each resident multi-year fishing license sold shall be deposited in the state fish and game protection fund and shall be used within this state for fish habitat development. Not less than fifty percent of this amount shall be used by the commission to enter into agreements with county conservation boards to carry out the purposes of }{{\f5\fs18\hyphpar0\qj{this section}}}{.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 148, \'a74, 9}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 152, \'a74, 6}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1096, \'a77, 23}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1159, \'a76, 28}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{483A.3B}}}{\*\bkmkstart stylerid1_2E6_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Game bird habitat development programs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E6_2E8_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E6_2E8_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Allocation of revenue }}}{{\i\f5\fs18\hyphpar0\qj{\u8212\'3f}}}{{\i\f5\fs18\hyphpar0\qj{ accounts.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All revenue collected from wildlife habitat fees as provided in }}}{{\f5\fs18\hyphpar0\qj{section 483A.3, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, that is deposited in the state fish and game protection fund and that is allocated pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be allocated as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Not less than two dollars of each wildlife habitat fee collected shall be allocated to the game bird wetlands conservation account.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Not less than one dollar of each wildlife habitat fee collected shall be allocated to the game bird buffer strip assistance account.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 12C.7, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, interest or earnings on moneys collected from wildlife habitat fees that are deposited in each account created under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be credited to that account. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 8.33}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{section 456A.17}}}{{\f5\fs18\hyphpar0\qj{, moneys credited to each account created under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not revert to the state general fund at the close of a fiscal year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All revenue collected from wildlife habitat fees as provided in }}}{{\f5\fs18\hyphpar0\qj{section 483A.3, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, that is allocated pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be used as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, except for that part which is specified by the department for use in paying administrative expenses as provided in }}}{{\f5\fs18\hyphpar0\qj{section 456A.17}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E6_2E8_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E6_2E8_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Game bird wetlands conservation program.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All moneys allocated to the game bird wetlands conservation account shall be used by the department only to carry out the purposes of the game bird wetlands conservation program and shall be used in addition to funds already being expended by the department each year for wetlands conservation purposes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The purpose of the game bird wetlands conservation program is to create a sustained source of revenue to be used by the department to qualify for federal matching funds that are available for wetlands conservation and to undertake projects in conjunction with soil and water conservation districts, county conservation boards, and other partners that will aid in wetlands and associated habitat conservation in the state, including the acquisition, restoration, maintenance, or preservation of wetlands and associated habitat.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All moneys that are allocated to the game bird wetlands conservation account shall accumulate in the account until the account balance is equal to one million dollars or an amount sufficient to be used by the department to qualify for federal matching funds. Each time the account balance reaches an amount sufficient to be used by the department to qualify for federal matching funds, the department shall apply for such matching funds, and upon obtaining such funds, shall expend the state and federal revenues available at that time to undertake projects as set forth in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Additional moneys that are generated by game bird wildlife habitat fees and allocated to the game bird wetlands conservation account shall again accumulate in the account, and each time the account balance is equal to one million dollars or an amount sufficient to be used by the department to qualify for federal matching funds, the department shall again apply for federal matching funds, and upon obtaining such funds, shall expend the state and federal revenues available at that time to undertake projects as set forth in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall use all state revenue and federal matching funds obtained under the federal North American Wetlands Conservation Act to undertake the purposes of the game bird wetlands conservation program as set forth in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. State revenue allocated to the account shall be used by the department only for projects that increase public recreational hunting opportunities in the state and shall not be used for projects on private land that is not accessible to the public for recreational hunting.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{\*\bkmkstart stylerid1_2E6_2E8_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E6_2E8_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Game bird buffer strip assistance program.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All moneys allocated to the game bird buffer strip assistance account shall be used by the department only to carry out the purposes of the game bird buffer strip assistance program and shall be used in addition to funds already being expended by the department each year for such purposes. The department shall not reduce the amount of other funds being expended for these purposes as of July 1, 2007.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The purpose of the game bird buffer strip assistance program is to increase landowner participation in federally funded conservation programs that benefit game birds and to increase opportunities for recreational hunting on private lands. To the extent possible, moneys allocated to the game bird buffer strip assistance account shall be used in conjunction with and to qualify for additional funding from private conservation organizations and other state and federal agencies to accomplish the purposes of the program. The funds may be used to provide private landowners with cost-sharing assistance for habitat improvement practices on projects that are not eligible for federal programs or where federal funding for such projects is not adequate. The department may utilize the funds to provide marketing and outreach efforts to landowners in order to maximize landowners\u8217\'3f use of federal conservation programs. The department may coordinate such marketing and outreach efforts with soil and water conservation districts and other partners.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All moneys that are allocated to the game bird buffer strip assistance account shall accumulate in the account for a period of three years. At the end of the three-year period, the moneys in the account shall be used by the department to carry out the purposes of the game bird buffer strip assistance program as set forth in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. The department shall, by rule pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{, establish eligibility requirements for the program and procedures for applications for and approval of projects to be funded under the program. The department shall expend moneys from the account only for projects on private land that is accessible to the public for recreational hunting.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Additional moneys that are generated by game bird wildlife habitat fees and allocated to the game bird buffer strip assistance account shall accumulate in the account and shall be used by the department every three years as set forth in subparagraph (1).}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 194, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1159, \'a77, 28}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7483A.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{483A.4}}}{\*\bkmkstart stylerid1_2E6_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{\u8220\'3fPermanent disability\u8221\'3f defined.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{For the purpose of obtaining a license, a person has a }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fpermanent disability\u8221\'3f}}}{ if any of the following apply:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person has been found under the provisions of the federal Social Security Act, Tit. II, or any other public or private pension system to have a total, permanent physical or mental condition which prevents that person from engaging in the person\u8217\'3fs occupation or qualifies that person for retirement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person has a severe physical disability and has qualified for a special license under }}}{{\f5\fs18\hyphpar0\qj{section 483A.24}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7110.4}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1260, \'a74}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7483A.4}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1129, \'a799}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7180}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{483A.5}}}{\*\bkmkstart stylerid1_2E6_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Fur harvester license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A fur harvester license is required to hunt and to trap any fur-bearing animal. A hunting license is not required when hunting furbearers with a fur harvester license. However, coyote and groundhog may be hunted with a hunting or a fur harvester license.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1260, \'a712}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C85, \'a7110.5}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 10, \'a72}}}{; }{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1114, \'a73}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7483A.5}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1199, \'a77, 27}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1223, \'a730}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{483A.6}}}{\*\bkmkstart stylerid1_2E6_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Trout fishing fee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Any person required to have a fishing license shall not fish for or possess trout unless that person has paid the trout fishing fee. The proceeds from the fee shall be used exclusively for the trout program designated by the commission. The commission may grant a permit to a community event in which trout will be stocked in water which is not designated trout water and a person may catch and possess trout during the period and from the water covered by the permit without having paid the trout fishing fee.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C62, 66, 71, 73, 75, 77, \'a7110.1; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7110.6}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1240, \'a72}}}{; }{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1245, \'a71877}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7483A.6}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1199, \'a78, 27}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1223, \'a730}}}{; }{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 152, \'a75, 6}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7805.8B(3)(b)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8B}}}{, subsection 3, paragraph b }\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Special licenses, see }{{\f5\fs12\hyphpar0\qj{\'a7483A.24}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{483A.6A}}}{\*\bkmkstart stylerid1_2E6_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Paddlefish fishing license and tag.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A resident fishing for paddlefish on the Missouri or Big Sioux river who is required to have a fishing license must purchase a paddlefish fishing license, in addition to a resident fishing license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A nonresident fishing for paddlefish on the Missouri or Big Sioux river is required to have a fishing license that is valid in Iowa and, in addition, purchase a nonresident paddlefish fishing license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall establish the number of annual paddlefish fishing licenses that may be issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 481A.39}}}{{\f5\fs18\hyphpar0\qj{ for use on the Missouri or Big Sioux river. A paddlefish fishing license shall be accompanied by a tag designed to be used only once. If a paddlefish is taken pursuant to a paddlefish fishing license, the paddlefish shall be tagged immediately and the tag shall be dated.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2014 Acts, ch 1058, \'a73}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7805.8B(3)(c)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8B}}}{, subsection 3, paragraph c}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Special licenses, see }{{\f5\fs12\hyphpar0\qj{\'a7483A.24}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{483A.6B}}}{\*\bkmkstart stylerid1_2E6_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Nonresident five-day hunting license }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ fee.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by its own terms; }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2018/CH1159.pdf" }{\fldrslt \cf5 \f5 \fs18{{2018 Acts, ch 1159, \'a78}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{483A.7}}}{\*\bkmkstart stylerid1_2E6_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Wild turkey hunting license and tag.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A resident hunting wild turkey who is required to have a license must purchase a resident hunting license that includes the wildlife habitat fee in addition to the wild turkey hunting license. Upon application and payment of the required fees for archery-only licenses, a resident archer shall be issued two wild turkey licenses for the spring season.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The wild turkey hunting license shall be accompanied by a tag designed to be used only once. If a wild turkey is taken, the wild turkey shall be tagged and the tag shall be dated.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A nonresident wild turkey hunter is required to purchase a nonresident hunting license that includes the wildlife habitat fee and a nonresident wild turkey hunting license. The commission shall annually limit to two thousand three hundred licenses the number of nonresidents allowed to have wild turkey hunting licenses. Of the two thousand three hundred licenses, one hundred fifty licenses shall be valid for hunting with muzzle loading shotguns only. The commission shall allocate the nonresident wild turkey hunting licenses issued among the zones based on the populations of wild turkey. A nonresident applying for a wild turkey hunting license must exhibit proof of having successfully completed a hunter education program as provided in }}}{{\f5\fs18\hyphpar0\qj{section 483A.27}}}{{\f5\fs18\hyphpar0\qj{ or its equivalent as determined by the department before the license is issued.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall assign one preference point to a nonresident whose application for a nonresident wild turkey hunting license is denied due to limitations on the number of nonresident wild turkey hunting licenses available for issuance that year. An additional preference point shall be assigned to that person each subsequent year the person\u8217\'3fs license application is denied for that reason. A nonresident may purchase additional preference points pursuant to rules adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 483A.1}}}{{\f5\fs18\hyphpar0\qj{. The first nonresident wild turkey hunting license drawing each year shall be made from the pool of applicants with the most preference points and continue to pools of applicants with successively fewer preference points until all available nonresident wild turkey hunting licenses have been issued. If a nonresident applicant receives a wild turkey hunting license, all of the applicant\u8217\'3fs assigned preference points at that time shall be removed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who is issued a youth spring wild turkey hunting license and does not take a wild turkey during the youth spring wild turkey hunting season may use the wild turkey hunting license and unused tag during any other wild turkey hunting season that is established by the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall authorize a person hunting wild turkey with a license that authorizes the use of a shotgun to use a caliber .410 shotgun or a 28-gauge shotgun. A caliber .410 shotgun or a 28-gauge shotgun used for hunting wild turkey shall only shoot shot not smaller than shot size number 10.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1240, \'a73}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C87, \'a7110.7}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 237, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1003, \'a71}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7483A.7}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1111, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1199, \'a79, 27}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1223, \'a730}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 134, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 148, \'a75, 9}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1119, \'a763}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 144, \'a737}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 179, \'a7147}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1096, \'a78, 9, 23}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1015, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 26, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1159, \'a716, 28}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1093, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 66, \'a7118}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7483A.24}}}{{\f5\fs12\hyphpar0\qj{, 805.8B(3)(c)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8B}}}{, subsection 3, paragraph c }\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Special licenses, see }{{\f5\fs12\hyphpar0\qj{\'a7483A.24}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{483A.8}}}{\*\bkmkstart stylerid1_2E6_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Deer hunting license and tag.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A resident hunting deer who is required to have a hunting license must purchase a resident hunting license that includes the wildlife habitat fee, in addition to the deer hunting license. In addition, a resident who purchases a deer hunting license shall pay a one dollar fee that shall be used and is appropriated for the purpose of deer herd population management, including assisting with the cost of processing deer donated to the help us stop hunger program administered by the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The deer hunting license shall be accompanied by a tag designed to be used only once. When a deer is taken, the deer shall be tagged and the tag shall be dated. The tag shall be attached to the carcass of a deer taken within fifteen minutes of the time the deer carcass is located after being taken, or before the carcass is moved to be transported by any means from the place where the deer was taken, whichever occurs first. For each antlered deer taken, the tag shall be affixed to the deer\u8217\'3fs antlers.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of the tagging requirements in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, a deer carcass may be moved away from an obstacle, entanglement, waterway, or any other area, including but not limited to a roadway, if tagging the carcass at that location would be a safety hazard to the hunter or a third person, before the tag is attached to the carcass. However, the carcass shall not be moved from the immediate vicinity of where the deer was taken, shall be moved only so far as is necessary to avoid the obstacle, entanglement, waterway, or other safety hazard, and shall be tagged immediately upon being so moved and before being moved to be transported.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A nonresident hunting deer is required to purchase a nonresident annual hunting license that includes the wildlife habitat fee and a nonresident deer hunting license. In addition, a nonresident who purchases a deer hunting license shall pay a one dollar fee that shall be used and is appropriated for the purpose of deer herd population management, including assisting with the cost of processing deer donated to the help us stop hunger program administered by the commission.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A nonresident who purchases an antlered or any sex deer hunting license pursuant to rules adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 483A.1}}}{{\f5\fs18\hyphpar0\qj{, is required to purchase an antlerless deer only deer hunting license at the same time, pursuant to rules adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 483A.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall annually limit to six thousand the number of nonresidents allowed to have antlered or any sex deer hunting licenses. Of the six thousand nonresident antlered or any sex deer hunting licenses issued, not more than thirty-five percent of the licenses shall be bow season licenses. After the six thousand antlered or any sex nonresident deer hunting licenses have been issued, all additional licenses shall be issued for antlerless deer only. The commission shall annually determine the number of nonresident antlerless deer only deer hunting licenses that will be available for issuance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall allocate all nonresident deer hunting licenses issued among the zones based on the populations of deer. However, a nonresident applicant may request one or more hunting zones, in order of preference, in which the applicant wishes to hunt. If the request cannot be fulfilled, the applicable fees shall be returned to the applicant. A nonresident applying for a deer hunting license must exhibit proof of having successfully completed a hunter education program as provided in }}}{{\f5\fs18\hyphpar0\qj{section 483A.27}}}{{\f5\fs18\hyphpar0\qj{ or its equivalent as determined by the department before the license is issued.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall assign one preference point to a nonresident whose application for a nonresident antlered or any sex deer hunting license is denied due to limitations on the number of nonresident antlered or any sex deer hunting licenses available for issuance that year. An additional preference point shall be assigned to that person each subsequent year the person\u8217\'3fs license application is denied for that reason. A nonresident may purchase additional preference points pursuant to rules adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 483A.1}}}{{\f5\fs18\hyphpar0\qj{. The first nonresident antlered or any sex deer hunting license drawing each year shall be made from the pool of applicants with the most preference points and continue to pools of applicants with successively fewer preference points until all available nonresident antlered or any sex deer hunting licenses have been issued. If a nonresident applicant receives an antlered or any sex deer hunting license, all of the applicant\u8217\'3fs assigned preference points at that time shall be removed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission may provide, by rule, for the issuance of an additional antlerless deer hunting license to a person who has been issued an antlerless deer hunting license. The rules shall specify the number of additional antlerless deer hunting licenses which may be issued, and the season and zone in which the license is valid. The fee for an additional antlerless deer hunting license shall be an amount established by rules adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 483A.1}}}{{\f5\fs18\hyphpar0\qj{ for residents.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A nonresident owning land in this state may apply for a nonresident antlered or any sex deer hunting license, and the provisions of }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{ shall apply. However, if a nonresident owning land in this state is unsuccessful in obtaining one of the nonresident antlered or any sex deer hunting licenses, the landowner shall be given preference for one of the antlerless deer only nonresident deer hunting licenses available pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{. A nonresident owning land in this state shall pay the fee for a nonresident antlerless only deer hunting license and the license shall be valid to hunt on the nonresident\u8217\'3fs land only. If one or more parcels of land have multiple nonresident owners, only one of the nonresident owners is eligible for a nonresident antlerless only deer hunting license. If a nonresident jointly owns land in this state with a resident, the nonresident shall not be given preference for a nonresident antlerless only deer hunting license. The department may require proof of land ownership from a nonresident landowner applying for a nonresident antlerless only deer hunting license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall provide by rule for the annual issuance to a nonresident of a nonresident antlerless deer hunting license that is valid for use only during the period beginning on December 24 and ending at sunset on January 2 of the following year and costs an amount established by rules adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 483A.1}}}{{\f5\fs18\hyphpar0\qj{. A nonresident hunting deer with a license issued under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be otherwise qualified to hunt deer in this state and shall purchase a nonresident annual hunting license that includes the wildlife habitat fee, and pay the one dollar fee for the purpose of deer herd population management as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{. Pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, the commission shall make available for issuance only the remaining nonresident antlerless deer hunting licenses allocated under }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{ that have not yet been issued for the current year\u8217\'3fs nonresident antlerless deer hunting seasons.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall make youth deer hunting licenses available for purchase during the same time period that general deer hunting licenses are available for purchase, including through all established deer hunting seasons. A person who is issued a youth deer hunting license may use the deer hunting license and tag during the season for which the license was issued or in any subsequent established deer hunting season using a method of take authorized for that season. If the tag is filled during one of the seasons, the license will not be valid in subsequent seasons.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall adopt a rule permitting a resident to use a crossbow for taking deer during the late season that is designated for taking deer by muzzleloading rifle or muzzleloading pistol.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{There shall be a January antlerless deer only hunting season in a county whenever that county has unsold antlerless deer licenses available in its county quota as set by the commission by rule. The commission shall establish the season dates. Licenses shall be available for sale beginning the day after the close of the late muzzleloader season until either the county quota allotment has been sold or until the end of the season, whichever occurs first. A January antlerless deer only license issued under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ is valid only in the county identified on the license. A rifle with a barrel length of at least sixteen inches and firing centerfire ammunition propelling an expanding-type bullet with a maximum diameter of no less than two hundred twenty-three thousandths of one inch and no larger than five hundred thousandths of one inch and with a published or calculated muzzle energy of five hundred foot pounds or higher is the approved method of take for this season.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7110.8}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1240, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 237, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1003, \'a72}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7483A.8}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1111, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1199, \'a710, 27}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1203, \'a75 \u8211\'3f 7}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1223, \'a728 \u8211\'3f 30}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 134, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 148, \'a76, 7, 9}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1119, \'a764}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 85, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 139, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 179, \'a7132}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 129, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1158, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 144, \'a738}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 179, \'a7216, 217}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 103, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1096, \'a710 \u8211\'3f 12, 23}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1100, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 26, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 48, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1159, \'a79, 17, 18, 28}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1137, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 55, \'a72}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7483A.24}}}{{\f5\fs12\hyphpar0\qj{, 805.8B(3)(c)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8B, subsection 3}}}{, paragraph c }\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Special licenses, see }{{\f5\fs12\hyphpar0\qj{\'a7483A.8B}}}{, }{{\f5\fs12\hyphpar0\qj{483A.8C}}}{, }{{\f5\fs12\hyphpar0\qj{483A.24}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 7 amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{483A.8A}}}{\*\bkmkstart stylerid1_2E6_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Deer and wild turkey harvest reporting system.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall provide, by rule, for the establishment of a deer and wild turkey harvest reporting system for the purpose of collecting information from hunters concerning the deer and wild turkey population in this state. Each person who is issued a deer or wild turkey hunting license in this state shall report such information pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. Information collected by the commission pursuant to the deer and wild turkey harvest reporting system from a hunter who takes a deer or wild turkey shall be limited to the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county where the deer or wild turkey was taken.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The season during which the deer or wild turkey was taken.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The sex of the deer or wild turkey taken.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The age of the deer or wild turkey taken.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The type of weapon used.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The hunting license number of the hunter.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The number of days the hunter hunted.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The total number of deer or wild turkey taken by the hunter.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The deer and wild turkey harvest reporting system established by the commission shall utilize and is limited to utilizing one or more of the following methods of reporting deer or wild turkey taken by hunters:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A toll-free telephone number.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A postcard.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reporting at an electronic licensing location.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Electronic internet communication.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 139, \'a75}}}{; }{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 144, \'a739}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7481C.2A}}}{{\f5\fs12\hyphpar0\qj{, 805.8B(3)(b)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8B}}}{, subsection 3, paragraph b}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{483A.8B}}}{\*\bkmkstart stylerid1_2E6_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Senior crossbow deer hunting licenses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who is a resident and who is sixty-five years of age or older may be issued one special senior statewide antlerless deer only crossbow deer hunting license to hunt deer during bow season as established by rule by the commission. A person who obtains a license to hunt deer under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is not required to pay the wildlife habitat fee but shall be otherwise qualified to hunt deer in this state and shall purchase a resident hunting license that does not include the wildlife habitat fee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person may obtain a license under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ in addition to a statewide antlered or any sex deer hunting bow season license. Season dates, shooting hours, limits, license quotas, and other regulations for this license shall be the same as set forth by the commission by rule for bow season deer hunts.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1064, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1096, \'a713, 23}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1091, \'a71}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{483A.8C}}}{\*\bkmkstart stylerid1_2E6_2E18_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E18_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Nonambulatory persons \u8212\'3f deer hunting licenses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A nonambulatory person who is a resident may be issued one any sex deer hunting license to hunt deer with a shotgun, muzzleloading rifle, or any handgun or rifle described in }}}{{\f5\fs18\hyphpar0\qj{section 481A.48}}}{{\f5\fs18\hyphpar0\qj{ during any established deer hunting season. If the tag is filled during one of the seasons, the license will not be valid in subsequent seasons. A person who applies for a license pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall complete a form, as required by rule, that is signed by a physician who verifies that the person is nonambulatory.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who obtains a deer hunting license under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is not required to pay the wildlife habitat fee but shall purchase a deer hunting license and hunting license that does not include the wildlife habitat fee, be otherwise qualified to hunt, and pay a one dollar fee that shall be used and is appropriated for the purpose of deer herd population management, including assisting with the cost of processing deer donated to the help us stop hunger program administered by the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person may obtain a license under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ in addition to any other deer hunting licenses for which the person is eligible.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fnonambulatory person\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an individual who has received a nonambulatory person\u8217\'3fs permit from the department as provided by rule, and at a minimum has one or more of the following conditions:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Paralysis of the lower half of the body, usually due to disease or a spinal cord injury.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Loss or partial loss of both legs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any other physical affliction which makes it impossible for the person to ambulate successfully.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 83, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1096, \'a714, 23}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 70, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1137, \'a79}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{483A.8D}}}{\*\bkmkstart stylerid1_2E6_2E19_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E19_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Disabled veterans }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ deer hunting licenses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A disabled veteran who is a resident may be issued one any sex deer hunting license to hunt deer during any established firearm deer hunting season using the method of take authorized for the season being hunted. A person who applies for a license pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall complete a form, as required by rule, that provides proof of the person\u8217\'3fs resident and disability status.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person may obtain a license under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ in addition to any other deer hunting license for which the person is eligible.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fdisabled veteran\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person who has served in the armed forces of the United States on federal active duty and who was disabled during the veteran\u8217\'3fs military service, as verified by the department of veterans affairs.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2025 Acts, ch 73, \'a71}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{NEW section}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{483A.9}}}{\*\bkmkstart stylerid1_2E6_2E2_30_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Blanks.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The director shall provide blanks for, and determine the method, means, and requirements of issuing licenses, including the issuance of licenses by electronic means.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a72563-a3; C24, 27, 31, \'a71722; C35, \'a71794-e2; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1794.083;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, \'a7110.2; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7110.9}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1245, \'a71878}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7483A.9}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1199, \'a711, 27}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1223, \'a730}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1032, \'a784}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1043, \'a794}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{483A.9A}}}{\*\bkmkstart stylerid1_2E6_2E21_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E21_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Combination packages of licenses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission is authorized, pursuant to rules adopted under }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{, to develop combination packages of licenses in order to offer incentives to residents to purchase additional licenses or for the specific purpose of increasing sales of licenses that will help to recruit or retain hunters, anglers, and trappers in the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The total cost of each combination package of licenses offered shall be less than the total cost of the licenses if each were purchased separately.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall offer to residents a combination package of an annual fishing license and an annual hunting license, as provided in rules adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 483A.1}}}{{\f5\fs18\hyphpar0\qj{, the cost of which includes the wildlife habitat fee.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 144, \'a740}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1096, \'a715, 23}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1159, \'a719, 28}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7483A.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{483A.10}}}{\*\bkmkstart stylerid1_2E6_2E22_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E22_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Issuance of licenses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The licenses and combination packages of licenses issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall be issued by the department or the license agents as specified by rules of the commission. A county recorder may issue licenses or combination packages of licenses subject to the rules of the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The rules shall include the application procedures as necessary. The licenses and combination packages of licenses shall show the total cost of the license or combination package of licenses, including a writing fee to be retained by the license agent and any administrative fees to be forwarded to the department, if applicable. A person authorized to issue a license or combination package of licenses or collect a fee pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{chapter 484A}}}{{\f5\fs18\hyphpar0\qj{ shall charge the fee specified in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{chapter 484A}}}{{\f5\fs18\hyphpar0\qj{ only plus a writing fee and administrative fee, if applicable.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An application for a hunting, fishing, or fur harvester license shall include a section where an applicant may request that the applicant\u8217\'3fs license include a symbol that indicates that the applicant is a donor under the revised uniform anatomical gift Act as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 142C}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[SS15, \'a72563-a4; C24, 27, 31, \'a71724; C35, \'a71794-e3; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1794.084;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, \'a7110.3; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7110.10}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1260, \'a75}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7483A.10}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1199, \'a712, 27}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1223, \'a730}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1019, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 134, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 144, \'a741}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 86, \'a710}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.602}}}{{\f5\fs12\hyphpar0\qj{, 483A.18}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{483A.11}}}{\*\bkmkstart stylerid1_2E6_2E23_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E23_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{License agents.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The director may designate license agents for the sale of licenses, but in so doing the interest of the state shall be fully protected.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, \'a71724-c1; C35, \'a71794-e4; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1794.085;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, \'a7110.4; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7110.11}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1260, \'a76}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7483A.11}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1199, \'a713, 27}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1223, \'a730}}}{; }{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 134, \'a77}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321G.4B}}}{{\f5\fs12\hyphpar0\qj{, 321G.6}}}{{\f5\fs12\hyphpar0\qj{, 321I.5}}}{{\f5\fs12\hyphpar0\qj{, 321I.7}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{483A.12}}}{\*\bkmkstart stylerid1_2E6_2E24_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E24_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{License agent responsibilities }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ fees and unused blanks }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ writing fee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The license agent shall be responsible for all fees for the issuance of hunting, fishing, and fur harvester licenses and combination packages of licenses sold by the license agent. All unused license blanks shall be surrendered to the department upon the department\u8217\'3fs demand.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A license agent shall retain a writing fee of fifty cents from the sale of each license or combination package of licenses except that the writing fee for a free deer or wild turkey hunting license as authorized under }}}{{\f5\fs18\hyphpar0\qj{section 483A.24, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, shall be one dollar. If a county recorder is a license agent, the writing fees retained by the county recorder shall be deposited in the general fund of the county.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, \'a71724-c1; C35, \'a71794-e5; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1794.086;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, \'a7110.5; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7110.12}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 123, \'a756, 209}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1260, \'a77}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7483A.12}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1199, \'a714, 27}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1223, \'a730}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 134, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 144, \'a742}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 34, \'a7113}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.427}}}{{\f5\fs12\hyphpar0\qj{, 331.602}}}{{\f5\fs12\hyphpar0\qj{, 331.605}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{483A.13}}}{\*\bkmkstart stylerid1_2E6_2E25_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E25_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Destroyed license blanks }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ accountability.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{When license blanks in the possession of a license agent are accidentally destroyed, the holder of the blanks shall only be relieved from accountability upon the presentation of satisfactory explanation and the filing of a bond to the director that the blanks have actually been so destroyed. The commission may determine by rule what shall constitute a satisfactory explanation of the occurrence.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a71794-e6; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1794.087;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, \'a7110.6; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7110.13}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7483A.13}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 134, \'a79}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.602}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{483A.14}}}{\*\bkmkstart stylerid1_2E6_2E26_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E26_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Duplicate licenses and permits.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{When any license for which a fee has been set has been lost, destroyed, or stolen, the director or a license agent may issue a replacement license, if evidence is available to demonstrate issuance of the original license and a fee of two dollars is paid, to be placed in the fish and game protection fund. If, on examination of the evidence, the director or the license agent, as the case may be, is satisfied that the license has been lost, destroyed, or stolen, the director or the license agent shall issue a duplicate license which shall be plainly marked \u8220\'3fduplicate\u8221\'3f and the duplicate shall serve in lieu of the original license and it shall contain the same information and signature as the original. The license agent shall charge a writing fee of one dollar and the departmental administrative fee for each duplicate license issued pursuant to }{{\f5\fs18\hyphpar0\qj{this section}}}{. The license agent shall retain the writing fee.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1794.088;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, \'a7110.7; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7110.14}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7483A.14}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1199, \'a715, 27}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1223, \'a730}}}{; }{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 134, \'a710}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.602}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{483A.15}}}{\*\bkmkstart stylerid1_2E6_2E27_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E27_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Accounting.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The director shall establish, by rule, specific requirements for remittance of funds, and the necessary accounting and reporting for all types of licenses issued based on the manner and location of the issuance.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[SS15, \'a72563-a4; C24, 27, 31, \'a71725; C35, \'a71794-e7; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1794.089;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, \'a7110.8; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7110.15}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7483A.15}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1199, \'a716, 27}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1223, \'a730}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.602}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{483A.16}}}{\*\bkmkstart stylerid1_2E6_2E28_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E28_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Duplicate issuance.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/1998/CH1199.pdf" }{\fldrslt \cf5 \f5 \fs18{{98 Acts, ch 1199, \'a726, 27}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{; }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/1998/CH1223.pdf" }{\fldrslt \cf5 \f5 \fs18{{98 Acts, ch 1223, \'a730}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{483A.17}}}{\*\bkmkstart stylerid1_2E6_2E29_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E29_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Tenure of license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Every license, except as otherwise provided in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, is valid from the date issued to January 10 of the succeeding calendar year for which it is issued. A license shall not be issued prior to December 15 for the subsequent calendar year except for a multi-year fishing license or a multi-year hunting license issued to a resident pursuant to rules adopted pursuant to }{{\f5\fs18\hyphpar0\qj{section 483A.1}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a72563-a8; C24, 27, 31, \'a71727; C35, \'a71794-e9; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1794.091;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, \'a7110.10; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7110.17}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1260, \'a78}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7483A.17}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{95 Acts, ch 46, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 134, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1096, \'a716, 23}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1159, \'a710, 28}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{483A.18}}}{\*\bkmkstart stylerid1_2E6_2E3_30_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E3_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Form of licenses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All hunting, fishing, and fur harvester licenses shall contain a general description of the licensee. Such licenses shall be upon such forms as the commission shall adopt. The address and the signature of the applicant and all signatures and other required information shall be in writing. All licenses shall clearly indicate the nature of the privilege granted.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon request of an applicant pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 483A.10}}}{{\f5\fs18\hyphpar0\qj{, the department shall indicate on the license that the applicant is a donor under the revised uniform anatomical gift Act as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 142C}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a72563-a3, -a8; C24, 27, 31, \'a71722, 1727; C35, \'a71794-e10; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1794.092;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, \'a7110.11; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7110.18}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1260, \'a79}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7483A.18}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2016 Acts, ch 1037, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 29, \'a7137}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 86, \'a711}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{483A.19}}}{\*\bkmkstart stylerid1_2E6_2E31_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E31_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Showing license document to officer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Every person shall, while fishing, hunting, or fur harvesting, show the person\u8217\'3fs license document to any peace officer or the owner or person in lawful control of the land or water upon which licensee may be hunting, fishing, or fur harvesting when requested by the persons to do so. Any failure to so carry or refusal to show or so exhibit the person\u8217\'3fs license document shall be a violation of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{. However, except for possession and exhibition of deer licenses and tags or wild turkey licenses and tags, a person charged with violating }{{\f5\fs18\hyphpar0\qj{this section}}}{ shall not be convicted if the person produces in court, within a reasonable time, a license document for hunting, fishing, or fur harvesting issued to that person and valid when the person was charged with a violation of }{{\f5\fs18\hyphpar0\qj{this section}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1794.093;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, \'a7110.12; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7110.19}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7483A.19}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1034, \'a746}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1199, \'a717, 27}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1223, \'a730}}}{; }{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 134, \'a712}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7805.8B(3)(b)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8B}}}{, subsection 3, paragraph b }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{483A.20}}}{\*\bkmkstart stylerid1_2E6_2E32_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E32_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Reciprocity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Licenses for bait dealers or for fishing, hunting, or fur harvesting shall not be issued to residents of states that do not sell similar licenses or certificates to residents of Iowa. However, this requirement is not applicable to the licensing of nonresident wholesale bait dealers who sell to licensed wholesale bait dealers in Iowa for resale.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1141, \'a716}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C87, \'a7110.20}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7483A.20}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1034, \'a747}}}{; }{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 120, \'a75, 6}}}{; }{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1105, \'a71, 2}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{483A.21}}}{\*\bkmkstart stylerid1_2E6_2E33_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E33_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Revocation or suspension.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon the conviction of a licensee of any violation of }}}{{\f5\fs18\hyphpar0\qj{chapter 481A}}}{{\f5\fs18\hyphpar0\qj{, or of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, or of any administrative order adopted and published by the commission, the magistrate may, as a part of the judgment, revoke one or more license privileges of the licensee, or suspend the privileges for any definite period.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The magistrate shall revoke the hunting license or suspend the privilege of procuring a hunting license for a period of one year of any person who has been convicted twice within a year of trespassing while hunting. If any of the license privileges of a licensee who purchased more than one license privilege is revoked, the remaining license privileges of the licensee shall still be valid and the magistrate shall enter on the license document the privilege that is revoked. A person shall not purchase a license for a privilege that was revoked or suspended during the period of revocation or suspension.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to other civil and criminal penalties imposed for illegally taking or possessing an elk, antelope, buffalo, or moose, the court shall revoke the hunting license of a violator. The violator shall not be allowed to procure a hunting license for the next two calendar years.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a72563-a9; C24, 27, 31, \'a71729; C35, \'a71794-e12; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1794.095;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, \'a7110.14; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7110.21}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1245, \'a71877}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1142, \'a72}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7483A.21}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 134, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1041, \'a7127}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{483A.22}}}{\*\bkmkstart stylerid1_2E6_2E34_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E34_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Record of revocation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{When a license is revoked, the date, cause, and tenure of such revocation shall be kept on file with the license records of the commission. The commission may refuse the issuance of a new license to any person whose license has been revoked.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a72563-a7; C24, 27, 31, \'a71726; C35, \'a71794-e13; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1794.096;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, \'a7110.15; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7110.22}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7483A.22}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 134, \'a714}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.602}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{483A.22A}}}{\*\bkmkstart stylerid1_2E6_2E35_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E35_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Sale of license lists.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department may establish, by rule, fees for lists of licensees. Notwithstanding }{{\f5\fs18\hyphpar0\qj{section 22.3}}}{, the fee for a list of licensees may exceed the cost of preparing the list and providing the copying service.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1199, \'a718, 27}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1223, \'a730}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{483A.23}}}{\*\bkmkstart stylerid1_2E6_2E36_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E36_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Game birds or animals as pets.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Any person may possess not more than two game birds or fur-bearing animals confined as pets without being required to purchase a license as a game breeder, but the person shall not be allowed to increase the person\u8217\'3fs stock beyond the original number nor shall the person be allowed to kill or sell such stock. Game birds or animals confined as authorized in }{{\f5\fs18\hyphpar0\qj{this section}}}{ must be obtained from a licensed game breeder or a legal source outside of this state.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, \'a71720; C35, \'a71794-e14; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1794.097;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, \'a7110.16; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7110.23}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7483A.23}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7805.8B(3)(c)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8B}}}{, subsection 3, paragraph c }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{483A.24}}}{\*\bkmkstart stylerid1_2E6_2E37_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E37_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{When license not required \u8212\'3f special licenses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Owners or tenants of land, and their minor children, may hunt, fish or trap upon such lands and may shoot by lawful means ground squirrels, gophers, or woodchucks upon adjacent roads without securing a license so to do; except, special licenses to hunt deer and wild turkey shall be required of owners and tenants but they shall not be required to have a special wild turkey hunting license to hunt wild turkey on a hunting preserve licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 484B}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fFamily member\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a resident of Iowa who is the spouse or child of the owner or tenant and who resides with the owner or tenant.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fFarm unit\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means all parcels of land which are certified by the commission pursuant to rule as meeting all of the following requirements:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Are in tracts of two or more contiguous acres.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Are operated as a unit for agricultural purposes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Are under the lawful control of the owner or the tenant.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fOwner\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an owner of a farm unit who is a resident of Iowa and who is one of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is the sole operator of the farm unit.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Makes all of the farm operation decisions but contracts for custom farming or hires labor for all or part of the work on the farm unit.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(iii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Participates annually in farm operation decisions or cropping practices on specific fields of the farm unit that are rented to a tenant.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(iv)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Raises specialty crops on the farm unit including but not limited to orchards, nurseries, or tree farms that do not always produce annual income but require annual operating decisions about maintenance or improvement.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(v)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Has all or part of the farm unit enrolled in a long-term agricultural land retirement program of the federal government.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fowner\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not mean a person who owns a farm unit and who employs a farm manager or third party to operate the farm unit, or a person who owns a farm unit and who rents the entire farm unit to a tenant who is responsible for all farm operations. However, this subparagraph division does not apply to an owner who is a parent of the tenant and who resides in this state.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fTenant\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person who is a resident of Iowa and who rents and actively farms a farm unit owned by another person. A member of the owner\u8217\'3fs family may be a tenant. A person who works on the farm for a wage and is not a family member does not qualify as a tenant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon written application on forms furnished by the department, the department shall issue annually without fee one wild turkey license to the owner of a farm unit or to a member of the owner\u8217\'3fs family, but not to both, and to the tenant or to a member of the tenant\u8217\'3fs family, but not to both. The wild turkey hunting licenses issued shall be valid only on the farm unit for which an applicant qualifies pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ and shall be equivalent to the least restrictive license issued under }}}{{\f5\fs18\hyphpar0\qj{section 481A.38}}}{{\f5\fs18\hyphpar0\qj{. The owner or the tenant need not reside on the farm unit to qualify for a free license to hunt on that farm unit. The free turkey hunting licenses issued pursuant to this paragraph shall be valid and may be used during any open turkey hunting season using a method of take authorized for that season, subject to any other restrictions that may apply, without first designating a season of use for the license. Each license issued under this paragraph authorizes the person issued the license to harvest one wild turkey.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon written application on forms furnished by the department, the department shall issue annually without fee two deer hunting licenses, one antlered or any sex deer hunting license and one antlerless deer only deer hunting license, to the owner of a farm unit or a member of the owner\u8217\'3fs family, but only a total of two licenses for both, and to the tenant of a farm unit or a member of the tenant\u8217\'3fs family, but only a total of two licenses for both. The deer hunting licenses issued shall be valid only for use on the farm unit for which the applicant applies pursuant to this paragraph. The owner or the tenant need not reside on the farm unit to qualify for the free deer hunting licenses to hunt on that farm unit. The free deer hunting licenses issued pursuant to this paragraph shall be valid and may be used during any open season using a method of take authorized for that season, subject to any other restrictions that may apply, without first designating a season of use for the license, but only one deer shall be harvested for each license. In addition, a person who receives a free deer hunting license pursuant to this paragraph shall pay a one dollar fee for each license that shall be used and is appropriated for the purpose of deer herd population management, including assisting with the cost of processing deer donated to the help us stop hunger program administered by the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to the free deer hunting licenses received pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, an owner of a farm unit or a member of the owner\u8217\'3fs family and the tenant or a member of the tenant\u8217\'3fs family may purchase a deer hunting license for any option offered to paying deer hunting licensees. An owner of a farm unit or a member of the owner\u8217\'3fs family and the tenant or a member of the tenant\u8217\'3fs family may also purchase two additional antlerless deer hunting licenses which are valid only on the farm unit for a fee established by rules adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 483A.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the commission establishes a deer hunting season to occur in the first quarter of a calendar year that is separate from a deer hunting season that continues from the last quarter of the preceding calendar year, each owner and each tenant of a farm unit located within a zone where a deer hunting season is established, upon application, shall be issued a free deer hunting license for each of the two calendar quarters. Each license is valid only for hunting on the farm unit of the owner and tenant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A deer hunting license or wild turkey hunting license issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be attested by the signature of the person to whom the license is issued and shall contain a statement in substantially the following form:}}}\par}{\pard\plain\keep\f5\fs18\hyphpar0\qj\fi0\sb80\ri1084\li1084\sa80{{\f5\fs18\hyphpar0\qj{\~\~}}}{By signing this license I certify that I qualify as an owner or tenant under Iowa Code }{{\f5\fs18\hyphpar0\qj{section 483A.24}}}{.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who makes a false attestation under this paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ff\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ is guilty of a simple misdemeanor. In addition, the person\u8217\'3fs hunting license shall be revoked and the person shall not be issued a hunting license for a period of one year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director shall provide up to one hundred twenty-five nonresident deer hunting licenses for allocation as provided in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Fifty of the nonresident deer hunting licenses shall be allocated as determined by the department. The licenses provided pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be in addition to the number of nonresident licenses authorized pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 483A.8}}}{{\f5\fs18\hyphpar0\qj{. The purpose of the special nonresident licenses is to allow state officials and local development groups to promote the state and its natural resources to nonresident guests and dignitaries. Photographs, videotapes, or any other form of media resulting from the hunting visitation shall not be used for political campaign purposes. The nonresident licenses shall be issued without application upon purchase of a nonresident annual hunting license that includes the wildlife habitat fee and the purchase of a nonresident deer hunting license. The licenses are valid in all zones open to deer hunting. The hunter education certificate requirement pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 483A.27}}}{{\f5\fs18\hyphpar0\qj{ is waived for a nonresident issued a license pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Seventy-five of the nonresident deer hunting licenses shall be allocated as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director shall provide up to one hundred twenty-five nonresident wild turkey hunting licenses for allocation as provided in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Fifty of the nonresident wild turkey hunting licenses shall be allocated as determined by the department. The licenses provided pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be in addition to the number of nonresident licenses authorized pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 483A.7}}}{{\f5\fs18\hyphpar0\qj{. The purpose of the special nonresident licenses is to allow state officials and local development groups to promote the state and its natural resources to nonresident guests and dignitaries. Photographs, videotapes, or any other form of media resulting from the hunting visitation shall not be used for political campaign purposes. The nonresident licenses shall be issued without application upon purchase of a nonresident annual hunting license that includes the wildlife habitat fee and the purchase of a nonresident wild turkey hunting license. The licenses are valid in all zones open to wild turkey hunting. The hunter education certificate requirement pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 483A.27}}}{{\f5\fs18\hyphpar0\qj{ is waived for a nonresident issued a license pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Seventy-five of the nonresident wild turkey hunting licenses shall be allocated as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Seventy-five of the nonresident deer hunting licenses allocated under }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{ and seventy-five of the wild turkey hunting licenses allocated under }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{ shall be available for issuance to nonresidents who have served in the armed forces of the United States on active federal service and who were disabled during the veteran\u8217\'3fs military service or who are serving in the armed forces of the United States on active federal service and have been disabled during military service to enable the disabled person to participate in a hunt that is conducted by an organization that conducts hunting experiences in this state for disabled persons. The licenses shall be issued as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall prepare an application to be used by a person requesting a special license under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall verify that the license will be used by the applicant in connection with a hunt conducted by an approved organization that conducts hunting experiences in this state for disabled veterans and members of the armed forces serving on active federal service who have been disabled during military service. The department shall specify, by rules adopted under }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{, what requirements an organization must meet in order to be approved to conduct hunts for disabled persons who obtain licenses under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of veterans affairs shall assist the department in verifying the status or claims of applicants under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. As used in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fdisabled\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means entitled to a service connected rating under}}}{{\f5\fs18\hyphpar0\qj{ 38 U.S.C. ch. 11}}}{{\f5\fs18\hyphpar0\qj{ with a degree of disability of thirty percent or more.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A license issued under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be in addition to the number of nonresident wild turkey hunting licenses authorized pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 483A.7}}}{{\f5\fs18\hyphpar0\qj{ and nonresident deer hunting licenses authorized pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 483A.8}}}{{\f5\fs18\hyphpar0\qj{. However, a nonresident who obtains a license pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ is not eligible to obtain a nonresident deer hunting license or wild turkey hunting license under any other provision of law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A disabled person who receives a special license under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall purchase a hunting license that includes the wildlife habitat fee, and a wild turkey hunting license or a deer hunting license, if applicable, all for the same fees that are charged to resident hunters. If hunting deer, the disabled person shall also pay a one dollar fee that shall be used and is appropriated for the purpose of deer herd population management, including assisting with the cost of processing deer donated to the help us stop hunger program administered by the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A special hunting license that includes the wildlife habitat fee shall be available for issuance under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ to a disabled veteran or disabled member of the armed forces serving on active federal service for the same fee that is charged to a resident hunter to enable such a disabled person to participate in a hunt conducted by an organization approved under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ for which only a hunting license is required.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A disabled person who receives a special license under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall complete the hunter education course.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A license issued under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ is valid for use only on a hunt conducted by an organization approved under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall adopt rules under }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ for the administration of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A resident or nonresident of the state under sixteen years of age is not required to have a license to fish in the waters of the state. However, residents and nonresidents under sixteen years of age must pay the trout fishing fee to possess trout or they must fish for trout with a licensed adult who has paid the trout fishing fee and limit their combined catch to the daily limit established by the commission. A resident or nonresident of the state under sixteen years of age is required to have a paddlefish fishing license to fish for paddlefish on the Missouri or Big Sioux river.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A license shall not be required of minor pupils of the Iowa school for the deaf or of minor residents of other state institutions under the control of the department of health and human services. In addition, a person who is on active duty with the armed forces of the United States, on authorized leave from a duty station located outside of this state, and a resident of the state of Iowa shall not be required to have a license to hunt or fish in this state. The military person shall carry the person\u8217\'3fs leave papers and a copy of the person\u8217\'3fs current earnings statement showing a deduction for Iowa income taxes while hunting or fishing. In lieu of carrying the person\u8217\'3fs earnings statement, the military person may also claim residency if the person is registered to vote in this state. If a deer or wild turkey is taken, the military person shall immediately contact a state conservation officer to obtain an appropriate tag to transport the animal. A license shall not be required of any person who is receiving supplementary assistance under }}}{{\f5\fs18\hyphpar0\qj{chapter 249}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person under sixteen years of age is not required to have a hunting license to hunt game or a fur harvester license to trap fur-bearing animals if accompanied by the minor\u8217\'3fs parent or guardian or in company with any other competent adult with the consent of the minor\u8217\'3fs parent or guardian, if the person accompanying the minor possesses a valid hunting license while hunting game or fur harvester license while trapping fur-bearing animals; however, there must be one licensed adult accompanying each person under sixteen years of age. The minor must have a deer hunting license to hunt deer and a wild turkey hunting license to hunt wild turkey appropriate for the minor\u8217\'3fs residency status. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ is not restricted by the provisions of }}}{{\f5\fs18\hyphpar0\qj{section 483A.31}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A resident of the state under sixteen years of age is not required to have a hunting or fur harvester license to accompany the minor\u8217\'3fs parent or guardian, or any other competent adult with the consent of the minor\u8217\'3fs parent or guardian, while the parent or guardian or other adult is hunting or trapping any game or fur-bearing animal so long as the minor is not hunting or trapping and does not carry or use a firearm or any other weapon.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person having a dog entered in a licensed field trial is not required to have a hunting license or fur harvester license to participate in the event or to exercise the person\u8217\'3fs dog on the area on which the field trial is to be held during the twenty-four-hour period immediately preceding the trial.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall issue without charge a special fishing license to residents of Iowa sixteen years or more of age who the commission finds have severe mental or physical disabilities. The commission is hereby authorized to prepare an application to be used by the person requesting the special license, which would require that the person\u8217\'3fs attending physician sign the form declaring that the person has a severe mental or physical disability and is eligible for exempt status.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall issue a special turkey hunting license or any sex deer hunting license to a nonresident twenty-one years of age or younger who the commission finds has a severe physical disability or has been diagnosed with a terminal illness. The licenses shall be issued as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission may prepare an application to be used by the person requesting the special license, which requires that the person\u8217\'3fs attending physician sign the form declaring that the person has a severe physical disability or has been diagnosed with a terminal illness and is eligible for the special license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The licenses provided pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be in addition to the number of nonresident turkey hunting licenses authorized pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 483A.7}}}{{\f5\fs18\hyphpar0\qj{ and nonresident deer hunting licenses authorized pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 483A.8}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The turkey hunting licenses are valid in all zones open to turkey hunting and shall be available for issuance and use during any turkey hunting season. The deer hunting licenses are valid in all zones open to deer hunting and shall be available for issuance and use during any deer hunting season.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A nonresident who receives a special license pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall purchase a hunting license that includes the wildlife habitat fee and the applicable nonresident turkey or deer hunting license, but is not required to complete the hunter education course if the person is accompanied and aided by a person who is at least eighteen years of age. The accompanying person must be qualified to hunt and have a hunting license that includes the wildlife habitat fee. During the hunt, the accompanying adult must be within arm\u8217\'3fs reach of the nonresident licensee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall adopt rules under }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ for the administration of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{No person shall be required to have a special wild turkey license to hunt wild turkey on a hunting preserve licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 484B}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A lessee of a camping space at a campground may fish on a private lake or pond on the premises of the campground without a license if the lease confers an exclusive right to fish in common with the rights of the owner and other lessees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department may issue a permit, subject to conditions established by the department, which authorizes patients of a substance use disorder facility, residents of health care facilities licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 135C}}}{{\f5\fs18\hyphpar0\qj{, tenants of elder group homes licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 231B}}}{{\f5\fs18\hyphpar0\qj{, tenants of assisted living program facilities licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 231C}}}{{\f5\fs18\hyphpar0\qj{, participants who attend adult day services programs licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 231D}}}{{\f5\fs18\hyphpar0\qj{, participants in services funded under a federal home and community-based services waiver implemented under the medical assistance program as defined in }}}{{\f5\fs18\hyphpar0\qj{chapter 249A}}}{{\f5\fs18\hyphpar0\qj{, and persons cared for in juvenile shelter care homes as provided for in }}}{{\f5\fs18\hyphpar0\qj{chapter 232}}}{{\f5\fs18\hyphpar0\qj{ to fish without a license as a supervised group. A person supervising a group pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ may fish with the group pursuant to the permit and is not required to obtain a fishing license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{16.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon payment of the fee established by rules adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 483A.1}}}{{\f5\fs18\hyphpar0\qj{ for a lifetime fishing license or lifetime hunting and fishing combined license, the department shall issue a lifetime fishing license or lifetime hunting and fishing combined license to a resident of Iowa who has served in the armed forces of the United States on federal active duty and who was disabled or was a prisoner of war during that veteran\u8217\'3fs military service. The department shall prepare an application to be used by a person requesting a lifetime fishing license or lifetime hunting and fishing combined license under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. The department of veterans affairs shall assist the department in verifying the status or claims of applicants under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. As used in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fdisabled\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means entitled to a service connected rating under }}}{{\f5\fs18\hyphpar0\qj{ 38 U.S.C. ch. 11.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{17.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon payment of a fee established by rules adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 483A.1}}}{{\f5\fs18\hyphpar0\qj{ for a lifetime fur harvester license, the department shall issue a lifetime fur harvester license to a resident of Iowa who has served in the armed forces of the United States on federal active duty and who was disabled during that veteran\u8217\'3fs military service. The department shall prepare an application to be used by a person requesting a lifetime fur harvester license under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. The department of veterans affairs shall assist the department in verifying the status or claims of applicants under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. As used in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fdisabled\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means entitled to a service connected rating under }}}{{\f5\fs18\hyphpar0\qj{38 U.S.C. ch. 11}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{18.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall issue without charge a special annual fishing or combined hunting and fishing license to residents of this state who have permanent disabilities and whose income falls below the federal poverty guidelines as published by the United States department of health and human services or residents of this state who are sixty-five years of age or older and whose income falls below the federal poverty guidelines as published by the United States department of health and human services. The commission shall provide for, by rule, an application to be used by an applicant requesting a special license. The commission shall require proof of age, income, and proof of permanent disability.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{19.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department may issue a permit, subject to conditions established by the department, which authorizes a student sixteen years of age or older attending an Iowa public or accredited nonpublic school who is participating in the Iowa department of natural resources fish Iowa! basic spincasting module to fish without a license as part of a supervised school outing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{20.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon payment of a fee established by rules adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 483A.1}}}{{\f5\fs18\hyphpar0\qj{ for a lifetime trout fishing license, the department shall issue a lifetime trout fishing license to a person who is at least sixty-five years of age or to a person who qualifies for the disabled veteran homestead credit under }}}{{\f5\fs18\hyphpar0\qj{section 425.15}}}{{\f5\fs18\hyphpar0\qj{. The department shall prepare an application to be used by a person requesting a lifetime trout fishing license under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{21.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon payment of a fee, not to exceed five dollars, established by rules adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 483A.1}}}{{\f5\fs18\hyphpar0\qj{ for an annual armed forces fishing license or annual armed forces hunting and fishing combined license, the department shall issue an annual armed forces fishing license or annual armed forces hunting and fishing combined license to a resident of Iowa who has served in the armed forces of the United States on federal active duty. The department shall prepare an application to be used by a person requesting an annual armed forces fishing license or annual armed forces hunting and fishing combined license under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. The department may consult with the department of veterans affairs when adopting rules to verify the status of applicants under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a72563-a3; C24, 27, 31, \'a71720, 1723; C35, \'a71794-e15; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1794.098;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, \'a7110.17; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7110.24}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1260, \'a716}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 96, \'a759, 159}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1260, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 10, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 67, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1240, \'a75 \u8211\'3f 7}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1245, \'a71877}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1216, \'a742}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 74, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 87, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1178, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 237, \'a74, 5}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1140, \'a712}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7483A.24}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1018, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1023, \'a758}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1129, \'a7100}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1172, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 180, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1199, \'a719, 20, 27}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1223, \'a730}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 180, \'a720}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1175, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 134, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 148, \'a78, 9}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 115, \'a735, 40}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 139, \'a76 \u8211\'3f 10}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 172, \'a724}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1010, \'a7125}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1026, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1043, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1108, \