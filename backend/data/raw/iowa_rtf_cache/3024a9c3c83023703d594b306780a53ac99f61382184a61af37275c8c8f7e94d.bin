 Acts, ch 1080, \'a779, 80, 98, 115, 125}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1130, \'a728}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 138, \'a7107, 126, 127}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1065, \'a72, 15, 16}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1138, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 29, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 161, \'a71, 18, 19}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 177, \'a7109}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1002, \'a761 \u8211\'3f 63}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1061, \'a728, 38}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 71, \'a723, 48, 49}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 136, \'a725, 26, 59, 70, 87, 90}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 148, \'a761 \u8211\'3f 64}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7422.25}}}{{\f5\fs12\hyphpar0\qj{, 423.37}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For future strike of subsection 3, paragraph h, effective July 1, 2039, see }{{\f5\fs12\hyphpar0\qj{2017 Acts, ch 29, \'a72, 169}}}{; }{{\f5\fs12\hyphpar0\qj{2025 Acts, ch 148, \'a765}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2025 amendment to subsection 3, paragraph e, former subparagraph (5) applies retroactively to January 1, 2025, for tax years beginning on or after that date; }{{\f5\fs12\hyphpar0\qj{2025 Acts, ch 136, \'a790}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2025 strike of subsection 3, paragraph a, former subparagraph (1) effective December 31, 2025; }{{\f5\fs12\hyphpar0\qj{2025 Acts, ch 136, \'a759}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2025 amendment to subsection 3, paragraph a, former subparagraph (2) effective December 31, 2025; }{{\f5\fs12\hyphpar0\qj{2025 Acts, ch 136, \'a759}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 2, paragraph a, subparagraph (1) amended}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 3, paragraphs a, b, d, and e amended and editorially internally renumbered}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{2.49 and 2.50}}}{Repealed by }{{\f5\fs18\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2003/CH0035.pdf" }{\fldrslt \f5 \fs18{{2003 Acts, ch 35, \'a747, 49}}}}}}{{\f5\fs18\qj{2003 Acts, ch 35, \'a747, 49}}}{.}{{\f5\fs18\qj{\~\~}}}{See }{{\f5\fs18\qj{chapter 2A}}}{. }{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{2.51}}}{\*\bkmkstart stylerid1_2E6_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Visitations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The legislative fiscal committee, with the approval of the legislative council, may direct a subcommittee, which shall be composed of the chairpersons and minority party ranking members of the appropriate subcommittees of the committees on appropriations of the senate and the house of representatives and the chairpersons of the appropriate standing committees of the general assembly, to visit the offices and facilities of any state office, department, agency, board, bureau, or commission to review programs authorized by the general assembly and the administration of the programs. When the legislative fiscal committee visits the offices and facilities of any state office, department, agency, board, bureau, or commission to review programs authorized by the general assembly and the administration of the programs, there shall be included the chairpersons and minority party ranking members of the appropriate subcommittees of the committees on appropriations of the senate and the house of representatives. The legislative council may appoint a member of the subcommittee or standing committee to serve in place of that subcommittee\u8217\'3fs or standing committee\u8217\'3fs chairperson or minority party ranking member on the legislative fiscal visitation committee or subcommittee if that person will be absent. The subcommittee and the legislative fiscal committee shall be provided with information by the legislative services agency concerning budgets, programs, and legislation authorizing programs prior to any visitation. Members of a committee shall be compensated pursuant to }{{\f5\fs18\hyphpar0\qj{section 2.10, subsection 5}}}{. The subcommittee shall make reports and recommendations as required by the legislative fiscal committee.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a72.51}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1026, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 35, \'a745, 49}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 64, \'a72}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{2.52}}}{\*\bkmkstart stylerid1_2E6_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Access \u8212\'3f subpoenas.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2003/CH0035.pdf" }{\fldrslt \cf5 \f5 \fs18{{2003 Acts, ch 35, \'a747, 49}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{See }}}{{\f5\fs18\hyphpar0\qj{\'a72A.3}}}{{\f5\fs18\hyphpar0\qj{. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{2.53 and 2.54}}}{Reserved. }{\f5\fs18\qj}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{2.55 and 2.55A}}}{Repealed by }{{\f5\fs18\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2003/CH0035.pdf" }{\fldrslt \f5 \fs18{{2003 Acts, ch 35, \'a747, 49}}}}}}{{\f5\fs18\qj{2003 Acts, ch 35, \'a747, 49}}}{. }{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0{\f5\fs18\chcbpat2}\par}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER III}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E7_2E2_2E2}{CORRECTIONAL IMPACT STATEMENTS}{\*\bkmkend stylerid1_2E7_2E2_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{2.56}}}{\*\bkmkstart stylerid1_2E7_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Correctional impact statements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prior to debate on the floor of a chamber of the general assembly, a correctional impact statement shall be attached to any bill, joint resolution, or amendment which proposes a change in the law which creates a public offense, significantly changes an existing public offense or the penalty for an existing offense, or changes existing sentencing, parole, or probation procedures. The statement shall include information concerning the estimated number of criminal cases per year that the legislation will impact, the fiscal impact of confining persons pursuant to the legislation, the impact of the legislation on minorities, the impact of the legislation upon existing correctional institutions, community-based correctional facilities and services, and jails, the likelihood that the legislation may create a need for additional prison capacity, and other relevant matters. The statement shall be factual and shall, if possible, provide a reasonable estimate of both the immediate effect and the long-range impact upon prison capacity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When a committee of the general assembly reports a bill, joint resolution, or amendment to the floor, the committee shall state in the report whether a correctional impact statement is or is not required.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The legislative services agency shall review all bills and joint resolutions placed on the calendar of either chamber of the general assembly, as well as amendments filed to bills or joint resolutions on the calendar, to determine whether a correctional impact statement is required.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A member of the general assembly may request the preparation of a correctional impact statement by submitting a request to the legislative services agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The legislative services agency shall cause to be prepared a correctional impact statement within a reasonable time after receiving a request or determining that a proposal is subject to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. All correctional impact statements approved by the legislative services agency shall be transmitted immediately to either the chief clerk of the house or the secretary of the senate, after notifying the sponsor of the legislation that the statement has been prepared for publication. The chief clerk of the house or the secretary of the senate shall attach the statement to the bill, joint resolution, or amendment affected as soon as it is available.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The legislative services agency may request the cooperation of any state department or agency or political subdivision in preparing a correctional impact statement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The legislative services agency, in cooperation with the department of health and human services as the agency responsible for criminal and juvenile justice planning, shall develop a protocol for analyzing the impact of the legislation on minorities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A revised correctional impact statement shall be prepared if the correctional impact has been changed by the adoption of an amendment, and may be requested by a member of the general assembly or be prepared upon a determination made by the legislative services agency. However, a request for a revised correctional impact statement shall not delay action on the bill, joint resolution, or amendment unless so ordered by the presiding officer of the chamber.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{93 Acts, ch 171, \'a714}}}{; }{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 35, \'a712, 49}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1095, \'a71, 2, 4}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a72A.4}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{2.57}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{2.58 through 2.60}}}{Repealed by }{{\f5\fs18\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2003/CH0035.pdf" }{\fldrslt \f5 \fs18{{2003 Acts, ch 35, \'a747, 49}}}}}}{{\f5\fs18\qj{2003 Acts, ch 35, \'a747, 49}}}{.}{{\f5\fs18\qj{\~\~}}}{See }{{\f5\fs18\qj{chapter 2A}}}{. }{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0{\f5\fs18\chcbpat2}\par}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER IV}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E8_2E2_2E2}{RESEARCH REQUESTS \u8212\'3f INTERIM STUDY COMMITTEES}{\*\bkmkend stylerid1_2E8_2E2_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{2.61}}}{\*\bkmkstart stylerid1_2E8_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Requests for research.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Requests for research on governmental matters may be made to the legislative services agency by either house of the general assembly, committees of either house of the general assembly, special interim committees of the general assembly, the legislative council, or upon petition by twenty or more members of the general assembly. Any legislative committee may request the legislative services agency to do research on any matter under consideration by such committee. For each such request the legislative council may, if deemed advisable, authorize a special interim study committee to conduct the research study or may request a standing committee to conduct such study. Members on a study committee shall be appointed by the council and shall consist of at least one member of the council and such other members of the majority and minority parties of the senate and the house of representatives as the council may designate. As far as practicable, a study committee shall include members of standing committees concerned with the subject matter of the study. No legislator shall serve on more than two study committees. Nonlegislative members having special knowledge of the subject under study may be appointed by the council to a study committee but such members shall be nonvoting members of such committee. The legislative services agency shall assist study committees on research studies when authorized by the legislative council.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C58, \'a72.52; C62, 66, \'a72.55; C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a72.61}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 35, \'a744, 46, 49}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{2.62}}}{\*\bkmkstart stylerid1_2E8_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Interim study committee powers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Special interim study committees shall have the following powers and duties:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Elect officers and adopt necessary rules for the conduct of business.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Conduct research on any matter connected with the study assigned by the legislative council.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Hold hearings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Make regular progress reports to the legislative council.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Make a report, which may include recommendations, to the legislative council. Copies of study committee reports shall be made available to members of the general assembly and may be made available to other interested individuals upon request. The reports shall not be final until approved by the legislative council.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C62, 66, \'a72.57; C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a72.62}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{2.63}}}{\*\bkmkstart stylerid1_2E8_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Interim study committee meetings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Special interim study committees shall first meet at the call of the ranking legislative council member assigned to the study committee, and shall thereafter meet at such time as study committee members shall so designate. Any legislator may attend any study committee meeting or any hearing held by a study committee. All study committee meetings shall be open to the public.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C62, 66, \'a72.58; C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a72.63}}}{]}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{2.64 through 2.67}}}{Repealed by }{{\f5\fs18\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2003/CH0035.pdf" }{\fldrslt \f5 \fs18{{2003 Acts, ch 35, \'a747, 49}}}}}}{{\f5\fs18\qj{2003 Acts, ch 35, \'a747, 49}}}{.}{{\f5\fs18\qj{\~\~}}}{See }{{\f5\fs18\qj{chapter 2A}}}{. }{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{2.68}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0{\f5\fs18\chcbpat2}\par}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER V}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E9_2E2_2E2}{STATE GOVERNMENT EFFICIENCY REVIEW COMMITTEE}{\*\bkmkend stylerid1_2E9_2E2_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{2.69}}}{\*\bkmkstart stylerid1_2E9_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{State government efficiency review committee established.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2024 Acts, ch 1170, \'a753}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\sb0\ri0\li0\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{2.70 through 2.99}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{2.100 through 2.104}}}{Repealed by }{{\f5\fs18\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2003/CH0035.pdf" }{\fldrslt \f5 \fs18{{2003 Acts, ch 35, \'a747, 49}}}}}}{{\f5\fs18\qj{2003 Acts, ch 35, \'a747, 49}}}{.}{{\f5\fs18\qj{\~\~}}}{See }{{\f5\fs18\qj{chapter 2A}}}{. }{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}}