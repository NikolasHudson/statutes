{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDepartment\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the department of inspections, appeals, and licensing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDirection\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means authoritative policy or procedural guidance for the accomplishment of a function or an activity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLicensee\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the holder of a license issued to operate a psychiatric medical institution for children.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMedical care plan\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a plan of care and services designed to eliminate the need for inpatient care by improving the condition of a youth. Services must be based upon a diagnostic evaluation, which includes a physical assessment and behavioral health evaluation of the medical, psychological, social, behavioral, and developmental aspects of the youth\u8217\'3fs situation, reflecting the need for inpatient care.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMental health disorder\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a mental disorder as defined by the most recent version of the diagnostic and statistical manual of mental disorders published by the American psychiatric association.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMental health professional\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an individual who has all of the following qualifications:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The individual holds at least a master\u8217\'3fs degree in a mental health field, including but not limited to, psychology, counseling and guidance, nursing, or social work, or the individual is a physician.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The individual holds a current Iowa license if practicing in a field that requires an Iowa license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The individual has at least two years of post-degree clinical experience, supervised by another mental health professional, in assessing mental health needs and problems and in providing appropriate mental health services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fNursing care\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means services which are provided under the direction of a physician or registered nurse.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPhysician\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 148}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fProtective locked environment\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a setting that prevents egress from a building or grounds as a protective measure to ensure safety and security.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPsychiatric medical institution for children\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fpsychiatric institution\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an institution providing more than twenty-four hours of continuous care involving long-term psychiatric services to three or more youth in residence for expected periods of fourteen or more days for an assessment, evaluation, and diagnosis or for expected periods of ninety days or more for treatment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPsychiatric services\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means services provided under the direction of a physician which address mental, emotional, medical, or behavioral problems.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fRecord check evaluation system\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as defined in }}}{{\f5\fs18\hyphpar0\qj{section 135C.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fRehabilitative services\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means services to encourage and assist restoration of a resident\u8217\'3fs optimum mental and physical capabilities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fResident\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a youth who has been admitted to a psychiatric medical institution for children.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{16.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSerious emotional disturbance\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a diagnosable mental, behavioral, or emotional disorder that meets the diagnostic criteria specified in the most current diagnostic and statistical manual of mental disorders published by the American psychiatric association. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSerious emotional disturbance\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include a substance use disorder or developmental disorder unless such disorder co-occurs with a diagnosable mental, behavioral, or emotional disorder.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{17.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSubstance use disorder\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as defined in }}}{{\f5\fs18\hyphpar0\qj{section 125.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{18.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSupervision\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means direct oversight and inspection of an act that accomplishes a function or activity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{19.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fYouth\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person who is less than twenty-one years of age.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 283, \'a72}}}{; }{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1120, \'a714, 15}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1088, \'a790}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71895}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 86, \'a72}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.2}}}{{\f5\fs12\hyphpar0\qj{, 249A.30A}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{135H.2}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Purpose.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The purpose of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ is to provide for the development, establishment, and enforcement of basic standards for the operation, construction, and maintenance of a psychiatric medical institution for children which will ensure the safe and adequate diagnosis and evaluation and treatment of the residents.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 283, \'a73}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{135H.3}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Nature of care.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A psychiatric medical institution for children shall provide shelter, food, supervision, care, assessment, evaluation, diagnosis, treatment, counseling, rehabilitative services, and related professional-directed services to youth who have a serious emotional disturbance, a substance use disorder, or both, with the intention of reducing or ameliorating the disorder, the symptoms of the disorder, or the effects of the disorder.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A psychiatric medical institution for children shall utilize a team of professionals to direct an organized program of diagnostic services, psychiatric services, nursing care, and rehabilitative services to meet the needs of residents in accordance with a medical care plan developed for each resident. The membership of the team of professionals may include but is not limited to an advanced registered nurse practitioner or a physician assistant. Social and rehabilitative services shall be provided under the direction of a qualified mental health professional.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a youth is diagnosed with a biologically based mental illness as defined in }}}{{\f5\fs18\hyphpar0\qj{section 514C.22}}}{{\f5\fs18\hyphpar0\qj{ and meets the medical assistance program criteria for admission to a psychiatric medical institution for children, the youth shall be deemed to meet the acuity criteria for medically necessary inpatient benefits under a group policy, contract, or plan providing for third-party payment or prepayment of health, medical, and surgical coverage benefits issued by a carrier, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 513B.2}}}{{\f5\fs18\hyphpar0\qj{, that is subject to }}}{{\f5\fs18\hyphpar0\qj{section 514C.22}}}{{\f5\fs18\hyphpar0\qj{. Such medically necessary benefits shall not be excluded or denied as care that is substantially custodial in nature under }}}{{\f5\fs18\hyphpar0\qj{section 514C.22, subsection 8}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 283, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 179, \'a7182}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 121, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 131, \'a7151, 153}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 148, \'a729}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 86, \'a73}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{135H.4}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Licensure.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not establish, operate, or maintain a psychiatric medical institution for children unless the person holds a license as a comprehensive residential facility for children under }}}{{\f5\fs18\hyphpar0\qj{chapter 237}}}{{\f5\fs18\hyphpar0\qj{, and holds a license under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to the requirements under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, a person shall not provide substance use disorder services at a psychiatric medical institution for children unless the person holds a license under }}}{{\f5\fs18\hyphpar0\qj{section 125.13}}}{{\f5\fs18\hyphpar0\qj{. The department of health and human services shall adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ to create an expedited process for a person to simultaneously obtain a license under }}}{{\f5\fs18\hyphpar0\qj{section 125.13}}}{{\f5\fs18\hyphpar0\qj{ and a license as a comprehensive residential facility for children under }}}{{\f5\fs18\hyphpar0\qj{chapter 237}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 283, \'a75}}}{; }{{\f5\fs18\hyphpar0\qj{93 Acts, ch 53, \'a76}}}{; }{{\f5\fs18\hyphpar0\qj{93 Acts, ch 172, \'a729}}}{; }{{\f5\fs18\hyphpar0\qj{93 Acts, ch 180, \'a779}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7185}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 86, \'a74}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{135H.5}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Application for license }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ initial application and annual fees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An application for a license under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall be submitted on a form required by the department. The application may require affirmative evidence of the applicant\u8217\'3fs ability to comply with rules adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. The application shall require the applicant to specify whether the applicant intends to provide services for serious emotional disturbances, substance use disorders, or both. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An application for a license shall be accompanied by the required license fee which shall be credited to the general fund of the state. The initial application fee and the annual license fee is twenty-five dollars.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 283, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 86, \'a75}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{135H.6}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Inspection }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ conditions for issuance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall issue a license to an applicant under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ if all the following conditions exist:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department has ascertained that the applicant\u8217\'3fs medical facilities and staff are adequate to provide the care and services required of a psychiatric medical institution for children.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The proposed psychiatric institution is accredited by an approved qualifying organization.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant complies with applicable state rules and standards for a psychiatric institution adopted by the department in accordance with federal requirements under }}}{{\f5\fs18\hyphpar0\qj\cf1{42 C.F.R. \'a7441.150 }}}{{\f5\fs18\hyphpar0\qj\cf1{\u8211\'3f}}}{{\f5\fs18\hyphpar0\qj\cf1{ 441.156}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of health and human services has submitted written approval of the application based on the department of health and human services\u8217\'3f determination of need. The department of health and human services shall identify the location and number of youth in the state who require the services of a psychiatric medical institution for children. Approval of an application shall be based upon the location of the proposed psychiatric institution relative to the need for services identified by the department of health and human services and an analysis of the applicant\u8217\'3fs ability to provide services and support consistent with requirements under }}}{{\f5\fs18\hyphpar0\qj{chapter 232}}}{{\f5\fs18\hyphpar0\qj{, specifically community-based treatment. If the proposed psychiatric institution is not freestanding from a facility licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 135B}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{135C}}}{{\f5\fs18\hyphpar0\qj{, approval under this paragraph shall not be given unless the department of health and human services certifies that the proposed psychiatric institution is capable of providing a resident with a living environment similar to the living environment provided by a licensee which is freestanding from a facility licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 135B}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{135C}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a youth has a serious emotional disturbance, the psychiatric institution does not require any of the following as a condition for the youth to obtain treatment:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Court proceedings to be initiated.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the youth\u8217\'3fs parent, guardian, or custodian to terminate parental rights over, or transfer legal custody of, the youth.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Relinquishment of the youth\u8217\'3fs custody.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of health and human services shall not give approval to an application which would cause the total number of beds licensed under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ for services reimbursed by the medical assistance program under }}}{{\f5\fs18\hyphpar0\qj{chapter 249A}}}{{\f5\fs18\hyphpar0\qj{ to exceed four hundred thirty beds, unless the director of health and human services determines approval of such an application is necessary for good cause. Good cause is established if the health and safety of Iowans would be adversely impacted if the application for additional beds is not approved.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to the beds authorized under }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, the department of health and human services may establish not more than thirty beds licensed under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ at the state mental health institute at Independence. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of health and human services may approve a conversion of beds approved under }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ if the beds are specialized to provide substance use disorder treatment. However, the total number of beds approved under }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not exceed four hundred thirty unless approved for good cause by the director pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{. The limitations on the number of beds under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not apply to beds for youth who do not reside in this state and whose service costs are not paid by public funds in this state.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 283, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1239, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 53, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 172, \'a730}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 180, \'a780}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1213, \'a732}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1218, \'a766}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 51, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 98, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 191, \'a735}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 117, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 121, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 131, \'a7151, 153}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1026, \'a749}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7186, 187}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1111, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 86, \'a76}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7226.9B}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsections 1 and 4 amended}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 5 stricken}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{135H.7}}}{\*\bkmkstart stylerid1_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Personnel.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not be allowed to provide services in a psychiatric institution if the person has a disease which is transmissible to other persons through required contact in the workplace, which presents a significant risk of infecting other persons, which presents a substantial possibility of harming other persons, or for which no reasonable accommodation can eliminate the risk of infecting other persons.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a person who has been convicted of a crime or has a record of founded child abuse is being considered for licensure under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, for employment with a psychiatric institution involving direct responsibility for a youth or access to a youth when the youth is alone, or residence in a facility utilized by a licensee, the record check evaluation system and the licensee considering the person for employment shall perform an evaluation to determine whether the crime or founded child abuse warrants prohibition of licensure, employment, or residence in the facility utilized by a licensee. The record check evaluation system shall conduct criminal and child abuse record checks in this state and may conduct these checks in other states. The record check evaluation shall be performed in accordance with procedures adopted for this purpose by the department of health and human services.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the record check evaluation system determines that a person has committed a crime or has a record of founded child abuse and is licensed, employed by a psychiatric institution licensed under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, or resides in a licensed facility, the record check evaluation system shall notify the program that an evaluation will be conducted to determine whether prohibition of the person\u8217\'3fs licensure, employment, or residence is warranted.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In an evaluation, the record check evaluation system and the licensee for an employee of the licensee shall consider the nature and seriousness of the crime or founded child abuse in relation to the position sought or held, the time elapsed since the commission of the crime or founded child abuse, the circumstances under which the crime or founded child abuse was committed, the degree of rehabilitation, the likelihood that the person will commit the crime or founded child abuse again, and the number of crimes or founded child abuses committed by the person involved. The record check evaluation system may permit a person who is evaluated to be licensed, employed, or to reside, or to continue to be licensed, employed, or to reside in a licensed facility, if the person complies with the record check evaluation system\u8217\'3fs conditions relating to the person\u8217\'3fs licensure, employment, or residence, which may include completion of additional training. For an employee of a licensee, these conditional requirements shall be developed with the licensee. The record check evaluation system has final authority in determining whether prohibition of the person\u8217\'3fs licensure, employment, or residence is warranted and in developing any conditional requirements under this paragraph.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the record check evaluation system determines that the person has committed a crime or has a record of founded child abuse which warrants prohibition of licensure, employment, or residence, the person shall not be licensed under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ to operate a psychiatric institution and shall not be employed by a psychiatric institution or reside in a facility licensed under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to the record checks required under }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, the record check evaluation system may conduct dependent adult abuse record checks in this state and may conduct these checks in other states, on a random basis. The provisions of }}}{{\f5\fs18\hyphpar0\qj{subsections 2 and 3}}}{{\f5\fs18\hyphpar0\qj{, relative to an evaluation following a determination that a person has been convicted of a crime or has a record of founded child abuse, shall also apply to a random dependent adult abuse record check conducted under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensee shall inform all new applicants for employment of the possibility of the performance of a record check and shall obtain, from the applicant, a signed acknowledgment of the receipt of the information.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensee shall include the following inquiry in an application for employment:}}}\par}{\pard\plain\keep\f5\fs18\hyphpar0\qj\fi0\sb80\ri1084\li1084\sa80{{\f5\fs18\hyphpar0\qj{\~\~}}}{Do you have a record of founded child or dependent adult abuse or have you ever been convicted of a crime, in this state or any other state?}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 283, \'a78}}}{; }{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1221, \'a72}}}{; }{{\f5\fs18\hyphpar0\qj{91 Acts, ch 138, \'a72}}}{; }{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1163, \'a735}}}{; }{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1130, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7188}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 86, \'a77}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 2, paragraph a amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{135H.7A}}}{\*\bkmkstart stylerid1_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Protective locked environment }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ rules.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department, in cooperation with the department of health and human services, shall adopt rules pursuant to }{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{ relating to the application of a protective locked environment in a psychiatric medical institution for children.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2025 Acts, ch 86, \'a78}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{NEW section}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{135H.8}}}{\*\bkmkstart stylerid1_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Denial, suspension, or revocation of license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department may deny an application or suspend or revoke a license if the department finds that an applicant or licensee has failed or is unable to comply with }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ or the rules establishing minimum standards pursuant to }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ or if any of the following conditions apply:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It is shown that a resident is a victim of cruelty or neglect due to the acts or omissions of the licensee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The licensee has permitted, aided, or abetted in the commission of an illegal act in the psychiatric institution.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An applicant or licensee acted to obtain or to retain a license by fraudulent means, misrepresentation, or submitting false information.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The licensee has willfully failed or neglected to maintain a continuing in-service education and training program for persons employed by the psychiatric institution.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The application involves a person who has failed to operate a psychiatric institution in compliance with the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 283, \'a79}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{135H.8A}}}{\*\bkmkstart stylerid1_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Provisional license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department may issue a provisional license, effective for not more than one year, to a licensee whose psychiatric institution does not meet the requirements of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, if, prior to issuance of the license, written plans to achieve compliance with the applicable requirements are submitted to and approved by the department. The plans shall specify the deadline for achieving compliance.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{95 Acts, ch 51, \'a72}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{135H.9}}}{\*\bkmkstart stylerid1_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Notice and hearings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The procedure governing notice and hearing to deny an application or suspend or revoke a license shall be in accordance with rules adopted by the department pursuant to }{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{. A full and complete record shall be kept of the proceedings and of any testimony. The record need not be transcribed unless judicial review is sought. A copy or copies of a transcript may be obtained by an interested party upon payment of the cost of preparing the transcript or copies.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 283, \'a710}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{135H.10}}}{\*\bkmkstart stylerid1_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Rules.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department, in consultation with the department of health and human services and affected professional groups, shall adopt and enforce rules setting out the standards for a psychiatric medical institution for children and the rights of the residents admitted to a psychiatric institution. The department and the department of health and human services shall coordinate the adoption of rules and the enforcement of the rules in order to prevent duplication of effort by the departments and of requirements of the licensee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This chapter}}}{{\f5\fs18\hyphpar0\qj{ shall not be construed to prohibit funds appropriated for foster care from being used to provide payment to a psychiatric medical institution for children for the financial participation required of a youth whose foster care placement is in a psychiatric medical institution for children. In accordance with established policies and procedures for foster care, the department of health and human services shall act to recover any such payment for financial participation, apply to be named payee for the youth\u8217\'3fs unearned income, and recommend parental liability for the costs of a court-ordered foster care placement in a psychiatric institution.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 283, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 135, \'a730}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1133, \'a794}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7189, 1896}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 86, \'a79}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 2 amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{135H.11}}}{\*\bkmkstart stylerid1_2E18_2E2_2E2}{\*\bkmkend stylerid1_2E18_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Complaints alleging violations \u8212\'3f confidentiality.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A person may request an inspection of a psychiatric medical institution for children by filing with the department a complaint of an alleged violation of an applicable requirement of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ or a rule adopted pursuant to }{{\f5\fs18\hyphpar0\qj{this chapter}}}{. The complaint shall state in a reasonably specific manner the basis of the complaint. A statement of the nature of the complaint shall be delivered to the psychiatric institution involved at the time of or prior to the inspection. The name of the person who files a complaint with the department shall be kept confidential and shall not be subject to discovery, subpoena, or other means of legal compulsion for its release to a person other than department employees involved in the investigation of the complaint.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 283, \'a712}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7135H.12}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{135H.12}}}{\*\bkmkstart stylerid1_2E19_2E2_2E2}{\*\bkmkend stylerid1_2E19_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Inspections upon complaints.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon receipt of a complaint made in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 135H.11}}}{{\f5\fs18\hyphpar0\qj{, the department shall make a preliminary review of the complaint. Unless the department concludes that the complaint is intended to harass a psychiatric institution or a licensee or is without reasonable basis, it shall within twenty working days of receipt of the complaint make or cause to be made an on-site inspection of the psychiatric institution which is the subject of the complaint. The department may refer to the department of health and human services any complaint received by the department if the complaint applies to rules adopted by the department of health and human services. The complainant shall also be notified of the name, address, and telephone number of the designated protection and advocacy agency if the alleged violation involves a facility with one or more residents with developmental disabilities or mental illness. In any case, the complainant shall be promptly informed of the result of any action taken by the department in the matter.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An inspection made pursuant to a complaint filed under }}}{{\f5\fs18\hyphpar0\qj{section 135H.11}}}{{\f5\fs18\hyphpar0\qj{ need not be limited to the matter or matters referred to in the complaint; however, the inspection shall not be a general inspection unless the complaint inspection coincides with a scheduled general inspection. Upon arrival at the psychiatric institution to be inspected, the inspector shall show identification to the person in charge of the psychiatric institution and state that an inspection is to be made, before beginning the inspection. Upon request of either the complainant or the department, the complainant or the complainant\u8217\'3fs representative or both may be allowed the privilege of accompanying the inspector during any on-site inspection made pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The inspector may cancel the privilege at any time if the inspector determines that the privacy of a resident of the psychiatric institution to be inspected would be violated. The dignity of the resident shall be given first priority by the inspector and others.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 283, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7190, 1897}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{135H.13}}}{\*\bkmkstart stylerid1_2E2_30_2E2_2E2}{\*\bkmkend stylerid1_2E2_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Information confidential.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department\u8217\'3fs final findings and the findings of an approved qualifying organization regarding licensure or program accreditation shall be made available to the public in a readily available form and place. Other information relating to the psychiatric institution is confidential and shall not be made available to the public except in a proceeding involving licensure, a civil suit involving a resident, or an administrative action involving a resident.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The name of a person who files a complaint with the department shall remain confidential and is not subject to discovery, subpoena, or any other means of legal compulsion for release to a person other than an employee of the department or an agent involved in the investigation of the complaint.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Information regarding a resident who has received or is receiving care shall not be disclosed directly or indirectly except as authorized under }}}{{\f5\fs18\hyphpar0\qj{section 217.30}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{232.69}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{237.21}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 283, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 86, \'a710}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 1 amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{135H.14}}}{\*\bkmkstart stylerid1_2E21_2E2_2E2}{\*\bkmkend stylerid1_2E21_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Judicial review.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Judicial review of the action of the department may be sought pursuant to the Iowa administrative procedure Act, }{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{. Notwithstanding the Iowa administrative procedure Act, }{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{, a petition for judicial review of the department\u8217\'3fs actions under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ may be filed in the district court of the county in which the related psychiatric medical institution for children is located or is proposed to be located. The status of the petitioner or the licensee shall be preserved pending final disposition of the judicial review.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 283, \'a715}}}{; }{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 44, \'a7114}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{135H.15}}}{\*\bkmkstart stylerid1_2E22_2E2_2E2}{\*\bkmkend stylerid1_2E22_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Penalty.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A person who establishes, operates, or manages a psychiatric medical institution for children without obtaining a license under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ commits a serious misdemeanor. Each day of continuing violation following conviction shall be considered a separate offense.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 283, \'a716}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{135H.16}}}{\*\bkmkstart stylerid1_2E23_2E2_2E2}{\*\bkmkend stylerid1_2E23_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Injunction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Notwithstanding the existence or pursuit of another remedy, the department may maintain an action for injunction or other process to restrain or prevent the establishment, operation, or management of a psychiatric medical institution for children without a license.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 283, \'a717}}}\par}}