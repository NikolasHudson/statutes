fs12\hyphpar0\qj{, 235B.3}}}{{\f5\fs12\hyphpar0\qj{, 249A.4}}}{{\f5\fs12\hyphpar0\qj{, 659A.4}}}{{\f5\fs12\hyphpar0\qj{, 915.35}}}{{\f5\fs12\hyphpar0\qj{, 915.84}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 3, unnumbered paragraph 1 amended}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 3, paragraph c stricken}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.69}}}{\*\bkmkstart stylerid1_2E8_2E5_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E5_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Mandatory and permissive reporters \u8212\'3f training required.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The classes of persons enumerated in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall make a report within twenty-four hours and as provided in }}}{{\f5\fs18\hyphpar0\qj{section 232.70}}}{{\f5\fs18\hyphpar0\qj{, of cases of child abuse. In addition, the classes of persons enumerated in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall make a report of abuse of a child which would be defined as child abuse under }}}{{\f5\fs18\hyphpar0\qj{section 232.68, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (3) or (5), except that the abuse resulted from the acts or omissions of a person other than a person responsible for the care of the child.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Every health practitioner who in the scope of professional practice, examines, attends, or treats a child and who reasonably believes the child has been abused. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 139A.30}}}{{\f5\fs18\hyphpar0\qj{, this provision applies to a health practitioner who receives information confirming that a child is infected with a sexually transmitted disease.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any of the following persons who, in the scope of professional practice or in their employment responsibilities, examines, attends, counsels, or treats a child and reasonably believes a child has suffered abuse:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A social worker.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An employee or operator of a public or private health care facility as defined in }}}{{\f5\fs18\hyphpar0\qj{section 135C.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A certified psychologist.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensed school employee, certified para-educator, holder of a coaching authorization issued under }}}{{\f5\fs18\hyphpar0\qj{section 256.165}}}{{\f5\fs18\hyphpar0\qj{, school employee who is eighteen years of age or older, or an instructor employed by a community college.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An employee or operator of a licensed child care center, registered child development home, head start program, family development and self-sufficiency grant program under }}}{{\f5\fs18\hyphpar0\qj{section 216A.107}}}{{\f5\fs18\hyphpar0\qj{, or healthy opportunities for parents to experience success \u8211\'3f healthy families Iowa program under }}}{{\f5\fs18\hyphpar0\qj{section 135.106}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An employee or operator of a substance use disorder program or facility licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 125}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(7)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An employee of a department institution listed in }}}{{\f5\fs18\hyphpar0\qj{section 218.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(8)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An employee or operator of a juvenile detention or juvenile shelter care facility approved under }}}{{\f5\fs18\hyphpar0\qj{section 232.142}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(9)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An employee or operator of a child foster care facility under }}}{{\f5\fs18\hyphpar0\qj{chapter 237}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(10)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An employee or operator of a mental health center.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(11)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A peace officer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(12)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A counselor or mental health professional.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(13)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An employee or operator of a provider of services to children funded under a federally approved medical assistance home and community-based services waiver.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(14)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An employee, operator, owner, or other person who performs duties for a children\u8217\'3fs residential facility certified under }}}{{\f5\fs18\hyphpar0\qj{chapter 237C}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(15)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A massage therapist licensed pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 152C}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any other person who believes that a child has been abused may make a report as provided in }}}{{\f5\fs18\hyphpar0\qj{section 232.70}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3flicensing board\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a board designated in }}}{{\f5\fs18\hyphpar0\qj{section 147.13}}}{{\f5\fs18\hyphpar0\qj{, the board of educational examiners created in }}}{{\f5\fs18\hyphpar0\qj{section 256.146}}}{{\f5\fs18\hyphpar0\qj{, or a licensing board as defined in }}}{{\f5\fs18\hyphpar0\qj{section 272C.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person required to make a report under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, other than a physician whose professional practice does not regularly involve providing primary health care to children, shall complete the core training curriculum relating to the identification and reporting of child abuse within six months of initial employment or self-employment involving physical assessments or behavioral health evaluations, or attending, counseling, or treating children on a regular basis. Within one month of initial employment or self-employment, the person shall obtain a statement of the abuse reporting requirements from the person\u8217\'3fs employer or, if self-employed, from the department. The person shall complete the core training curriculum relating to the identification and reporting of child abuse every three years.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The core training curriculum relating to the identification and reporting of child abuse, as provided in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, shall be developed and provided by the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An employer of a person required to make a report under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ may provide supplemental training, specific to identification and reporting of child abuse as it relates to the person\u8217\'3fs professional practice, in addition to the core training provided by the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensing board with authority over the license of a person required to make a report under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ shall require as a condition of licensure that the person is in compliance with the requirements for the core training curriculum relating to the identification and reporting of child abuse under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. The licensing board shall require the person upon licensure renewal to accurately document for the licensing board the person\u8217\'3fs completion of the training requirements. However, the licensing board may adopt rules providing for waiver or suspension of the compliance requirements, if the waiver or suspension is in the public interest, applicable to a person who is engaged in active duty in the military service of this state or of the United States, to a person for whom compliance with the training requirements would impose a significant hardship, or to a person who is practicing a licensed profession outside this state or is otherwise subject to circumstances that would preclude the person from encountering child abuse in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For persons required to make a report under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ who are not engaged in a licensed profession that is subject to the authority of a licensing board but are employed by a facility or program subject to licensure, registration, or approval by a state agency, the agency shall require as a condition of renewal of the facility\u8217\'3fs or program\u8217\'3fs licensure, registration, or approval, that such persons employed by the facility or program are in compliance with the training requirements of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For peace officers, the elected or appointed official designated as the head of the agency employing the peace officer shall ensure compliance with the training requirements of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For persons required to make a report under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ who are employees of state departments and political subdivisions of the state, the department director or the chief administrator of the political subdivision shall ensure the persons\u8217\'3f compliance with the training requirements of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, \'a7235A.3; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7232.69}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 96, \'a7157, 159}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1279, \'a74, 6}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 173, \'a73 \u8211\'3f 5}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 153, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1238, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 89, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 230, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 265, \'a740}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1130, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 85, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 192, \'a727, 33}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1066, \'a742}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 122, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1047, \'a72, 20}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1142, \'a71, 31}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 121, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 10, \'a7164, 165}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1072, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 129, \'a754}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1113, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 91, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1078, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7607}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 95, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1075, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 86, \'a721}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 135, \'a74}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7135H.13}}}{{\f5\fs12\hyphpar0\qj{, 152C.3}}}{{\f5\fs12\hyphpar0\qj{, 232.68}}}{{\f5\fs12\hyphpar0\qj{, 232.70}}}{{\f5\fs12\hyphpar0\qj{, 232.75}}}{{\f5\fs12\hyphpar0\qj{, 232.77}}}{{\f5\fs12\hyphpar0\qj{, 237.9}}}{{\f5\fs12\hyphpar0\qj{, 237A.5}}}{{\f5\fs12\hyphpar0\qj{, 256.165}}}{{\f5\fs12\hyphpar0\qj{, 907.3}}}{{\f5\fs12\hyphpar0\qj{, 915.35}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 1, paragraph b, subparagraph (9) amended}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 3, paragraph b amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.70}}}{\*\bkmkstart stylerid1_2E8_2E5_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E5_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Reporting procedure.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each report made by a mandatory reporter, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 232.69, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, or a permissive reporter, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 232.69, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, shall be oral.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The employer or supervisor of a person who is a mandatory or permissive reporter shall not apply a policy, work rule, or other requirement that interferes with the person making a report of child abuse.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The oral report shall be made by telephone or otherwise to the department. If the person making the report has reason to believe that immediate protection for the child is advisable, that person shall also make an oral report to an appropriate law enforcement agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon receipt of a report, the department shall do all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Immediately make a determination as to whether the report constitutes an allegation of child abuse as defined in }}}{{\f5\fs18\hyphpar0\qj{section 232.68}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notify the appropriate county attorney of the receipt of the report.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The oral and written reports shall contain the following information, or as much of the following information as the person making the report is able to furnish:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The names and home address of the child and the child\u8217\'3fs parents or other persons believed to be responsible for the child\u8217\'3fs care.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child\u8217\'3fs present whereabouts if not the same as the parent\u8217\'3fs or other person\u8217\'3fs home address.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child\u8217\'3fs age.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The nature and extent of the child\u8217\'3fs injuries, including any evidence of previous injuries.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The name, age and condition of other children in the same home.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the person making the report is a licensed school employee who reasonably believes the person responsible for the injury is also a licensed school employee, the identity of the licensed school employee the person making the report believes is responsible for the injury.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any other information which the person making the report believes might be helpful in establishing the cause of the injury to the child, the identity of the person or persons responsible for the injury, or in providing assistance to the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The name and address of the person making the report.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A report made by a permissive reporter, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 232.69, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, shall be regarded as a report pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ whether or not the report contains all of the information required by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and may be made to the department, county attorney, or law enforcement agency. If the report is made to any agency other than the department, such agency shall promptly refer the report to the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Within twenty-four hours of receiving a report from a mandatory or permissive reporter, the department shall inform the reporter, orally or by other appropriate means, whether or not the department has commenced an assessment of the allegation in the report.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a report would be determined to constitute an allegation of child abuse as defined under }}}{{\f5\fs18\hyphpar0\qj{section 232.68, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (3) or (5), except that the suspected abuse resulted from the acts or omissions of a person other than a person responsible for the care of the child, the department shall refer the report to the appropriate law enforcement agency having jurisdiction to investigate the allegation. The department shall refer the report orally as soon as practicable and in writing within seventy-two hours of receiving the report.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the department has reasonable cause to believe that a child under the placement, care, or supervision of the department is, or is at risk of becoming, a sex trafficking victim, the department shall do all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Identify the child as a sex trafficking victim or at risk of becoming a sex trafficking victim and include documentation in the child\u8217\'3fs department records.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Refer the child for appropriate services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Refer the child identified as a sex trafficking victim, within twenty-four hours, to the appropriate law enforcement agency having jurisdiction to investigate the allegation.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, \'a7235A.4; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7232.70}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 96, \'a7157, 159}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 153, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 176, \'a72, 17}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1137, \'a74, 14}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 122, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 115, \'a72, 19}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1063, \'a710, 11}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1098, \'a722, 75}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7608}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 95, \'a73}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.68}}}{{\f5\fs12\hyphpar0\qj{, 232.69}}}{{\f5\fs12\hyphpar0\qj{, 232.75}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{232.71 and 232.71A}}}{Repealed by }{{\f5\fs18\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/1997/CH0035.pdf" }{\fldrslt \f5 \fs18{{97 Acts, ch 35, \'a724, 25}}}}}}{{\f5\fs18\qj{97 Acts, ch 35, \'a724, 25}}}{. }{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.71B}}}{\*\bkmkstart stylerid1_2E8_2E5_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E5_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Duties of the department upon receipt of report.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E8_2E5_2E8_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E8_2E5_2E8_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Commencement of assessment }}}{{\i\f5\fs18\hyphpar0\qj{\u8212\'3f}}}{{\i\f5\fs18\hyphpar0\qj{ differential response }}}{{\i\f5\fs18\hyphpar0\qj{\u8212\'3f}}}{{\i\f5\fs18\hyphpar0\qj{ purpose.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the department determines a report constitutes a child abuse allegation, the department shall promptly commence either a child abuse assessment within twenty-four hours of receiving the report or a family assessment within seventy-two hours of receiving the report.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon acceptance of a report of child abuse, the department shall commence a child abuse assessment when the report alleges child abuse as defined in }}}{{\f5\fs18\hyphpar0\qj{section 232.68, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraphs (1) through (3) and subparagraphs (5) through (11), or which alleges child abuse as defined in }}}{{\f5\fs18\hyphpar0\qj{section 232.68, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (4), that also alleges imminent danger, death, or injury to a child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon acceptance of a report of child abuse, the department shall commence a family assessment when the report alleges child abuse as defined in }}}{{\f5\fs18\hyphpar0\qj{section 232.68, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (4), but does not allege imminent danger, death, or injury to a child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The primary purpose of either the child abuse assessment or the family assessment shall be the protection of the child named in the report. The secondary purpose of either type of assessment shall be to engage the child\u8217\'3fs family in services to enhance family strengths and to address needs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E8_2E5_2E8_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E8_2E5_2E8_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Notification of parents.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department, within five working days of commencing the assessment, shall provide written notification of the assessment to the child\u8217\'3fs parents. If a parent is alleged to have committed the child abuse, the notice shall inform the parents regarding the complaint or allegation made regarding the parent. The parents shall be informed in a manner that protects the confidentiality rights of an individual who reported the child abuse or provided information as part of the assessment process. However, if the department shows the court to the court\u8217\'3fs satisfaction that notification is likely to endanger the child or other persons, the court shall orally direct the department to withhold notification. Within one working day of issuing an oral directive, the court shall issue a written order restraining the notification. The department shall not reveal in the written notification to the parents or otherwise the identity of the reporter of child abuse to a subject of a child abuse report listed in }}}{{\f5\fs18\hyphpar0\qj{section 235A.15, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{\*\bkmkstart stylerid1_2E8_2E5_2E8_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E8_2E5_2E8_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Involvement of law enforcement.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall apply protocols, developed with the local child protection assistance team established pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 915.35}}}{{\f5\fs18\hyphpar0\qj{, to prioritize the actions taken in response to a child abuse assessment and shall work jointly with child protection assistance teams and law enforcement agencies in performing assessment and investigative processes for child abuse assessments in which a criminal act harming a child is alleged. The county attorney and appropriate law enforcement agencies shall also take any other lawful action which may be necessary or advisable for the protection of the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a report is determined not to constitute a child abuse allegation or if the child abuse report is accepted but assessed under the family assessment, but a criminal act harming a child is alleged, the department shall immediately refer the matter to the appropriate law enforcement agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the department has reasonable cause to believe that a child under the placement, care, or supervision of the department is, or is at risk of becoming, a sex trafficking victim, the department shall do all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Identify the child as a sex trafficking victim or at risk of becoming a sex trafficking victim and include documentation in the child\u8217\'3fs department records.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Refer the child for appropriate services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Refer the child identified as a sex trafficking victim, within twenty-four hours, to the appropriate law enforcement agency having jurisdiction to investigate the allegation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall report a child under the placement, care, or supervision of the department who is reported as missing or abducted to law enforcement and to the national center for missing and exploited children within twenty-four hours of receipt of the report.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{\*\bkmkstart stylerid1_2E8_2E5_2E8_2E6_2E1_2E2}{\*\bkmkend stylerid1_2E8_2E5_2E8_2E6_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Assessment process.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A child abuse assessment or family assessment shall include all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A safety assessment and risk assessment. If at any time during a family assessment, a child is determined unsafe or in imminent danger, it appears that the immediate safety or well-being of a child is endangered, it appears that the family may flee or the child may disappear, or the facts otherwise warrant, the department shall immediately commence a child abuse assessment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An evaluation of the home environment. If concerns regarding protection of children are identified by the child protection worker, the child protection worker shall evaluate the child named in the report and any other children in the same home as the parents or other persons responsible for their care.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to the requirements of paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, a child abuse assessment shall include the following: }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Identification of the nature, extent, and cause of the injuries, if any, to the child named in the report.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Identification of the person or persons responsible for the alleged child abuse.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A description of the name, age, and condition of other children in the same home as the child named in the report.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An interview of the person alleged to have committed the child abuse, if the person\u8217\'3fs identity and location are known. The offer of an interview shall be made to the person prior to any consideration or determination being made that the person committed the alleged abuse. The person shall be informed of the complaint or allegation made regarding the person. The person shall be informed in a manner that protects the confidentiality rights of the individual who reported the child abuse or provided information as part of the assessment process. The purpose of the interview shall be to provide the person with the opportunity to explain or rebut the allegations of the child abuse report or other allegations made during the assessment. The court may waive the requirement to offer the interview only for good cause. The person offered an interview, or the person\u8217\'3fs attorney on the person\u8217\'3fs behalf, may decline the offer of an interview of the person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{\*\bkmkstart stylerid1_2E8_2E5_2E8_2E7_2E1_2E2}{\*\bkmkend stylerid1_2E8_2E5_2E8_2E7_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Child abuse determination.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Unless otherwise prohibited under }}}{{\f5\fs18\hyphpar0\qj{section 234.40}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{280.21}}}{{\f5\fs18\hyphpar0\qj{, the use of corporal punishment by the person responsible for the care of a child which does not result in a physical injury to the child shall not be considered child abuse.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{\*\bkmkstart stylerid1_2E8_2E5_2E8_2E8_2E1_2E2}{\*\bkmkend stylerid1_2E8_2E5_2E8_2E8_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Home visit.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The assessment may, with the consent of the parent or guardian, include a visit to the home of the child named in the report and an interview or observation of the child may be conducted. If permission to enter the home to interview or observe the child is refused, the juvenile court or district court upon a showing of probable cause may authorize the person making the assessment to enter the home and interview or observe the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{\*\bkmkstart stylerid1_2E8_2E5_2E8_2E9_2E1_2E2}{\*\bkmkend stylerid1_2E8_2E5_2E8_2E9_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Facility or school visit.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The assessment may include a visit to a facility providing care to the child named in the report or to any public or private school subject to the authority of the department of education where the child named in the report is located. The administrator of a facility, or a public or private school shall cooperate with the child protection worker by providing confidential access to the child named in the report for the purpose of interviewing the child, and shall allow the child protection worker confidential access to other children for the purpose of conducting interviews in order to obtain relevant information. The child protection worker may observe a child named in a report in accordance with the provisions of }}}{{\f5\fs18\hyphpar0\qj{section 232.68, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. A witness shall be present during an observation of a child. Any child aged ten years of age or older can terminate contact with the child protection worker by stating or indicating the child\u8217\'3fs wish to discontinue the contact. The immunity granted by }}}{{\f5\fs18\hyphpar0\qj{section 232.73}}}{{\f5\fs18\hyphpar0\qj{ applies to acts or omissions in good faith of administrators and their facilities or school districts for cooperating in an assessment and allowing confidential access to a child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{\*\bkmkstart stylerid1_2E8_2E5_2E8_2E1_30_2E1_2E2}{\*\bkmkend stylerid1_2E8_2E5_2E8_2E1_30_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Information requests.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department may request information from any person believed to have knowledge of a child abuse case. The county attorney, any law enforcement or social services agency in the state, and any mandatory reporter, whether or not the reporter made the specific child abuse report, shall cooperate and assist in the assessment upon the request of the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In performing an assessment, the department may request criminal history data from the department of public safety on any person believed to be responsible for an injury to a child which, if confirmed, would constitute child abuse. The department shall establish procedures for determining when a criminal history records check is necessary.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{\*\bkmkstart stylerid1_2E8_2E5_2E8_2E11_2E1_2E2}{\*\bkmkend stylerid1_2E8_2E5_2E8_2E11_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Protective disclosure.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the department determines that disclosure is necessary for the protection of a child, the department may disclose to a subject of a child abuse report referred to in }}}{{\f5\fs18\hyphpar0\qj{section 235A.15, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, that an individual is listed in the child or dependent adult abuse registry or is required to register with the sex offender registry in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapter 692A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{\*\bkmkstart stylerid1_2E8_2E5_2E8_2E12_2E1_2E2}{\*\bkmkend stylerid1_2E8_2E5_2E8_2E12_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Physical assessment.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the department refers a child to a physician or physician assistant for a physical assessment, the department shall contact the physician or physician assistant regarding the physical assessment within twenty-four hours of making the referral. If the physician or physician assistant who performs the physical assessment reasonably believes the child has been abused, the physician or physician assistant shall report to the department within twenty-four hours of performing the physical assessment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{\*\bkmkstart stylerid1_2E8_2E5_2E8_2E13_2E1_2E2}{\*\bkmkend stylerid1_2E8_2E5_2E8_2E13_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Multidisciplinary team.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In each county or multicounty area in which more than fifty child abuse reports are made per year, the department shall establish a multidisciplinary team, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 235A.13, subsection 9}}}{{\f5\fs18\hyphpar0\qj{. Upon the department\u8217\'3fs request, a multidisciplinary team shall assist the department in the assessment, diagnosis, and disposition of a child abuse assessment and the subsequent provision of services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{\*\bkmkstart stylerid1_2E8_2E5_2E8_2E14_2E1_2E2}{\*\bkmkend stylerid1_2E8_2E5_2E8_2E14_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Facility protocol.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall apply a protocol, developed in consultation with facilities providing care to children, for conducting an assessment of reports of abuse of children allegedly caused by employees of facilities providing care to children. As part of such an assessment, the department shall notify the licensing authority for the facility, the governing body of the facility, and the administrator in charge of the facility of any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A violation of facility policy noted in the assessment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An instance in which facility policy or lack of facility policy may have contributed to the reported incident of alleged child abuse.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An instance in which general practice in the facility appears to differ from the facility\u8217\'3fs written policy.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The licensing authority, the governing body, and the administrator in charge of the facility shall take any lawful action which may be necessary or advisable to protect children receiving care.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{\*\bkmkstart stylerid1_2E8_2E5_2E8_2E15_2E1_2E2}{\*\bkmkend stylerid1_2E8_2E5_2E8_2E15_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{ Written assessment report.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department, upon completion of the child abuse assessment or the family assessment, shall make a written report of the assessment, in accordance with all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The written assessment report shall incorporate the information required by }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{ A written child abuse assessment report shall be completed within twenty business days of the receipt of the child abuse report. A written family assessment report shall be completed within ten business days of the receipt of the child abuse report.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The written assessment report shall identify the strengths and needs of the child, and of the child\u8217\'3fs parent, home, and family.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The written assessment report shall identify services available from the department and informal and formal services and other support available in the community to address the strengths and needs identified in the assessment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon completion of the assessment, the department shall consult with the child\u8217\'3fs family in offering services to the child and the child\u8217\'3fs family to address strengths and needs identified in the assessment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to the requirements of paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, a written child abuse assessment report shall include a description of the child\u8217\'3fs condition, identification of the injury or risk to which the child was exposed, the circumstances which led to the injury or risk to the child, and the identity of any person alleged to be responsible for the injury or risk to the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{ Following a child abuse assessment, the department shall notify each subject of the child abuse report, as identified in }}}{{\f5\fs18\hyphpar0\qj{section 235A.15, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, of the results of the child abuse assessment, of the subject\u8217\'3fs right, pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 235A.19}}}{{\f5\fs18\hyphpar0\qj{, to correct the report data or disposition data which refers to the subject, and of the procedures to correct the data.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Following a family assessment, the department shall notify the parent or guardian of each child listed in the report of suspected child abuse of the completion of the family assessment and any service recommendations. For cases assessed pursuant to a family assessment, there shall be no right to a contested case hearing pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If after completing the assessment the child protection worker determines, with the concurrence of the worker\u8217\'3fs supervisor and the department\u8217\'3fs area administrator, that a report of suspected child abuse is a spurious report or that protective concerns are not present, the portions of the written assessment report described under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraphs (3) and (4) shall not be required.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{\*\bkmkstart stylerid1_2E8_2E5_2E8_2E16_2E1_2E2}{\*\bkmkend stylerid1_2E8_2E5_2E8_2E16_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Court-ordered and voluntary services.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall provide or arrange for and monitor services for abused children and their families on a voluntary basis or under a final or intermediate order of the juvenile court. The department may provide or arrange for and monitor services for children and their families on a voluntary basis for cases in which a family assessment is completed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{\*\bkmkstart stylerid1_2E8_2E5_2E8_2E17_2E1_2E2}{\*\bkmkend stylerid1_2E8_2E5_2E8_2E17_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Safety issue.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{ If the department determines that a safety issue continues to require a child to reside outside of the child\u8217\'3fs home at the conclusion of a family assessment, the department shall transfer the assessment to the child abuse assessment pathway for a disposition.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{16.}}}{\*\bkmkstart stylerid1_2E8_2E5_2E8_2E18_2E1_2E2}{\*\bkmkend stylerid1_2E8_2E5_2E8_2E18_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Conclusion of family assessment.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At the conclusion of a family assessment, the department shall transfer the case, if appropriate, to a contracted provider to review the service plan for the child and family. The contracted provider shall make a referral to the department abuse hotline if a family\u8217\'3fs noncompliance with a service plan places a child at risk. If any of the criteria for child abuse as defined in }}}{{\f5\fs18\hyphpar0\qj{section 232.68, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, are met, the department shall commence a child abuse assessment. If any of the criteria for a child in need of assistance pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 232.96A}}}{{\f5\fs18\hyphpar0\qj{ are met, the department shall determine whether to request a child in need of assistance petition.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{17.}}}{\*\bkmkstart stylerid1_2E8_2E5_2E8_2E19_2E1_2E2}{\*\bkmkend stylerid1_2E8_2E5_2E8_2E19_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{County attorney }}}{{\i\f5\fs18\hyphpar0\qj{\u8212\'3f}}}{{\i\f5\fs18\hyphpar0\qj{ juvenile court.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall provide the juvenile court and the county attorney with a copy of the written child abuse assessment report, the written family assessment report for cases in which the department requests a child in need of assistance petition, or other reports for cases in which the department requests a child in need of assistance petition. The juvenile court and the county attorney shall notify the department of any action taken concerning an assessment provided by the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{18.}}}{\*\bkmkstart stylerid1_2E8_2E5_2E8_2E2_30_2E1_2E2}{\*\bkmkend stylerid1_2E8_2E5_2E8_2E2_30_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{False reports.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a fourth report is received from the same person who made three earlier reports which identified the same child as a victim of child abuse and the same person responsible for the care of the child as the alleged abuser and which were determined by the department to be entirely false or without merit, the department may determine that the report is again false or without merit due to the report\u8217\'3fs spurious or frivolous nature and may in its discretion terminate its assessment of the report. If the department receives more than three reports which identify the same child as a victim of child abuse or the same person as the alleged abuser of a child, or which were made by the same person, and the department determined the reports to be entirely false or without merit, the department shall provide information concerning the reports to the county attorney for consideration of criminal charges under }}}{{\f5\fs18\hyphpar0\qj{section 232.75, subsection 3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{19.}}}{\*\bkmkstart stylerid1_2E8_2E5_2E8_2E21_2E1_2E2}{\*\bkmkend stylerid1_2E8_2E5_2E8_2E21_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Rules.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall adopt rules regarding the intake process, assessment process, assessment reports, contact with juvenile court or the county attorney, involvement with law enforcement, case record retention, and dissemination of records for both child abuse assessments and family assessments.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{20.}}}{\*\bkmkstart stylerid1_2E8_2E5_2E8_2E22_2E1_2E2}{\*\bkmkend stylerid1_2E8_2E5_2E8_2E22_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Quality assurance.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall engage external stakeholders, including but not limited to representatives of the county attorneys\u8217\'3f offices, service providers, and parent partners to develop a quality assurance component to the differential response system.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 35, \'a76, 25}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 176, \'a724, 43}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 122, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1074, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 44, \'a750}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 47, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 107, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 123, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 179, \'a768}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1152, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 41, \'a7239}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 115, \'a73, 4, 19}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1063, \'a712, 13}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1066, \'a730}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1098, \'a723, 76}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 86, \'a722}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7135.43}}}{{\f5\fs12\hyphpar0\qj{, 232.68}}}{{\f5\fs12\hyphpar0\qj{, 232.71C}}}{{\f5\fs12\hyphpar0\qj{, 232.71D}}}{{\f5\fs12\hyphpar0\qj{, 232.72}}}{{\f5\fs12\hyphpar0\qj{, 232.73}}}{{\f5\fs12\hyphpar0\qj{, 232.73A}}}{{\f5\fs12\hyphpar0\qj{, 232.77}}}{{\f5\fs12\hyphpar0\qj{, 232.141}}}{{\f5\fs12\hyphpar0\qj{, 235A.15}}}{{\f5\fs12\hyphpar0\qj{, 235A.19}}}{{\f5\fs12\hyphpar0\qj{, 279.76}}}{{\f5\fs12\hyphpar0\qj{, 331.653}}}{{\f5\fs12\hyphpar0\qj{, 601.1}}}{{\f5\fs12\hyphpar0\qj{, 915.35}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 10 amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.71C}}}{\*\bkmkstart stylerid1_2E8_2E5_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E5_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Court action following assessment }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ guardian ad litem.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If, upon completion of an assessment performed under }}}{{\f5\fs18\hyphpar0\qj{section 232.71B}}}{{\f5\fs18\hyphpar0\qj{, the department determines that the best interests of the child require juvenile court action, the department shall act appropriately to initiate the action. If at any time during the assessment process the department believes court action is necessary to safeguard a child, the department shall act appropriately to initiate the action. The county attorney shall assist the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall assist the juvenile court or district court during all stages of court proceedings involving an alleged child abuse case in accordance with the purposes of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In every case involving child abuse which results in a child protective judicial proceeding, whether or not the proceeding arises under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, a guardian ad litem shall be appointed by the court to represent the child in the proceedings. Before a guardian ad litem is appointed pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the court shall require the person responsible for the care of the child to complete under oath a detailed financial statement. If, on the basis of that financial statement, the court determines that the person responsible for the care of the child is able to bear the cost of the guardian ad litem, the court shall so order. In cases where the person responsible for the care of the child is unable to bear the cost of the guardian ad litem, the expense shall be paid out of the county treasury.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 35, \'a77, 25}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 113, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 115, \'a75, 19}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.68}}}{{\f5\fs12\hyphpar0\qj{, 331.424}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.71D}}}{\*\bkmkstart stylerid1_2E8_2E5_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E5_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Founded child abuse \u8212\'3f central registry.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The requirements of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall apply to child abuse information relating to a report of child abuse and to a child abuse assessment performed in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 232.71B}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{subsections 3 and 4}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{section 235A.19, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, if the department issues a finding that the alleged child abuse meets the definition of child abuse under }}}{{\f5\fs18\hyphpar0\qj{section 232.68, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, the names of the child and the alleged perpetrator of the alleged child abuse and any other child abuse information shall be placed in the central registry as a case of founded child abuse.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Unless any of the circumstances listed in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ are applicable, cases to which any of the following circumstances apply shall not be placed in the central registry:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A finding of physical abuse in which the department has determined the injury resulting from the abuse was minor, isolated, and unlikely to reoccur.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A finding of abuse by failure to provide adequate supervision or by failure to provide adequate clothing, in which the department has determined the risk from the abuse to the child\u8217\'3fs health and welfare was minor, isolated, and unlikely to reoccur.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If any of the following circumstances apply in addition to those listed in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the names of the child and the alleged perpetrator of the alleged child abuse and any other child abuse information shall be placed in the central registry as a case of founded child abuse:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The case was referred for juvenile or criminal court action as a result of the acts or omissions of the alleged perpetrator or a criminal or juvenile court action was initiated by the county attorney or juvenile court within twelve months of the date of the department\u8217\'3fs report concerning the case, in which the alleged perpetrator was convicted of a crime involving the child or there was a delinquency or child in need of assistance adjudication.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department determines the acts or omissions of the alleged perpetrator meet the definition of child abuse and the department has previously determined within the five-year period preceding the issuance of the department\u8217\'3fs report that the acts or omissions of the alleged perpetrator in a prior case met the definition of child abuse.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department determines the alleged perpetrator of the child abuse will continue to pose a danger to the child who is the subject of the report of child abuse or to another child with whom the alleged perpetrator may come into contact.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Cases of alleged child abuse to which any of the following circumstances apply shall be placed in the central registry as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A finding of sexual abuse in which the alleged perpetrator of the abuse is age thirteen or younger. However, the name of the alleged perpetrator shall be withheld from the registry.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A finding of sexual abuse in which the alleged perpetrator of the abuse is age fourteen through seventeen and the court has found there is good cause for the name of the alleged perpetrator to be removed from the central registry. Only the name of the alleged perpetrator shall be removed from the registry.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If report data and disposition data are placed in the central registry in accordance with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the department shall make periodic follow-up reports in a manner prescribed by the registry so that the registry is kept up-to-date and fully informed concerning the case.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The confidentiality of all of the following shall be maintained in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 217.30}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Assessment data.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Information pertaining to an allegation of child abuse for which there was no assessment performed.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Information pertaining to a report of suspected child abuse for which there was an assessment performed but no determination was made as to whether the definition of child abuse was met.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Information pertaining to an allegation of child abuse which was determined to not meet the definition of child abuse. Individuals identified in }}}{{\f5\fs18\hyphpar0\qj{section 235A.15, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, are authorized to have access to such information under }}}{{\f5\fs18\hyphpar0\qj{section 217.30}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Report data and disposition data pertaining to an allegation of child abuse determined to meet the definition of child abuse which is not subject to placement in the central registry. Individuals identified in }}}{{\f5\fs18\hyphpar0\qj{section 235A.15, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, are authorized to have access to such data under }}}{{\f5\fs18\hyphpar0\qj{section 217.30}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The confidentiality of report data and disposition data pertaining to an allegation of child abuse determined to meet the definition of child abuse which is subject to placement in the central registry, shall be maintained as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 235A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 176, \'a75, 25, 26, 43}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 192, \'a733}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1086, \'a743}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 121, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 28, \'a73, 4}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 131, \'a757, 158}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1082, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 115, \'a76 \u8211\'3f 8, 19, 20}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.68}}}{{\f5\fs12\hyphpar0\qj{, 235A.14}}}{{\f5\fs12\hyphpar0\qj{, 235A.15}}}{{\f5\fs12\hyphpar0\qj{, 235A.17}}}{{\f5\fs12\hyphpar0\qj{, 235A.18}}}{{\f5\fs12\hyphpar0\qj{, 235A.19}}}{{\f5\fs12\hyphpar0\qj{, 237A.5}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.72}}}{\*\bkmkstart stylerid1_2E8_2E5_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E5_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Jurisdiction \u8212\'3f transfer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{, the terms }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fdepartment of health and human services\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fdepartment\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fcounty attorney\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ ordinarily refer to the local office of the department or of the county attorney\u8217\'3fs office serving the county in which the child\u8217\'3fs home is located.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the person making a report of child abuse pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ does not know where the child\u8217\'3fs home is located, the report may be made to the department or to the local office serving the county where the person making the report resides or the county where the health practitioner examines, attends, or treats the child. These agencies shall promptly proceed as provided in }}}{{\f5\fs18\hyphpar0\qj{section 232.71B}}}{{\f5\fs18\hyphpar0\qj{, unless the matter is transferred as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the child\u8217\'3fs home is located in a county not served by the office receiving the report, the department shall promptly transfer the matter by transmitting a copy of the report of injury and any other pertinent information to the office and the county attorney serving the other county. The office and the county attorney shall promptly proceed as provided in }}}{{\f5\fs18\hyphpar0\qj{section 232.71B}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, \'a7235A.6; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7232.72}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 96, \'a7157, 159}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 35, \'a78, 25}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1116, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1041, \'a762}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1062, \'a794}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 80, \'a7127}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7609}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.68}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.73}}}{\*\bkmkstart stylerid1_2E8_2E5_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E5_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Medically relevant tests \u8212\'3f immunity from liability.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person participating in good faith in the making of a report, photographs, or X rays, or in the performance of a medically relevant test pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, or aiding and assisting in an assessment of a child abuse report pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 232.71B}}}{{\f5\fs18\hyphpar0\qj{, shall have immunity from any liability, civil or criminal, which might otherwise be incurred or imposed. The person shall have the same immunity with respect to participation in good faith in any judicial proceeding resulting from the report or relating to the subject matter of the report.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and in }}}{{\f5\fs18\hyphpar0\qj{sections 232.73A,}}}{{\f5\fs18\hyphpar0\qj{ }}}{{\f5\fs18\hyphpar0\qj{232.77}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{232.78}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fmedically relevant test\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a test that produces reliable results of exposure to cocaine, heroin, amphetamine, methamphetamine, or other illegal drugs, or combinations or derivatives of the illegal drugs, including a drug urine screen test.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, \'a7235A.7; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7232.73}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 88, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1264, \'a728}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 182, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1092, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 35, \'a79, 25}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 135, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1040, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.68}}}{{\f5\fs12\hyphpar0\qj{, 232.71B}}}{{\f5\fs12\hyphpar0\qj{, 232.77}}}{{\f5\fs12\hyphpar0\qj{, 232.96A}}}{{\f5\fs12\hyphpar0\qj{, 232.106}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.73A}}}{\*\bkmkstart stylerid1_2E8_2E5_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E5_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Retaliation prohibited }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ remedy.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An employer shall not take retaliatory action against an employee as a reprisal for the employee\u8217\'3fs participation in good faith in making a report, photograph, or X ray, or in the performance of a medically relevant test pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, or aiding and assisting in an assessment of a child abuse report pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 232.71B}}}{{\f5\fs18\hyphpar0\qj{. }}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not apply to a disclosure of information that is prohibited by statute.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fretaliatory action\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes but is not limited to an employer\u8217\'3fs action to discharge an employee or to take or fail to take action regarding an employee\u8217\'3fs appointment or proposed appointment to a position in employment, to take or fail to take action regarding an employee\u8217\'3fs promotion or proposed promotion to a position in employment, or to fail to provide an advantage in a position in employment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subsection 1}}}{{\f5\fs18\hyphpar0\qj{ may be enforced through a civil action.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who violates }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ is liable to an aggrieved employee for affirmative relief including reinstatement, with or without back pay, or any other equitable relief the court deems appropriate, including attorney fees and costs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When a person commits, is committing, or proposes to commit an act in violation of }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, an injunction may be granted through an action in district court to prohibit the person from continuing such acts. The action for injunctive relief may be brought by an aggrieved employee or the county attorney.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2012 Acts, ch 1040, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 90, \'a759}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.68}}}{{\f5\fs12\hyphpar0\qj{, 232.73}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.74}}}{\*\bkmkstart stylerid1_2E8_2E5_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E5_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Evidence not privileged or excluded.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Sections 622.9}}}{ and }{{\f5\fs18\hyphpar0\qj{622.10}}}{ and any other statute or rule of evidence which excludes or makes privileged the testimony of a husband or wife against the other or the testimony of a health practitioner or mental health professional as to confidential communications, do not apply to evidence regarding a child\u8217\'3fs injuries or the cause of the injuries in any judicial proceeding, civil or criminal, resulting from a report pursuant to }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ or relating to the subject matter of such a report.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, \'a7235A.8; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7232.74}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 37, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{87 Acts, ch 153, \'a76}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7228.6}}}{{\f5\fs12\hyphpar0\qj{, 232.68}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.75}}}{\*\bkmkstart stylerid1_2E8_2E5_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E5_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Sanctions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any person, official, agency, or institution required by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ to report a suspected case of child abuse who knowingly and willfully fails to do so is guilty of a simple misdemeanor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any person, official, agency, or institution required by }}}{{\f5\fs18\hyphpar0\qj{section 232.69}}}{{\f5\fs18\hyphpar0\qj{ to report a suspected case of child abuse who knowingly fails to do so or who knowingly interferes with the making of such a report in violation of }}}{{\f5\fs18\hyphpar0\qj{section 232.70}}}{{\f5\fs18\hyphpar0\qj{ is civilly liable for the damages proximately caused by such failure or interference.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who reports or causes to be reported to the department false information regarding an alleged act of child abuse, knowing that the information is false or that the act did not occur, commits a simple misdemeanor.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, \'a7235A.9; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7232.75}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1238, \'a711}}}{; }{{\f5\fs18\hyphpar0\qj{87 Acts, ch 13, \'a72}}}{; }{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 122, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7610}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.68}}}{{\f5\fs12\hyphpar0\qj{, 232.71B}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.76}}}{\*\bkmkstart stylerid1_2E8_2E5_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E5_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Publicity, educational, and training programs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department, within the limits of available funds, shall conduct a continuing publicity and educational program for the personnel of the department, persons required to report, and any other appropriate persons to encourage the fullest possible degree of reporting of suspected cases of child abuse. Educational programs shall include but not be limited to the diagnosis and cause of child abuse, the responsibilities, obligations, duties, and powers of persons and agencies under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and the procedures of the department and the juvenile court with respect to suspected cases of child abuse and disposition of actual cases.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, in addition to the definition in }}}{{\f5\fs18\hyphpar0\qj{section 232.68}}}{{\f5\fs18\hyphpar0\qj{, a }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fchild protection worker\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ also includes any employee of the department who provides services to or otherwise works directly with children and families for whom child abuse has been alleged.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The training of a child protection worker shall include but is not limited to the worker\u8217\'3fs legal duties to protect the constitutional and statutory rights of a child and the child\u8217\'3fs family members throughout the child or family members\u8217\'3f period of involvement with the department beginning with the child abuse report and ending with the department\u8217\'3fs closure of the case. The curriculum used for the training shall specifically include instruction on the }}}{{\f5\fs18\hyphpar0\qj{fourth amendment to the Constitution of the United States}}}{{\f5\fs18\hyphpar0\qj{ and parents\u8217\'3f legal rights.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, \'a7235A.10; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7232.76}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1152, \'a73}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.68}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.77}}}{\*\bkmkstart stylerid1_2E8_2E5_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E5_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Photographs, X rays, and medically relevant tests.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who is required to report suspected child abuse may take or perform, or may cause to be taken or performed, at public expense, photographs, X rays, physical assessments, or other tests of a child which would provide medical indication of allegations arising from an assessment.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A health practitioner may, if medically indicated, cause to be performed a radiological examination, physical assessment, or other test of the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who takes any photographs or X rays or performs any physical assessments or other tests pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall notify the department that the photographs or X rays have been taken or the physical assessments or other tests have been performed, and shall retain the photographs, X rays, or physical assessment or other test findings for a reasonable time following the notification.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Whenever the person is required to report under }}}{{\f5\fs18\hyphpar0\qj{section 232.69}}}{{\f5\fs18\hyphpar0\qj{ in that person\u8217\'3fs capacity as a member of the staff of a medical or other private or public institution, agency or facility, that person shall immediately notify the person in charge of the institution, agency, or facility or that person\u8217\'3fs designated delegate of the need for photographs, X rays, physical assessments, or other tests.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a health practitioner discovers in a child physical or behavioral symptoms of the effects of exposure to cocaine, heroin, amphetamine, methamphetamine, or other illegal drugs, or combinations or derivatives thereof, which were not prescribed by a health practitioner, or if the health practitioner has determined through examination of the natural mother of the child that the child was exposed in utero, the health practitioner may perform or cause to be performed a medically relevant test, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 232.73}}}{{\f5\fs18\hyphpar0\qj{, on the child. The practitioner shall report any positive results of such a test on the child to the department. The department shall begin an assessment pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 232.71B}}}{{\f5\fs18\hyphpar0\qj{ upon receipt of such a report. A positive test result obtained prior to the birth of a child shall not be used for the criminal prosecution of a parent for acts and omissions resulting in intrauterine exposure of the child to an illegal drug.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a health practitioner involved in the delivery or care of a newborn or infant discovers in the newborn or infant physical or behavioral symptoms that are consistent with the effects of prenatal drug exposure or a fetal alcohol spectrum disorder, the health practitioner shall report such information to the department in a manner prescribed by rule of the department.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, \'a7235A.11; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7232.77}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 96, \'a7157, 159}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1264, \'a729}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 93, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1130, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1092, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 35, \'a710, 25}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 115, \'a79, 19}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 86, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 86, \'a723}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.68}}}{{\f5\fs12\hyphpar0\qj{, 232.73}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 1 amended}\par}{}{}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{PART 3}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E8_2E6_2E1_2E2}{TEMPORARY CUSTODY OF A CHILD}{\*\bkmkend stylerid1_2E8_2E6_2E1_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.78}}}{\*\bkmkstart stylerid1_2E8_2E6_2E2_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E6_2E2_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Temporary custody of a child pursuant to ex parte court order.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The juvenile court may enter an ex parte order directing a peace officer or a juvenile court officer to take custody of a child before or after the filing of a petition under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ provided all of the following apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any of the following circumstances exist:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person responsible for the care of the child consents to the removal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person responsible for the care of the child is absent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person responsible for the care of the child, though present, was asked and refused to consent to the removal of the child and was informed of an intent to apply for an order under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{There is reasonable cause to believe that a request for consent would further endanger the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{There is reasonable cause to believe that a request for consent will cause the person responsible for the care of the child to take flight with the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court has found that substantial evidence exists to demonstrate that the need for removal outweighs the potential harm removal of the child would cause the child, including but not limited to any physical, emotional, social, and mental trauma the removal may cause the child. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court finds that the child\u8217\'3fs immediate removal is necessary to avoid imminent danger to the child\u8217\'3fs life or health. The circumstances or conditions indicating the presence of such imminent danger shall include but are not limited to any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The refusal or failure of the person responsible for the care of the child to comply with the request of a peace officer, juvenile court officer, or child protection worker for the person to obtain and provide to the requester the results of a physical assessment or behavioral health evaluation of the child. The request for a physical assessment of the child may specify the performance of a medically relevant test.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The refusal or failure of the person responsible for the care of the child or a person present in the person\u8217\'3fs home to comply with a request of a peace officer, juvenile court officer, or child protection worker for such a person to submit to and provide to the requester the results of a medically relevant test of the person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{There is not enough time to file a petition and hold a hearing under }}}{{\f5\fs18\hyphpar0\qj{section 232.95}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The application for the order includes a statement of the facts to support the findings specified in paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person making the application for an order shall assert facts showing there is reasonable cause to believe that the child cannot either be returned to the place where the child was residing or placed with the parent who does not have physical care of the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except for good cause shown or unless the child is sooner returned to the place where the child was residing or permitted to return to the child care facility, a petition shall be filed under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ within three days of the issuance of the order.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The juvenile court may enter an order authorizing a physician or physician assistant or hospital to provide emergency medical or surgical procedures before the filing of a petition under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ provided all of the following conditions are met:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Such procedures are necessary to safeguard the life and health of the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{There is not enough time to file a petition under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and hold a hearing as provided in }}}{{\f5\fs18\hyphpar0\qj{section 232.95}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The juvenile court, before or after the filing of a petition under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, may enter an ex parte order authorizing an inpatient or outpatient physical assessment or an inpatient or outpatient behavioral health evaluation of a child, provided all of the following apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any of the following circumstances exist:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child\u8217\'3fs parent, guardian, or custodian consents to the physical assessment or the behavioral health evaluation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child\u8217\'3fs parent, guardian, or custodian is absent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child\u8217\'3fs parent, guardian, or custodian, though present, was asked and refused to provide written consent to the physical assessment or the behavioral health evaluation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The juvenile court has entered an ex parte order directing the removal of the child from the child\u8217\'3fs home or a child care facility under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{There is not enough time to file a petition and to hold a hearing as provided in }}}{{\f5\fs18\hyphpar0\qj{section 232.98}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any person who may file a petition under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ may apply for, or the court on its own motion may issue, an order for temporary removal under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. An appropriate person designated by the court shall confer with a person seeking the removal order, shall make every reasonable effort to inform the parent or other person legally responsible for the child\u8217\'3fs care of the application, and shall make such inquiries as will aid the court in disposing of such application. The person designated by the court shall file with the court a complete written report providing all details of the designee\u8217\'3fs conference with the person seeking the removal order, the designee\u8217\'3fs efforts to inform the parents or other person legally responsible for the child\u8217\'3fs care of the application, any inquiries made by the designee to aid the court in disposing of the application, and all information the designee communicated to the court. The report shall be filed within five days of the date of the removal order. If the court does not designate an appropriate person who performs the required duties, notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 234.39}}}{{\f5\fs18\hyphpar0\qj{ or any other provision of law, the child\u8217\'3fs parent shall not be responsible for paying the cost of care and services for the duration of the removal order.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any order entered under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ authorizing temporary removal of a child must include all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A determination made by the court that continuation of the child in the child\u8217\'3fs home would be contrary to the welfare of the child. Such a determination must be made on a case-by-case basis. The grounds for the court\u8217\'3fs determination must be explicitly documented and stated in the order. However, preserving the safety of the child must be the court\u8217\'3fs paramount consideration. If imminent danger to the child\u8217\'3fs life or health exists at the time of the court\u8217\'3fs consideration, the determination shall not be a prerequisite to the removal of the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A determination made by the court that the necessity of the removal of the child from the child\u8217\'3fs home, due to an imminent risk to the child\u8217\'3fs life or health, is greater than the potential harm including but not limited to physical, emotional, social, and mental trauma the removal may cause the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A statement informing the child\u8217\'3fs parent that the consequences of a permanent removal may include termination of the parent\u8217\'3fs rights with respect to the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the juvenile court determines that the child should be temporarily removed from the child\u8217\'3fs home under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the court shall consider placing the child in the custody of another parent of the child. If the juvenile court determines placing custody of the child with any of the child\u8217\'3fs parents is not in the child\u8217\'3fs best interests, the child\u8217\'3fs custody shall be transferred to the department for placement of the child in any of the following categories in the following order of priority: }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An adult relative of the child including but not limited to adult siblings and parents of siblings. }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A fictive kin.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any other suitable placement identified by the child\u8217\'3fs relatives.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An individual licensee or an approved kinship caregiver under }}}{{\f5\fs18\hyphpar0\qj{chapter 237}}}{{\f5\fs18\hyphpar0\qj{. If the child is placed with an individual licensee or an approved kinship caregiver, the department shall assign decision-making authority to the individual licensee or the approved kinship caregiver for the purpose of applying the reasonable and prudent parent standard during the child\u8217\'3fs placement.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A group care facility, shelter care facility, or other residential treatment facility.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the court places custody of the child with the department pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the court may identify a category listed in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ for placement of the child, but the department shall have the authority to select the specific person or facility within that category for placement, subject to court review at the request of an interested party.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court shall give deference to the department\u8217\'3fs decision for placement of a child. A party opposed to the department\u8217\'3fs placement of a child shall have the burden to prove the department failed to act in the child\u8217\'3fs best interests by unreasonably or irresponsibly failing to discharge its duties in selecting a suitable placement for the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A juvenile court shall not order placement of a child in a category listed in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (2), (3), (4), or (5), without a specific finding that placement with a relative is not in the child\u8217\'3fs best interests and shall provide reasons for the court\u8217\'3fs finding.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any provision to the contrary including priority in placement of a child under }}}{{\f5\fs18\hyphpar0\qj{subsection 8}}}{{\f5\fs18\hyphpar0\qj{, if an ex parte order is requested from the juvenile court under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 233.2}}}{{\f5\fs18\hyphpar0\qj{ for transfer of custody of a newborn infant, one of the following shall be applicable:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If physical custody of the newborn infant was not initially relinquished under }}}{{\f5\fs18\hyphpar0\qj{section 233.2}}}{{\f5\fs18\hyphpar0\qj{ to an adoption service provider, the department shall request that custody be transferred to the department.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If physical custody of the newborn infant was initially relinquished under }}}{{\f5\fs18\hyphpar0\qj{section 233.2}}}{{\f5\fs18\hyphpar0\qj{ to an adoption service provider, the adoption service provider shall request that custody be transferred to the adoption service provider.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon receiving the order, the department or the adoption service provider shall take custody of the newborn infant and proceed in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapter 233}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fadoption service provider\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as defined in }}}{{\f5\fs18\hyphpar0\qj{section 233.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7232.78}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1279, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 173, \'a710, 11}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 230, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1172, \'a723}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 35, \'a711, 25}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1190, \'a74 \u8211\'3f 6}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 192, \'a733}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1067, \'a76, 7}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 135, \'a712, 13}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1066, \'a731, 32}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1098, \'a724 \u8211\'3f 26}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7611}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 46, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 66, \'a744}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 86, \'a724 \u8211\'3f 26}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 135, \'a75}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.44}}}{{\f5\fs12\hyphpar0\qj{, 232.73}}}{{\f5\fs12\hyphpar0\qj{, 232.79}}}{{\f5\fs12\hyphpar0\qj{, 232.95}}}{{\f5\fs12\hyphpar0\qj{, 232.98}}}{{\f5\fs12\hyphpar0\qj{, 232.104}}}{{\f5\fs12\hyphpar0\qj{, 233.2}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 1, paragraph a amended}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 1, paragraph c, subparagraph (1) amended}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 5 amended}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 8, paragraph a, subparagraph (4) amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.79}}}{\*\bkmkstart stylerid1_2E8_2E6_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E6_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Custody without court order.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A peace officer or juvenile court officer may take a child into custody, a physician or physician assistant treating a child may keep the child in custody, or a juvenile court officer may authorize a peace officer, physician or physician assistant, or medical security personnel to take a child into custody, without a court order as required under }}}{{\f5\fs18\hyphpar0\qj{section 232.78}}}{{\f5\fs18\hyphpar0\qj{ and without the consent of a parent, guardian, or custodian provided that both of the following apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child is in a circumstance or condition that presents an imminent danger to the child\u8217\'3fs life or health.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{There is not enough time to apply for an order under }}}{{\f5\fs18\hyphpar0\qj{section 232.78}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a person authorized by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ removes or retains custody of a child, the person shall:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Bring the child immediately to a place designated by the rules of the court for this purpose, unless the person is a physician or physician assistant treating the child and the child is or will presently be admitted to a hospital.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Make every reasonable effort to inform the parent, guardian, or custodian of the whereabouts of the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Make every reasonable effort to place the child with an adult relative or a fictive kin of the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In accordance with court-established procedures, immediately orally inform the court of the emergency removal and the circumstances surrounding the removal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Within twenty-four hours of orally informing the court of the emergency removal in accordance with paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, inform the court in writing of the emergency removal and the circumstances surrounding the removal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any person, agency, or institution acting in good faith in the removal or keeping of a child pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, and any employer of or person under the direction of such a person, agency, or institution, shall have immunity from any civil or criminal liability that might otherwise be incurred or imposed as the result of such removal or keeping.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When the court is informed that there has been an emergency removal or keeping of a child without a court order, the court shall direct the department or the juvenile probation department to make every reasonable effort to communicate immediately with the child\u8217\'3fs parent or parents or other person legally responsible for the child\u8217\'3fs care. Upon locating the child\u8217\'3fs parent or parents or other person legally responsible for the child\u8217\'3fs care, the department or the juvenile probation department shall, in accordance with court-established procedures, immediately orally inform the court. After orally informing the court, the department or the juvenile probation department shall provide to the court written documentation of the oral information.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court shall authorize the department or the juvenile probation department to cause a child thus removed or kept to be returned if it concludes there is not an imminent risk to the child\u8217\'3fs life and health in so doing. If the department or the juvenile probation department receives information which could affect the court\u8217\'3fs decision regarding the child\u8217\'3fs return, the department or the juvenile probation department, in accordance with court established procedures, shall immediately orally provide the information to the court. After orally providing the information to the court, the department or the juvenile probation department shall provide to the court written documentation of the oral information. If the child is not returned, the department or the juvenile probation department shall cause a petition to be filed within three days after the removal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If deemed appropriate by the court, upon being informed that there has been an emergency removal or keeping of a child without a court order, the court may enter an order in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 232.78}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When there has been an emergency removal or keeping of a child without a court order, a physical assessment of the child by a licensed medical practitioner shall be performed within twenty-four hours of the emergency removal or keeping of a child, unless the child is returned to the child\u8217\'3fs home within twenty-four hours of the emergency removal or keeping of a child.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7232.79}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 96, \'a7157, 159}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1279, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 230, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1215, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1172, \'a724}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 135, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1066, \'a733, 34}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1098, \'a727}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7612}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 86, \'a727}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.44}}}{{\f5\fs12\hyphpar0\qj{, 232.79A}}}{{\f5\fs12\hyphpar0\qj{, 232.95}}}{{\f5\fs12\hyphpar0\qj{, 232.104}}}{{\f5\fs12\hyphpar0\qj{, 232B.6}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 5 amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.79A}}}{\*\bkmkstart stylerid1_2E8_2E6_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E6_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Children without adult supervision.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If a peace officer determines that a child does not have adult supervision because the child\u8217\'3fs parent, guardian, or other person responsible for the care of the child has been arrested and detained or has been unexpectedly incapacitated, and that no adult who is legally responsible for the care of the child can be located within a reasonable period of time, the peace officer shall attempt to place the child with an adult relative of the child or a fictive kin. The person with whom the child is placed is authorized to give consent for emergency medical treatment of the child and shall not be held liable for any action arising from giving the consent. Upon the request of the peace officer, the department shall assist in making the placement. The placement shall not exceed a period of twenty-four hours and shall be terminated when a person who is legally responsible for the care of the child is located and takes custody of the child. If a person who is legally responsible for the care of the child cannot be located within the twenty-four hour period or a placement in accordance with }{{\f5\fs18\hyphpar0\qj{this section}}}{ is unavailable, the provisions of }{{\f5\fs18\hyphpar0\qj{section 232.79}}}{ shall apply. If the person with whom the child is placed charges a fee for the care of the child, the fee shall be paid from funds provided in the appropriation to the department for protective child care.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1215, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1098, \'a728}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.79B}}}{\*\bkmkstart stylerid1_2E8_2E6_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E6_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Safety plans.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fsafety plan\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a short-term, time-limited agreement entered into between the department and a child\u8217\'3fs parent or guardian designed to address signs of imminent or impending danger to a child identified by the department. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon the department\u8217\'3fs determination that potential harm to a child may be mitigated by the development of a safety plan, the department may enter into a safety plan with the child\u8217\'3fs parent or guardian.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A safety plan shall not be construed as a removal from parental or guardian custody absent a court order placing the child with a person or facility other than the parent or guardian who entered into the safety plan.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall adopt rules to implement }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2022 Acts, ch 1098, \'a729, 93}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 140, \'a72}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section applies beginning on the effective date specified in rules adopted by the department of health and human services pursuant to }{{\f5\fs12\hyphpar0\qj{chapter 17A}}}{ to implement the section; }{{\f5\fs12\hyphpar0\qj{2022 Acts, ch 1098, \'a793}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.80}}}{\*\bkmkstart stylerid1_2E8_2E6_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E6_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Homemaker services.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2018 Acts, ch 1137, \'a719}}}{{\f5\fs18\hyphpar0\qj{.}}}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.81}}}{\*\bkmkstart stylerid1_2E8_2E6_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E6_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Complaint.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any person having knowledge of the circumstances may file a complaint with the person or agency designated by the court to perform intake duties alleging that a child is a child in need of assistance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon receipt of a complaint, the court may request the department, juvenile probation office, or other authorized agency or individual to conduct a preliminary investigation of the complaint to determine if further action should be taken.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A petition alleging the child to be a child in need of assistance may be filed pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 232.87}}}{{\f5\fs18\hyphpar0\qj{ provided the allegations of the complaint, if proven, are sufficient to establish the court\u8217\'3fs jurisdiction and the filing is in the best interests of the child.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[SS15, \'a7254-a15; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{3621;}}}{ C46, 50, 54, 58, 62, \'a7232.5; C71, 73, 75, 77, \'a7232.3; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7232.81}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 96, \'a7157, 159}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 98, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7613}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.21}}}{{\f5\fs12\hyphpar0\qj{, 232.83}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.82}}}{\*\bkmkstart stylerid1_2E8_2E6_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E6_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Removal of sexual offenders, physical abusers, and domestic abusers from the residence pursuant to court order.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 561.15}}}{{\f5\fs18\hyphpar0\qj{, if it is alleged by a person authorized to file a petition under }}}{{\f5\fs18\hyphpar0\qj{section 232.87, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, or by the court on its own motion, that a parent, guardian, custodian, or an adult member of the household in which a child resides has committed a sexual offense with or against the child, pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 709}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{section 726.2}}}{{\f5\fs18\hyphpar0\qj{, or physical abuse as defined in }}}{{\f5\fs18\hyphpar0\qj{section 232.2, subsection 51}}}{{\f5\fs18\hyphpar0\qj{, or domestic abuse assault as defined in }}}{{\f5\fs18\hyphpar0\qj{section 708.2A}}}{{\f5\fs18\hyphpar0\qj{, against the child or another household member at a location or in a manner a reasonably prudent person would know the child could see, hear, or otherwise experience, the juvenile court may enter an ex parte order requiring the alleged sexual offender, physical abuser, or domestic abuser to vacate the child\u8217\'3fs residence upon a showing that probable cause exists to believe that the sexual offense, physical abuse, or domestic abuse has occurred and that substantial evidence exists to believe that the presence of the alleged sexual offender, physical abuser, or domestic abuser in the child\u8217\'3fs residence presents a danger to the child\u8217\'3fs life or physical, emotional, or mental health.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If an order is entered under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ and a petition has not yet been filed under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, the petition shall be filed under }}}{{\f5\fs18\hyphpar0\qj{section 232.87}}}{{\f5\fs18\hyphpar0\qj{ by the county attorney, the department, or a juvenile court officer within three days of the entering of the order.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The juvenile court may order on its own motion, or shall order upon the request of the alleged sexual offender, physical abuser, or domestic abuser a hearing to determine whether the order to vacate the residence should be upheld, modified, or vacated. The hearing shall be held within thirty days of removal of the alleged sexual offender, physical abuser, or domestic abuser from the residence. The juvenile court may in any later child in need of assistance proceeding uphold, modify, or vacate the order to vacate the residence.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1209, \'a714}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 96, \'a7157, 159}}}{{\f5\fs18\hyphpar0\qj{; 83 Acts, ch 186, \'a710055, 10201}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1186, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1251, \'a727}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1098, \'a730}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7614}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section not amended; internal reference change applied}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.83}}}{\*\bkmkstart stylerid1_2E8_2E6_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E6_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Child sexual abuse involving a person not responsible for the care of the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A complaint related to circumstances involving a child who is alleged to be a victim of an offense defined in }}}{{\f5\fs18\hyphpar0\qj{chapter 709}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{726}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{728}}}{{\f5\fs18\hyphpar0\qj{ and an alleged offender who is not a person responsible for the care of the child shall be handled pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 232.81}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Anyone authorized to conduct a preliminary investigation in response to a complaint may apply for, or the court on its own motion may enter, an ex parte order authorizing an inpatient or outpatient physical assessment or an inpatient or outpatient behavioral health evaluation provided all of the following apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any of the following circumstances exist:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The parent, guardian, or custodian consents to the physical assessment or the behavioral health evaluation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The parent, guardian, or custodian is absent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The parent, guardian, or custodian, though present, was asked and refused to authorize the physical assessment or the behavioral health evaluation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{There is not enough time to file a petition and hold a hearing under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The parent, guardian, or custodian has not provided care and treatment related to the child\u8217\'3fs alleged victimization.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1252, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1066, \'a735}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1098, \'a777}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 86, \'a728}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7709.13}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 2 amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.84}}}{\*\bkmkstart stylerid1_2E8_2E6_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E6_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Transfer of custody \u8212\'3f notice to adult relatives.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, unless the context otherwise requires, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fagency\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the department, juvenile court services, or a private agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Unless the custody of a child is transferred from one of the child\u8217\'3fs parents to another parent of the child, within thirty days after the entry of an order under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ removing a child from the custody of a parent or parents of the child, the department shall exercise due diligence in identifying and providing notice to the child\u8217\'3fs grandparents, aunts, uncles, adult siblings, parents of the child\u8217\'3fs siblings, and adult relatives suggested by the child\u8217\'3fs parents, subject to exceptions due to the presence of family or domestic violence.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The notice content shall include but is not limited to all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A statement that the child has been or is being removed from the custody of the child\u8217\'3fs parent or parents.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An explanation of the options the relative has under federal, state, and other law to participate in the care and placement of the child on a temporary or permanent basis. The options addressed shall include but are not limited to assistance and support options, options for participating in legal proceedings, and any options that may be lost by failure to respond to the notice.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A description of the requirements for the relative to serve as a foster family home provider or other type of care provider for the child and the additional services, training, and other support available for children receiving such care.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Information concerning the option to apply for kinship guardianship assistance payments.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The agency may share information as necessary to explore a child\u8217\'3fs potential placement with any adult relative who may receive notice pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If an adult relative entitled to notice pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ is later discovered by or identified to the department, the department shall provide notice to that relative within thirty days of that relative becoming known to the department.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 120, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 50, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1098, \'a731, 32}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{232.85 and 232.86}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{PART 4}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E8_2E7_2E1_2E2}{JUDICIAL PROCEEDINGS}{\*\bkmkend stylerid1_2E8_2E7_2E1_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.87}}}{\*\bkmkstart stylerid1_2E8_2E7_2E2_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E7_2E2_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Filing of a child in need of assistance petition \u8212\'3f contents of petition.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A formal judicial proceeding to determine whether a child is a child in need of assistance under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall be initiated by the filing of a petition alleging a child to be a child in need of assistance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A petition may be filed by the department, juvenile court officer, or county attorney.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department, juvenile court officer, county attorney or judge may authorize the filing of a petition with the clerk of the court by any competent person having knowledge of the circumstances without the payment of a filing fee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The petition shall be submitted in the form specified in }}}{{\f5\fs18\hyphpar0\qj{section 232.36}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The petition shall contain the information specified in }}}{{\f5\fs18\hyphpar0\qj{section 232.36}}}{{\f5\fs18\hyphpar0\qj{ and a clear and concise summary of the facts which bring the child within the jurisdiction of the court under }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7232.87}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 96, \'a7157, 159}}}{{\f5\fs18\hyphpar0\qj{; 83 Acts, ch 186, \'a710055, 10201}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1062, \'a794}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7615}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.81}}}{{\f5\fs12\hyphpar0\qj{, 232.82}}}{{\f5\fs12\hyphpar0\qj{, 232.95}}}{{\f5\fs12\hyphpar0\qj{, 232.98}}}{{\f5\fs12\hyphpar0\qj{, 232D.204}}}{{\f5\fs12\hyphpar0\qj{, 233.2}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.88}}}{\*\bkmkstart stylerid1_2E8_2E7_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E7_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Summons, notice, subpoenas, and service.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{After a petition has been filed, the court shall issue and serve summons, subpoenas, and other process in the same manner as for adjudicatory hearings in cases of juvenile delinquency as provided in }{{\f5\fs18\hyphpar0\qj{section 232.37}}}{. Reasonable notice shall be provided to the persons required to be provided notice under }{{\f5\fs18\hyphpar0\qj{section 232.37}}}{, except that notice shall be waived regarding a person who was notified of the adjudicatory hearing and who failed to appear. In addition, reasonable notice for any hearing under }{{\f5\fs18\hyphpar0\qj{this subchapter}}}{ shall be provided to the agency, facility, institution, or person, including a foster parent, relative, or other individual providing preadoptive care, with whom a child has been placed.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[SS15, \'a7254-a16; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{3623;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, \'a7232.4; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7232.88}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 229, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 182, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1034, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 164, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 135, \'a728}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1062, \'a794}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.91}}}{{\f5\fs12\hyphpar0\qj{, 331.653}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.89}}}{\*\bkmkstart stylerid1_2E8_2E7_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E7_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Right to and appointment of counsel.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon the filing of a petition the parent, guardian, putative father, or custodian identified in the petition shall have the right to counsel in connection with all subsequent hearings and proceedings. If that person desires but is financially unable to employ counsel, the court shall appoint counsel. A putative father is not a necessary party to a proceeding until the putative father\u8217\'3fs paternity is established.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon the filing of a petition, the court shall appoint counsel and a guardian ad litem for the child identified in the petition as a party to the proceedings. If a guardian ad litem has previously been appointed for the child in a proceeding under }}}{{\f5\fs18\hyphpar0\qj{subchapter II }}}{{\f5\fs18\hyphpar0\qj{ or a proceeding in which the court has waived jurisdiction under }}}{{\f5\fs18\hyphpar0\qj{section 232.45}}}{{\f5\fs18\hyphpar0\qj{, the court shall appoint the same guardian ad litem upon the filing of the petition under }}}{{\f5\fs18\hyphpar0\qj{this part}}}{{\f5\fs18\hyphpar0\qj{. Counsel shall be appointed as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the child is represented by counsel and the court determines there is a conflict of interest between the child and the child\u8217\'3fs parent, guardian, putative father, or custodian and that the retained counsel could not properly represent the child as a result of the conflict, the court shall appoint other counsel to represent the child, who shall be compensated pursuant to the provisions of }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the child is not represented by counsel, the court shall either order the parent, guardian, or custodian to retain counsel for the child or shall appoint counsel for the child, who shall be compensated pursuant to the provisions of }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court shall determine, after giving the parent, guardian, or custodian an opportunity to be heard, whether the person has the ability to pay in whole or in part for counsel appointed for the child. If the court determines that the person possesses sufficient financial ability, the court shall then consult with the department, the juvenile probation office, or other authorized agency or individual regarding the likelihood of impairment of the relationship between the child and the child\u8217\'3fs parent, guardian, or custodian as a result of ordering the parent, guardian, or custodian to pay for the child\u8217\'3fs counsel. If impairment is deemed unlikely, the court shall order that person to pay an amount the court finds appropriate in the manner and to whom the court directs. If the person fails to comply with the order without good reason, the court shall enter judgment against the person. If impairment is deemed likely or if the court determines that the parent, guardian, or custodian cannot pay any part of the expenses of counsel appointed to represent the child, counsel shall be reimbursed pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 232.141, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The same person may serve both as the child\u8217\'3fs counsel and as guardian ad litem. However, the court may appoint a separate guardian ad litem, if the same person cannot properly represent the legal interests of the child as legal counsel and also represent the best interests of the child as guardian ad litem in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 232.2, subsection 27}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, or a separate guardian ad litem is required to fulfill the requirements of }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{. If a child\u8217\'3fs guardian ad litem is also acting as an attorney for the child, each report submitted to a court by the guardian ad litem shall contain a statement indicating whether a separate guardian ad litem is required based on the guardian ad litem\u8217\'3fs interviews and investigations conducted until the time a report is submitted to the court.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{3631;}}}{ C46, 50, 54, 58, 62, \'a7232.15; C66, 71, 73, 75, 77, \'a7232.28; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7232.89}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 96, \'a7157, 159}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1186, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 121, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 283, \'a724}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1271, \'a71506, 1507}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1193, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 23, \'a722}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 99, \'a73, 11}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1162, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1062, \'a733}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1098, \'a734 \u8211\'3f 36, 78}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7616}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.108}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section not amended; internal reference change applied}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.90}}}{\*\bkmkstart stylerid1_2E8_2E7_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E7_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Duties of county attorney.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fstate\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the general interest held by the people in the health, safety, welfare, and protection of all children living in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county attorney shall represent the state in proceedings arising from a petition filed under }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ and shall present evidence in support of the petition. The county attorney shall be present at proceedings initiated by petition under }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ filed by an intake officer or the county attorney, or if a party to the proceedings contests the proceedings, or if the court determines there is a conflict of interest between the child and the child\u8217\'3fs parent, guardian, or custodian or if there are contested issues before the court.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{ If there is disagreement between the department and the county attorney regarding the appropriate action to be taken, the department may request that the state be represented by the attorney general in place of the county attorney. If the state is represented by the attorney general, the county attorney may continue to appear in the proceeding and may present the position of the county attorney regarding the appropriate action to be taken in the case.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county attorney and the attorney general shall comply with the requirements of }}}{{\f5\fs18\hyphpar0\qj{chapter 232B}}}{{\f5\fs18\hyphpar0\qj{ and the federal }}}{{\f5\fs18\hyphpar0\qj{Indian Child Welfare Act, }}}{{\f5\fs18\hyphpar0\qj{Pub. L. No. 95-608}}}{{\f5\fs18\hyphpar0\qj{, when either }}}{{\f5\fs18\hyphpar0\qj{chapter 232B}}}{{\f5\fs18\hyphpar0\qj{ or the federal }}}{{\f5\fs18\hyphpar0\qj{Indian Child Welfare Act}}}{{\f5\fs18\hyphpar0\qj{ is determined to be applicable in any proceeding under }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, \'a7232.29; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7232.90}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{87 Acts, ch 151, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 230, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 113, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1092, \'a751}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1062, \'a794}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.91}}}{\*\bkmkstart stylerid1_2E8_2E7_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E7_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Presence of child, parents, guardian ad litem, and others at hearings \u8212\'3f additional parties }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ department recordkeeping.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any hearings or proceedings under }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ subsequent to the filing of a petition shall not take place without the presence of the child\u8217\'3fs parent, guardian, custodian, or guardian ad litem in accordance with and subject to }}}{{\f5\fs18\hyphpar0\qj{section 232.38}}}{{\f5\fs18\hyphpar0\qj{. A parent without custody shall be made a party to proceedings under }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An agency, facility, institution, adult relative with a substantial relationship to the child, fictive kin, or individual providing custodial care to the child may petition the court to be made a party to proceedings under }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any person who is entitled under }}}{{\f5\fs18\hyphpar0\qj{section 232.88}}}{{\f5\fs18\hyphpar0\qj{ to receive notice of a hearing concerning a child shall be given the opportunity to be heard in any other review or hearing involving the child. A foster parent, adult relative, or other individual with whom a child has been placed for preadoptive care shall have the right to be heard in any proceeding involving the child. If a child is of an age appropriate to attend the hearing but the child does not attend, the court shall determine if the child was informed of the child\u8217\'3fs right to attend the hearing. A presumption exists that it is in the best interests of a child ten years of age or older to attend all hearings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a child is of an age appropriate to attend a hearing but the child does not attend, the court shall determine if the child was informed of the child\u8217\'3fs right to attend the hearing. A presumption exists that it is in the best interests of a child ten years of age or older to attend all hearings and all staff or family meetings involving placement options or services provided to the child. The department shall allow the child to attend all such hearings and meetings unless the attorney for the child finds the child\u8217\'3fs attendance is not in the best interests of the child. If the child is excluded from attending a hearing or meeting, the department shall maintain a written record detailing the reasons for excluding the child. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{sections 232.147 through 232.151}}}{{\f5\fs18\hyphpar0\qj{, a copy of the written record shall be made available to the child upon the request of the child after reaching the age of majority.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fattend\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes the appearance of the child at a hearing by video or telephonic means.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[SS15, \'a7254-a16; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{3631;}}}{ C46, 50, 54, 58, 62, \'a7232.15; C66, 71, 73, 75, 77, \'a7232.11; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7232.91}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1279, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 182, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 164, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1190, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 172, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1114, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1187, \'a7133}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1065, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1062, \'a794}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1098, \'a737}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7600A.7}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.92}}}{\*\bkmkstart stylerid1_2E8_2E7_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E7_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Exclusion of public from hearings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Hearings held under }{{\f5\fs18\hyphpar0\qj{this subchapter}}}{ are open to the public unless the court, on the motion of any of the parties or upon the court\u8217\'3fs own motion, excludes the public. The court shall exclude the public from a hearing if the court determines that the possibility of damage or harm to the child outweighs the public\u8217\'3fs interest in having an open hearing. Upon closing the hearing to the public, the court may admit those persons who have direct interest in the case or in the work of the court.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7232.92}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 230, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1062, \'a794}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.147}}}{{\f5\fs12\hyphpar0\qj{, 600A.7}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.93}}}{\*\bkmkstart stylerid1_2E8_2E7_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E7_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Other issues adjudicated.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{When it appears during the course of any hearing or proceeding that some action or remedy other than those indicated by the application or pleading appears appropriate, the court may, provided all necessary parties consent, proceed to hear and determine the other issues as though originally properly sought and pleaded.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, \'a7232.12; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7232.93}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7600A.7}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.94}}}{\*\bkmkstart stylerid1_2E8_2E7_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E7_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Reporter required.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Stenographic notes or electronic or mechanical recordings shall be taken of all court hearings held pursuant to }{{\f5\fs18\hyphpar0\qj{this subchapter}}}{ unless waived by the parties. The child shall not be competent to waive the reporting requirement, but waiver may be made for the child by the child\u8217\'3fs counsel or guardian ad litem. Matters which must be reported under the provisions of }{{\f5\fs18\hyphpar0\qj{this section}}}{ shall be reported in the same manner as required in }{{\f5\fs18\hyphpar0\qj{section 624.9}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, \'a7232.32; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7232.94}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2020 Acts, ch 1062, \'a794}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.94A}}}{{\f5\fs12\hyphpar0\qj{, 600A.7}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.94A}}}{\*\bkmkstart stylerid1_2E8_2E7_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E7_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Records \u8212\'3f subsequent hearings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Juvenile court records, social records, and the material required to be recorded pursuant to }{{\f5\fs18\hyphpar0\qj{section 232.94}}}{ shall be maintained and shall be a part of each hearing relating to the child so long as and whenever the child is a child in need of assistance.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1279, \'a712}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7600A.7}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.94B}}}{\*\bkmkstart stylerid1_2E8_2E7_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E7_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Continuances.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A court may grant a continuance in a child in need of assistance proceeding or a termination of a parent-child relationship proceeding only for good cause shown.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2022 Acts, ch 1098, \'a738}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7600A.7}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.95}}}{\*\bkmkstart stylerid1_2E8_2E7_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E7_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Hearing concerning temporary removal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At any time after the petition is filed, any person who may file a petition under }}}{{\f5\fs18\hyphpar0\qj{section 232.87}}}{{\f5\fs18\hyphpar0\qj{ may apply for, or the court on its own motion may order, a hearing to determine whether the child should be temporarily removed from home. If the child is in the custody of a person other than the child\u8217\'3fs parent, guardian, or custodian as the result of action taken pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 232.78}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{232.79}}}{{\f5\fs18\hyphpar0\qj{, the court shall hold a hearing within ten days of the date of temporary removal to determine whether the temporary removal should be continued.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon such hearing, the court may do any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Return the child to a person with legal custody of the child pending a final order of disposition.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Remove the child from home and place the child with a parent of the child pending a final order of disposition. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Remove the child from home and place custody of the child with the department for placement of the child, pending a final order of disposition, in any of the following categories in the following order of priority: }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An adult relative of the child including but not limited to adult siblings and parents of siblings. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A fictive kin.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any other suitable placement identified by the child\u8217\'3fs relatives.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An individual licensee or an approved kinship caregiver under }}}{{\f5\fs18\hyphpar0\qj{chapter 237}}}{{\f5\fs18\hyphpar0\qj{. If the child is placed with an individual licensee or an approved kinship caregiver, the department shall assign decision-making authority to the individual licensee or approved kinship caregiver for the purpose of applying the reasonable and prudent parent standard during the child\u8217\'3fs placement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A group care facility, shelter care facility, or other residential treatment facility.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Authorize a physician, physician assistant, or hospital to provide medical or surgical procedures if such procedures are necessary to safeguard the child\u8217\'3fs life or health. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any provision to the contrary including placement of custody of a child pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, if the hearing under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is the result of a request for an ex parte order from the court pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 232.78}}}{{\f5\fs18\hyphpar0\qj{ for a newborn infant for whom physical custody was relinquished pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 233.2}}}{{\f5\fs18\hyphpar0\qj{, the court shall place custody of the child as provided in }}}{{\f5\fs18\hyphpar0\qj{section 232.78, subsection 9}}}{{\f5\fs18\hyphpar0\qj{, and proceed in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapter 233}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court shall make and file written findings as to the grounds for granting or denying an application under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the court orders the child removed from the home pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the court shall hold a hearing to review the removal order within six months unless a dispositional hearing pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 232.99}}}{{\f5\fs18\hyphpar0\qj{ has been held.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the court orders a removal pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the court shall, in addition, make a determination that continuation of the child in the child\u8217\'3fs home would be contrary to the welfare of the child, and that reasonable efforts have been made to prevent or eliminate the need for removal of the child from the child\u8217\'3fs home. The court shall also make a finding that substantial evidence exists to demonstrate that the need for removal due to an imminent risk to the child\u8217\'3fs life or health is greater than the potential harm including but not limited to any physical, emotional, social, or mental trauma the removal may cause the child.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court\u8217\'3fs determination regarding continuation of the child in the child\u8217\'3fs home and regarding reasonable efforts, including those made to prevent removal and those made to finalize any permanency plan in effect as well as any determination by the court that reasonable efforts are not required, must be made on a case-by-case basis. The grounds for each determination must be specifically documented and stated in the court order. However, preserving the safety of the child must be the court\u8217\'3fs paramount consideration. If imminent danger to the child\u8217\'3fs life or health exists at the time of the court\u8217\'3fs consideration, the determinations otherwise required under this paragraph shall not be a prerequisite for an order for temporary removal of the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the court places custody of the child with the department pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the court may identify a category listed in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, for placement of the child, but the department shall have the authority to select the specific person or facility within that category for placement, subject to court review at the request of an interested party.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court shall give deference to the department\u8217\'3fs decision for placement of a child. A party opposed to the department\u8217\'3fs placement of a child shall have the burden to prove the department failed to act in the child\u8217\'3fs best interests by unreasonably or irresponsibly failing to discharge its duties in selecting a suitable placement for the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court shall not order placement of a child in a category identified in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (2), (3), (4), or (5), without a specific finding that placement with an adult relative is not in the child\u8217\'3fs best interests and providing reasons for the finding.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the court orders the removal of a child pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the order shall also include a statement informing the child\u8217\'3fs parent that the consequences of a permanent removal may include termination of the parent\u8217\'3fs rights with respect to the child.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7232.95}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1279, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1186, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 159, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1190, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1067, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 135, \'a715}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[Subsection 2, paragraphs b and c, were inadvertently omitted in the 2001 Code Supplement and 2003 Code]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1101, \'a728}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1066, \'a736}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1098, \'a739, 40}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 46, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 140, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 135, \'a76}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.44}}}{{\f5\fs12\hyphpar0\qj{, 232.78}}}{{\f5\fs12\hyphpar0\qj{, 232.96}}}{{\f5\fs12\hyphpar0\qj{, 232.104}}}{{\f5\fs12\hyphpar0\qj{, 232B.6}}}{{\f5\fs12\hyphpar0\qj{, 600A.7}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 2, paragraph c, subparagraph (4) amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.96}}}{\*\bkmkstart stylerid1_2E8_2E7_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E7_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Adjudicatory hearing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court shall hear and adjudicate cases involving a petition alleging a child to be a child in need of assistance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state shall have the burden of proving the allegations by clear and convincing evidence.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Only evidence which is admissible under the rules of evidence applicable to the trial of civil cases shall be admitted, except as otherwise provided by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A report made to the department pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 235A}}}{{\f5\fs18\hyphpar0\qj{ shall be admissible in evidence, but such a report shall not alone be sufficient to support a finding that the child is a child in need of assistance unless the attorneys for the child and the parents consent to such a finding.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Neither the privilege attaching to confidential communications between a health practitioner or mental health professional and patient nor the prohibition upon admissibility of communications between husband and wife shall be ground for excluding evidence at an adjudicatory hearing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A report, study, record, or other writing or an audiotape or videotape recording made by the department, a juvenile court officer, a peace officer, a child protection center, or a hospital relating to a child in a proceeding under }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ is admissible notwithstanding any objection to hearsay statements contained in it provided it is relevant and material and provided its probative value substantially outweighs the danger of unfair prejudice to the child\u8217\'3fs parent, guardian, or custodian. The circumstances of the making of the report, study, record or other writing or an audiotape or videotape recording, including the maker\u8217\'3fs lack of personal knowledge, may be proved to affect its weight.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{After the hearing is concluded, the court shall make and file written findings as to the truth of allegations of the petition and as to whether the child is a child in need of assistance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the court concludes facts sufficient to sustain a petition have not been established by clear and convincing evidence or if the court concludes that its aid is not required in the circumstances, the court shall dismiss the petition.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the court concludes that facts sufficient to sustain the petition have been established by clear and convincing evidence and that its aid is required, the court may enter an order adjudicating the child to be a child in need of assistance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the court enters an order adjudicating the child to be a child in need of assistance, the court, if it has not previously done so, may issue an order authorizing temporary removal of the child from the child\u8217\'3fs home as set forth in }}}{{\f5\fs18\hyphpar0\qj{section 232.95, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, pending a final order of disposition. The order shall include all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A determination that continuation of the child in the child\u8217\'3fs home would be contrary to the welfare of the child, that reasonable efforts have been made to prevent or eliminate the need for removal of the child from the child\u8217\'3fs home and the court has found that substantial evidence exists to demonstrate that the need for removal due to an imminent risk to the child\u8217\'3fs life or health is greater than the potential harm including but not limited to any physical, emotional, social, or mental trauma the removal may cause the child. The court\u8217\'3fs determination regarding continuation of the child in the child\u8217\'3fs home, and regarding reasonable efforts, including those made to prevent removal and those made to finalize any permanency plan in effect, as well as any determination by the court that reasonable efforts are not required, must be made on a case-by-case basis. The grounds for each determination must be explicitly documented and stated in the court order. However, preserving the safety of the child is the paramount consideration. If imminent danger to the child\u8217\'3fs life or health exists at the time of the court\u8217\'3fs consideration, the determinations otherwise required under this paragraph shall not be a prerequisite for an order for temporary removal of the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A statement informing the child\u8217\'3fs parent that the consequences of a permanent removal may include termination of the parent\u8217\'3fs rights with respect to the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the court orders a removal of a child pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ and placement of a child pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 232.95, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (2), (3), (4), or (5), a specific finding that placement with an adult relative is not in the child\u8217\'3fs best interests and the reasons for the finding.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the court places custody of the child with the department pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 10}}}{{\f5\fs18\hyphpar0\qj{, the court may identify a category listed in }}}{{\f5\fs18\hyphpar0\qj{section 232.95, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, for placement of the child, but the department shall have the authority to select the specific person or facility within that category for placement, subject to court review at the request of an interested party.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court shall give deference to the department\u8217\'3fs decision for placement of a child. A party opposed to the department\u8217\'3fs placement of a child shall have the burden to prove the department failed to act in the child\u8217\'3fs best interests by unreasonably or irresponsibly failing to discharge its duties in selecting a suitable placement for the child.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, \'a7232.31; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7232.96}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 96, \'a7157, 159}}}{{\f5\fs18\hyphpar0\qj{; 83 Acts, ch 186, \'a710055, 10201}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1207, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 153, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1190, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1067, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 135, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1062, \'a794}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1098, \'a741 \u8211\'3f 43}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7617}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.99}}}{{\f5\fs12\hyphpar0\qj{, 232.104}}}{{\f5\fs12\hyphpar0\qj{, 232.116}}}{{\f5\fs12\hyphpar0\qj{, 600A.7}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.96A}}}{\*\bkmkstart stylerid1_2E8_2E7_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E7_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Child in need of assistance adjudication.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The court may adjudicate a child in need of assistance if such child is unmarried and meets any of the following requirements:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child\u8217\'3fs parent, guardian, or other custodian has abandoned or deserted the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child\u8217\'3fs parent, guardian, other custodian, or other member of the household in which the child resides has physically abused or neglected the child, or is imminently likely to physically abuse or neglect the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child has suffered or is imminently likely to suffer harmful effects as a result of any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Mental injury caused by the acts of the child\u8217\'3fs parent, guardian, or custodian.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The failure of the child\u8217\'3fs parent, guardian, custodian, or other member of the household in which the child resides to exercise a reasonable degree of care in supervising the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child\u8217\'3fs parent, guardian, custodian, or person responsible for the care of a child as defined in }}}{{\f5\fs18\hyphpar0\qj{section 232.68}}}{{\f5\fs18\hyphpar0\qj{, has knowingly disseminated or exhibited obscene material, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 728.1}}}{{\f5\fs18\hyphpar0\qj{, to the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child has been, or is imminently likely to be, sexually abused by the child\u8217\'3fs parent, guardian, custodian, or other member of the household in which the child resides.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child is in need of medical treatment to cure, alleviate, or prevent serious physical injury or illness and whose parent, guardian, or custodian is unwilling or unable to provide such treatment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child is in need of treatment to cure or alleviate serious mental illness or disorder, or emotional damage as evidenced by severe anxiety, depression, withdrawal, or untoward aggressive behavior toward the child\u8217\'3fs self or others and the child\u8217\'3fs parent, guardian, or custodian is unwilling to provide such treatment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child\u8217\'3fs parent, guardian, or custodian fails to exercise a minimal degree of care in supplying the child with adequate food, clothing, or shelter and refuses other means made available to provide such essentials.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child has committed a delinquent act as a result of pressure, guidance, or approval from a parent, guardian, custodian, or other member of the household in which the child resides.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child has been the subject of or a party to sexual activities for hire or who poses for live display or for photographic or other means of pictorial reproduction or display which is designed to appeal to the prurient interest, is patently offensive, and taken as a whole, lacks serious literary, scientific, political, or artistic value.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child is without a parent, guardian, or other custodian.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child\u8217\'3fs parent, guardian, or other custodian for good cause desires to be relieved of the child\u8217\'3fs care and custody.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child for good cause desires to have the child\u8217\'3fs parents relieved of the child\u8217\'3fs care and custody.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child is in need of treatment to cure or alleviate chemical dependency and whose parent, guardian, or custodian is unwilling or unable to provide such treatment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child\u8217\'3fs parent, guardian, or custodian suffers from a mental incapacity, a mental condition, imprisonment, or drug or alcohol abuse that results in the child not receiving adequate care or being imminently likely not to receive adequate care.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child\u8217\'3fs body has an illegal drug present as a direct and foreseeable consequence of the acts or omissions of the child\u8217\'3fs parent, guardian, or custodian. The presence of the drug shall be determined in accordance with a medically relevant test as defined in }}}{{\f5\fs18\hyphpar0\qj{section 232.73}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{16.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child\u8217\'3fs parent, guardian, custodian, or other adult member of the household in which a child resides does any of the following: }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Unlawfully uses, possesses, manufactures, cultivates, or distributes a dangerous substance in the presence of the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Knowingly allows the use, possession, manufacture, cultivation, or distribution of a dangerous substance by another person in the presence of the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Possesses a product with the intent to use the product as a precursor or an intermediary to a dangerous substance in the presence of the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Unlawfully uses, possesses, manufactures, cultivates, or distributes a dangerous substance listed in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ff\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (1), (2), or (3), in the child\u8217\'3fs home, on the premises, or in a motor vehicle located on the premises. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, \u8220\'3f}}}{{\i\f5\fs18\hyphpar0\qj{in the presence of a child\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means in the physical presence of a child or occurring under other circumstances in which a reasonably prudent person would know that the use, possession, manufacture, cultivation, or distribution of a dangerous substance may be seen, smelled, ingested, or heard by a child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fdangerous substance\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Amphetamine, its salts, isomers, or salts of its isomers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Methamphetamine, its salts, isomers, or salts of its isomers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A chemical or combination of chemicals that poses a reasonable risk of causing an explosion, fire, or other danger to the life or health of persons who are in the vicinity while the chemical or combination of chemicals is used or is intended to be used in any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The process of manufacturing an illegal or controlled substance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As a precursor in the manufacturing of an illegal or controlled substance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As an intermediary in the manufacturing of an illegal or controlled substance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Cocaine, its salts, isomers, salts of its isomers, or derivatives.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Heroin, its salts, isomers, salts of its isomers, or derivatives.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Opium and opiate, and any salt, compound, derivative, or preparation of opium or opiate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{17.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child is a newborn infant whose parent has voluntarily released custody of the child in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapter 233}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2022 Acts, ch 1098, \'a733}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.2}}}{{\f5\fs12\hyphpar0\qj{, 232.68}}}{{\f5\fs12\hyphpar0\qj{, 232.71B}}}{{\f5\fs12\hyphpar0\qj{, 232.98}}}{{\f5\fs12\hyphpar0\qj{, 232.102}}}{{\f5\fs12\hyphpar0\qj{, 232.117}}}{{\f5\fs12\hyphpar0\qj{, 709A.5}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.97}}}{\*\bkmkstart stylerid1_2E8_2E7_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E7_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Social investigation and report.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court shall not make a disposition of the petition until five working days after a social report has been submitted to the court and counsel for the child and has been considered by the court. The court may waive the five-day requirement upon agreement by all the parties. The court may direct either the juvenile court officer or the department or any other agency licensed by the state to conduct a social investigation and to prepare a social report which may include any evidence provided by an individual providing foster care for the child. A report prepared shall include any founded reports of child abuse.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The social investigation may be conducted and the social history may be submitted to the court prior to the adjudication of the child as a child in need of assistance with the consent of the parties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The social report shall not be disclosed except as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. At least five days prior to the hearing at which the disposition is determined, the department shall file a copy of the social report with the court and the court shall restrict access of the social report to counsel for the child, counsel for the child\u8217\'3fs parent, guardian, or custodian, the department, the court appointed special advocate, a local board as defined in }}}{{\f5\fs18\hyphpar0\qj{section 237.15}}}{{\f5\fs18\hyphpar0\qj{, the county attorney, the state\u8217\'3fs counsel, and the guardian ad litem. The court may in its discretion order counsel not to disclose parts of the report to the child, or to the parent, guardian, or custodian. If the report indicates the child or parent has behaved in a manner that threatened the safety of another person, has committed a violent act causing bodily injury to another person, or has committed sexual abuse, or the child has been a victim of sexual abuse, unless otherwise ordered by the court, the child\u8217\'3fs parent, guardian, or foster parent or other person with custody of or providing substantial care to the child shall be provided with that information.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, \'a7232.14; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7232.97}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 96, \'a7157, 159}}}{{\f5\fs18\hyphpar0\qj{; 83 Acts, ch 186, \'a710055, 10201}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1279, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1186, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 124, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 62, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1098, \'a744}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7618}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.147}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.98}}}{\*\bkmkstart stylerid1_2E8_2E7_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E7_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Physical assessments and behavioral health evaluations }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ child in need of assistance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as provided in }}}{{\f5\fs18\hyphpar0\qj{section 232.78, subsection 5}}}{{\f5\fs18\hyphpar0\qj{, a physical assessment or behavioral health evaluation of a child may be ordered only after the filing of a petition pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 232.87}}}{{\f5\fs18\hyphpar0\qj{, and after a hearing to determine whether a physical assessment or behavioral health evaluation is necessary to determine the child\u8217\'3fs physical condition or if the child has a behavioral health condition.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court may consider chemical dependency as either a physical or behavioral health condition and may consider a chemical dependency evaluation as either a physical assessment or behavioral health evaluation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The hearing required by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ may be held simultaneously with the adjudicatory hearing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A physical assessment or a behavioral health evaluation ordered prior to the adjudication shall be conducted on an outpatient basis when possible. However, if deemed necessary by the court, the court may order the child to a suitable nonsecure hospital, facility, or institution for the purpose of an inpatient physical assessment or an inpatient behavioral health evaluation for a period not to exceed thirty days if all of the following circumstances exist:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Probable cause exists to believe that the child is a child in need of assistance pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 232.96A, subsection 5 or 6}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An inpatient physical assessment or inpatient behavioral health evaluation is necessary to determine whether there is clear and convincing evidence that the child is a child in need of assistance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child\u8217\'3fs attorney agrees to an inpatient physical assessment or inpatient behavioral health evaluation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A physical assessment or a behavioral health evaluation ordered after the adjudication shall be conducted on an outpatient basis when possible. However, if deemed necessary by the court, the court may order the child to a suitable nonsecure hospital, facility, or institution for the purpose of an inpatient physical assessment or an inpatient behavioral health evaluation for a period not to exceed thirty days.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child\u8217\'3fs parent, guardian, or custodian shall be included in counseling sessions offered during the child\u8217\'3fs stay in a hospital, facility, or institution when feasible, and when in the best interests of the child and the child\u8217\'3fs parent, guardian, or custodian. If separate counseling sessions are conducted for the child and the child\u8217\'3fs parent, guardian, or custodian, a joint counseling session shall be offered prior to the release of the child from the hospital, facility, or institution. The court shall require that notice be provided to the child\u8217\'3fs guardian ad litem of the counseling sessions, the counseling session participants, and the outcomes of the counseling sessions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Following an adjudication that a child is a child in need of assistance, the court may, after a hearing, order a physical assessment or behavioral health evaluation of the child\u8217\'3fs parent, guardian, or custodian if that person\u8217\'3fs ability to care for the child is at issue.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, \'a7232.13; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7232.98}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1209, \'a715}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1279, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 173, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1186, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 41, \'a7263}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1098, \'a779}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7619}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 86, \'a729}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.78}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.99}}}{\*\bkmkstart stylerid1_2E8_2E7_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E7_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Dispositional hearing \u8212\'3f findings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Following the entry of an order pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 232.96}}}{{\f5\fs18\hyphpar0\qj{, the court shall, as soon as practicable, hold a dispositional hearing in order to determine what disposition should be made of the petition.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All relevant and material evidence shall be admitted.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In the initial dispositional hearing, any hearing held under }}}{{\f5\fs18\hyphpar0\qj{section 232.103}}}{{\f5\fs18\hyphpar0\qj{, and any dispositional review or permanency hearing, the court shall inquire of the parties as to the sufficiency of the services being provided and whether additional services are needed to facilitate the safe return of the child to the child\u8217\'3fs home. If the court determines such services are needed, the court shall order the services to be provided. The court shall advise the parties that failure to identify a deficiency in services or to request additional services may preclude the party from challenging the sufficiency of the services in a termination of parent-child relationship proceeding.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When the dispositional hearing is concluded the court shall make the least restrictive disposition appropriate considering all the circumstances of the case. The dispositions which may be entered under }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ are listed in }}}{{\f5\fs18\hyphpar0\qj{sections 232.100 through 232.102}}}{{\f5\fs18\hyphpar0\qj{ in order from least to most restrictive.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court shall make and file written findings as to its reason for the disposition.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, \'a7232.31; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7232.99}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1190, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1062, \'a794}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1063, \'a789}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.58}}}{{\f5\fs12\hyphpar0\qj{, 232.95}}}{{\f5\fs12\hyphpar0\qj{, 232.104}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.100}}}{\*\bkmkstart stylerid1_2E8_2E7_2E18_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E7_2E18_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Suspended judgment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{After the dispositional hearing the court may enter an order suspending judgment and continuing the proceedings subject to terms and conditions imposed to assure the proper care and protection of the child. Such terms and conditions may include the supervision of the child and of the parent, guardian, or custodian by the department, juvenile court office, or other appropriate agency designated by the court. The maximum duration of any term or condition of a suspended judgment shall be twelve months unless the court finds at a hearing held during the last month of that period that exceptional circumstances require an extension of the term or condition for an additional six months.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7232.100}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 96, \'a7157, 159}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7620}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.99}}}{{\f5\fs12\hyphpar0\qj{, 232.103}}}{{\f5\fs12\hyphpar0\qj{, 232.117}}}{{\f5\fs12\hyphpar0\qj{, 232.127}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.101}}}{\*\bkmkstart stylerid1_2E8_2E7_2E19_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E7_2E19_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Retention of custody by parent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{After the dispositional hearing, the court may enter an order permitting the child\u8217\'3fs parent, guardian, or custodian at the time of the filing of the petition to retain custody of the child subject to terms and conditions which the court prescribes to assure the proper care and protection of the child. Such terms and conditions may include supervision of the child and the parent, guardian, or custodian by the department, juvenile court office, or other appropriate agency which the court designates. Such terms and conditions may also include the provision or acceptance by the parent, guardian, or custodian of special treatment or care which the child needs for the child\u8217\'3fs physical or mental health. If the parent, guardian, or custodian fails to provide the treatment or care, the court may order the department or some other appropriate state agency to provide such care or treatment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The duration of any period of supervision or other terms or conditions shall be for an initial period of no more than twelve months and the court, at the expiration of that period, upon a hearing and for good cause shown, may make not more than two successive extensions of such supervision or other terms or conditions of up to twelve months each.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a7254-a20, 2708; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{3637;}}}{ C46, 50, 54, 58, 62, \'a7232.21; C66, 71, 73, 75, 77, \'a7232.33; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7232.101}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 96, \'a7157, 159}}}{; }{{\f5\fs18\hyphpar0\qj{97 Acts, ch 99, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7621}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.99}}}{{\f5\fs12\hyphpar0\qj{, 232.103}}}{{\f5\fs12\hyphpar0\qj{, 232.117}}}{{\f5\fs12\hyphpar0\qj{, 232.127}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.101A}}}{\*\bkmkstart stylerid1_2E8_2E7_2E2_30_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E7_2E2_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Appointment of guardian.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{After a dispositional hearing the court may close the child in need of assistance case and appoint a guardian pursuant to sections }}}{{\f5\fs18\hyphpar0\qj{232D.308}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{232D.401}}}{{\f5\fs18\hyphpar0\qj{ if all of the following conditions are met:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person receiving guardianship meets the definition of custodian in }}}{{\f5\fs18\hyphpar0\qj{section 232.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person receiving guardianship has assumed responsibility for the child prior to filing of the petition under }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ and has maintained placement of the child since the filing of the petition under }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The parent of the child does not appear at the dispositional hearing, or the parent appears at the dispositional hearing, does not object to the transfer of guardianship, and agrees to waive the requirement for making reasonable efforts as defined in }}}{{\f5\fs18\hyphpar0\qj{section 232.102A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the court appoints a guardian pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, the court may close the child in need of assistance case. The court shall inform the proposed guardian of the guardian\u8217\'3fs reporting duties under }}}{{\f5\fs18\hyphpar0\qj{section 232D.501}}}{{\f5\fs18\hyphpar0\qj{ and other duties under }}}{{\f5\fs18\hyphpar0\qj{chapter 232D}}}{{\f5\fs18\hyphpar0\qj{. The court shall direct the clerk of court, once the proposed guardian has filed an oath of office and identification, to issue letters of appointment for guardianship. }}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2014 Acts, ch 1048, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 56, \'a730, 44, 45}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1062, \'a794}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 86, \'a760}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.99}}}{{\f5\fs12\hyphpar0\qj{, 232.103}}}{{\f5\fs12\hyphpar0\qj{, 232.127}}}{{\f5\fs12\hyphpar0\qj{, 232D.201}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 1, paragraph c amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.102}}}{\*\bkmkstart stylerid1_2E8_2E7_2E21_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E7_2E21_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Transfer of legal custody of child and placement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{After a dispositional hearing, the court may enter an order transferring the legal custody of the child to a parent of the child. If the court finds that custody with either of the child\u8217\'3fs parents is not in the child\u8217\'3fs best interests, the child\u8217\'3fs custody shall be transferred to the department for placement of the child in any of the following categories in the following order of priority: }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An adult relative of the child including but not limited to adult siblings and parents of siblings. }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A fictive kin.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any other suitable placement identified by the child\u8217\'3fs relatives.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An individual licensee or an approved kinship caregiver under }}}{{\f5\fs18\hyphpar0\qj{chapter 237}}}{{\f5\fs18\hyphpar0\qj{. If the child is placed with an individual licensee or an approved kinship caregiver, the department shall assign decision-making authority to the individual licensee or approved kinship caregiver for the purpose of applying the reasonable and prudent parent standard during the child\u8217\'3fs placement.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A group care facility, shelter care facility, or other residential treatment facility.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the court places custody of the child with the department pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the court may identify a category listed in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ for placement of the child, but the department shall have the authority to select the specific person or facility within that category for placement, subject to court review at the request of an interested party.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court shall give deference to the department\u8217\'3fs decision for placement of a child. A party opposed to the department\u8217\'3fs placement of a child shall have the burden to prove the department failed to act in the child\u8217\'3fs best interests by unreasonably or irresponsibly failing to discharge its duties in selecting a suitable placement for the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A court shall not order placement of a child in a category identified in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (2), (3), (4), or (5) without a specific finding that placement with an adult relative is not in the child\u8217\'3fs best interests and providing reasons for the court\u8217\'3fs finding. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the child is fourteen years of age or older, the order shall specify the services needed to assist the child in preparing for the transition from foster care to adulthood. If the child has a case permanency plan, the court shall consider the written transition plan of services and needs assessment developed for the child\u8217\'3fs case permanency plan. If the child does not have a case permanency plan containing the transition plan and needs assessment at the time the order is entered, the written transition plan and needs assessment shall be developed and submitted for the court\u8217\'3fs consideration no later than six months from the date of the transfer order. The court shall modify the initial transfer order as necessary to specify the services needed to assist the child in preparing for the transition from foster care to adulthood. If the transition plan identifies services or other support needed to assist the child when the child becomes an adult and the court deems it to be beneficial to the child, the court may authorize the individual who is the child\u8217\'3fs guardian ad litem or court appointed special advocate to continue a relationship with and provide advice to the child for a period of time beyond the child\u8217\'3fs eighteenth birthday.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court shall not order group foster care placement of the child which is a charge upon the state unless the group foster care meets the requirements established by the department by rule.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{After a dispositional hearing and upon the request of the department, the court may enter an order appointing the department as the guardian of an unaccompanied refugee child or of a child without parent or guardian.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Whenever possible the court should permit the child to remain at home with the child\u8217\'3fs parent, guardian, or custodian. Custody of the child should not be transferred unless the court finds there is clear and convincing evidence of any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child cannot be protected from physical abuse without transfer of custody.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child cannot be protected from some harm which would justify the adjudication of the child as a child in need of assistance and an adequate placement is available.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In order to transfer custody of the child under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, the court must make a determination that continuation of the child in the child\u8217\'3fs home would be contrary to the welfare of the child, and shall identify the reasonable efforts that have been made. The court\u8217\'3fs determination regarding continuation of the child in the child\u8217\'3fs home, and regarding reasonable efforts, including those made to prevent removal and those made to finalize any permanency plan in effect, as well as any determination by the court that reasonable efforts are not required, must be made on a case-by-case basis. The grounds for each determination must be explicitly documented and stated in the court order. However, preserving the safety of the child is the paramount consideration. If imminent danger to the child\u8217\'3fs life or health exists at the time of the court\u8217\'3fs consideration, the determinations otherwise required under this paragraph shall not be a prerequisite for an order for removal of the child. If the court transfers custody of the child, unless the court waives the requirement for making reasonable efforts or otherwise makes a determination that reasonable efforts are not required, reasonable efforts shall be made to make it possible for the child to safely return to the family\u8217\'3fs home.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child shall not be placed in the state training school.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In any order transferring custody to the department or an agency, or in orders pursuant to a custody order, the court shall specify the nature and category of disposition which will serve the best interests of the child, and shall prescribe the means by which the placement shall be monitored by the court. If the court orders the transfer of the custody of the child to the department or other agency for placement, the department or agency shall submit a case permanency plan to the court and shall make every reasonable effort to return the child to the child\u8217\'3fs home as quickly as possible consistent with the best interests of the child. When the child is not returned to the child\u8217\'3fs home and if the child has been previously placed in a licensed foster care facility, the department or agency shall consider placing the child in the same licensed foster care facility. If the court orders the transfer of custody to a parent who does not have physical care of the child, other relative, or other suitable person, the court may direct the department or other agency to provide services to the child\u8217\'3fs parent, guardian, or custodian in order to enable them to resume custody of the child. If the court orders the transfer of custody to the department or to another agency for placement in group foster care, the department or agency shall make every reasonable effort to place the child in the least restrictive, most family-like, and most appropriate setting available, and in close proximity to the parents\u8217\'3f home, consistent with the child\u8217\'3fs best interests and special needs, and shall consider the placement\u8217\'3fs proximity to the school in which the child is enrolled at the time of placement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any order transferring custody to the department or an agency shall include a statement informing the child\u8217\'3fs parent that the consequences of a permanent removal may include the termination of the parent\u8217\'3fs rights with respect to the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An agency, facility, institution, or person to whom custody of the child has been transferred pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall file a written report with the court at least every six months concerning the status and progress of the child. The court shall hold a periodic dispositional review hearing for each child in placement pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ in order to determine whether the child should be returned home, an extension of the placement should be made, a permanency hearing should be held, or a termination of the parent-child relationship proceeding should be instituted. The placement shall be terminated and the child returned to the child\u8217\'3fs home if the court finds by a preponderance of the evidence that the child will not suffer harm in the manner specified in }}}{{\f5\fs18\hyphpar0\qj{section 232.96A}}}{{\f5\fs18\hyphpar0\qj{. If the placement is extended, the court shall determine whether additional services are necessary to facilitate the return of the child to the child\u8217\'3fs home, and if the court determines such services are needed, the court shall order the provision of such services. When the child is not returned to the child\u8217\'3fs home and if the child has been previously placed in a licensed foster care facility, the department or agency responsible for the placement of the child shall consider placing the child in the same licensed foster care facility.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The initial dispositional review hearing shall not be waived or continued beyond six months after the date of the dispositional hearing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subsequent dispositional review hearings shall not be waived or continued beyond twelve months after the date of the most recent dispositional review hearing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, a hearing held pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 232.103}}}{{\f5\fs18\hyphpar0\qj{ satisfies the requirements for initial dispositional review or subsequent permanency hearing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Unless prohibited by court order or the department or juvenile court services finds that allowing the visitation would not be in the child\u8217\'3fs best interests, the department or juvenile court services may authorize reasonable visitation between the child and the child\u8217\'3fs adult relative or a fictive kin.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any provision to the contrary, transfer of legal custody and placement of a newborn infant for whom physical custody was relinquished pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 233.2}}}{{\f5\fs18\hyphpar0\qj{ shall be determined in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapter 233}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a7254-a20, -a23, 2708, 2709; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{3637, 3646, 3647;}}}{ C46, 50, 54, 58, 62, \'a7232.21, 232.27, 232.28; C66, 71, 73, 75, 77, \'a7232.33; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7232.102}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 11, \'a717}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1260, \'a723}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 96, \'a7157, 159}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1279, \'a716 \u8211\'3f 18}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 173, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 159, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1134, \'a752}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1249, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1239, \'a710, 11}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 232, \'a77, 8}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1229, \'a75}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{; }{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/92/CH1004.pdf" }{\fldrslt \f5 \fs18{{\f5\fs18\hyphpar0\qj\cf5{92 Acts, 1st Ex, ch 1004, \'a72}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 67, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 99, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1190, \'a711 \u8211\'3f 17}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1067, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 24, \'a740}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 135, \'a717 \u8211\'3f 19}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1081, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 117, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1116, \'a78 \u8211\'3f 10}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 172, \'a76, 9}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 218, \'a7114}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1098, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 41, \'a7263}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1092, \'a752}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1063, \'a714, 15}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 54, \'a731}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 100, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1062, \'a794}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1098, \'a745 \u8211\'3f 48, 80}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7622}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 46, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 140, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 135, \'a77}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.99}}}{{\f5\fs12\hyphpar0\qj{, 232.103}}}{{\f5\fs12\hyphpar0\qj{, 232.104}}}{{\f5\fs12\hyphpar0\qj{, 232.116}}}{{\f5\fs12\hyphpar0\qj{, 232.117}}}{{\f5\fs12\hyphpar0\qj{, 232.127}}}{{\f5\fs12\hyphpar0\qj{, 234.35}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Copy of dispositional order under subsection 8 to be submitted to foster care review boards; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/84/CH1279.pdf" }{\fldrslt \cf5 \f5 \fs12{{84 Acts, ch 1279, \'a742}}}}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 1, paragraph a, subparagraph (4) amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.102A}}}{\*\bkmkstart stylerid1_2E8_2E7_2E22_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E7_2E22_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Reasonable efforts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fReasonable efforts\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the efforts made to preserve and unify a family prior to the out-of-home placement of a child in foster care or to eliminate the need for removal of the child or make it possible for the child to safely return to the family\u8217\'3fs home. Reasonable efforts include but are not limited to giving consideration, if appropriate, to interstate placement of a child in the permanency planning decisions involving the child and giving consideration to in-state and out-of-state placement options at a permanency hearing and when using concurrent planning. If returning the child to the family\u8217\'3fs home is not appropriate or not possible, reasonable efforts shall include the efforts made in a timely manner to finalize a permanency plan for the child. A child\u8217\'3fs health and safety shall be the paramount concern in making reasonable efforts. Reasonable efforts may include but are not limited to family-centered services, if the child\u8217\'3fs safety in the home can be maintained during the time the services are provided. In determining whether reasonable efforts have been made, the court shall consider all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The type, duration, and intensity of services or support offered or provided to the child and the child\u8217\'3fs family. If family-centered services were not provided, the court record shall enumerate the reasons the services were not provided, including but not limited to whether the services were not available, not accepted by the child\u8217\'3fs family, judged to be unable to protect the child and the child\u8217\'3fs family during the time the services would have been provided, judged to be unlikely to be successful in resolving the problems which would lead to removal of the child, or other services were found to be more appropriate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The relative risk to the child of remaining in the child\u8217\'3fs home versus removal of the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fFamily-centered services\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means services and other support intended to safely maintain a child with the child\u8217\'3fs family or with an adult relative, to safely and in a timely manner return a child to the home of the child\u8217\'3fs parent or relative, or to promote achievement of concurrent planning goals by identifying and helping the child secure placement for adoption, with a guardian, or with other alternative permanent family connections. Family-centered services include services adapted to the individual needs of a family in regard to the specific services and other support provided to the child\u8217\'3fs family and the intensity and duration of service delivery and services intended to preserve a child\u8217\'3fs connections to the child\u8217\'3fs neighborhood, community, and family and to improve the overall capacity of the child\u8217\'3fs family to provide for the needs of the children in the family.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Family interactions shall continue regardless of a parent\u8217\'3fs failure to comply with the requirements of a court order or the department unless a court finds that substantial evidence exists that the family interactions, whether supervised or unsupervised, would pose a serious risk of physical or emotional harm to the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The performance of reasonable efforts to place a child for adoption or with a guardian may be made concurrently with making reasonable efforts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the court determines by clear and convincing evidence that aggravated circumstances exist supported by written findings of fact based upon evidence in the record, the court may waive the requirement for making reasonable efforts. The existence of aggravated circumstances is indicated by any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The parent has abandoned the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court finds the circumstances described in }}}{{\f5\fs18\hyphpar0\qj{section 232.116, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fi\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, are applicable to the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The parent\u8217\'3fs parental rights have been terminated under }}}{{\f5\fs18\hyphpar0\qj{section 232.116}}}{{\f5\fs18\hyphpar0\qj{ or involuntarily terminated by an order of a court of competent jurisdiction in another state with respect to another child who is a member of the same family, and there is clear and convincing evidence to show that the offer or receipt of services would not be likely within a reasonable period of time to correct the conditions which led to the child\u8217\'3fs removal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The parent has been convicted of the murder of another child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The parent has been convicted of the voluntary manslaughter of another child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The parent has been convicted of aiding or abetting, attempting, conspiring in, or soliciting the commission of the murder or voluntary manslaughter of another child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The parent has been convicted of a felony assault which resulted in serious bodily injury to the child or another child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prior services the state provided to the family shall not be considered in making a determination as to whether a waiver of reasonable efforts is appropriate.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2022 Acts, ch 1098, \'a749}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 23, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 86, \'a761}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.2}}}{{\f5\fs12\hyphpar0\qj{, 232.101A}}}{{\f5\fs12\hyphpar0\qj{, 232.104}}}{{\f5\fs12\hyphpar0\qj{, 232.111}}}{{\f5\fs12\hyphpar0\qj{, 232B.5}}}{{\f5\fs12\hyphpar0\qj{, 233.2}}}{{\f5\fs12\hyphpar0\qj{, 234.6}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 2 amended}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 3 amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.103}}}{\*\bkmkstart stylerid1_2E8_2E7_2E23_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E7_2E23_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Termination, modification, vacation, and substitution of dispositional order.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At any time prior to expiration of a dispositional order and upon the motion of an authorized party or upon its own motion as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the court may terminate the order and discharge the child, modify the order, or vacate the order and make a new order.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The following persons shall be authorized to file a motion to terminate, modify, or vacate and substitute a dispositional order:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child\u8217\'3fs parent, guardian, or custodian, except that such motion may be filed by that person not more often than once every sixty days except with leave of court for good cause shown.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child\u8217\'3fs guardian ad litem.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person supervising the child pursuant to a dispositional order.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An agency, facility, institution, or person to whom legal custody has been transferred pursuant to a dispositional order.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county attorney.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A change in the level of care for a child who is subject to a dispositional order for out-of-home placement requires modification of the dispositional order. A hearing shall be held on a motion to terminate or modify a dispositional order except that a hearing on a motion to terminate or modify an order may be waived upon agreement by all parties. Reasonable notice of the hearing shall be given to the parties. The hearing shall be conducted in accordance with the procedure established for dispositional hearings under }}}{{\f5\fs18\hyphpar0\qj{section 232.50, subsection 3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court may modify a dispositional order, vacate and substitute a dispositional order, or terminate a dispositional order and release the child if the court finds that any of the following circumstances exist:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The purposes of the order have been accomplished and the child is no longer in need of supervision, care, or treatment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The purposes of the order cannot reasonably be accomplished.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The efforts made to effect the purposes of the order have been unsuccessful and other options to effect the purposes of the order are not available.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The purposes of the order have been sufficiently accomplished and the continuation of supervision, care, or treatment is unjustified or unwarranted.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court may modify or vacate an order for good cause shown provided that where the request to modify or vacate is based on the child\u8217\'3fs alleged failure to comply with the conditions or terms of the order, the court may modify or vacate the order only if it finds that there is clear and convincing evidence that the child violated a material and reasonable condition or term of the order.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the court vacates the order it may make any other order in accordance with and subject to the provisions of }}}{{\f5\fs18\hyphpar0\qj{sections 232.100 through 232.102}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7232.103}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1239, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 135, \'a720}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 117, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1154, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1021, \'a751}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 54, \'a772}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 100, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1062, \'a734}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1063, \'a790}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1098, \'a750}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.99}}}{{\f5\fs12\hyphpar0\qj{, 232.102}}}{{\f5\fs12\hyphpar0\qj{, 232.104}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.103A}}}{\*\bkmkstart stylerid1_2E8_2E7_2E24_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E7_2E24_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Transfer of jurisdiction related to child in need of assistance case }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ bridge order.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The juvenile court may close a child in need of assistance case by transferring jurisdiction over the child\u8217\'3fs custody, physical care, and visitation to the district court through a bridge order, if all of the following criteria are met:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child has been adjudicated a child in need of assistance in an active juvenile court case, and a dispositional order in that case is in place.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Paternity of the child has been legally established by one of the methods enumerated in }}}{{\f5\fs18\hyphpar0\qj{section 252A.3, subsection 10}}}{{\f5\fs18\hyphpar0\qj{, or by operation of law due to the established father\u8217\'3fs marriage to the mother at the time of conception, birth, or at any time during the period between conception and birth of the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child is safely placed by the juvenile court with a parent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{There is not a current district court order for custody in place.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The juvenile court has determined that the child in need of assistance case can safely close once orders for custody, physical care, and visitation are entered by the district court.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A parent qualified for a court-appointed attorney in the juvenile court case.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When the criteria specified in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ are met, any party to a child in need of assistance proceeding in juvenile court may file a motion with the juvenile court for a bridge order under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{. Such motion shall be set for hearing by the juvenile court no less than thirty days nor more than ninety days from the date of filing the motion. The juvenile court, on its own motion, may set a hearing on the issue of a bridge order if such hearing is set no less than thirty days from the date of notice to the parties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The juvenile court shall designate the petitioner and respondent for the purposes of the bridge order. A bridge order shall only address matters of custody, physical care, and visitation. All other matters, including child support, shall be filed by separate petition or by action of child support services, and shall be subject to existing applicable statutory provisions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon transferring jurisdiction from the juvenile court to the district court, the clerk of court shall docket the case. Filing fees and other court costs shall not be assessed against the parties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The district court shall take judicial notice of the juvenile file in any hearing related to the case. Records contained in the district court case file that were copied or transferred from the juvenile court file concerning the case shall be subject to }}}{{\f5\fs18\hyphpar0\qj{section 232.147}}}{{\f5\fs18\hyphpar0\qj{ and other confidentiality provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ for cases not involving juvenile delinquency, and shall be disclosed, upon request, to child support services without a court order.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Following the issuance of a bridge order, a party may file a petition in district court for modification of the bridge order for custody, physical care, or visitation. If the petition for modification is filed within one year of the filing date of the bridge order, the party requesting modification shall not be required to demonstrate a substantial change of circumstances but instead shall demonstrate that such modification is in the best interest of the child. If a petition for modification is filed within one year of the filing date of the bridge order, filing fees and other court costs shall not be assessed against the parties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Nothing in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be construed to require appointment of counsel for the parties in the district court action.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A court-appointed attorney shall be paid by the state public defender\u8217\'3fs office for work done relating to a bridge order.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2015 Acts, ch 43, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1098, \'a751}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7623}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 123, \'a73}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232D.201}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.103B}}}{\*\bkmkstart stylerid1_2E8_2E7_2E25_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E7_2E25_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Child in need of assistance cases }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ transfer of jurisdiction pursuant to bridge modification order.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A juvenile court may close a child in need of assistance case by returning jurisdiction of the child\u8217\'3fs custody to the district court through an order modifying issues of legal custody, physical care, and parenting time if all of the following criteria have been met:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child has been adjudicated a child in need of assistance in an active juvenile court case, and a permanency order is in place in that case.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Legal paternity has been established for the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child is safely unified with a parent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The district court has issued an order concerning custody, physical care, and parenting time regarding the child and the order is in place at the time of the filing of the child in need of assistance petition.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The juvenile court has determined that the child in need of assistance case can safely close when the modified district court order for custody, physical care, and parenting time is in place.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Either parent has qualified for a court-appointed attorney in the juvenile case.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When the criteria specified in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ are met, any party to a child in need of assistance proceeding in juvenile court may file a motion with the juvenile court for a bridge modification order as described in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{. Such motion shall be set for hearing by the juvenile court no less than thirty days but not more than ninety days from the date of filing of the motion. The juvenile court, on its own motion, may set a hearing on the issue of the bridge modification order if such hearing is set no less than thirty days from the date of notice to the parties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Bridge modification orders shall only address legal custody, physical care, and parenting time. All other matters, including child support, shall be filed by separate petition in district court, and shall be subject to existing statutory requirements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon transferring jurisdiction, the clerk of court shall docket the bridge modification order in the current district court custodial order court file. The clerk of court shall not assess any filing fees or other court costs. The juvenile court shall follow the previously designated listing of the parties as petitioner and as respondent for the purposes of the bridge modification order.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The district court shall take judicial notice of the current child in need of assistance case related to the bridge modification order, as well as any prior child in need of assistance cases relating to any prior bridge orders in any hearing related to the case. Records that are copied or transferred from the juvenile court file shall be subject to }}}{{\f5\fs18\hyphpar0\qj{section 232.147}}}{{\f5\fs18\hyphpar0\qj{ and other confidentiality provisions of this chapter for cases not involving juvenile delinquency. Such documents shall be disclosed, upon request, to child support services without a court order, subject to any statutory confidentiality provisions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Nothing in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be construed to require the appointment of counsel for the parties in the district court action.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2023 Acts, ch 19, \'a71358}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 132, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1043, \'a7109}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.104}}}{\*\bkmkstart stylerid1_2E8_2E7_2E26_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E7_2E26_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Permanency hearing }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ permanency order }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ subsequent proceedings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The time for the initial permanency hearing for a child subject to out-of-home placement shall be the earlier of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For a temporary removal order entered under }}}{{\f5\fs18\hyphpar0\qj{section 232.78}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{232.95}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{232.96}}}{{\f5\fs18\hyphpar0\qj{, for a child who was removed without a court order under }}}{{\f5\fs18\hyphpar0\qj{section 232.79}}}{{\f5\fs18\hyphpar0\qj{, or for an order entered under }}}{{\f5\fs18\hyphpar0\qj{section 232.102}}}{{\f5\fs18\hyphpar0\qj{, for which the court has not waived reasonable efforts requirements, the permanency hearing shall be held within twelve months of the date the child was removed from the home.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For an order entered under }}}{{\f5\fs18\hyphpar0\qj{section 232.102}}}{{\f5\fs18\hyphpar0\qj{, for which the court has waived reasonable efforts requirements under }}}{{\f5\fs18\hyphpar0\qj{section 232.102A, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, the permanency hearing shall be held within thirty days of the date the requirements were waived.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The permanency hearing may be held concurrently with a hearing under }}}{{\f5\fs18\hyphpar0\qj{section 232.103}}}{{\f5\fs18\hyphpar0\qj{ to review, modify, substitute, vacate, or terminate a dispositional order.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reasonable notice of a permanency hearing shall be provided to the parties. A permanency hearing shall be conducted in substantial conformance with the provisions of }}}{{\f5\fs18\hyphpar0\qj{section 232.99}}}{{\f5\fs18\hyphpar0\qj{. During the hearing, the court shall consider the child\u8217\'3fs need for a secure and permanent placement in light of any permanency plan or evidence submitted to the court and the reasonable efforts made concerning the child. Upon completion of the hearing, the court shall enter written findings and make a determination identifying a primary permanency goal for the child. If a permanency plan is in effect at the time of the hearing, the court shall also make a determination as to whether reasonable progress is being made in achieving the permanency goal and complying with the other provisions of that permanency plan.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{After a permanency hearing the court shall do one of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Enter an order pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 232.102}}}{{\f5\fs18\hyphpar0\qj{ to return the child to the child\u8217\'3fs home.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Enter an order pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 232.102}}}{{\f5\fs18\hyphpar0\qj{ to continue placement of the child for an additional six months at which time the court shall hold a hearing to consider modification of its permanency order. An order entered under this paragraph shall enumerate the specific factors, conditions, or expected behavioral changes which comprise the basis for the determination that the need for removal of the child from the child\u8217\'3fs home will no longer exist at the end of the additional six-month period.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Direct the county attorney or the attorney for the child to institute proceedings to terminate the parent-child relationship.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Enter an order, pursuant to findings required by }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{, to do one of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Transfer sole custody of the child from one parent to another parent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Transfer guardianship and custody of the child to an adult relative, a fictive kin, or another suitable person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Transfer custody of the child to a suitable person for the purpose of long-term care.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the child is sixteen years of age or older and the department has documented to the court\u8217\'3fs satisfaction a compelling reason for determining that an order under the other subparagraphs of this paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ would not be in the child\u8217\'3fs best interest, order another planned permanent living arrangement for the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the court enters an order for another planned permanent living arrangement pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the court shall do all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Ask the child about the child\u8217\'3fs desired permanency outcome and make a judicial determination that another planned permanent living arrangement is the best permanency plan for the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Require the department to do all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Document the efforts to place a child permanently with a parent, relative, or in a guardianship or adoptive placement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Document that the planned permanent living arrangement is the best permanency plan for the child and compelling reasons why it is not in the child\u8217\'3fs best interest to be placed permanently with a parent, relative, or in a guardianship or adoptive placement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Document all of the following at the permanency hearing and the six-month periodic review:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The steps the department is taking to ensure that the planned permanent living arrangement follows the reasonable and prudent parent standard.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Whether the child has regular opportunities to engage in age-appropriate or developmentally appropriate activities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prior to entering a permanency order pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, convincing evidence must exist showing that all of the following apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A termination of the parent-child relationship would not be in the best interest of the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Services were offered to the child\u8217\'3fs family to correct the situation which led to the child\u8217\'3fs removal from the home.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child cannot be returned to the child\u8217\'3fs home.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A court shall apply the priority of placement requirements of }}}{{\f5\fs18\hyphpar0\qj{section 232.102, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, when entering a permanency order pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any permanency order may provide restrictions upon the contact between the child and the child\u8217\'3fs parent or parents, consistent with the best interest of the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{With respect to a dispositional order providing for transfer of custody of a child and siblings to the department or other agency for placement for which the court has suspended or terminated sibling visitation or interaction, when a review is made under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ the court shall consider whether the visitation or interaction can be safely resumed and may modify the suspension or termination as appropriate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subsequent to the entry of a permanency order pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the child shall not be returned to the care, custody, or control of the child\u8217\'3fs parent or parents, over a formal objection filed by the child\u8217\'3fs attorney or guardian ad litem, unless the court finds by a preponderance of the evidence, that returning the child to such custody would be in the best interest of the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Following an initial permanency hearing and the entry of a permanency order which places a child in the custody or guardianship of another person or agency, the court shall retain jurisdiction and annually review the order to ascertain whether the best interest of the child is being served. When the order places the child in the custody of the department for the purpose of long-term foster care placement in a facility, the review shall be in a hearing that shall not be waived or continued beyond twelve months after the initial permanency hearing or the last permanency review hearing. Any modification shall be accomplished through a hearing procedure following reasonable notice. During the hearing, all relevant and material evidence shall be admitted and procedural due process shall be provided to all parties.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In lieu of the procedures specified in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the court may close the child in need of assistance case and may appoint a guardian pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 232D}}}{{\f5\fs18\hyphpar0\qj{. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any provision to the contrary, legal custody and placement of a newborn infant for whom physical custody was relinquished pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 233.2}}}{{\f5\fs18\hyphpar0\qj{ shall be determined in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapter 233}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{87 Acts, ch 159, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 229, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 182, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1190, \'a718, 19}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1067, \'a711, 12}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 135, \'a721, 22}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 67, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 172, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1143, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1063, \'a716, 17}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 54, \'a773}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 56, \'a731, 44, 45}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1098, \'a752, 53}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 46, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 66, \'a745}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.117}}}{{\f5\fs12\hyphpar0\qj{, 232D.201}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.105}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.106}}}{\*\bkmkstart stylerid1_2E8_2E7_2E28_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E7_2E28_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Terms and conditions on child\u8217\'3fs parent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If the court enters an order under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ which imposes terms and conditions on the child\u8217\'3fs parent, guardian, or custodian, the purpose of the terms and conditions shall be to assure the protection of the child. The order is subject to the following provisions:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The order shall state the reasons for and purpose of the terms and conditions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a parent, guardian, or custodian is required to have a chemical test of blood or urine for the purpose of determining the presence of an illegal drug, the test shall be a medically relevant test as defined in }}}{{\f5\fs18\hyphpar0\qj{section 232.73}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{95 Acts, ch 182, \'a79}}}{; }{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1092, \'a75}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.107}}}{\*\bkmkstart stylerid1_2E8_2E7_2E29_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E7_2E29_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Parent visitation.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2022 Acts, ch 1098, \'a790}}}{{\f5\fs18\hyphpar0\qj{.}}}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.108}}}{\*\bkmkstart stylerid1_2E8_2E7_2E3_30_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E7_2E3_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Sibling placement and ongoing interaction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the court orders the transfer of custody of a child and siblings to the department or other agency for placement under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, the department or other agency shall make reasonable efforts to place the child and siblings together whenever possible if such placement is in the best interests of each child. The requirement of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ remains applicable to custody transfer orders made at separate times provided the requirement will not jeopardize the stability of placements and is in the best interests of each child. The requirement of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ also applies in addition to efforts made to place the child with an adult relative.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the requirements of }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ apply but the siblings are not placed in the same placement together, the child\u8217\'3fs attorney or guardian ad litem shall provide the siblings with the reasons why and the efforts being made to facilitate such placement, or why making efforts for such placement is not appropriate. An explanation is not required if the ages or mental states of the siblings make such an explanation inappropriate. Unless visitation or ongoing interaction with siblings is suspended or terminated by the court, the department shall make reasonable efforts to provide for visitation or other ongoing interaction between the child and the child\u8217\'3fs siblings from the time of the child\u8217\'3fs out-of-home placement until the child returns home or is in a permanent placement. The department shall make reasonable efforts for such visitations or interactions to occur at least once every thirty days unless more frequent or less frequent visitation is ordered by the court based on the child\u8217\'3fs circumstances.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who wishes to assert a sibling relationship with a child who is subject to an order under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ for an out-of-home placement and to request visitation or other ongoing interaction with the child may file a motion or petition with the court with jurisdiction over the child. Unless the court determines it would not be in the child\u8217\'3fs best interests, upon finding that the person is a sibling of the child, the provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ providing for frequent visitation or other ongoing interaction between the siblings shall apply. Nothing in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is intended to provide or expand a right to counsel under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ beyond the right provided and persons specified in }}}{{\f5\fs18\hyphpar0\qj{sections 232.89}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{232.113}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the court determines by clear and convincing evidence that visitation or other ongoing interaction between a child and the child\u8217\'3fs siblings would be detrimental to the well-being of the child or a sibling, the court shall order the visitation or interaction to be suspended or terminated. The reasons for the determination shall be noted in the court order suspending or terminating the visitation or interaction and shall be explained to the child and the child\u8217\'3fs siblings, and to the parent, guardian, or custodian of the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The case permanency plan of a child who is subject to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall comply with all of the following, as applicable:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The plan shall document the efforts being made to provide for the child\u8217\'3fs frequent visitation or other ongoing interaction with the child\u8217\'3fs siblings from the time of the child\u8217\'3fs out-of-home placement until the child returns home or is in a permanent placement. The child\u8217\'3fs parent, guardian, or custodian may comment on the efforts as documented in the case permanency plan.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If at any point the court determines that the child\u8217\'3fs visitation or interaction with siblings would be detrimental to the child\u8217\'3fs well-being and visitation or interaction with siblings is suspended or terminated by the court, the determination shall be noted in the case permanency plan. If the court lifts the suspension or termination, the case permanency plan shall be revised to document the efforts to provide for visitation or interaction as required under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If one or more of the child\u8217\'3fs siblings are also subject to an order under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ for an out-of-home placement and the siblings are not placed in the same placement together, the plan shall document the reasons why and the efforts being made to facilitate such placement, or why making efforts for such placement is not appropriate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If an order is entered for termination of parental rights of a child who is subject to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, unless the court has suspended or terminated sibling visitation or interaction in accordance with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the department or child-placing agency shall do all of the following to facilitate frequent visitation or ongoing interaction between the child and siblings when the child is adopted or enters a permanent placement:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Include in the training provided to prospective adoptive parents information regarding the importance of sibling relationships to an adopted child and counseling methods for maintaining sibling relationships.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide prospective adoptive parents with information regarding the child\u8217\'3fs siblings. The address of a sibling\u8217\'3fs residence shall not be disclosed in the information unless authorized by court order for good cause shown.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Encourage prospective adoptive parents to plan for facilitating postadoption contact between the child and the child\u8217\'3fs siblings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any information regarding court-ordered or authorized sibling visitation, interaction, or contact shall be provided to the foster parent, relative caretaker, guardian, prospective adoptive parent, and child as soon as reasonably possible following the entry of the court order or authorization as necessary to facilitate the visitation or interaction.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 67, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1062, \'a794}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1098, \'a754}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.2}}}{{\f5\fs12\hyphpar0\qj{, 232.117}}}{{\f5\fs12\hyphpar0\qj{, 238.18}}}\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0{\f5\fs18\chcbpat2}\par}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER IV}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E9_2E2_2E2}{TERMINATION OF PARENT-CHILD RELATIONSHIP PROCEEDING}{\*\bkmkend stylerid1_2E9_2E2_2E2}\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a7232.2}}}{{\f5\fs12\qc{, 232.3A}}}{{\f5\fs12\qc{, 232.147}}}{{\f5\fs12\qc{, 600A.5}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.109}}}{\*\bkmkstart stylerid1_2E9_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Jurisdiction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The juvenile court shall have exclusive jurisdiction over proceedings under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ to terminate a parent-child relationship and all parental rights with respect to a child. No such termination shall be ordered except under the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ if the court has made an order concerning the child pursuant to the provisions of }{{\f5\fs18\hyphpar0\qj{subchapter III }}}{ and the order is in force at the time a petition for termination is filed.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7232.109}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2020 Acts, ch 1062, \'a735}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.110}}}{\*\bkmkstart stylerid1_2E9_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Venue.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Venue for termination proceedings under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall be in the judicial district where the child is found or the judicial district where the child resides except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a court has made an order concerning the child pursuant to the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and the order is still in force at the time the termination petition is filed, such court shall hear and adjudicate the case unless the court transfers the case.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The judge may transfer the case to the juvenile court of any county having venue in accordance with the provisions of }}}{{\f5\fs18\hyphpar0\qj{section 232.62}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7232.110}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.111}}}{\*\bkmkstart stylerid1_2E9_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Petition.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A child\u8217\'3fs guardian, guardian ad litem, or custodian, the department, a juvenile court officer, or the county attorney may file a petition for termination of the parent-child relationship and parental rights with respect to a child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Unless any of the circumstances described in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ exist, the county attorney shall file a petition for termination of the parent-child relationship and parental rights with respect to a child or if a petition has been filed, join in the petition, under any of the following circumstances:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child has been placed in foster care for fifteen months of the most recent twenty-two-month period. The petition shall be filed by the end of the child\u8217\'3fs fifteenth month of foster care placement.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A court has determined aggravated circumstances exist and has waived the requirement for making reasonable efforts, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 232.102A}}}{{\f5\fs18\hyphpar0\qj{, because the court has found the circumstances described in }}}{{\f5\fs18\hyphpar0\qj{section 232.116, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fi\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, are applicable to the child.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child is less than twelve months of age and has been judicially determined to have been abandoned or the child is a newborn infant whose parent has voluntarily released custody of the child in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapter 233}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The parent has been convicted of the murder or the voluntary manslaughter of another child.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The parent has been convicted of aiding or abetting, attempting, conspiring in, or soliciting the commission of the murder or voluntary manslaughter of another child.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The parent has been convicted of a felony assault which resulted in serious bodily injury of the child or of another child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If any of the following conditions exist, the county attorney is not required to file a petition or join in an existing petition as provided in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At the option of the department or by order of the court, the child is being cared for by a relative.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department or a state agency has documented in the child\u8217\'3fs case permanency plan provided or available to the court a compelling reason for determining that filing the petition would not be in the best interest of the child. A compelling reason shall include but is not limited to documentation in the child\u8217\'3fs case permanency plan indicating it is reasonably likely the completion of the services being received in accordance with the permanency plan will eliminate the need for removal of the child or make it possible for the child to safely return to the family\u8217\'3fs home within six months.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department has not provided the child\u8217\'3fs family, consistent with the time frames outlined in the child\u8217\'3fs case permanency plan, with those services the state deems necessary for the safe return of the child to the child\u8217\'3fs home, and the limited extension of time necessary to complete the services is clearly documented in the case permanency plan.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department, juvenile court officer, county attorney or judge may authorize any competent person having knowledge of the circumstances to file a termination petition with the clerk of the court without the payment of a filing fee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A petition for termination of parental rights shall include the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The legal name, age, and domicile, if any, of the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The names, residences, and domicile of any:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Living parents of the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Guardian of the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Custodian of the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Guardian ad litem of the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Petitioner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Person standing in the place of the parents of the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A plain statement of those facts and grounds specified in }}}{{\f5\fs18\hyphpar0\qj{section 232.116}}}{{\f5\fs18\hyphpar0\qj{ which indicate that the parent-child relationship should be terminated.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A plain statement explaining why the petitioner does not know any of the information required under paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A complete list of the services which have been offered to preserve the family and a statement specifying the services provided to address the reasons stated in any order for removal or in any dispositional or permanency order which did not return the child to the child\u8217\'3fs home.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The signature and verification of the petitioner.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7232.111}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 96, \'a7157, 159}}}{{\f5\fs18\hyphpar0\qj{; 83 Acts, ch 186, \'a710055, 10201}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 147, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1190, \'a720, 21}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 67, \'a78, 13}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 135, \'a725}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1050, \'a723}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1098, \'a755}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7624}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.112}}}{{\f5\fs12\hyphpar0\qj{, 233.2}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.112}}}{\*\bkmkstart stylerid1_2E9_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Notice \u8212\'3f service.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Persons listed in }}}{{\f5\fs18\hyphpar0\qj{section 232.111, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, shall be necessary parties to a termination of parent-child relationship proceeding and are entitled to receive notice and an opportunity to be heard, except that notice may be dispensed with in the case of any such person whose name or whereabouts the court determines is unknown and cannot be ascertained by reasonably diligent search. In addition to the persons who are necessary parties who may be parties under }}}{{\f5\fs18\hyphpar0\qj{section 232.111}}}{{\f5\fs18\hyphpar0\qj{, notice for any hearing under }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ shall be provided to the child\u8217\'3fs foster parent, an individual providing preadoptive care for the child, or a relative providing care for the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prior to the service of notice on the necessary parties, the juvenile court shall appoint a guardian ad litem for a child if the child does not have a guardian or guardian ad litem or if the interests of the guardian or guardian ad litem conflict with the interests of the child. Such guardian ad litem shall be a necessary party under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notice under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be served personally, sent by restricted certified mail, or sent by electronic mail or other electronic means with the consent of the party to be served, whichever is determined by the court to be the most effective means of notification. If the court determines that personal service is impracticable, the court may order service by publication. Such notice shall be made according to the rules of civil procedure relating to an original notice where not inconsistent with the provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. Notice by personal delivery and notice sent by electronic mail or other electronic means with the consent of the party to be served shall be served not less than seven days prior to the hearing on termination of parental rights. Notice by restricted certified mail shall be sent not less than fourteen days prior to the hearing on termination of parental rights. A notice by restricted certified mail which is refused by the necessary party given notice shall be sufficient notice to the party under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7232.112}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1190, \'a722}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 127, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1062, \'a794}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1098, \'a756}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.113}}}{\*\bkmkstart stylerid1_2E9_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Right to and appointment of counsel.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon the filing of a petition the parent identified in the petition shall have the right to counsel in connection with all subsequent hearings and proceedings. If the parent desires but is financially unable to employ counsel, the court shall appoint counsel.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon the filing of a petition the court shall appoint counsel for the child identified in the petition as a party to the proceedings. The same person may serve both as the child\u8217\'3fs counsel and as guardian ad litem.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7232.113}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.108}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.114}}}{\*\bkmkstart stylerid1_2E9_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Duties of county attorney.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fstate\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the general interest held by the people in the health, safety, welfare, and protection of all children living in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon the filing of a petition the county attorney shall represent the state in all adversary proceedings arising under }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ and shall present evidence in support of the petition.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{ If there is disagreement between the department and the county attorney regarding the appropriate action to be taken, the department may request that the state be represented by the attorney general in place of the county attorney. If the state is represented by the attorney general, the county attorney may continue to appear in the proceeding and may present the position of the county attorney regarding the appropriate action to be taken in the case.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county attorney and attorney general shall comply with the requirements of }}}{{\f5\fs18\hyphpar0\qj{chapter 232B}}}{{\f5\fs18\hyphpar0\qj{ and the federal }}}{{\f5\fs18\hyphpar0\qj{Indian Child Welfare Act, }}}{{\f5\fs18\hyphpar0\qj{Pub. L. No. 95-608}}}{{\f5\fs18\hyphpar0\qj{, when either }}}{{\f5\fs18\hyphpar0\qj{chapter 232B}}}{{\f5\fs18\hyphpar0\qj{ or the federal }}}{{\f5\fs18\hyphpar0\qj{Indian Child Welfare Act}}}{{\f5\fs18\hyphpar0\qj{ is determined to be applicable in any proceeding under }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{C81, \'a7232.114}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 230, \'a718}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 113, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 29, \'a753}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1062, \'a794}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.115}}}{\*\bkmkstart stylerid1_2E9_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Reporter required.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Stenographic notes or electronic or mechanical recordings shall be taken of all court hearings held pursuant to }{{\f5\fs18\hyphpar0\qj{this subchapter}}}{ unless waived by the parties. The child shall not be competent to waive the reporting requirement, but waiver may be made for the child by the child\u8217\'3fs counsel or guardian ad litem. Matters which must be reported under the provisions of }{{\f5\fs18\hyphpar0\qj{this section}}}{ shall be reported in the same manner as required in }{{\f5\fs18\hyphpar0\qj{section 624.9}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{C81, \'a7232.115}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2020 Acts, ch 1062, \'a794}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.116}}}{\*\bkmkstart stylerid1_2E9_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Grounds for termination.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{, the court may order the termination of both the parental rights with respect to a child and the relationship between the parent and the child on any of the following grounds:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The parents voluntarily and intelligently consent to the termination of parental rights and the parent-child relationship and for good cause desire the termination.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court finds that there is clear and convincing evidence that the child has been abandoned or deserted.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court finds that there is clear and convincing evidence that the child is a newborn infant whose parent has voluntarily released custody of the child in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapter 233}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court finds that both of the following have occurred:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court has previously adjudicated the child to be a child in need of assistance after finding the child to have been physically or sexually abused or neglected as the result of the acts or omissions of one or both parents, or the court has previously adjudicated a child who is a member of the same family to be a child in need of assistance after such a finding. This paragraph shall not be construed to require that a finding of sexual abuse or neglect requires a finding of a nonaccidental physical injury.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subsequent to the child in need of assistance adjudication, the parents were offered or received services to correct the circumstance which led to the adjudication, and the circumstance continues to exist despite the offer or receipt of services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court finds that all of the following have occurred:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child has been adjudicated a child in need of assistance pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 232.96}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child has been removed from the physical custody of the child\u8217\'3fs parents for a period of at least six consecutive months.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{There is clear and convincing evidence that the parents have not maintained significant and meaningful contact with the child during the previous six consecutive months and have made no reasonable efforts to resume care of the child despite being given the opportunity to do so. For the purposes of this subparagraph, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fsignificant and meaningful contact\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes but is not limited to the affirmative assumption by the parents of the duties encompassed by the role of being a parent. This affirmative duty, in addition to financial obligations, requires continued interest in the child, a genuine effort to complete the responsibilities prescribed in the case permanency plan, a genuine effort to maintain communication with the child, and requires that the parents establish and maintain a place of importance in the child\u8217\'3fs life.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court finds that all of the following have occurred:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child is four years of age or older.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child has been adjudicated a child in need of assistance pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 232.96}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child has been removed from the physical custody of the child\u8217\'3fs parents for at least twelve of the last eighteen months, or for the last twelve consecutive months and any trial period at home has been less than thirty days.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{There is clear and convincing evidence that at the present time the child cannot be returned to the custody of the child\u8217\'3fs parents as provided in }}}{{\f5\fs18\hyphpar0\qj{section 232.102}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court finds that all of the following have occurred:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child has been adjudicated a child in need of assistance pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 232.96}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court has terminated parental rights pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 232.117}}}{{\f5\fs18\hyphpar0\qj{ with respect to another child who is a member of the same family or a court of competent jurisdiction in another state has entered an order involuntarily terminating parental rights with respect to another child who is a member of the same family.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{There is clear and convincing evidence that the parent continues to lack the ability or willingness to respond to services which would correct the situation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{There is clear and convincing evidence that an additional period of rehabilitation would not correct the situation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court finds that all of the following have occurred:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child is three years of age or younger.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child has been adjudicated a child in need of assistance pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 232.96}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child has been removed from the physical custody of the child\u8217\'3fs parents for at least six months of the last twelve months, or for the last six consecutive months and any trial period at home has been less than thirty days.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{There is clear and convincing evidence that the child cannot be returned to the custody of the child\u8217\'3fs parents as provided in }}}{{\f5\fs18\hyphpar0\qj{section 232.102}}}{{\f5\fs18\hyphpar0\qj{ at the present time.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court finds that all of the following have occurred:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child meets the definition of child in need of assistance based on a finding of physical or sexual abuse or neglect as a result of the acts or omissions of one or both parents. This paragraph shall not be construed to require that a finding of sexual abuse or neglect requires a finding of a nonaccidental physical injury.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{There is clear and convincing evidence that the abuse or neglect posed a significant risk to the life of the child or constituted imminent danger to the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{There is clear and convincing evidence that the offer or receipt of services would not correct the conditions which led to the abuse or neglect of the child within a reasonable period of time.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court finds that both of the following have occurred:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child has been adjudicated a child in need of assistance pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 232.96}}}{{\f5\fs18\hyphpar0\qj{ and custody has been transferred from the child\u8217\'3fs parents for placement pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 232.102}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The parent has been imprisoned for a crime against the child, the child\u8217\'3fs sibling, or another child in the household, or the parent has been imprisoned and it is unlikely that the parent will be released from prison for a period of five or more years.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{k.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court finds that all of the following have occurred:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child has been adjudicated a child in need of assistance pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 232.96}}}{{\f5\fs18\hyphpar0\qj{ and custody has been transferred from the child\u8217\'3fs parents for placement pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 232.102}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The parent has a chronic mental illness and has been repeatedly institutionalized for mental illness, and presents a danger to self or others as evidenced by prior acts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{There is clear and convincing evidence that the parent\u8217\'3fs prognosis indicates that the child will not be able to be returned to the custody of the parent within a reasonable period of time considering the child\u8217\'3fs age and need for a permanent home.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{l.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court finds that all of the following have occurred:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child has been adjudicated a child in need of assistance pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 232.96}}}{{\f5\fs18\hyphpar0\qj{ and custody has been transferred from the child\u8217\'3fs parents for placement pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 232.102}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The parent has a severe substance use disorder as described by either of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The severe substance use disorder meets the definition for that term as defined in the most current edition of the diagnostic and statistical manual prepared by the American psychiatric association, and the parent presents a danger to self or others as evidenced by prior acts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The disorder is evidenced by continued and repeated use through the case, the parent\u8217\'3fs refusal to obtain a substance use disorder evaluation or treatment after given the opportunity to do so, and the parent presents a danger to self or others as evidenced by prior acts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{There is clear and convincing evidence that the parent\u8217\'3fs prognosis indicates that the child will not be able to be returned to the custody of the parent within a reasonable period of time considering the child\u8217\'3fs age and need for a permanent home.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{m.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court finds that both of the following have occurred:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child has been adjudicated a child in need of assistance pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 232.96}}}{{\f5\fs18\hyphpar0\qj{ after finding that the child has been physically or sexually abused or neglected as a result of the acts or omissions of a parent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The parent found to have physically or sexually abused or neglected the child has been convicted of a felony and imprisoned for physically or sexually abusing or neglecting the child, the child\u8217\'3fs sibling, or any other child in the household.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{n.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court finds that all of the following have occurred:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child has been adjudicated a child in need of assistance pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 232.96}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The parent has been convicted of child endangerment resulting in the death of the child\u8217\'3fs sibling, has been convicted of three or more acts of child endangerment involving the child, the child\u8217\'3fs sibling, or another child in the household, or has been convicted of child endangerment resulting in a serious injury to the child, the child\u8217\'3fs sibling, or another child in the household.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{There is clear and convincing evidence that the circumstances surrounding the parent\u8217\'3fs conviction for child endangerment would result in a finding of imminent danger to the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{o.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The parent has been convicted of a felony offense that is a sex offense against a minor as defined in }}}{{\f5\fs18\hyphpar0\qj{section 692A.101}}}{{\f5\fs18\hyphpar0\qj{, the parent is divorced from or was never married to the minor\u8217\'3fs other parent, and the parent is serving a minimum sentence of confinement of at least five years for that offense.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{p.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court finds there is clear and convincing evidence that the child was conceived as the result of sexual abuse as defined in }}}{{\f5\fs18\hyphpar0\qj{section 709.1}}}{{\f5\fs18\hyphpar0\qj{, and the biological parent against whom the sexual abuse was perpetrated requests termination of the parental rights of the biological parent who perpetrated the sexual abuse.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In considering whether to terminate the rights of a parent under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the court shall give primary consideration to the child\u8217\'3fs safety, to the best placement for furthering the long-term nurturing and growth of the child, and to the physical, mental, and emotional condition and needs of the child. This consideration may include any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Whether the parent\u8217\'3fs ability to provide the needs of the child is affected by the parent\u8217\'3fs mental capacity or mental condition or the parent\u8217\'3fs imprisonment for a felony.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For a child who has been placed in foster family care by a court or has been voluntarily placed in foster family care by a parent or by another person, whether the child has become integrated into the foster family to the extent that the child\u8217\'3fs familial identity is with the foster family, and whether the foster family is able and willing to permanently integrate the child into the foster family. In considering integration into a foster family, the court shall review the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The length of time the child has lived in a stable, satisfactory environment and the desirability of maintaining that environment and continuity for the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The reasonable preference of the child, if the court determines that the child has sufficient capacity to express a reasonable preference.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The relevant testimony or written statement that a foster parent, relative, or other individual with whom the child has been placed for preadoptive care or other care has a right to provide to the court.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court need not terminate the relationship between the parent and child if the court finds any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A relative has legal custody of the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child is over ten years of age and objects to the termination.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{There is clear and convincing evidence that the termination would be detrimental to the child at the time due to the closeness of the parent-child relationship.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It is necessary to place the child in a hospital, facility, or institution for care and treatment and the continuation of the parent-child relationship is not preventing a permanent family placement for the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The absence of a parent is due to the parent\u8217\'3fs admission or commitment to any institution, hospital, or health facility or due to active service in the state or federal armed forces.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, \'a7232.114; }{{\f5\fs18\hyphpar0\qj{C81, \'a7232.116}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1279, \'a719, 20}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1186, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 159, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 229, \'a77 \u8211\'3f 12}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1251, \'a728}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1231, \'a727 \u8211\'3f 29}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 76, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1174, \'a73, 22}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 182, \'a710, 11}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1190, \'a723}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 67, \'a79, 13}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1182, \'a759}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 172, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1098, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 119, \'a738}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 121, \'a758, 62}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1046, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1098, \'a757 \u8211\'3f 59}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7625}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.57}}}{{\f5\fs12\hyphpar0\qj{, 232.102A}}}{{\f5\fs12\hyphpar0\qj{, 232.111}}}{{\f5\fs12\hyphpar0\qj{, 232.117}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.117}}}{\*\bkmkstart stylerid1_2E9_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Termination \u8212\'3f findings \u8212\'3f disposition.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{After the hearing is concluded the court shall make and file written findings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the court concludes that facts sufficient to terminate parental rights have not been established by clear and convincing evidence, the court shall dismiss the petition.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the court concludes that facts sufficient to sustain the petition have been established by clear and convincing evidence, the court may order parental rights terminated. If the court terminates the parental rights of a child\u8217\'3fs parent, the court shall transfer the guardianship and custody of the child to a parent of the child whose parental rights have not been terminated. If the court finds guardianship and custody with the child\u8217\'3fs parents is not in the child\u8217\'3fs best interests, guardianship and custody shall be transferred for placement of the child in any of the following categories in the following order of priority: }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department if the department had custody of the child at the time of the filing of the petition for termination of parental rights, or if custody with the department is necessary to facilitate the permanency or adoption goal, unless the department waives its priority.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An adult relative of the child, including but not limited to adult siblings or parents of siblings. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A fictive kin.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A child-placing agency or other suitable private agency, facility, or institution which is licensed or otherwise authorized by law to receive and to provide care for the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the court orders a termination of parental rights and siblings are not placed together but have an existing relationship, the court shall order ongoing contact between the siblings in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 232.108}}}{{\f5\fs18\hyphpar0\qj{ if the court finds that either visitation or ongoing interaction is in the best interests of each sibling. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not be construed to require visitation between a child and a parent whose parental rights have been terminated as to that child, even if a sibling remains with the parent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If after a hearing the court does not order the termination of parental rights but finds that there is clear and convincing evidence that the child is a child in need of assistance, pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 232.96A}}}{{\f5\fs18\hyphpar0\qj{, due to the acts or omissions of one or both of the child\u8217\'3fs parents the court may adjudicate the child to be a child in need of assistance and may enter an order in accordance with the provisions of }}}{{\f5\fs18\hyphpar0\qj{section 232.100}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{232.101}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{232.102}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{232.104}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the court orders the termination of parental rights and transfers guardianship and custody under }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{, the guardian shall submit a case permanency plan to the court and shall make every effort to establish a stable placement for the child by adoption or other permanent placement. Within forty-five days of receipt of the termination order, and every forty-five days thereafter until the court determines such reports are no longer necessary, the guardian shall report to the court regarding efforts made to place the child for adoption or providing the rationale as to why adoption would not be in the child\u8217\'3fs best interest.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The guardian of each child whose guardianship and custody has been transferred under }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{ and who has not been placed for adoption shall file a written report with the court every six months concerning the child\u8217\'3fs placement. The court shall hold a hearing to review the placement at intervals not to exceed six months after the date of the termination of parental rights or the last placement review hearing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The guardian of each child whose guardianship and custody has been transferred under }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{ and who has been placed for adoption and whose adoption has not been finalized shall file a written report with the court every six months concerning the child\u8217\'3fs placement. The court shall hold a hearing to review the placement at intervals not to exceed twelve months after the date of the adoptive placement or the last placement review hearing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Hearings held under }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ are open to the public unless the court, on the motion of any of the parties or upon the court\u8217\'3fs own motion, excludes the public. The court shall exclude the public from a hearing if the court determines that the possibility of damage or harm to the child outweighs the public\u8217\'3fs interest in having a public hearing. Upon closing the hearing, the court may admit persons who have a direct interest in the case or in the work of the court.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a termination of parental rights order is issued on the grounds that the child is a newborn infant whose parent has voluntarily released custody of the child under }}}{{\f5\fs18\hyphpar0\qj{section 232.116, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the court shall retain jurisdiction to change a guardian or custodian and to allow a parent whose rights have been terminated to request vacation or appeal of the termination order which request must be made within thirty days of issuance of the granting of the termination order. The period for request for vacation or appeal by a parent whose rights have been terminated shall not be waived or extended and a vacation or appeal shall not be granted for a request made after the expiration of this period. The court shall grant the vacation request only if it is in the best interest of the child. The supreme court shall prescribe rules to establish the period of thirty days, which shall not be waived or extended, in which a parent whose parental rights have been terminated may request a vacation or appeal of such a termination order.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, \'a7232.115; }{{\f5\fs18\hyphpar0\qj{C81, \'a7232.117}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 96, \'a7157, 159}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1279, \'a721}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 159, \'a75, 7}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 229, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 230, \'a719}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1229, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1046, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1190, \'a724, 25}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 67, \'a710, 13}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1116, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1062, \'a794}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1098, \'a760, 61, 81}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.116}}}{{\f5\fs12\hyphpar0\qj{, 232.118}}}{{\f5\fs12\hyphpar0\qj{, 232.119}}}{{\f5\fs12\hyphpar0\qj{, 232.133}}}{{\f5\fs12\hyphpar0\qj{, 237.20}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.118}}}{\*\bkmkstart stylerid1_2E9_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Removal of guardian.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon application of an interested party or upon the court\u8217\'3fs own motion, the court having jurisdiction of the child may, after notice to the parties and a hearing, remove a court-appointed guardian and appoint a guardian in accordance with the provisions of }}}{{\f5\fs18\hyphpar0\qj{section 232.117, subsection 3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The moving party or a party opposed to the actions of the guardian has the burden to establish that the court-appointed guardian failed to act in the child\u8217\'3fs best interests by unreasonably or irresponsibly failing to discharge the guardian\u8217\'3fs duties in finding a suitable adoptive home for the child. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court shall give deference to the decision of the guardian.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A child fourteen years of age or older who has not been adopted but who is placed in a satisfactory foster home may, with the consent of the foster parents, join with the guardian appointed by the court in an application to the court to remove the existing guardian and appoint the foster parents as guardians of the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The authority of a guardian appointed by the court terminates when the child reaches the age of majority or is adopted.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, \'a7232.116; }{{\f5\fs18\hyphpar0\qj{C81, \'a7232.118}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1134, \'a753}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1098, \'a762}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.119}}}{\*\bkmkstart stylerid1_2E9_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Adoption exchange established.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The purpose of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is to facilitate the placement of all children in Iowa who are legally available for adoption through the establishment of an adoption exchange to help find adoptive homes for these children.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An adoption information exchange is established within the department to be operated by the department or by an individual or agency under contract with the department.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All special needs children under state guardianship shall be registered on the adoption exchange within sixty days of the termination of parental rights pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 232.117}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{600A.9}}}{{\f5\fs18\hyphpar0\qj{ and assignment of guardianship to the director.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prospective adoptive families requesting a special needs child shall be registered on the adoption exchange upon receipt of an approved home study.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To register a child on the Iowa exchange, the department adoption worker or the private agency worker shall register the pertinent information concerning the child on the exchange. A photograph of the child and other necessary information shall be forwarded to the department to be included in the photo-listing book which shall be updated regularly. The department adoption worker or the private agency worker who places a child on the exchange shall update the registration information within ten working days after a change in the information occurs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The exchange shall include a matching service for children registered or listed in the adoption photo-listing book and prospective adoptive families listed on the exchange. The department shall register a child with the national electronic exchange and electronic photo-listing system if the child has not been placed for adoption after three months on the exchange established pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A request to defer registering the child on the exchange shall be submitted in writing and shall be granted if any of the following conditions exist:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child is in an adoptive placement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child\u8217\'3fs foster parents or another person with a significant relationship is being considered as the adoptive family.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A diagnostic study or testing is necessary to clarify the child\u8217\'3fs needs and to provide an adequate description of the child\u8217\'3fs needs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At the time of the request, the child is receiving medical care, mental health treatment, or other treatment and the child\u8217\'3fs care or treatment provider has determined that meeting prospective adoptive parents is not in the child\u8217\'3fs best interest.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child is fourteen years of age or older and will not consent to an adoption plan and the consequences of not being adopted have been explained to the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The following requirements apply to a request to defer registering a child on the adoption exchange under }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For a deferral granted by the exchange pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the child\u8217\'3fs guardian shall address the child\u8217\'3fs deferral status in the report filed with the court and the court shall review the deferral status in the six-month review hearings held pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 232.117, subsection 7}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to the requirements of paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, a deferral granted by the exchange pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, shall be limited to not more than a one-time, ninety-day period unless the termination of parental rights order is appealed or the child is placed in a hospital or other institutional placement. However, if the foster parents or another person with a significant relationship continues to be considered the child\u8217\'3fs prospective adoptive family, additional extensions of the deferral request under }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, may be granted until sixty days after the date of the final decision regarding the appeal or until the date the child is discharged from a hospital or other institutional placement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A deferral granted by the exchange pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, shall be limited to not more than a one-time, ninety-day period.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A deferral granted by the exchange pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, shall be limited to not more than a one-time, one-hundred-twenty-day period.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{87 Acts, ch 159, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 232, \'a79, 10}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 22, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 182, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1190, \'a726}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 29, \'a734}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.120}}}{\*\bkmkstart stylerid1_2E9_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Preadoptive care \u8212\'3f continued placement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If a foster parent is providing preadoptive care to a child for whom a termination of parental rights petition has been filed, the placement of the child with that foster parent shall continue through the termination of parental rights proceeding unless the court orders otherwise based upon the best interests of the child.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1190, \'a727}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.121}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0{\f5\fs18\chcbpat2}\par}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER V}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{FAMILY IN NEED OF ASSISTANCE PROCEEDINGS}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a7232.147}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.122}}}{\*\bkmkstart stylerid1_2E1_30_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Jurisdiction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The juvenile court shall have exclusive jurisdiction over family in need of assistance proceedings.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7232.122}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232C.2}}}{{\f5\fs12\hyphpar0\qj{, 232C.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.123}}}{\*\bkmkstart stylerid1_2E1_30_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Venue.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Venue for family in need of assistance proceedings shall be determined in accordance with }{{\f5\fs18\hyphpar0\qj{section 232.62}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7232.123}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232C.2}}}{{\f5\fs12\hyphpar0\qj{, 232C.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.124}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.125}}}{\*\bkmkstart stylerid1_2E1_30_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Petition.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A family in need of assistance proceeding shall be initiated by the filing of a petition alleging that a child and the child\u8217\'3fs parent, guardian, or custodian are a family in need of assistance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Such a petition may be filed by the child\u8217\'3fs parent, guardian, or custodian, by the child, or on the court\u8217\'3fs own motion as provided in }}}{{\f5\fs18\hyphpar0\qj{section 232C.2}}}{{\f5\fs18\hyphpar0\qj{. The judge, county attorney, or juvenile court officer may authorize such parent, guardian, custodian, or child to file a petition with the clerk of the court without the payment of a filing fee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The petition and subsequent court documents shall be entitled as follows: }}}\par}{}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\b0\fs18\hyphpar0\qj\ul0\strike0{\~\~\~}}}{\f5\fs18\hyphpar0\qj}{In re the family of }{{\f5\fs18\hyphpar0\qj{........................}}}{.}{\f5\fs18\hyphpar0\qj}\par}{\pard\plain\f5\fs8\hyphpar0\qj\fi0\ri1084\li1084\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The petition shall state all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The names and residences of the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The names and residences of the child\u8217\'3fs living parents, guardian, custodian, and guardian ad litem, if any. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The age of the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The petition shall allege that there has been a breakdown in the familial relationship and that the petitioner has sought services from public or private agencies to maintain and improve the familial relationship.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7232.125}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 186, \'a710055, 10201}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 153, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 30, \'a778}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 24, \'a725}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.21}}}{{\f5\fs12\hyphpar0\qj{, 232C.2}}}{{\f5\fs12\hyphpar0\qj{, 232C.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.126}}}{\*\bkmkstart stylerid1_2E1_30_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Appointment of counsel and guardian ad litem.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court shall appoint counsel or a guardian ad litem to represent the interests of the child at the hearing to determine whether the family is a family in need of assistance unless the child already has such counsel or guardian. The court shall appoint counsel for the parent, guardian, or custodian if that person desires but is financially unable to employ counsel.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court may appoint a court appointed special advocate. The court appointed special advocate shall receive notice of and may attend all depositions, hearings, and trial proceedings to support the child and advocate for the protection of the child. The court appointed special advocate shall not be allowed to separately introduce evidence or to directly examine or cross-examine witnesses. The court appointed special advocate shall submit reports to the court and the parties to the proceedings containing the information required in reports submitted by a court appointed special advocate under section }}}{{\f5\fs18\hyphpar0\qj{237.24, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fg\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fh\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. In addition, the court appointed special advocate shall file other reports to the court as required by the court.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7232.126}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{87 Acts, ch 121, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1162, \'a718}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1098, \'a763}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232C.2}}}{{\f5\fs12\hyphpar0\qj{, 232C.3}}}{{\f5\fs12\hyphpar0\qj{, 237.21}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.127}}}{\*\bkmkstart stylerid1_2E1_30_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Hearing \u8212\'3f adjudication \u8212\'3f disposition.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon the filing of a petition, the court shall fix a time for a hearing and give notice thereof to the child and the child\u8217\'3fs parent, guardian, or custodian.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A parent without custody may petition the court to be made a party to proceedings under }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court shall exclude the general public from such hearing except the court in its discretion may admit persons having a legitimate interest in the case or the work of the court.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The hearing shall be informal and all relevant and material evidence shall be admitted.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court may adjudicate the family to be a family in need of assistance and enter an appropriate dispositional order if the court finds all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{There has been a breakdown in the relationship between the child and the child\u8217\'3fs parent, guardian, or custodian.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child or the child\u8217\'3fs parent, guardian, or custodian has sought services from public or private agencies to maintain and improve the familial relationship.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court has at its disposal services for this purpose which can be made available to the family.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the court makes such a finding the court may order any or all of the parties to accept counseling and to comply with any other reasonable orders designed to maintain and improve the familial relationship. At the conclusion of any counseling ordered by the court, or at any other time deemed necessary, the parties shall be required to meet together and be apprised of the findings and recommendations of such counseling. Such an order shall remain in force for a period not to exceed one year unless the court otherwise specifies or sooner terminates the order.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court may not order the child placed on probation, in a foster home or in a nonsecure facility unless the child requests and agrees to such supervision or placement. In no event shall the court order the child placed in the state training school or other secure facility.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court shall not order group foster care placement of the child which is a charge upon the state unless the group foster care meets requirements as established by the department by rule.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A child found in contempt of court because of violation of conditions imposed under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not be considered delinquent. Such a contempt may be punished by imposition of a work assignment or assignments to benefit the state or a governmental subdivision of the state. In addition to or in lieu of such an assignment or assignments, the court may impose one of the dispositions set out in }}}{{\f5\fs18\hyphpar0\qj{sections 232.100 through 232.102}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the child is fourteen years of age or older and an order for an out-of-home placement is entered, the order shall specify the services needed to assist the child in preparing for the transition from foster care to adulthood. If the child has a case permanency plan, the court shall consider the written transition plan of services and needs assessment developed for the child\u8217\'3fs case permanency plan. If the child does not have a case permanency plan containing the transition plan and needs assessment at the time the order is entered, the written transition plan and needs assessment shall be developed and submitted for the court\u8217\'3fs consideration no later than six months from the date of the transfer order. The court shall modify the initial transfer order as necessary to specify the services needed to assist the child in preparing for the transition from foster care to adulthood. If the transition plan identifies services or other support needed to assist the child in transitioning from foster care to adulthood and the court deems it to be beneficial to the child, the court may authorize the individual who is the child\u8217\'3fs guardian ad litem or court appointed special advocate to continue a relationship with and provide advice to the child for a period of time beyond the child\u8217\'3fs eighteenth birthday.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If after hearing pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the court finds, by clear and convincing evidence, that no remedy is available that would result in strengthening or maintaining the familial relationship, the court may order the minor emancipated pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 232C.3, subsection 4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7232.127}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1260, \'a724}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1229, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 117, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1116, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 153, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1063, \'a718}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 59, \'a769}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1062, \'a794}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 80, \'a7128}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1098, \'a764}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232C.2}}}{{\f5\fs12\hyphpar0\qj{, 232C.3}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{232.128 through 232.132}}}{Reserved.}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0{\f5\fs18\chcbpat2}\par}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER VI}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E11_2E2_2E2}{APPEAL}{\*\bkmkend stylerid1_2E11_2E2_2E2}\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a7232.147}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.133}}}{\*\bkmkstart stylerid1_2E11_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Appeal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An interested party aggrieved by an order or decree of the juvenile court may appeal from the court for review of questions of law or fact. However, an order adjudicating a child to have committed a delinquent act, entered pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 232.47}}}{{\f5\fs18\hyphpar0\qj{, shall not be appealed until the court enters a corresponding dispositional order pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 232.52}}}{{\f5\fs18\hyphpar0\qj{. An appeal that affects the custody of a child shall be heard at the earliest practicable time.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except for appeals from orders entered in child in need of assistance proceedings or orders entered pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 232.117}}}{{\f5\fs18\hyphpar0\qj{, appellate procedures shall be governed by the same provisions applicable to appeals from the district court. The supreme court may prescribe rules to expedite the resolution of appeals from orders entered in child in need of assistance proceedings or orders entered pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 232.117}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The pendency of an appeal or application therefor shall not suspend the order of the juvenile court regarding a child and shall not discharge the child from the custody of the court or the agency, association, facility, institution or person to whom the court has transferred legal custody unless the appellate court otherwise orders on application of an appellant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the appellate court does not dismiss the proceedings and discharge the child, the appellate court shall affirm or modify the order of the juvenile court and remand the child to the jurisdiction of the juvenile court for disposition not inconsistent with the appellate court\u8217\'3fs finding on the appeal.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, \'a7232.58; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7232.133}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1186, \'a712}}}{; }{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 117, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 25, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1129, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 126, \'a745}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{232.134 through 232.140}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0{\f5\fs18\chcbpat2}\par}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER VII}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E12_2E2_2E2}{EXPENSES AND COSTS}{\*\bkmkend stylerid1_2E12_2E2_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.141}}}{\*\bkmkstart stylerid1_2E12_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Expenses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as otherwise provided by law, the court shall inquire into the ability of the child or the child\u8217\'3fs parent to pay expenses incurred pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsections 2, 4, and 8}}}{{\f5\fs18\hyphpar0\qj{. After giving the parent a reasonable opportunity to be heard, the court may order the parent to pay all or part of the costs of the child\u8217\'3fs care, physical assessment, behavioral health evaluation, treatment, legal expenses, or other expenses. An order entered under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ does not obligate a parent paying child support under a custody decree, except that part of the monthly support payment may be used to satisfy the obligations imposed by the order entered pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. If a parent fails to pay as ordered, without good reason, the court may proceed against the parent for contempt and may inform the county attorney who shall proceed against the parent to collect the unpaid amount. Any payment ordered by the court shall be a judgment against each of the child\u8217\'3fs parents and a lien as provided in }}}{{\f5\fs18\hyphpar0\qj{section 624.23}}}{{\f5\fs18\hyphpar0\qj{. If all or part of the amount that the parents are ordered to pay is subsequently paid by the county or state, the judgment and lien shall thereafter be against each of the parents in favor of the county to the extent of the county\u8217\'3fs payments and in favor of the state to the extent of the state\u8217\'3fs payments.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All of the following juvenile court expenses are a charge upon the county in which the proceedings are held, to the extent provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Juvenile court expenses incurred by an attorney appointed by the court to serve as counsel to any party or to serve as a guardian ad litem for any child, including fees and expenses for foreign language interpreters, costs of depositions and transcripts, fees and mileage of witnesses, and the expenses of officers serving notices and subpoenas.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reasonable compensation for an attorney appointed by the court to serve as counsel to any party or as guardian ad litem for any child in juvenile court.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Fees and expenses incurred by the juvenile court for foreign language interpreters for court proceedings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Costs incurred under }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ shall be paid as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county shall be required to pay for the fiscal year beginning July 1, 1989, an amount equal to the county\u8217\'3fs base cost for witness and mileage fees and attorney fees established pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 232.141, subsection 8}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, Code 1989, for the fiscal year beginning July 1, 1988, plus an amount equal to the percentage rate of change in the consumer price index as tabulated by the federal bureau of labor statistics for the current year times the county\u8217\'3fs base cost.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county\u8217\'3fs base cost for a fiscal year plus the percentage rate of change amount as computed in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ is the county\u8217\'3fs base cost for the succeeding fiscal year. The amount to be paid in the succeeding year by the county shall be computed as provided in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county, on an annual basis, shall pay to the indigent defense fund created under }}}{{\f5\fs18\hyphpar0\qj{section 815.11}}}{{\f5\fs18\hyphpar0\qj{ the amount of the county\u8217\'3fs base cost as determined in accordance with }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Costs incurred under }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ shall be paid by the state from the appropriations to the indigent defense fund under }}}{{\f5\fs18\hyphpar0\qj{section 815.11}}}{{\f5\fs18\hyphpar0\qj{ in accordance with }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{chapter 815}}}{{\f5\fs18\hyphpar0\qj{, and the rules adopted by the state public defender. The county shall be required to reimburse the indigent defense fund for costs incurred by the state up to the county\u8217\'3fs base in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon certification of the court, all of the following expenses are a charge upon the state to the extent provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The expenses of transporting a child to or from a place designated by the court for the purpose of care or treatment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Expenses for physical assessments or behavioral health evaluations of a child if ordered by the court.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The expenses of care or treatment ordered by the court.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If no other provision of law requires the county to reimburse costs incurred pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{, the department shall reimburse the costs as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall prescribe by administrative rule all services eligible for reimbursement pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{ and shall establish an allowable rate of reimbursement for each service.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall receive billings for services provided and, after determining allowable costs, shall reimburse providers at a rate which is not greater than allowed by administrative rule. Reimbursement paid to a provider by the department shall be considered reimbursement in full unless a county voluntarily agrees to pay any difference between the reimbursement amount and the actual cost. When there are specific program regulations prohibiting supplementation those regulations shall be applied to providers requesting supplemental payments from a county. Billings for services not listed in administrative rule shall not be paid. However, if the court orders a service not currently listed in administrative rule, the department shall review the order and, if reimbursement for the service of the department is not in conflict with other law or administrative rule, and meets the criteria of }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{, the department shall reimburse the provider.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A physical assessment, behavioral health evaluation, or any treatment relating to an assessment performed pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 232.71B}}}{{\f5\fs18\hyphpar0\qj{, shall be paid by the state if physical assessment, behavioral health evaluation, or other treatment was performed with the consent of the child\u8217\'3fs parent, guardian, or custodian and no other provision of law requires payment for the costs. The department shall reimburse costs under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ in accordance with }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county charged with the costs and expenses under }}}{{\f5\fs18\hyphpar0\qj{subsections 2 and 3}}}{{\f5\fs18\hyphpar0\qj{ may recover the costs and expenses from the child\u8217\'3fs custodial parent\u8217\'3fs county of residence, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 331.190}}}{{\f5\fs18\hyphpar0\qj{, by filing verified claims which are payable as are other claims against the county. A detailed statement of the facts upon which a claim is based shall accompany the claim. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ applies only to placements in a juvenile shelter care home which is publicly owned, operated as a county or multicounty shelter care home, organized under a }}}{{\f5\fs18\hyphpar0\qj{chapter 28E}}}{{\f5\fs18\hyphpar0\qj{ agreement, or operated by a private juvenile shelter care home. If the actual and allowable costs of a child\u8217\'3fs shelter care placement exceed the amount the department is authorized to pay, the unpaid costs may be recovered from the child\u8217\'3fs custodial parent\u8217\'3fs county of residence. However, the maximum amount of the unpaid costs which may be recovered under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ is limited to the difference between the amount the department is authorized to pay and the statewide average of the actual and allowable rates as reasonably determined by the department annually. A home may only be reimbursed for the lesser of the home\u8217\'3fs actual and allowable costs or the statewide average of the actual and allowable rates as determined by the department in effect on the date the costs were paid. The unpaid costs are payable pursuant to filing of verified claims against the child\u8217\'3fs custodial parent\u8217\'3fs county of residence. A detailed statement of the facts upon which a claim is based shall accompany the claim. Any dispute between counties arising from claims filed pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be settled in the manner provided to determine county of residence in }}}{{\f5\fs18\hyphpar0\qj{section 331.190}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a7254-a25, -a45; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{3644, 3645;}}}{ C46, 50, 54, 58, 62, \'a7232.25, 232.26; C66, 71, 73, 75, 77, \'a7232.51 \u8211\'3f 232.53; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7232.141}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1260, \'a7119}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 173, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 152, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1134, \'a754}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 283, \'a723}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1233, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1229, \'a78}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{; }{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/92/CH1004.pdf" }{\fldrslt \f5 \fs18{{\f5\fs18\hyphpar0\qj\cf5{92 Acts, 1st Ex, ch 1004, \'a73}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 76, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 172, \'a734}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 35, \'a712, 25}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 126, \'a731}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 135, \'a720, 21}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1115, \'a72 \u8211\'3f 4}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1119, \'a7147}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1090, \'a751}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1175, \'a7148}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1041, \'a75, 6}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1120, \'a7118, 130}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 115, \'a710, 19}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1137, \'a725}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1098, \'a766}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1161, \'a7183, 184}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 86, \'a730 \u8211\'3f 32}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.11}}}{{\f5\fs12\hyphpar0\qj{, 232.52}}}{{\f5\fs12\hyphpar0\qj{, 232.89}}}{{\f5\fs12\hyphpar0\qj{, 234.8}}}{{\f5\fs12\hyphpar0\qj{, 237.20}}}{{\f5\fs12\hyphpar0\qj{, 331.401}}}{{\f5\fs12\hyphpar0\qj{, 602.1302}}}{{\f5\fs12\hyphpar0\qj{, 602.1303}}}{{\f5\fs12\hyphpar0\qj{, 815.11}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 amendment to subsections 7 and 8 effective July 1, 2025; }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 1161, \'a7184}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 1 amended}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 4, paragraph b amended}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsections 6, 7, and 8 amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.142}}}{\*\bkmkstart stylerid1_2E12_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Maintenance and cost of juvenile homes }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ fund }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ appropriation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{County boards of supervisors which singly or in conjunction with one or more other counties provide and maintain juvenile detention and juvenile shelter care homes are subject to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purpose of providing and maintaining a county or multicounty home, the board of supervisors of any county may issue general county purpose bonds in accordance with }}}{{\f5\fs18\hyphpar0\qj{sections 331.441 through 331.449}}}{{\f5\fs18\hyphpar0\qj{. Expenses for providing and maintaining a multicounty home shall be paid by the counties participating in a manner to be determined by the boards of supervisors.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county or multicounty juvenile detention home approved pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall receive financial aid from the state in a manner approved by the director. Aid paid by the state shall be at least ten percent and not more than fifty percent of the total cost of the establishment, improvements, operation, and maintenance of the home. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director shall adopt minimal rules and standards for the establishment, maintenance, and operation of such homes as shall be necessary to effect the purposes of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. The rules shall apply the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 237.8}}}{{\f5\fs18\hyphpar0\qj{, concerning employment and evaluation of persons with direct responsibility for a child or with access to a child when the child is alone and persons residing in a child foster care facility, to persons employed by, residing in, or volunteering for a home approved under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The director shall, upon request, give guidance and consultation in the establishment and administration of the homes and programs for the homes. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director shall approve annually all such homes established and maintained under the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. A home shall not be approved unless it complies with minimal rules and standards adopted by the director and has been inspected by the department of inspections, appeals, and licensing. The statewide number of beds in the homes approved by the director shall not exceed two hundred seventy-two beds beginning July 1, 2017. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A juvenile detention home fund is created in the state treasury under the authority of the department. The fund shall consist of moneys deposited in the fund pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 602.8108}}}{{\f5\fs18\hyphpar0\qj{. The moneys in the fund shall be used for the costs of the establishment, improvement, operation, and maintenance of county or multicounty juvenile detention homes in accordance with }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Moneys deposited in the juvenile detention home fund during a fiscal year are appropriated to the department for the same fiscal year for distribution of an amount equal to a percentage of the costs of the establishment, improvement, operation, and maintenance of county or multicounty juvenile detention homes in the prior fiscal year. Such percentage shall be determined by the department based on the amount available for distribution from the fund.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Moneys appropriated for distribution in accordance with }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be allocated among eligible detention homes, prorated on the basis of an eligible detention home\u8217\'3fs proportion of the costs of all eligible detention homes in the prior fiscal year.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a7254-a20, -a26, -a29, -a30; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{3653 \u8211\'3f 3655;}}}{ C46, 50, 54, 58, 62, \'a7232.35 \u8211\'3f 232.37; C66, 71, 73, 75, 77, \'a7232.21 \u8211\'3f 232.26; C79, }{{\f5\fs18\hyphpar0\qj{81}}}{, }{{\f5\fs18\hyphpar0\qj{S81, \'a7232.142}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a71031}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 123, \'a791, 209}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1134, \'a755}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1204, \'a747}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1239, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 138, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1229, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 191, \'a738}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 98, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 138, \'a747}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 174, \'a7109}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1074, \'a750, 93}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 80, \'a7129}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1098, \'a767}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7626, 1932}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1157, \'a752}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.69}}}{{\f5\fs12\hyphpar0\qj{, 237.4}}}{{\f5\fs12\hyphpar0\qj{, 237C.1}}}{{\f5\fs12\hyphpar0\qj{, 331.382}}}{{\f5\fs12\hyphpar0\qj{, 602.8108}}}{{\f5\fs12\hyphpar0\qj{, 709.16}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.143}}}{\*\bkmkstart stylerid1_2E12_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Service area group foster care budget targets.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2022 Acts, ch 1098, \'a790}}}{{\f5\fs18\hyphpar0\qj{.}}}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{232.144 through 232.146}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0{\f5\fs18\chcbpat2}\par}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER VIII}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E13_2E2_2E2}{RECORDS}{\*\bkmkend stylerid1_2E13_2E2_2E2}\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a7232.11}}}{{\f5\fs12\qc{, 232.48}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.147}}}{\*\bkmkstart stylerid1_2E13_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Confidentiality of juvenile court records.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Juvenile court social records shall be confidential. They shall not be inspected and their contents shall not be disclosed except as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ or as authorized by other provisions in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Official juvenile court records in all cases except those alleging delinquency shall be confidential and are not public records. Confidential records may be inspected and their contents shall be disclosed to the following without court order, provided that a person or entity who inspects or receives a confidential record under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not disclose the confidential record or its contents unless required by law:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The judge and professional court staff, including juvenile court officers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child and the child\u8217\'3fs counsel.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child\u8217\'3fs parent, guardian, or custodian, court appointed special advocate, and guardian ad litem, and the members of the child advocacy board created in }}}{{\f5\fs18\hyphpar0\qj{section 237.16}}}{{\f5\fs18\hyphpar0\qj{ or a local citizen foster care review board created in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 237.19}}}{{\f5\fs18\hyphpar0\qj{ who are assigning or reviewing the child\u8217\'3fs case.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county attorney, the county attorney\u8217\'3fs assistants, or the attorney representing the state in absence of the county attorney.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An agency, individual, association, facility, or institution responsible for the care, treatment, or supervision of the child pursuant to a court order or voluntary placement agreement with the department, juvenile officer, or intake officer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A court, court professional staff, and adult probation officers in connection with the preparation of a presentence report concerning a person who prior thereto had been the subject of a juvenile court proceeding.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child\u8217\'3fs foster parent or an individual providing preadoptive care to the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state public defender.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The statistical analysis center for the purposes stated in }}}{{\f5\fs18\hyphpar0\qj{section 216A.136}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Official juvenile court records in all cases alleging the commission of a delinquent act except those alleging the commission of a delinquent act that would be a forcible felony if committed by an adult shall be confidential and are not public records. Unless an order sealing such confidential records in a delinquency proceeding has been entered pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 232.150}}}{{\f5\fs18\hyphpar0\qj{, confidential records may be inspected and their contents shall be disclosed to the following without court order, provided that a person or entity who inspects or receives a confidential record under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not disclose the confidential record or its contents unless required by law:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The judge and professional court staff, including juvenile court officers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child and the child\u8217\'3fs counsel.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child\u8217\'3fs parent, guardian, or custodian, court appointed special advocate, guardian ad litem, and the members of the child advocacy board created in }}}{{\f5\fs18\hyphpar0\qj{section 237.16}}}{{\f5\fs18\hyphpar0\qj{ or a local citizen foster care review board created in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 237.19}}}{{\f5\fs18\hyphpar0\qj{ who are assigning or reviewing the child\u8217\'3fs case.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county attorney, the county attorney\u8217\'3fs assistants, or the attorney representing the state in absence of the county attorney.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An agency, individual, association, facility, or institution responsible for the care, treatment, or supervision of the child pursuant to a court order or voluntary placement agreement with the department, juvenile court officer, or intake officer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A court, court professional staff, and adult probation officers in connection with the preparation of a presentence report concerning a person who prior thereto had been the subject of a juvenile court delinquency proceeding.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state public defender.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of corrections.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A judicial district department of correctional services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{k.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of parole.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{l.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The superintendent or the superintendent\u8217\'3fs designee of the school district for the school attended by the child or the authorities in charge of an accredited nonpublic school attended by the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{m.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A member of the armed forces of the United States who is conducting a background investigation of an individual pursuant to federal law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{n.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The statistical analysis center for the purposes stated in }}}{{\f5\fs18\hyphpar0\qj{section 216A.136}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{o.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A state or local law enforcement agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{p.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The alleged victim of the delinquent act.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{q.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An individual involved in the operation of a juvenile diversion program, who may also receive from a state or local law enforcement agency police reports and related information that assist in the operation of the juvenile diversion program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Official juvenile court records containing a petition or complaint alleging the commission of a delinquent act that would be a forcible felony if committed by an adult shall be public records subject to a confidentiality order under }}}{{\f5\fs18\hyphpar0\qj{section 232.149A}}}{{\f5\fs18\hyphpar0\qj{ or sealing under }}}{{\f5\fs18\hyphpar0\qj{section 232.150}}}{{\f5\fs18\hyphpar0\qj{. However, such official records shall not be available to the public or any governmental agency through the internet or in an electronic customized data report unless the child has been adjudicated delinquent in the matter. However, such official juvenile court records shall be disclosed through the internet or in an electronic customized data report prior to the child being adjudicated delinquent to the following without court order:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The judge and professional court staff, including juvenile court officers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child and the child\u8217\'3fs counsel.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child\u8217\'3fs parent, guardian, or custodian, court appointed special advocate, guardian ad litem, and the members of the child advocacy board created in }}}{{\f5\fs18\hyphpar0\qj{section 237.16}}}{{\f5\fs18\hyphpar0\qj{ or a local citizen foster care review board created in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 237.19}}}{{\f5\fs18\hyphpar0\qj{ who are assigning or reviewing the child\u8217\'3fs case.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county attorney, the county attorney\u8217\'3fs assistants, or the attorney representing the state in absence of the county attorney.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A court, court professional staff, and adult probation officers in connection with the preparation of a presentence report concerning a person who prior thereto had been the subject of a juvenile court proceeding.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An agency, individual, association, facility, or institution responsible for the care, treatment, or supervision of the child pursuant to a court order or voluntary placement agreement with the department, juvenile court officer, or intake officer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A state or local law enforcement agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state public defender.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The statistical analysis center for the purposes stated in }}}{{\f5\fs18\hyphpar0\qj{section 216A.136}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{k.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of corrections.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{l.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A judicial district department of correctional services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{m.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of parole.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{n.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The superintendent or the superintendent\u8217\'3fs designee of the school district for the school attended by the child or the authorities in charge of an accredited nonpublic school attended by the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{o.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A member of the armed forces of the United States who is conducting a background investigation of an individual pursuant to federal law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{p.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The alleged victim of the delinquent act.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{q.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An individual involved in the operation of a juvenile diversion program, who may also receive from a state or local law enforcement agency police reports and related information that assist in the operation of the juvenile diversion program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the court has excluded the public from a hearing pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 232.39}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{232.92}}}{{\f5\fs18\hyphpar0\qj{, the transcript of the proceedings shall not be deemed a public record and inspection and disclosure of the contents of the transcript shall not be permitted except pursuant to a court order or unless otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Delinquency complaints under }}}{{\f5\fs18\hyphpar0\qj{section 232.28}}}{{\f5\fs18\hyphpar0\qj{ shall be released in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 915.25}}}{{\f5\fs18\hyphpar0\qj{. Other official juvenile court records in a delinquency proceeding that are public records under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and that have not been made confidential pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 232.149A}}}{{\f5\fs18\hyphpar0\qj{ or sealed pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 232.150}}}{{\f5\fs18\hyphpar0\qj{ may be released under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ by a juvenile court officer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Official juvenile court records enumerated in }}}{{\f5\fs18\hyphpar0\qj{section 232.2, subsection 47}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, relating to paternity, support, or the termination of parental rights, shall be disclosed, upon request, to child support services without court order.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Pursuant to court order, official juvenile court records may be inspected by and their contents may be disclosed to:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person conducting bona fide research for research purposes under whatever conditions the court may deem proper, provided that no personal identifying data shall be disclosed to such a person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Persons who have a direct interest in a proceeding or in the work of the court.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Social records prior to adjudication may be disclosed without court order to the superintendent or superintendent\u8217\'3fs designee of a school district, authorities in charge of an accredited nonpublic school, or any other state or local agency that is part of the juvenile justice system, in accordance with an interagency agreement established under }}}{{\f5\fs18\hyphpar0\qj{section 280.25}}}{{\f5\fs18\hyphpar0\qj{. The disclosure shall only include identifying information that is necessary to fulfill the purpose of the disclosure. The social records disclosed shall be used solely for the purpose of determining the programs and services appropriate to the needs of the child or the family of the child and shall not be disclosed for any other purpose unless otherwise provided by law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subject to restrictions imposed by }}}{{\f5\fs18\hyphpar0\qj{sections 232.48, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{232.97, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, all juvenile court records shall be made available for inspection and their contents shall be disclosed to any party to the case and the party\u8217\'3fs counsel and to any trial or appellate court in connection with an appeal pursuant to }}}{{\f5\fs18\hyphpar0\qj{subchapter VI}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The clerk of the district court shall enter information from the juvenile record on the judgment docket and lien index, but only as necessary to record support judgments.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state agency designated to enforce support obligations may release information as necessary in order to meet statutory responsibilities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Release of official juvenile court records to a victim of a delinquent act is subject to the provisions of }}}{{\f5\fs18\hyphpar0\qj{section 915.24}}}{{\f5\fs18\hyphpar0\qj{, notwithstanding contrary provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any provision of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ or a confidentiality order entered pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 232.149A}}}{{\f5\fs18\hyphpar0\qj{, the juvenile court shall notify the department of transportation as required by }}}{{\f5\fs18\hyphpar0\qj{sections 321.213}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{321.213A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The confidentiality of a final adjudication of delinquency under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ or pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 232.149A}}}{{\f5\fs18\hyphpar0\qj{ shall not prohibit the state from pleading or proving the adjudication at a subsequent criminal or delinquency proceeding for the purpose of penalty enhancement when a provision of the Code specifically deems the delinquency adjudication to constitute a final conviction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{16.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A provision in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{section 232.149A}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{232.150}}}{{\f5\fs18\hyphpar0\qj{ shall not be construed to limit or restrict the production, use, or introduction of official juvenile court records in any juvenile or adult criminal proceeding, where such records are relevant and deemed admissible under any other provision of the law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{17.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A provision in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{section 232.149A}}}{{\f5\fs18\hyphpar0\qj{ shall not limit or prohibit individuals from performing any duties or responsibilities as required by }}}{{\f5\fs18\hyphpar0\qj{section 123.47B}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{124.415}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{232.47}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{232.49}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{321J.2B}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{18.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any provision of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{section 232.149A}}}{{\f5\fs18\hyphpar0\qj{ to the contrary, if the child has been discharged from the jurisdiction of the juvenile court in a delinquency proceeding due to reaching the age of eighteen and restitution remains unpaid, the name of the court, the title of the action, and the court\u8217\'3fs file number shall not be kept confidential, and the restitution amount shall be a judgment and lien as provided in }}}{{\f5\fs18\hyphpar0\qj{sections 910.7A}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{910.8}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{910.10}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{915.28}}}{{\f5\fs18\hyphpar0\qj{ until the restitution is paid.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{19.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any other provision of law, a public record which is confidential under the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall only be subject to release upon order of a court in a proceeding under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{20.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any other provision of law to the contrary, the department may inspect, and the court shall disclose to the department, records that are confidential under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ if the records were filed in a proceeding under }}}{{\f5\fs18\hyphpar0\qj{subchapter III}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{IV}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{V of this chapter}}}{{\f5\fs18\hyphpar0\qj{ to which the department is a participant.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, \'a7232.54, 232.57; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7232.147}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1209, \'a716}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 186, \'a710057, 10201}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1208, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1271, \'a71508}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1195, \'a7301}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 172, \'a735, 56}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 191, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1110, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 164, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1090, \'a763, 83, 84}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1123, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 79, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 55, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1164, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1185, \'a776}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 41, \'a7263}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 116, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 58, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1002, \'a74 \u8211\'3f 9, 17}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1153, \'a75 \u8211\'3f 7}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1062, \'a736}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7627 \u8211\'3f 630}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1075, \'a74}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a713B.4A}}}{{\f5\fs12\hyphpar0\qj{, 135L.3}}}{{\f5\fs12\hyphpar0\qj{, 216A.136}}}{{\f5\fs12\hyphpar0\qj{, 228.6}}}{{\f5\fs12\hyphpar0\qj{, 232.3A}}}{{\f5\fs12\hyphpar0\qj{, 232.19}}}{{\f5\fs12\hyphpar0\qj{, 232.91}}}{{\f5\fs12\hyphpar0\qj{, 232.103A}}}{{\f5\fs12\hyphpar0\qj{, 232.103B}}}{{\f5\fs12\hyphpar0\qj{, 232.149A}}}{{\f5\fs12\hyphpar0\qj{, 232.149B}}}{{\f5\fs12\hyphpar0\qj{, 232.150}}}{{\f5\fs12\hyphpar0\qj{, 232.151}}}{{\f5\fs12\hyphpar0\qj{, 232C.4}}}{{\f5\fs12\hyphpar0\qj{, 235A.17}}}{{\f5\fs12\hyphpar0\qj{, 280.25}}}{{\f5\fs12\hyphpar0\qj{, 280.36}}}{{\f5\fs12\hyphpar0\qj{, 692.2}}}{{\f5\fs12\hyphpar0\qj{, 692A.121}}}{{\f5\fs12\hyphpar0\qj{, 915.10A}}}{{\f5\fs12\hyphpar0\qj{, 915.25}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section not amended; internal reference change applied}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.148}}}{\*\bkmkstart stylerid1_2E13_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Fingerprints \u8212\'3f photographs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, a child shall not be fingerprinted or photographed by a criminal or juvenile justice agency after the child is taken into custody.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Fingerprints of a child who has been taken into custody shall be taken and filed by a criminal or juvenile justice agency investigating the commission of a public offense other than a simple misdemeanor. In addition, photographs of a child who has been taken into custody may be taken and filed by a criminal or juvenile justice agency investigating the commission of a public offense other than a simple misdemeanor. The criminal or juvenile justice agency shall forward the fingerprints to the department of public safety for inclusion in the automated fingerprint identification system and may also retain a copy of the fingerprint card for comparison with latent fingerprints and the identification of repeat offenders.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a peace officer has reasonable grounds to believe that latent fingerprints found during the investigation of the commission of a public offense are those of a particular child, fingerprints of the child may be taken for immediate comparison with the latent fingerprints regardless of the nature of the offense. If the comparison is negative the fingerprint card and other copies of the fingerprints taken shall be immediately destroyed. If the comparison is positive, the fingerprint card and other copies of the fingerprints taken shall be delivered to the division of criminal investigation of the department of public safety in the manner and on the forms prescribed by the commissioner of public safety within two working days after the fingerprints are taken. After notification by the child or the child\u8217\'3fs representative that the child has not had a delinquency petition filed against the child or has not entered into an informal adjustment agreement, the fingerprint card and copies of the fingerprints shall be immediately destroyed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Fingerprint and photograph files of children may be inspected by peace officers when necessary for the discharge of their official duties. The juvenile court may authorize other inspections of such files in individual cases upon a showing that inspection is necessary in the public interest.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Fingerprints and photographs of a child shall be removed from the file and destroyed upon notification by the child\u8217\'3fs guardian ad litem or legal counsel to the department of public safety that either of the following situations apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A petition alleging the child to be delinquent is not filed and the child has not entered into an informal adjustment, admitting involvement in a delinquent act alleged in the complaint.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{After a petition is filed, the petition is dismissed or the proceedings are suspended and the child has not entered into a consent decree and has not been adjudicated delinquent on the basis of a delinquent act other than one alleged in the petition in question, or the child has not been placed on youthful offender status.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7232.148}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1209, \'a717}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1172, \'a725}}}{; }{{\f5\fs18\hyphpar0\qj{95 Acts, ch 67, \'a717}}}{; }{{\f5\fs18\hyphpar0\qj{95 Acts, ch 191, \'a716, 17}}}{; }{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1034, \'a711}}}{; }{{\f5\fs18\hyphpar0\qj{97 Acts, ch 126, \'a732, 33}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1100, \'a726}}}{; }{{\f5\fs18\hyphpar0\qj{99 Acts, ch 37, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a713B.4A}}}{{\f5\fs12\hyphpar0\qj{, 216A.136}}}{{\f5\fs12\hyphpar0\qj{, 232.91}}}{{\f5\fs12\hyphpar0\qj{, 232.151}}}{{\f5\fs12\hyphpar0\qj{, 232C.4}}}{{\f5\fs12\hyphpar0\qj{, 692.15}}}{{\f5\fs12\hyphpar0\qj{, 692A.121}}}{{\f5\fs12\hyphpar0\qj{, 726.23}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Other provisions relating to fingerprints and photographs, see }{{\f5\fs12\hyphpar0\qj{\'a7690.2}}}{ and }{{\f5\fs12\hyphpar0\qj{690.4}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.149}}}{\*\bkmkstart stylerid1_2E13_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Records of criminal or juvenile justice agencies, intake officers, and juvenile court officers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The taking of a child into custody under the provisions of }}}{{\f5\fs18\hyphpar0\qj{section 232.19}}}{{\f5\fs18\hyphpar0\qj{ shall not be considered an arrest.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Records and files of a criminal or juvenile justice agency, an intake officer, or a juvenile court officer concerning a child involved in a delinquent act are confidential. The records are subject to sealing under }}}{{\f5\fs18\hyphpar0\qj{section 232.150}}}{{\f5\fs18\hyphpar0\qj{ unless the juvenile court waives its jurisdiction over the child so that the child may be prosecuted as an adult for a public offense. A criminal or juvenile justice agency may disclose to individuals involved in the operation of a juvenile diversion program police reports and related information that assist in the operation of the juvenile diversion program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Records and files of a criminal or juvenile justice agency, an intake officer, or a juvenile court officer concerning a defendant transferred under }}}{{\f5\fs18\hyphpar0\qj{section 803.6}}}{{\f5\fs18\hyphpar0\qj{ to the juvenile court for the alleged commission of a public offense are public records, except that release of criminal history data, intelligence data, and law enforcement investigatory files is subject to the provisions of }}}{{\f5\fs18\hyphpar0\qj{section 22.7}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{chapter 692}}}{{\f5\fs18\hyphpar0\qj{, and juvenile court social records shall be deemed confidential criminal identification files under }}}{{\f5\fs18\hyphpar0\qj{section 22.7, subsection 9}}}{{\f5\fs18\hyphpar0\qj{. The records are subject to sealing under }}}{{\f5\fs18\hyphpar0\qj{section 232.150}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, if a juvenile who has been placed in detention under }}}{{\f5\fs18\hyphpar0\qj{section 232.22}}}{{\f5\fs18\hyphpar0\qj{ escapes from the facility, the criminal or juvenile justice agency may release the name of the juvenile, the facts surrounding the escape, and the offense or alleged offense which resulted in the placement of the juvenile in the facility.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Records of an intake officer or juvenile court officer containing a dismissal of a complaint or an informal adjustment of a complaint if no petition is filed relating to the complaint, shall not be available to the public and may only be inspected by or disclosed to the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The judge and professional court staff, including juvenile court officers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child\u8217\'3fs counsel or guardian ad litem.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county attorney and county attorney\u8217\'3fs assistants.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The superintendent or the superintendent\u8217\'3fs designee of the school district for the school attended by the child or the authorities in charge of an accredited nonpublic school attended by the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A member of the armed forces of the United States who is conducting a background investigation of an individual pursuant to federal law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The statistical analysis center for the purposes stated in }}}{{\f5\fs18\hyphpar0\qj{section 216A.136}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state public defender.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The alleged victim of the delinquent act.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{subsections 2 and 5}}}{{\f5\fs18\hyphpar0\qj{, information from such records and files may be disclosed by a juvenile justice agency, intake officer, or juvenile court officer, when making referrals for placement of the child, to an agency, individual, association, facility, or institution that will have physical custody of the child, or will become responsible for the care, treatment, or supervision of the child upon placement.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, \'a7232.15; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7232.149}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 186, \'a710057, 10201}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 173, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1172, \'a726}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 191, \'a718, 19}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 126, \'a734, 35}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 58, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1002, \'a710, 17}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1153, \'a78, 9}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7631}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a713B.4A}}}{{\f5\fs12\hyphpar0\qj{, 216A.136}}}{{\f5\fs12\hyphpar0\qj{, 232.19}}}{{\f5\fs12\hyphpar0\qj{, 232.91}}}{{\f5\fs12\hyphpar0\qj{, 232.150}}}{{\f5\fs12\hyphpar0\qj{, 232.151}}}{{\f5\fs12\hyphpar0\qj{, 232C.4}}}{{\f5\fs12\hyphpar0\qj{, 280.36}}}{{\f5\fs12\hyphpar0\qj{, 692.2}}}{{\f5\fs12\hyphpar0\qj{, 692A.121}}}{{\f5\fs12\hyphpar0\qj{, 915.25}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.149A}}}{\*\bkmkstart stylerid1_2E13_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Confidentiality orders.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any other provision of the Code to the contrary, upon the court\u8217\'3fs own motion or application of a person who was the subject of a complaint or petition alleging the commission of a delinquent act that would be a forcible felony if committed by an adult, the court after hearing, shall order official juvenile court records in the case to be confidential and no longer public records under sections }}}{{\f5\fs18\hyphpar0\qj{232.19}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{232.147}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{915.25}}}{{\f5\fs18\hyphpar0\qj{, if the court finds both of the following apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The case has been dismissed without any adjudication of delinquency and the person is no longer subject to the jurisdiction of the juvenile court in the matter.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child\u8217\'3fs interest in making the records confidential outweighs the public\u8217\'3fs interest in the records remaining public records.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The records subject to a confidentiality order may be sealed at a later date if }}}{{\f5\fs18\hyphpar0\qj{section 232.150}}}{{\f5\fs18\hyphpar0\qj{ applies.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Unless an order sealing the records has been entered pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 232.150}}}{{\f5\fs18\hyphpar0\qj{, official juvenile court records subject to a confidentiality order may be inspected and their contents shall be disclosed to the following without court order:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The judge and professional court staff, including juvenile court officers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child and the child\u8217\'3fs counsel.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child\u8217\'3fs parent, guardian, or custodian, court appointed special advocate, and guardian ad litem, and the members of the child advocacy board created in }}}{{\f5\fs18\hyphpar0\qj{section 237.16}}}{{\f5\fs18\hyphpar0\qj{ or a local citizen foster care review board created in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 237.19}}}{{\f5\fs18\hyphpar0\qj{ who are assigning or reviewing the child\u8217\'3fs case.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county attorney and the county attorney\u8217\'3fs assistants.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An agency, association, facility, or institution which has custody of the child, or is legally responsible for the care, treatment, or supervision of the child, including but not limited to the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A court, court professional staff, and adult probation officers in connection with the preparation of a presentence report concerning a person who had been the subject of a juvenile court proceeding.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child\u8217\'3fs foster parent or an individual providing preadoptive care to the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A state or local law enforcement agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state public defender.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of corrections.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{k.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A judicial district department of correctional services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{l.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of parole.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{m.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The statistical analysis center for the purposes stated in }}}{{\f5\fs18\hyphpar0\qj{section 216A.136}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{n.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The alleged victim of the delinquent act.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{o.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A member of the armed forces of the United States who is conducting a background investigation of an individual pursuant to federal law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Pursuant to court order, official juvenile court records subject to a confidentiality order may be inspected by and their contents may be disclosed to:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person conducting bona fide research for research purposes under whatever conditions the court may deem proper, provided that no personal identifying data shall be disclosed to such a person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Persons who have a direct interest in a proceeding or in the work of the court.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1164, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1185, \'a777}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1002, \'a711, 12, 17}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7632}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a713B.4A}}}{{\f5\fs12\hyphpar0\qj{, 216A.136}}}{{\f5\fs12\hyphpar0\qj{, 232.11}}}{{\f5\fs12\hyphpar0\qj{, 232.91}}}{{\f5\fs12\hyphpar0\qj{, 232.147}}}{{\f5\fs12\hyphpar0\qj{, 232.150}}}{{\f5\fs12\hyphpar0\qj{, 232.151}}}{{\f5\fs12\hyphpar0\qj{, 232C.4}}}{{\f5\fs12\hyphpar0\qj{, 280.36}}}{{\f5\fs12\hyphpar0\qj{, 692.2}}}{{\f5\fs12\hyphpar0\qj{, 692A.121}}}{{\f5\fs12\hyphpar0\qj{, 915.25}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.149B}}}{\*\bkmkstart stylerid1_2E13_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Public records orders.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A rebuttable presumption exists that official juvenile court records in delinquency proceedings that do not involve an allegation of delinquency that would be a forcible felony offense if committed by an adult shall remain confidential as provided by }}}{{\f5\fs18\hyphpar0\qj{section 232.147}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon application of any person or upon the court\u8217\'3fs own motion at any time prior to the termination of juvenile court jurisdiction over the charged juvenile, and after hearing, the court shall order the official juvenile court records in such a delinquency proceeding to be public records if any of the following apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The public\u8217\'3fs interest in making the records public outweighs the juvenile\u8217\'3fs interest in maintaining the confidentiality of the records.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The juvenile has been placed on youthful offender status pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 232.45, subsection 7}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{section 907.3A, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, and will be transferred back to the district court for sentencing prior to the child\u8217\'3fs eighteenth birthday.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon application of any person or upon the court\u8217\'3fs own motion at any time prior to the termination of juvenile court jurisdiction over the charged juvenile, and after hearing, the court may order the official juvenile court records in such a delinquency proceeding to be public records if the juvenile has been subsequently adjudicated delinquent for a public offense that would be a serious misdemeanor, aggravated misdemeanor, or felony offense if committed by an adult, or another delinquency proceeding is pending seeking such an adjudication.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Records subject to a public records order may be sealed at a later date pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 232.150}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2016 Acts, ch 1002, \'a713, 17}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a713B.4A}}}{{\f5\fs12\hyphpar0\qj{, 216A.136}}}{{\f5\fs12\hyphpar0\qj{, 232.11}}}{{\f5\fs12\hyphpar0\qj{, 232.91}}}{{\f5\fs12\hyphpar0\qj{, 232.150}}}{{\f5\fs12\hyphpar0\qj{, 232.151}}}{{\f5\fs12\hyphpar0\qj{, 232C.4}}}{{\f5\fs12\hyphpar0\qj{, 692.2}}}{{\f5\fs12\hyphpar0\qj{, 692A.121}}}{{\f5\fs12\hyphpar0\qj{, 915.25}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.150}}}{\*\bkmkstart stylerid1_2E13_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Sealing of records.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{ In the case of an adjudication of delinquency, the court shall upon its own motion schedule a sealing of records hearing to be held two years after the date of the last official action, or the date the child becomes eighteen years of age, whichever is later. The court shall also schedule a sealing of records hearing upon application of a person who was the subject of a complaint or petition alleging delinquency that did not result in an adjudication. The court, after hearing, shall order the official juvenile court records in the case including those specified in }}}{{\f5\fs18\hyphpar0\qj{sections 232.147}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{232.149}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{232.149A}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{232.149B}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{915.25}}}{{\f5\fs18\hyphpar0\qj{, sealed if the court finds all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person is eighteen years of age or older and two years have elapsed since the last official action in the person\u8217\'3fs case.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person has not been subsequently convicted of a felony or an aggravated or serious misdemeanor or adjudicated a delinquent child for an act which if committed by an adult would be a felony, an aggravated misdemeanor, or a serious misdemeanor and no proceeding is pending seeking such conviction or adjudication.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person was not placed on youthful offender status, transferred back to district court after the youthful offender\u8217\'3fs eighteenth birthday, and sentenced for the offense which precipitated the youthful offender placement.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person was not adjudicated delinquent on an offense involving a violation of }}}{{\f5\fs18\hyphpar0\qj{section 321J.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the person was adjudicated delinquent for an offense which if committed by an adult would be an aggravated misdemeanor or a felony, the court shall not order the records in the case sealed unless, upon application of the person or upon the court\u8217\'3fs own motion and after hearing, the court finds that paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraphs (1) and (2), apply and that the sealing is in the best interests of the person and the public.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the person is required to pay monetary restitution to a victim due to a delinquent act and the restitution is unpaid, the records in the case may be sealed, but the name of the court, the title of the action, and the court\u8217\'3fs file number shall remain unsealed as provided in }}}{{\f5\fs18\hyphpar0\qj{section 910.10}}}{{\f5\fs18\hyphpar0\qj{ and the restitution amount shall be a judgment and lien as provided in }}}{{\f5\fs18\hyphpar0\qj{sections 910.7A}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{910.8}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{910.10}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{915.28}}}{{\f5\fs18\hyphpar0\qj{ until the restitution is paid in full.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reasonable notice of the hearing shall be given to the person who is the subject of the records named in the motion, the county attorney, and the agencies having custody of the records named in the application or motion.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notice and copies of a sealing order shall be sent to each agency or person having custody or the records named in the sealing order.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On entry of a sealing order:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All agencies and persons having custody of records which are named therein, shall send such records to the court issuing the order. Maintenance or destruction of these records shall be prescribed by the state court administrator.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All index references to sealed records shall be deleted.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The sealed records shall no longer be deemed to exist as a matter of law, and the juvenile court and any other agency or person who received notice and a copy of the sealing order shall reply to an inquiry that no such records exist, except when such reply is made to an inquiry pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 6}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Inspection of sealed records and disclosure of their contents thereafter may be permitted only pursuant to an order of the court upon application of the person who is the subject of such records except that the court in its discretion may permit reports to be inspected by or their contents to be disclosed for research purposes to a person conducting bona fide research under whatever conditions the court deems proper.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7232.150}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1209, \'a718}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 126, \'a736}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1164, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1105, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1002, \'a714, 15, 17}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1153, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 59, \'a770}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a713B.4A}}}{{\f5\fs12\hyphpar0\qj{, 216A.136}}}{{\f5\fs12\hyphpar0\qj{, 229A.2}}}{{\f5\fs12\hyphpar0\qj{, 232.55}}}{{\f5\fs12\hyphpar0\qj{, 232.91}}}{{\f5\fs12\hyphpar0\qj{, 232.147}}}{{\f5\fs12\hyphpar0\qj{, 232.149}}}{{\f5\fs12\hyphpar0\qj{, 232.149A}}}{{\f5\fs12\hyphpar0\qj{, 232.149B}}}{{\f5\fs12\hyphpar0\qj{, 232.151}}}{{\f5\fs12\hyphpar0\qj{, 232C.4}}}{{\f5\fs12\hyphpar0\qj{, 692.2}}}{{\f5\fs12\hyphpar0\qj{, 692A.101}}}{{\f5\fs12\hyphpar0\qj{, 692A.121}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.151}}}{\*\bkmkstart stylerid1_2E13_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Criminal penalties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any person who knowingly discloses, receives, or makes use or permits the use of information derived directly or indirectly from the records concerning a child referred to in }}}{{\f5\fs18\hyphpar0\qj{sections 232.147 through 232.150}}}{{\f5\fs18\hyphpar0\qj{, except as provided by those sections or }}}{{\f5\fs18\hyphpar0\qj{section 13B.4A, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, shall be guilty of a serious misdemeanor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not apply to a person or entity authorized to receive or inspect the contents of confidential official juvenile court records, or the confidential records of a criminal or juvenile justice agency, juvenile court officer, or juvenile intake officer, when such person or entity discloses such information to another person or entity also authorized to receive or inspect the confidential information, or discloses to a witness or other interested person the date, time, and nature of a court proceeding concerning the child in order to secure the appearance of the witness or other interested person at the proceeding.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7232.151}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2014 Acts, ch 1038, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1041, \'a7121}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1153, \'a711}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7216A.136}}}{{\f5\fs12\hyphpar0\qj{, 232.91}}}{{\f5\fs12\hyphpar0\qj{, 232C.4}}}{{\f5\fs12\hyphpar0\qj{, 280.36}}}{{\f5\fs12\hyphpar0\qj{, 692A.121}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.152}}}{\*\bkmkstart stylerid1_2E13_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Rules of juvenile procedure.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Transferred to }}}{{\f5\fs18\hyphpar0\qj{\'a7232.7A}}}{{\f5\fs18\hyphpar0\qj{; }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2021/CH0076.pdf" }{\fldrslt \cf5 \f5 \fs18{{2021 Acts, ch 76, \'a7150}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.153}}}{\*\bkmkstart stylerid1_2E13_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Applicability of }}}{{\f5\b\fs18\hyphpar0\qj{this chapter}}}{{\f5\b\fs18\hyphpar0\qj{ prior to July 1, 1979.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Transferred to }}}{{\f5\fs18\hyphpar0\qj{\'a7232.7B}}}{{\f5\fs18\hyphpar0\qj{; }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2021/CH0076.pdf" }{\fldrslt \cf5 \f5 \fs18{{2021 Acts, ch 76, \'a7150}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{232.154 through 232.157}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0{\f5\fs18\chcbpat2}\par}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER IX}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E14_2E2_2E2}{INTERSTATE COMPACT ON PLACEMENT OF CHILDREN}{\*\bkmkend stylerid1_2E14_2E2_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.158}}}{\*\bkmkstart stylerid1_2E14_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Interstate compact on placement of children.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The interstate compact on the placement of children is hereby enacted into law and entered into with all other jurisdictions legally joining therein in form substantially as follows:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E14_2E3_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E14_2E3_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article I \u8212\'3f Purpose and policy.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It is the purpose and policy of the party states to cooperate with each other in the interstate placement of children to the end that:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each child requiring placement shall receive the maximum opportunity to be placed in a suitable environment and with persons or institutions having appropriate qualifications and facilities to provide a necessary and desirable degree and type of care.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The appropriate authorities in a state where a child is to be placed may have full opportunity to ascertain the circumstances of the proposed placement, thereby promoting full compliance with applicable requirements for the protection of the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The proper authorities of the state from which the placement is made may obtain the most complete information on the basis of which to evaluate a projected placement before it is made.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Appropriate jurisdictional arrangements for the care of children will be promoted.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E14_2E3_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E14_2E3_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article II \u8212\'3f Definitions.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in this compact:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fChild\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person who, by reason of minority, is legally subject to parental, guardianship or similar control.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSending agency\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a party state, officer or employee thereof; a subdivision of a party state, or officer or employee thereof; a court of a party state; a person, corporation, association, charitable agency or other entity which sends, brings, or causes to be sent or brought any child to another party state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fReceiving state\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the state to which a child is sent, brought, or caused to be sent or brought, whether by public authorities or private persons or agencies, and whether for placement with state or local public authorities or for placement with private agencies or persons.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPlacement\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the arrangement for the care of a child in a family free or boarding home or in a child-caring agency or institution, but not in an institution caring for the mentally ill, mentally defective, or epileptic, in an institution primarily educational in character, or in a hospital or other medical facility.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{\*\bkmkstart stylerid1_2E14_2E3_2E6_2E1_2E2}{\*\bkmkend stylerid1_2E14_2E3_2E6_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article III \u8212\'3f Conditions for placement.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A sending agency shall not send, bring, or cause to be sent or brought into any other party state a child for placement in foster care or as a preliminary to a possible adoption unless the sending agency complies with every requirement set forth in this article and with the applicable laws of the receiving state governing the placement of children in the receiving state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prior to sending, bringing or causing any child to be sent or brought into a receiving state for placement in foster care or as a preliminary to a possible adoption, the sending agency shall furnish the appropriate public authorities in the receiving state written notice of the intention to send, bring, or place the child in the receiving state. The notice shall contain:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The name, date and place of birth of the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The identity and address or addresses of the parents or legal guardian.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The name and address of the person, agency or institution to or with which the sending agency proposes to send, bring or place the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A full statement of the reasons for such proposed action and evidence of the authority pursuant to which the placement is proposed to be made.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any public officer or agency in a receiving state which is in receipt of a notice pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ of this article may request of the sending agency, or any other appropriate officer or agency of or in the sending agency\u8217\'3fs state, and shall be entitled to receive therefrom, such supporting or additional information as it may deem necessary under the circumstances to carry out the purpose and policy of this compact.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child shall not be sent, brought, or caused to be sent or brought into the receiving state until the appropriate public authorities in the receiving state shall notify the sending agency, in writing, to the effect that the proposed placement does not appear to be contrary to the interests of the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{\*\bkmkstart stylerid1_2E14_2E3_2E7_2E1_2E2}{\*\bkmkend stylerid1_2E14_2E3_2E7_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article IV \u8212\'3f Penalty for illegal placement.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The sending, bringing, or causing to be sent or brought into any receiving state of a child in violation of the terms of this compact shall constitute a violation of the laws respecting the placement of children of both the state in which the sending agency is located or from which it sends or brings the child and of the receiving state. Such violation may be punished or subjected to penalty in either jurisdiction in accordance with its laws. In addition to liability for any such punishment or penalty, any such violation shall constitute full and sufficient grounds for the suspension or revocation of any license, permit, or other legal authorization held by the sending agency which empowers or allows it to place, or care for children.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{\*\bkmkstart stylerid1_2E14_2E3_2E8_2E1_2E2}{\*\bkmkend stylerid1_2E14_2E3_2E8_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article V \u8212\'3f Retention of jurisdiction.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The sending agency shall retain jurisdiction over the child sufficient to determine all matters in relation to the custody, supervision, care, treatment and disposition of the child which it would have had if the child had remained in the sending agency\u8217\'3fs state, until the child is adopted, reaches majority, becomes self-supporting or is discharged with the concurrence of the appropriate authority in the receiving state. Such jurisdiction shall also include the power to effect or cause the return of the child or its transfer to another location and custody pursuant to law. The sending agency shall continue to have financial responsibility for support and maintenance of the child during the period of the placement. Nothing contained herein shall defeat a claim of jurisdiction by a receiving state sufficient to deal with an act of delinquency or crime committed therein.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When the sending agency is a public agency, it may enter into an agreement with an authorized public or private agency in the receiving state providing for the performance of one or more services in respect of such case by the latter as agent for the sending agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Nothing in this compact shall be construed to prevent a private charitable agency authorized to place children in the receiving state from performing services or acting as agent in that state for a private charitable agency of the sending state; nor to prevent the agency in the receiving state from discharging financial responsibility for the support and maintenance of a child who has been placed on behalf of the sending agency without relieving the responsibility set forth in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ hereof.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{\*\bkmkstart stylerid1_2E14_2E3_2E9_2E1_2E2}{\*\bkmkend stylerid1_2E14_2E3_2E9_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article VI \u8212\'3f Institutional care of delinquent children.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A child adjudicated delinquent may be placed in an institution in another party jurisdiction pursuant to this compact but no such placement shall be made unless the child is given a court hearing on notice to the parent or guardian with opportunity to be heard, prior to the child being sent to such other party jurisdiction for institutional care and the court finds that:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Equivalent facilities for the child are not available in the sending agency\u8217\'3fs jurisdiction; and}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Institutional care in the other jurisdiction is in the best interest of the child and will not produce undue hardship.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{\*\bkmkstart stylerid1_2E14_2E3_2E1_30_2E1_2E2}{\*\bkmkend stylerid1_2E14_2E3_2E1_30_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article VII \u8212\'3f Compact administrator.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The executive head of each jurisdiction party to this compact shall designate an officer who shall be general coordinator of activities under this compact in the officer\u8217\'3fs jurisdiction and who, acting jointly with like officers of other party jurisdictions, shall have power to promulgate rules and regulations to carry out more effectively the terms and provisions of this compact.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{\*\bkmkstart stylerid1_2E14_2E3_2E11_2E1_2E2}{\*\bkmkend stylerid1_2E14_2E3_2E11_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article VIII \u8212\'3f Limitations.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This compact shall not apply to:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The sending or bringing of a child into a receiving state by the child\u8217\'3fs parent, stepparent, grandparent, adult brother or sister, adult uncle or aunt, or guardian and leaving the child with any such relative or nonagency guardian in the receiving state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any placement, sending or bringing of a child into a receiving state pursuant to any other interstate compact to which both the state from which the child is sent or brought and the receiving state are party, or to any other agreement between said states which has the force of law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{\*\bkmkstart stylerid1_2E14_2E3_2E12_2E1_2E2}{\*\bkmkend stylerid1_2E14_2E3_2E12_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article IX \u8212\'3f Enactment and withdrawal.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This compact shall be open to joinder by any state, territory or possession of the United States, the District of Columbia, the commonwealth of Puerto Rico, and, with the consent of Congress, the government of Canada or any province thereof. It shall become effective with respect to any such jurisdiction when such jurisdiction has enacted the same into law. Withdrawal from this compact shall be by the enactment of a statute repealing the same, but shall not take effect until two years after the effective date of such statute and until written notice of the withdrawal has been given by the withdrawing state to the governor of each other party jurisdiction. Withdrawal of a party state shall not affect the rights, duties and obligations under this compact of any sending agency therein with respect to a placement made prior to the effective date of withdrawal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{\*\bkmkstart stylerid1_2E14_2E3_2E13_2E1_2E2}{\*\bkmkend stylerid1_2E14_2E3_2E13_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article X \u8212\'3f Construction and severability.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The provisions of this compact shall be liberally construed to effectuate the purposes thereof. The provisions of this compact shall be severable and if any phrase, clause, sentence or provision of this compact is declared to be contrary to the constitution of any party state or of the United States or the applicability thereof to any government, agency, person or circumstance is held invalid, the validity of the remainder of this compact and the applicability thereof to any government, agency, person or circumstance shall not be affected thereby. If this compact shall be held contrary to the constitution of any state party thereto, the compact shall remain in full force and effect as to the remaining states and in full force and effect as to the state affected as to all severable matters.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a73260-1; C24, \'a73672, 3675; C27, 31, 35, \'a73661-a90, -a93, -a95, -a96; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{3661.104, 3661.107, 3661.109, 3661.110;}}}{ C46, 50, 54, 58, 62, 66, \'a7238.33, 238.36, 238.38, 238.39; C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7238.33}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 173, \'a721 \u8211\'3f 23, 30}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{CS85, \'a7232.158}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1032, \'a7201}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a791A.5B}}}{{\f5\fs12\hyphpar0\qj{, 232.158A}}}{{\f5\fs12\hyphpar0\qj{, 232.159}}}{{\f5\fs12\hyphpar0\qj{, 232.160}}}{{\f5\fs12\hyphpar0\qj{, 232.161}}}{{\f5\fs12\hyphpar0\qj{, 232.162}}}{{\f5\fs12\hyphpar0\qj{, 232.163}}}{{\f5\fs12\hyphpar0\qj{, 232.164}}}{{\f5\fs12\hyphpar0\qj{, 232.165}}}{{\f5\fs12\hyphpar0\qj{, 232.166}}}{{\f5\fs12\hyphpar0\qj{, 232.167}}}{{\f5\fs12\hyphpar0\qj{, 422.12A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.158A}}}{\*\bkmkstart stylerid1_2E14_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Legal risk placement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any provision of the interstate compact on the placement of children under }}}{{\f5\fs18\hyphpar0\qj{section 232.158}}}{{\f5\fs18\hyphpar0\qj{ to the contrary, the department shall permit the legal risk placement of a child under the interstate compact on the placement of children if the prospective adoptive parent provides a legal risk statement, in writing, acknowledging all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the placement is a legal risk placement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the court of the party state of the sending agency retains jurisdiction over the child for purposes of the termination of the parental rights of the biological parents.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That if termination of parental rights cannot be accomplished in accordance with applicable laws, the child shall be promptly returned to the party state of the sending agency to be returned to the child\u8217\'3fs biological parent or placed as deemed appropriate by a court of the party state of the sending agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the prospective adoptive parent assumes full legal, financial, and other risks associated with the legal risk placement and that the prospective adoptive parent agrees to hold the department harmless for any disruption or failure of the placement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the prospective adoptive parent shall provide support and medical and other appropriate care to the child pending the termination of parental rights of the biological parents and shall assume liability for all costs associated with the return of the child to the party state of the sending agency if the placement is disrupted or fails.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any written legal risk statement utilized in establishing a legal risk placement shall, at a minimum, state all of the information required under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, shall be signed by any prospective adoptive parent, and shall be notarized. The legal risk statement shall also contain the following notice printed in clearly legible type:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb80\ri1084\li1084\sa80{{\f5\fs18\hyphpar0\qj{\~\~}}}{If termination of parental rights is not accomplished and return of the child to the biological parent is required, the prospective adoptive parents are encouraged to seek mental health counseling to address any resulting psychological or family problems.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3flegal risk placement\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the placement of a child, who is to be adopted, with a prospective adoptive parent prior to the termination of parental rights of the biological parents, under which the prospective adoptive parent assumes the risk that if the parental rights of the biological parents are not terminated the child shall be returned to the biological parents or placed as deemed appropriate by a court of the party state of the sending agency, and under which the prospective adoptive parent assumes other risks and liabilities specified in a written agreement.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 57, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1041, \'a763}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7633, 634}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.166}}}{{\f5\fs12\hyphpar0\qj{, 232.167}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.159}}}{\*\bkmkstart stylerid1_2E14_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Financial responsibility.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Financial responsibility for any child placed pursuant to the provisions of the interstate compact on the placement of children under }{{\f5\fs18\hyphpar0\qj{section 232.158}}}{ shall be determined in accordance with the provisions of article V of that interstate compact in the first instance. However, in the event of partial or complete default of performance thereunder, the provisions of }{{\f5\fs18\hyphpar0\qj{chapters 252}}}{ and }{{\f5\fs18\hyphpar0\qj{252A}}}{, fixing responsibility for the support of children also may be invoked.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7238.34}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 173, \'a730}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{CS85, \'a7232.159}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1032, \'a7201}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.166}}}{{\f5\fs12\hyphpar0\qj{, 232.167}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.160}}}{\*\bkmkstart stylerid1_2E14_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Department of health and human services as public authority.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fappropriate public authorities\u8221\'3f}}}{ as used in article III of the interstate compact on the placement of children under }{{\f5\fs18\hyphpar0\qj{section 232.158}}}{ shall, with reference to this state, mean the state department of health and human services and the department shall receive and act with reference to notices required by article III of that interstate compact.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7238.35}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 96, \'a7157, 159}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 173, \'a730}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{CS85, \'a7232.160}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1032, \'a7201}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7635}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.166}}}{{\f5\fs12\hyphpar0\qj{, 232.167}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.161}}}{\*\bkmkstart stylerid1_2E14_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Department as authority in receiving state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{As used in paragraph }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{ of article V of the interstate compact on the placement of children under }{{\f5\fs18\hyphpar0\qj{section 232.158}}}{, the phrase }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fappropriate authority in the receiving state\u8221\'3f}}}{ with reference to this state means the state department of health and human services.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7238.36}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 96, \'a7157, 159}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 173, \'a730}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{CS85, \'a7232.161}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1032, \'a7201}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7636}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.166}}}{{\f5\fs12\hyphpar0\qj{, 232.167}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.162}}}{\*\bkmkstart stylerid1_2E14_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Authority to enter agreements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The officers and agencies of this state and its subdivisions having authority to place children may enter into agreements with appropriate officers or agencies of or in other party states pursuant to paragraph }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{ of article V of the interstate compact on the placement of children under }{{\f5\fs18\hyphpar0\qj{section 232.158}}}{. Any such agreement which contains a financial commitment or imposes a financial obligation on this state or a subdivision or agency of this state shall not be binding unless it has the approval in writing of the director or the director\u8217\'3fs designee in the case of the state and the county general assistance director in the case of a subdivision of the state.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7238.37}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 173, \'a730}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{CS85, \'a7232.162}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1212, \'a78}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1032, \'a7201}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7637}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.166}}}{{\f5\fs12\hyphpar0\qj{, 232.167}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.163}}}{\*\bkmkstart stylerid1_2E14_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Visitation, inspection, or supervision.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any requirements for visitation, inspection, or supervision of children, homes, institutions, or other agencies in another party state which may apply under the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall be deemed to be met if performed pursuant to an agreement entered into by appropriate officers or agencies of this state or a subdivision of this state as contemplated by paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ of article V of the interstate compact on the placement of children contained in }}}{{\f5\fs18\hyphpar0\qj{section 232.158}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a child is placed outside the residency state of the child\u8217\'3fs parent, the sending agency shall provide for a designee to visit the child at least once every twelve months and to submit a written report to the court concerning the child and the visit.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7238.38}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 173, \'a730}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{CS85, \'a7232.163}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 99, \'a76}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1100, \'a727}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1032, \'a7201}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.166}}}{{\f5\fs12\hyphpar0\qj{, 232.167}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.164}}}{\*\bkmkstart stylerid1_2E14_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Court authority to place child in another state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Any court having jurisdiction to place delinquent children may place such a child in an institution of or in another state pursuant to article VI of the interstate compact on the placement of children, }{{\f5\fs18\hyphpar0\qj{section 232.158}}}{, and shall retain jurisdiction as provided in article V of that interstate compact.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7238.39}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 173, \'a730}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{CS85, \'a7232.164}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1032, \'a7201}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.166}}}{{\f5\fs12\hyphpar0\qj{, 232.167}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.165}}}{\*\bkmkstart stylerid1_2E14_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Executive head.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{As used in article VII of the interstate compact on the placement of children, }{{\f5\fs18\hyphpar0\qj{section 232.158}}}{, the term }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fexecutive head\u8221\'3f}}}{ means the governor. The governor is hereby authorized to appoint a compact administrator in accordance with the terms of article VII of that interstate compact.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7238.40}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 173, \'a730}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{CS85, \'a7232.165}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1032, \'a7201}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.166}}}{{\f5\fs12\hyphpar0\qj{, 232.167}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.166}}}{\*\bkmkstart stylerid1_2E14_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Statutes not affected.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Nothing contained in }{{\f5\fs18\hyphpar0\qj{sections 232.158 through 232.165}}}{ shall be deemed to affect or modify the other provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ or of }{{\f5\fs18\hyphpar0\qj{chapter 600}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7238.41}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 173, \'a730}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{CS85, \'a7232.166}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2020 Acts, ch 1063, \'a791}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.167}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.167}}}{\*\bkmkstart stylerid1_2E14_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Penalty.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A person or agency which violates or aids and abets in the violation of any of the provisions of }{{\f5\fs18\hyphpar0\qj{sections 232.158 through 232.166}}}{ commits a fraudulent practice.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1249, \'a715}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.168}}}{\*\bkmkstart stylerid1_2E14_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Attorney general to enforce.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The attorney general may, on the attorney general\u8217\'3fs own initiative, institute any criminal and civil actions and proceedings under }{{\f5\fs18\hyphpar0\qj{this subchapter}}}{, at whatever stage of placement necessary, to enforce the interstate compact on the placement of children, including, but not limited to, seeking enforcement of the provisions of the compact through the courts of a party state. The department shall cooperate with the attorney general and shall refer any placement or proposed placement to the attorney general which may require enforcement measures.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1174, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1062, \'a794}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7638}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{232.169 and 232.170}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0{\f5\fs18\chcbpat2}\par}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER X}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E15_2E2_2E2}{INTERSTATE JUVENILE COMPACTS}{\*\bkmkend stylerid1_2E15_2E2_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.171}}}{\*\bkmkstart stylerid1_2E15_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Interstate compact on juveniles.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The state of Iowa through its courts and agencies is hereby authorized to enter into interstate compacts on juveniles in behalf of this state with any other contracting state which legally joins therein in substantially the following form and the contracting states solemnly agree:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E15_2E3_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E3_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article I \u8212\'3f Findings and purposes.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That juveniles who are not under proper supervision and control, or who have absconded, escaped or run away, are likely to endanger their own health, morals and welfare, and the health, morals and welfare of others. The cooperation of the states party to this compact is therefore necessary to provide for the welfare and protection of juveniles and of the public with respect to}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Cooperative supervision of delinquent juveniles on probation or parole;}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The return, from one state to another, of delinquent juveniles who have escaped or absconded;}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The return, from one state to another, of nondelinquent juveniles who have run away from home; and}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Additional measures for the protection of juveniles and of the public, which any two or more of the party states may find desirable to undertake cooperatively. In carrying out the provisions of this compact the party states shall be guided by the noncriminal, reformative and protective policies which guide their laws concerning delinquent, neglected or dependent juveniles generally. It shall be the policy of the states party to this compact to cooperate and observe their respective responsibilities for the prompt return and acceptance of juveniles and delinquent juveniles who become subject to the provisions of this compact. The provisions of this compact shall be reasonably and liberally construed to accomplish the foregoing purposes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E15_2E3_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E3_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article II \u8212\'3f Existing rights and remedies.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That all remedies and procedures provided by this compact shall be in addition to and not in substitution for other rights, remedies and procedures, and shall not be in derogation of parental rights and responsibilities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{\*\bkmkstart stylerid1_2E15_2E3_2E6_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E3_2E6_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article III \u8212\'3f Definitions.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That, for the purposes of this compact, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fdelinquent juvenile\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any juvenile who has been adjudged delinquent and who, at the time the provisions of this compact are invoked, is still subject to the jurisdiction of the court that has made such adjudication or to the jurisdiction or supervision of an agency or institution pursuant to an order of such court; }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fprobation or parole\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any kind of conditional release of juveniles authorized under the laws of the states party hereto; }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fcourt\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any court having jurisdiction over delinquent, neglected or dependent children; }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fstate\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any state, territory or possession of the United States, the District of Columbia, and the Commonwealth of Puerto Rico; and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fresidence\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or any variant thereof means a place at which a home or regular place of abode is maintained.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{\*\bkmkstart stylerid1_2E15_2E3_2E7_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E3_2E7_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article IV }}}{{\i\f5\fs18\hyphpar0\qj{\u8212\'3f}}}{{\i\f5\fs18\hyphpar0\qj{ Return of runaways.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the parent, guardian, or person or agency entitled to legal custody of a juvenile who has not been adjudged delinquent but who has run away without the consent of such parent, guardian, or person or agency may petition the appropriate court in the demanding state for the issuance of a requisition for the juvenile\u8217\'3fs return. The petition shall state the name and age of the juvenile, the name of the petitioner and the basis of entitlement to the juvenile\u8217\'3fs custody, the circumstances of the juvenile\u8217\'3fs running away, the juvenile\u8217\'3fs location if known at the time application is made, and such other facts as may tend to show that the juvenile who has run away is endangering the juvenile\u8217\'3fs own welfare or the welfare of others and is not an emancipated minor. The petition shall be verified by affidavit, shall be executed in duplicate, and shall be accompanied by two certified copies of the document or documents on which the petitioner\u8217\'3fs entitlement to the juvenile\u8217\'3fs custody is based, such as birth certificates, letters of guardianship, or custody decrees. Such further affidavits and other documents as may be deemed proper may be submitted with such petition. The judge of the court to which this application is made may hold a hearing thereon to determine whether for the purposes of this compact the petitioner is entitled to the legal custody of the juvenile, whether or not it appears that the juvenile has in fact run away without consent, whether or not the juvenile is an emancipated minor, and whether or not it is in the best interest of the juvenile to compel the juvenile\u8217\'3fs return to the state. If the judge determines, either with or without a hearing, that the juvenile should be returned, the judge shall present to the appropriate court or to the executive authority of the state where the juvenile is alleged to be located a written requisition for the return of such juvenile. Such requisition shall set forth the name and age of the juvenile, the determination of the court that the juvenile has run away without the consent of a parent, guardian, or person or agency entitled to the juvenile\u8217\'3fs legal custody, and that it is in the best interest and for the protection of such juvenile that the juvenile be returned. In the event that a proceeding for the adjudication of the juvenile as a delinquent, neglected or dependent juvenile is pending in the court at the time when such juvenile runs away, the court may issue a requisition for the return of such juvenile upon its own motion, regardless of the consent of the parent, guardian, or person or agency entitled to legal custody, reciting therein the nature and circumstances of the pending proceeding. The requisition shall in every case be executed in duplicate and shall be signed by the judge. One copy of the requisition shall be filed with the compact administrator of the demanding state, there to remain on file subject to the provisions of law governing records of such court. Upon the receipt of a requisition demanding the return of a juvenile who has run away, the court or the executive authority to whom the requisition is addressed shall issue an order to any peace officer or other appropriate person directing the officer or person to take into custody and detain such juvenile. Such detention order must substantially recite the facts necessary to the validity of its issuance hereunder. No juvenile detained upon such order shall be delivered over to the officer whom the court demanding the juvenile shall have appointed to receive the juvenile, unless the juvenile shall first be taken forthwith before a judge of a court in the state, who shall inform the juvenile of the demand made for the juvenile\u8217\'3fs return, and who may appoint counsel or guardian ad litem for the juvenile. If the judge of such court shall find that the requisition is in order, the judge shall deliver such juvenile over to the officer whom the court demanding the juvenile shall have appointed to receive the juvenile. The judge, however, may fix a reasonable time to be allowed for the purpose of testing the legality of the proceeding.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon reasonable information that a person is a juvenile who has run away from another state party to this compact without the consent of a parent, guardian, or person or agency entitled to the juvenile\u8217\'3fs legal custody, such juvenile may be taken into custody without a requisition and brought forthwith before a judge of the appropriate court who may appoint counsel or guardian ad litem for such juvenile and who shall determine after a hearing whether sufficient cause exists to hold the person, subject to the order of the court, for the person\u8217\'3fs own protection and welfare, for such a time not exceeding ninety days as will enable the person\u8217\'3fs return to another state party to this compact pursuant to a requisition for the person\u8217\'3fs return from a court of that state. If, at the time when a state seeks the return of a juvenile who has run away, there is pending in the state wherein the juvenile is found any criminal charge, or any proceeding to have the juvenile adjudicated a delinquent juvenile for an act committed in such state, or if the juvenile is suspected of having committed within such state a criminal offense or an act of juvenile delinquency, the juvenile shall not be returned without the consent of such state until discharged from prosecution or other form of proceeding, imprisonment, detention or supervision for such offense or juvenile delinquency. The duly accredited officers of any state party to this compact, upon the establishment of their authority and the identity of the juvenile being returned, shall be permitted to transport such juvenile through any and all states party to this compact, without interference. Upon the juvenile\u8217\'3fs return to the state from which the juvenile ran away, the juvenile shall be subject to such further proceedings as may be appropriate under the laws of that state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the state to which a juvenile is returned under this article shall be responsible for payment of the transportation costs of such return.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fjuvenile\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ as used in this article means any person who is a minor under the law of the state of residence of the parent, guardian, or person or agency entitled to the legal custody of such minor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{\*\bkmkstart stylerid1_2E15_2E3_2E8_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E3_2E8_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article V \u8212\'3f Return of escapees and absconders.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the appropriate person or authority from whose probation or parole supervision a delinquent juvenile has absconded or from whose institutional custody the delinquent juvenile has escaped shall present to the appropriate court or to the executive authority of the state where the delinquent juvenile is alleged to be located a written requisition for the return of such delinquent juvenile. Such requisition shall state the name and age of the delinquent juvenile, the particulars of the juvenile\u8217\'3fs adjudication as a delinquent juvenile, the circumstances of the breach of the terms of the juvenile\u8217\'3fs probation or parole or of the juvenile\u8217\'3fs escape from an institution or agency vested with the juvenile\u8217\'3fs legal custody or supervision, and the location of such delinquent juvenile, if known, at the time the requisition is made. The requisition shall be verified by affidavit, shall be executed in duplicate, and shall be accompanied by two certified copies of the judgment, formal adjudication, or order of commitment which subjects such delinquent juvenile to probation or parole or to the legal custody of the institution or agency concerned. Such further affidavits and other documents as may be deemed proper may be submitted with such requisition. One copy of the requisition shall be filed with the compact administrator of the demanding state, there to remain on file subject to the provisions of law governing records of the appropriate court. Upon the receipt of a requisition demanding the return of a delinquent juvenile who has absconded or escaped, the court or the executive authority to whom the requisition is addressed shall issue an order to any peace officer or other appropriate person directing the officer or person to take into custody and detain such delinquent juvenile. Such detention order must substantially recite the facts necessary to the validity of its issuance hereunder. No delinquent juvenile detained upon such order shall be delivered over to the officer whom the appropriate person or authority demanding the juvenile shall have appointed to receive the juvenile, unless the juvenile shall first be taken forthwith before a judge of an appropriate court in the state, who shall inform the juvenile of the demand made for the juvenile\u8217\'3fs return and who may appoint counsel or guardian ad litem for the juvenile. If the judge of such court shall find that the requisition is in order, the judge shall deliver such delinquent juvenile over to the officer whom the appropriate person or authority demanding the juvenile shall have appointed to receive the juvenile. The judge, however, may fix a reasonable time to be allowed for the purpose of testing the legality of the proceeding.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon reasonable information that a person is a delinquent juvenile who has absconded while on probation or parole, or escaped from an institution or agency vested with the person\u8217\'3fs legal custody or supervision in any state party to this compact, such person may be taken into custody in any other state party to this compact without a requisition. But in such event, the person must be taken forthwith before a judge of the appropriate court, who may appoint counsel or guardian ad litem for such person and who shall determine, after a hearing, whether sufficient cause exists to hold the person subject to the order of the court for such a time, not exceeding ninety days, as will enable the person\u8217\'3fs detention under a detention order issued on a requisition pursuant to this article. If, at the time when a state seeks the return of a delinquent juvenile who has either absconded while on probation or parole or escaped from an institution or agency vested with the juvenile\u8217\'3fs legal custody or supervision, there is pending in the state wherein the juvenile is detained any criminal charge or any proceeding to have the juvenile adjudicated a delinquent juvenile for an act committed in such state, or if the juvenile is suspected of having committed within such state a criminal offense or an act of juvenile delinquency, the juvenile shall not be returned without the consent of such state until discharged from prosecution or other form of proceeding, imprisonment, detention or supervision for such offense or juvenile delinquency. The duly accredited officers of any state party to this compact, upon the establishment of their authority and the identity of the delinquent juvenile being returned, shall be permitted to transport such delinquent juvenile through any and all states party to this compact, without interference. Upon the juvenile\u8217\'3fs return to the state from which the juvenile escaped or absconded, the delinquent juvenile shall be subject to such further proceedings as may be appropriate under the laws of that state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the state to which a delinquent juvenile is returned under this article shall be responsible for payment of the transportation costs of such return.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{\*\bkmkstart stylerid1_2E15_2E3_2E9_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E3_2E9_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article VI \u8212\'3f Voluntary return procedure.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That any delinquent juvenile who has absconded while on probation or parole, or escaped from an institution or agency vested with the juvenile\u8217\'3fs legal custody or supervision in any state party to this compact, and any juvenile who has run away from any state party to this compact, who is taken into custody without a requisition in another state party to this compact under the provisions of article IV, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, or of article V, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, may consent to the juvenile\u8217\'3fs immediate return to the state from which the juvenile absconded, escaped or ran away. Such consent shall be given by the juvenile or delinquent juvenile and the juvenile\u8217\'3fs counsel or guardian ad litem, if any, by executing or subscribing a writing, in the presence of a judge of the appropriate court, which states that the juvenile or delinquent juvenile and the juvenile\u8217\'3fs counsel or guardian ad litem, if any, consent to the juvenile\u8217\'3fs return to the demanding state. Before such consent shall be executed or subscribed, however, the judge, in the presence of counsel or guardian ad litem, if any, shall inform the juvenile or delinquent juvenile of the juvenile\u8217\'3fs rights under this compact. When the consent has been duly executed, it shall be forwarded to and filed with the compact administrator of the state in which the court is located and the judge shall direct the officer having the juvenile or delinquent juvenile in custody to deliver the juvenile to the duly accredited officer or officers of the state demanding the juvenile\u8217\'3fs return, and shall cause to be delivered to such officer or officers a copy of the consent. The court may, however, upon the request of the state to which the juvenile or delinquent juvenile is being returned, order the juvenile to return unaccompanied to such state and shall provide the juvenile with a copy of such court order; in such event a copy of the consent shall be forwarded to the compact administrator of the state to which said juvenile or delinquent juvenile is ordered to return.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{\*\bkmkstart stylerid1_2E15_2E3_2E1_30_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E3_2E1_30_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article VII \u8212\'3f Cooperative supervision of probationers and parolees.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the duly constituted judicial and administrative authorities of a state party to this compact, herein called }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fsending state\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, may permit any delinquent juvenile within such state, placed on probation or parole, to reside in any other state party to this compact, herein called }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3freceiving state\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, while on probation or parole, and the receiving state shall accept such delinquent juvenile, if the parent, guardian, or person entitled to the legal custody of such delinquent juvenile is residing or undertakes to reside within the receiving state. Before granting such permission, opportunity shall be given to the receiving state to make such investigations as it deems necessary. The authorities of the sending state shall send to the authorities of the receiving state copies of pertinent court orders, social case studies and all other available information which may be of value to and assist the receiving state in supervising a probationer or parolee under this compact. A receiving state, in its discretion, may agree to accept supervision of a probationer or parolee in cases where the parent, guardian, or person entitled to the legal custody of the delinquent juvenile is not a resident of the receiving state, and if so accepted the sending state may transfer supervision accordingly.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That each receiving state will assume the duties of visitation and of supervision over any such delinquent juvenile and in the exercise of those duties will be governed by the same standards of visitation and supervision that prevail for its own delinquent juveniles released on probation or parole.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That, after consultation between the appropriate authorities of the sending state and of the receiving state as to the desirability and necessity of returning such a delinquent juvenile, the duly accredited officers of a sending state may enter a receiving state and there apprehend and retake any such delinquent juvenile on probation or parole. For that purpose, no formalities will be required, other than establishing the authority of the officer and the identity of the delinquent juvenile to be retaken and returned. The decision of the sending state to retake a delinquent juvenile on probation or parole shall be conclusive upon and not reviewable within the receiving state, but if, at the time the sending state seeks to retake a delinquent juvenile on probation or parole, there is pending against the juvenile within the receiving state any criminal charge or any proceeding to have the juvenile adjudicated a delinquent juvenile for any act committed in such state, or if the juvenile is suspected of having committed within such state a criminal offense or an act of juvenile delinquency, the juvenile shall not be returned without the consent of the receiving state until discharged from prosecution or other form of proceeding, imprisonment, detention or supervision for such offense or juvenile delinquency. The duly accredited officers of the sending state shall be permitted to transport delinquent juveniles being so returned through any and all states party to this compact, without interference.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the sending state shall be responsible under this article for paying the costs of transporting any delinquent juvenile to the receiving state or of returning any delinquent juvenile to the sending state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{\*\bkmkstart stylerid1_2E15_2E3_2E11_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E3_2E11_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article VIII \u8212\'3f Responsibility for costs.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the provisions of article IV, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, article V, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and article VII, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ of this compact shall not be construed to alter or affect any internal relationship among the departments, agencies and officers of and in the government of a party state, or between a party state and its subdivisions, as to the payment of costs, or responsibilities therefor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That nothing in this compact shall be construed to prevent any party state or subdivision thereof from asserting any right against any person, agency or other entity in regard to costs for which such party state or subdivision thereof may be responsible pursuant to article IV, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, article V, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, or article VII, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ of this compact.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{\*\bkmkstart stylerid1_2E15_2E3_2E12_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E3_2E12_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article IX \u8212\'3f Detention practices.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That, to every extent possible, it shall be the policy of states party to this compact that no juvenile or delinquent juvenile shall be placed or detained in any prison, jail or lockup nor be detained or transported in association with criminal, vicious or dissolute persons.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{\*\bkmkstart stylerid1_2E15_2E3_2E13_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E3_2E13_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article X \u8212\'3f Supplementary agreements.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the duly constituted administrative authorities of a state party to this compact may enter into supplementary agreements with any other state or states party hereto for the cooperative care, treatment and rehabilitation of delinquent juveniles whenever they shall find that such agreements will improve the facilities or programs available for such care, treatment and rehabilitation. Such care, treatment and rehabilitation may be provided in an institution located within any state entering into such supplementary agreement. Such supplementary agreements shall:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide the rates to be paid for the care, treatment and custody of such delinquent juveniles, taking into consideration the character of facilities, services and subsistence furnished;}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide that the delinquent juvenile shall be given a court hearing prior to the juvenile being sent to another state for care, treatment and custody;}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide that the state receiving such a delinquent juvenile in one of its institutions shall act solely as agent for the state sending such delinquent juvenile;}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide that the sending state shall at all times retain jurisdiction over delinquent juveniles sent to an institution in another state;}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide for reasonable inspection of such institutions by the sending state;}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide that the consent of the parent, guardian, or person or agency entitled to the legal custody of the delinquent juvenile shall be secured prior to the juvenile being sent to another state; and}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Make provision for such other matters and details as shall be necessary to protect the rights and equities of such delinquent juveniles and of the cooperating states.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{\*\bkmkstart stylerid1_2E15_2E3_2E14_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E3_2E14_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article XI \u8212\'3f Acceptance of federal and other aid.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That any state party to this compact may accept any and all donations, gifts and grants of money, equipment and services from the federal or any local government, or any agency thereof and from any person, firm or corporation, for any of the purposes and functions of this compact, and may receive and utilize the same subject to the terms, conditions and regulations governing such donations, gifts and grants.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{\*\bkmkstart stylerid1_2E15_2E3_2E15_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E3_2E15_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article XII \u8212\'3f Compact administrators.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the governor of each state party to this compact shall designate an officer who, acting jointly with like officers of other party states, shall promulgate rules and regulations to carry out more effectively the terms and provisions of this compact.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{\*\bkmkstart stylerid1_2E15_2E3_2E16_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E3_2E16_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article XIII \u8212\'3f Execution of compact.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That this compact shall become operative immediately upon its execution by any state as between it and any other state or states so executing. When executed it shall have the full force and effect of law within such state, the form of execution to be in accordance with the laws of the executing state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{\*\bkmkstart stylerid1_2E15_2E3_2E17_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E3_2E17_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article XIV \u8212\'3f Renunciation.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That this compact shall continue in force and remain binding upon each executing state until renounced by it. Renunciation of this compact shall be by the same authority which executed it, by sending six months\u8217\'3f notice in writing of its intention to withdraw from the compact to the other states party hereto. The duties and obligations of a renouncing state under article VII hereof shall continue as to parolees and probationers residing therein at the time of withdrawal until retaken or finally discharged. Supplementary agreements entered into under article X hereof shall be subject to renunciation as provided by such supplementary agreements, and shall not be subject to the six months\u8217\'3f renunciation notice of the present article.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{\*\bkmkstart stylerid1_2E15_2E3_2E18_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E3_2E18_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article XV \u8212\'3f Rendition amendment.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This article shall provide additional remedies, and shall be binding only as among and between those party states which specifically execute the same.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All provisions and procedures of articles V and VI of the Interstate Compact on Juveniles shall be construed to apply to any juvenile charged with being a delinquent by reason of a violation of any criminal law. Any juvenile charged with being a delinquent by reason of violating any criminal law shall be returned to the requesting state upon a requisition to the state where the juvenile may be found. A petition in such case shall be filed in a court of competent jurisdiction in the requesting state where the violation of criminal law is alleged to have been committed. The petition may be filed regardless of whether the juvenile has left the state before or after the filing of the petition. The requisition described in article V of the compact shall be forwarded by the judge of the court in which the petition has been filed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{16.}}}{\*\bkmkstart stylerid1_2E15_2E3_2E19_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E3_2E19_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Out-of-state confinement amendment.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Whenever the duly constituted judicial or administrative authorities in a sending state shall determine that confinement of a probationer or reconfinement of a parolee is necessary or desirable, said officials may direct that the confinement or reconfinement be in an appropriate institution for delinquent juveniles within the territory of the receiving state, such receiving state to act in that regard solely as agent for the sending state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Escapees and absconders who would otherwise be returned pursuant to article V of the compact may be confined or reconfined in the receiving state pursuant to this amendment. In any such case the information and allegations required to be made and furnished in a requisition pursuant to such article shall be made and furnished, but in place of the demand pursuant to article V, the sending state shall request confinement or reconfinement in the receiving state. Whenever applicable, detention orders as provided in article V may be employed pursuant to this paragraph preliminary to disposition of the escapee or absconder.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The confinement or reconfinement of a parolee, probationer, escapee, or absconder pursuant to this amendment shall require the concurrence of the appropriate judicial or administrative authorities of the receiving state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in this amendment:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSending state\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means sending state as that term is used in article VII of the compact or the state from which a delinquent juvenile has escaped or absconded within the meaning of article V of the compact.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fReceiving state\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any state, other than the sending state, in which a parolee, probationer, escapee, or absconder may be found, provided that said state is a party to this amendment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Every state which adopts this amendment shall designate at least one of its institutions for delinquent juveniles as a \u8220\'3fcompact institution\u8221\'3f and shall confine persons therein as provided in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ hereof unless the sending and receiving state in question shall make specific contractual arrangements to the contrary. All states party to this amendment shall have access to \u8220\'3fcompact institutions\u8221\'3f at all reasonable hours for the purpose of inspecting the facilities thereof and for the purpose of visiting such of said state\u8217\'3fs delinquents as may be confined in the institution.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Persons confined in \u8220\'3fcompact institutions\u8221\'3f pursuant to the terms of this compact shall at all times be subject to the jurisdiction of the sending state and may at any time be removed from said \u8220\'3fcompact institution\u8221\'3f for transfer to an appropriate institution within the sending state, for return to probation or parole, for discharge or for any purpose permitted by the laws of the sending state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All persons who may be confined in a \u8220\'3fcompact institution\u8221\'3f pursuant to the provisions of this amendment shall be treated in a reasonable and humane manner. The fact of confinement or reconfinement in a receiving state shall not deprive any person so confined or reconfined of any rights which said person would have had if confined or reconfined in an appropriate institution of the sending state; nor shall any agreement to submit to confinement or reconfinement pursuant to the terms of this amendment be construed as a waiver of any rights which the delinquent would have had if the delinquent had been confined or reconfined in any appropriate institution of the sending state except that the hearing or hearings, if any, to which a parolee, probationer, escapee, or absconder may be entitled, prior to confinement or reconfinement, by the laws of the sending state may be had before the appropriate judicial or administrative officers of the receiving state. In this event, said judicial and administrative officers shall act as agents of the sending state after consultation with appropriate officers of the sending state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any receiving state incurring costs or other expenses under this amendment shall be reimbursed in the amount of such costs or other expenses by the sending state unless the states concerned shall specifically otherwise agree. Any two or more states party to this amendment may enter into supplementary agreements determining a different allocation of costs as among themselves.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This amendment shall take initial effect when entered into by any two or more states party to the compact and shall be effective as to those states which have specifically enacted this amendment. Rules and regulations necessary to effectuate the terms of this amendment may be promulgated by the appropriate officers of those states which have enacted this amendment.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C62, 66, 71, 73, 75, 77, \'a7231.14; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7232.139}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 182, \'a71}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{CS85, \'a7232.171}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1032, \'a7201}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7639 \u8211\'3f 641}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.172}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{See }{{\f5\fs12\hyphpar0\qj{\'a7232.172}}}{ for limitations on applicability of this section}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.172}}}{\*\bkmkstart stylerid1_2E15_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Confinement of delinquent juvenile.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For a juvenile under the jurisdiction of this state who is subject to the interstate compact for juveniles under }}}{{\f5\fs18\hyphpar0\qj{section 232.173}}}{{\f5\fs18\hyphpar0\qj{, the confinement of the juvenile in an institution located within another compacting state shall be as provided under the compact.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ applies to the confinement of a delinquent juvenile under the jurisdiction of this state in an institution located within a noncompacting state, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 232.173}}}{{\f5\fs18\hyphpar0\qj{, that entered into the interstate compact on juveniles under }}}{{\f5\fs18\hyphpar0\qj{section 232.171}}}{{\f5\fs18\hyphpar0\qj{. In addition to any institution in which the authorities of this state may otherwise confine or order the confinement of the delinquent juvenile, such authorities may, pursuant to the out-of-state confinement amendment to the interstate compact on juveniles in }}}{{\f5\fs18\hyphpar0\qj{section 232.171,}}}{{\f5\fs18\hyphpar0\qj{ confine or order the confinement of the delinquent juvenile in a compact institution within another party state.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, \'a7231.15; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7232.140}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{CS85, \'a7232.172}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2010 Acts, ch 1192, \'a775}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 34, \'a758}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.173}}}{\*\bkmkstart stylerid1_2E15_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Interstate compact for juveniles.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E15_2E5_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E5_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article I }}}{{\i\f5\fs18\hyphpar0\qj{\u8212\'3f}}}{{\i\f5\fs18\hyphpar0\qj{ Purpose.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The compacting states to this interstate compact recognize that each state is responsible for the proper supervision or return of juveniles, delinquents, and status offenders who are on probation or parole and who have absconded, escaped, or run away from supervision and control and in so doing have endangered their own safety and the safety of others. The compacting states also recognize that each state is responsible for the safe return of juveniles who have run away from home and in doing so have left their state of residence. The compacting states also recognize that Congress, by enacting the }}}{{\f5\fs18\hyphpar0\qj{Crime Control Act}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{4 U.S.C. \'a7112 (1965)}}}{{\f5\fs18\hyphpar0\qj{, has authorized and encouraged compacts for cooperative efforts and mutual assistance in the prevention of crime.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It is the purpose of this compact, through means of joint and cooperative action among the compacting states to:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Ensure that the adjudicated juveniles and status offenders subject to this compact are provided adequate supervision and services in the receiving state as ordered by the adjudicating judge or parole authority in the sending state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Ensure that the public safety interests of the citizens, including the victims of juvenile offenders, in both the sending and receiving states are adequately protected.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Return juveniles who have run away, absconded, or escaped from supervision or control or have been accused of an offense to the state requesting their return.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Make contracts for the cooperative institutionalization in public facilities in member states for delinquent youth needing special services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide for the effective tracking and supervision of juveniles.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Equitably allocate the costs, benefits, and obligations of the compacting states.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(7)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Establish procedures to manage the movement between states of juvenile offenders released to the community under the jurisdiction of courts, juvenile departments, or any other criminal or juvenile justice agency which has jurisdiction over juvenile offenders.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(8)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Insure immediate notice to jurisdictions where defined offenders are authorized to travel or to relocate across state lines.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(9)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Establish procedures to resolve pending charges (detainers) against juvenile offenders prior to transfer or release to the community under the terms of this compact.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(10)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Establish a system of uniform data collection on information pertaining to juveniles subject to this compact that allows access by authorized juvenile justice and criminal justice officials, and regular reporting of compact activities to heads of state executive, judicial, and legislative branches and juvenile and criminal justice administrators.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(11)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Monitor compliance with rules governing interstate movement of juveniles and initiate interventions to address and correct noncompliance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(12)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Coordinate training and education regarding the regulation of interstate movement of juveniles for officials involved in such activity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(13)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Coordinate the implementation and operation of the compact with the interstate compact for the placement of children, the interstate compact for adult offender supervision, and other compacts affecting juveniles particularly in those cases where concurrent or overlapping supervision issues arise.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It is the policy of the compacting states that the activities conducted by the interstate commission created in this compact are the formation of public policies and therefore are public business. Furthermore, the compacting states shall cooperate and observe their individual and collective duties and responsibilities for the prompt return and acceptance of juveniles subject to the provisions of this compact. The provisions of this compact shall be reasonably and liberally construed to accomplish the purposes and policies of the compact.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E15_2E5_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E5_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article II }}}{{\i\f5\fs18\hyphpar0\qj{\u8212\'3f}}}{{\i\f5\fs18\hyphpar0\qj{ Definitions.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in this compact, unless the context clearly requires a different construction:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fBylaws\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means those bylaws established by the interstate commission for its governance, or for directing or controlling its actions or conduct.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCompact administrator\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the individual in each compacting state appointed pursuant to the terms of this compact, responsible for the administration and management of the state\u8217\'3fs supervision and transfer of juveniles subject to the terms of this compact, the rules adopted by the interstate commission, and policies adopted by the state council under this compact.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCompacting state\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any state which has enacted the enabling legislation for this compact.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCommissioner\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the voting representative of each compacting state appointed pursuant to article III of this compact.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCourt\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any court having jurisdiction over delinquent, neglected, or dependent children.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDeputy compact administrator\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the individual, if any, in each compacting state appointed to act on behalf of a compact administrator pursuant to the terms of this compact responsible for the administration and management of the state\u8217\'3fs supervision and transfer of juveniles subject to the terms of this compact, the rules adopted by the interstate commission, and policies adopted by the state council under this compact.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fInterstate commission\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the interstate commission for juveniles created by article III of this compact.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fJuvenile\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any person defined as a juvenile in any member state or by the rules of the interstate commission, including persons who are any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An accused delinquent, meaning a person charged with an offense that, if committed by an adult, would be a criminal offense.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An adjudicated delinquent, meaning a person found to have committed an offense that, if committed by an adult, would be a criminal offense.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An accused status offender, meaning a person charged with an offense that would not be a criminal offense if committed by an adult.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An adjudicated status offender, meaning a person found to have committed an offense that would not be a criminal offense if committed by an adult.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A nonoffender, meaning a person in need of supervision who has not been accused or adjudicated a status offender or delinquent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fNoncompacting state\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any state which has not enacted the enabling legislation for this compact.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fProbation or parole\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any kind of supervision or conditional release of juveniles authorized under the laws of the compacting states.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{k.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fRule\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a written statement by the interstate commission promulgated pursuant to article VI of this compact that is of general applicability, implements, interprets or prescribes a policy or provision of the compact, or an organizational, procedural, or practice requirement of the commission, and has the force and effect of statutory law in a compacting state, and includes the amendment, repeal, or suspension of an existing rule. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{l.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fState\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a state of the United States, the District of Columbia or its designee, the Commonwealth of Puerto Rico, the United States Virgin Islands, Guam, American Samoa, and the Northern Marianas Islands.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{\*\bkmkstart stylerid1_2E15_2E5_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E5_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article III }}}{{\i\f5\fs18\hyphpar0\qj{\u8212\'3f}}}{{\i\f5\fs18\hyphpar0\qj{ Interstate commission for juveniles.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The compacting states hereby create the interstate commission for juveniles. The commission shall be a body corporate and joint agency of the compacting states. The commission shall have all the responsibilities, powers, and duties set forth in this compact, and such additional powers as may be conferred upon it by subsequent action of the respective legislatures of the compacting states in accordance with the terms of this compact.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The interstate commission shall consist of commissioners appointed by the appropriate appointing authority in each state pursuant to the rules and requirements of each compacting state and in consultation with the state council for interstate juvenile supervision created in this compact. The commissioner shall be the compact administrator, deputy compact administrator, or designee from that state who shall serve on the interstate commission in such capacity under or pursuant to the applicable law of the compacting state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to the commissioners who are the voting representatives of each state, the interstate commission shall include individuals who are not commissioners, but who are members of interested organizations. Such noncommissioner members must include a member of the national organizations of governors, legislators, state chief justices, attorneys general, interstate compact for adult offender supervision, interstate compact for the placement of children, juvenile justice and juvenile corrections officials, and crime victims. All noncommissioner members of the interstate commission shall be ex officio, nonvoting members. The interstate commission may provide in its bylaws for such additional ex officio, nonvoting members, including members of other national organizations, in such numbers as shall be determined by the commission. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each compacting state represented at any meeting of the commission is entitled to one vote. A majority of the compacting states shall constitute a quorum for the transaction of business, unless a larger quorum is required by the bylaws of the interstate commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall meet at least once each calendar year. The chairperson may call additional meetings and, upon the request of a simple majority of the compacting states, shall call additional meetings. Public notice shall be given of all meetings and meetings shall be open to the public.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The interstate commission shall establish an executive committee, which shall include commission officers, members, and others as determined by the bylaws. The executive committee shall have the power to act on behalf of the interstate commission during periods when the interstate commission is not in session, with the exception of rulemaking or amendment to the compact. The executive committee shall oversee the day-to-day activities of the administration of the compact managed by an executive director and interstate commission staff; administer enforcement and compliance with the provisions of the compact, its bylaws, and rules; and perform such other duties as directed by the interstate commission or set forth in the bylaws.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each member of the interstate commission shall have the right and power to cast a vote to which that compacting state is entitled and to participate in the business and affairs of the interstate commission. A member shall vote in person and shall not delegate a vote to another compacting state. However, a commissioner, in consultation with the state council, shall appoint another authorized representative, in the absence of the commissioner from that state, to cast a vote on behalf of the compacting state at a specified meeting. The bylaws may provide for members\u8217\'3f participation in meetings by telephone or other means of telecommunication or electronic communication.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The interstate commission\u8217\'3fs bylaws shall establish conditions and procedures under which the interstate commission shall make its information and official records available to the public for inspection or copying. The interstate commission may exempt from disclosure any information or official records to the extent they would adversely affect personal privacy rights or proprietary interests.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Public notice shall be given of all meetings and all meetings shall be open to the public, except as set forth in the rules or as otherwise provided in the compact. The interstate commission and any of its committees may close a meeting to the public where it determines by two-thirds vote that an open meeting would be likely to:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Relate solely to the interstate commission\u8217\'3fs internal personnel practices and procedures.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Disclose matters specifically exempted from disclosure by statute.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Disclose trade secrets or commercial or financial information which is privileged or confidential.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Involve accusing any person of a crime, or formally censuring any person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Disclose information of a personal nature where disclosure would constitute a clearly unwarranted invasion of personal privacy.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Disclose investigative records compiled for law enforcement purposes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(7)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Disclose information contained in or related to an examination or operating or condition reports prepared by, or on behalf of or for the use of, the interstate commission with respect to a regulated person or entity for the purpose of regulation or supervision of such person or entity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(8)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Disclose information, the premature disclosure of which would significantly endanger the stability of a regulated person or entity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(9)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Specifically relate to the interstate commission\u8217\'3fs issuance of a subpoena, or its participation in a civil action or other legal proceeding.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For every meeting closed pursuant to this provision, the interstate commission\u8217\'3fs legal counsel shall publicly certify that, in the legal counsel\u8217\'3fs opinion, the meeting may be closed to the public, and shall reference each relevant exemptive provision. The interstate commission shall keep minutes which shall fully and clearly describe all matters discussed in any meeting and shall provide a full and accurate summary of any actions taken, and the reasons therefore, including a description of each of the views expressed on any item and the record of any roll call vote, reflected in the vote of each member on the question. All documents considered in connection with any action shall be identified in such minutes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{k.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The interstate commission shall collect standardized data concerning the interstate movement of juveniles as directed through its rules which shall specify the data to be collected, the means of collection, and data exchange and reporting requirements. Such methods of data collection, exchange, and reporting shall insofar as is reasonably possible conform to up-to-date technology and coordinate its information functions with the appropriate repository of records.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{\*\bkmkstart stylerid1_2E15_2E5_2E6_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E5_2E6_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article IV }}}{{\i\f5\fs18\hyphpar0\qj{\u8212\'3f}}}{{\i\f5\fs18\hyphpar0\qj{ Powers and duties of the interstate commission.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall have the following powers and duties:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To provide for dispute resolution among compacting states.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To promulgate rules to effect the purposes and obligations as enumerated in this compact, which shall have the force and effect of statutory law and shall be binding in the compacting states to the extent and in the manner provided in this compact. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To oversee, supervise, and coordinate the interstate movement of juveniles subject to the terms of this compact and any bylaws adopted and rules promulgated by the interstate commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To enforce compliance with the compact provisions, the rules promulgated by the interstate commission, and the bylaws, using all necessary and proper means, including but not limited to the use of judicial process.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To establish and maintain offices which shall be located within one or more of the compacting states.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To purchase and maintain insurance and bonds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To borrow, accept, hire, or contract for services of personnel.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To establish and appoint committees and hire staff which it deems necessary for the carrying out of its functions including but not limited to an executive committee as required by article III which shall have the power to act on behalf of the interstate commission in carrying out its powers and duties hereunder.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To elect or appoint such officers, attorneys, employees, agents, or consultants, and to fix their compensation, define their duties and determine their qualifications; and to establish the interstate commission\u8217\'3fs personnel policies and programs relating to, inter alia, conflicts of interest, rates of compensation, and qualifications of personnel.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To accept any and all donations and grants of money, equipment, supplies, materials, and services, and to receive, utilize, and dispose of it.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{k.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To lease, purchase, accept contributions or donations of, or otherwise to own, hold, improve, or use any property, real, personal, or mixed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{l.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To sell, convey, mortgage, pledge, lease, exchange, abandon, or otherwise dispose of any property, real, personal, or mixed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{m.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To establish a budget and make expenditures and levy dues as provided in article VIII of this compact.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{n.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To sue and be sued.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{o.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To adopt a seal and bylaws governing the management and operation of the interstate commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{p.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To perform such functions as may be necessary or appropriate to achieve the purposes of this compact.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{q.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To report annually to the legislatures, governors, judiciary, and state councils of the compacting states concerning the activities of the interstate commission during the preceding year. Such reports shall also include any recommendations that may have been adopted by the interstate commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{r.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To coordinate education, training, and public awareness regarding the interstate movement of juveniles for officials involved in such activity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{s.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To establish uniform standards of the reporting, collecting, and exchanging of data.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{t.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The interstate commission shall maintain its corporate books and records in accordance with the bylaws.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{\*\bkmkstart stylerid1_2E15_2E5_2E7_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E5_2E7_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article V }}}{{\i\f5\fs18\hyphpar0\qj{\u8212\'3f}}}{{\i\f5\fs18\hyphpar0\qj{ Organization and operation of the interstate commission.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{\*\bkmkstart stylerid1_2E15_2E5_2E7_2E2_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E5_2E7_2E2_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Bylaws.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The interstate commission shall, by a majority of the members present and voting, within twelve months after the first interstate commission meeting, adopt bylaws to govern its conduct as may be necessary or appropriate to carry out the purposes of the compact, including but not limited to all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Establishing the fiscal year of the interstate commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Establishing an executive committee and such other committees as may be necessary.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide for the establishment of committees governing any general or specific delegation of any authority or function of the interstate commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Providing reasonable procedures for calling and conducting meetings of the interstate commission and ensuring reasonable notice of each such meeting.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Establishing the titles and responsibilities of the officers of the interstate commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Providing a mechanism for concluding the operations of the interstate commission and the return of any surplus funds that may exist upon the termination of the compact after the payment or reserving of all of its debts and obligations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(7)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Providing \u8220\'3fstart-up\u8221\'3f rules for initial administration of the compact.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(8)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Establishing standards and procedures for compliance and technical assistance in carrying out the compact.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{\*\bkmkstart stylerid1_2E15_2E5_2E7_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E5_2E7_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Officers and staff.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The interstate commission shall, by a majority of the members, elect annually from among its members a chairperson and a vice chairperson, each of whom shall have such authority and duties as may be specified in the bylaws. The chairperson or, in the chairperson\u8217\'3fs absence or disability, the vice chairperson shall preside at all meetings of the interstate commission. The officers so elected shall serve without compensation or remuneration from the interstate commission; provided that, subject to the availability of budgeted funds, the officers shall be reimbursed for any ordinary and necessary costs and expenses incurred by them in the performance of their duties and responsibilities as officers of the interstate commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The interstate commission shall, through its executive committee, appoint or retain an executive director for such period, upon such terms and conditions and for such compensation as the interstate commission may deem appropriate. The executive director shall serve as secretary to the interstate commission, but shall not be a member and shall hire and supervise such other staff as may be authorized by the interstate commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{\*\bkmkstart stylerid1_2E15_2E5_2E7_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E5_2E7_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Immunity, defense, and indemnification.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission\u8217\'3fs executive director and employees shall be immune from suit and liability, either personally or in their official capacity, for any claim for damage to or loss of property or personal injury or other civil liability caused or arising out of or relating to any actual or alleged act, error, or omission that occurred, or that such person had a reasonable basis for believing occurred within the scope of commission employment, duties, or responsibilities; provided, that any such person shall not be protected from suit or liability for any damage, loss, injury, or liability caused by the intentional or willful and wanton misconduct of any such person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The liability of any commissioner, or the employee or agent of a commissioner, acting within the scope of such person\u8217\'3fs employment or duties for acts, errors, or omissions occurring within such person\u8217\'3fs state may not exceed the limits of liability set forth under the constitution and laws of that state for state officials, employees, and agents. Nothing in this subparagraph shall be construed to protect any such person from suit or liability for any damage, loss, injury, or liability caused by the intentional or willful and wanton misconduct of any such person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The interstate commission shall defend the executive director or the employees or representatives of the interstate commission and, subject to the approval of the attorney general of the state represented by any commissioner of a compacting state, shall defend such commissioner or the commissioner\u8217\'3fs representatives or employees in any civil action seeking to impose liability arising out of any actual or alleged act, error, or omission that occurred within the scope of interstate commission employment, duties, or responsibilities, or that the defendant had a reasonable basis for believing occurred within the scope of interstate commission employment, duties, or responsibilities, provided that the actual or alleged act, error, or omission did not result from intentional or willful and wanton misconduct on the part of such person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The interstate commission shall indemnify and hold the commissioner of a compacting state, or the commissioner\u8217\'3fs representatives or employees, or the interstate commission\u8217\'3fs representatives or employees, harmless in the amount of any settlement or judgment obtained against such persons arising out of any actual or alleged act, error, or omission that occurred within the scope of interstate commission employment, duties, or responsibilities, or that such persons had a reasonable basis for believing occurred within the scope of interstate commission employment, duties, or responsibilities, provided that the actual or alleged act, error, or omission did not result from intentional or willful and wanton misconduct on the part of such persons.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{\*\bkmkstart stylerid1_2E15_2E5_2E8_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E5_2E8_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article VI }}}{{\i\f5\fs18\hyphpar0\qj{\u8212\'3f}}}{{\i\f5\fs18\hyphpar0\qj{ Rulemaking functions of the interstate commission.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The interstate commission shall promulgate and publish rules in order to effectively and efficiently achieve the purposes of the compact.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Rulemaking shall occur pursuant to the criteria set forth in this article and the bylaws and rules adopted pursuant thereto. Such rulemaking shall substantially conform to the principles of the model state administrative procedures Act, 1981 Act, Uniform Laws Annotated, Vol. 15, p.1 (2000), or such other administrative procedures act, as the interstate commission deems appropriate consistent with due process requirements under the Constitution of the United States as now or hereafter interpreted by the United States supreme court. All rules and amendments shall become binding as of the date specified, as published with the final version of the rule as approved by the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When promulgating a rule, the interstate commission shall, at a minimum, do all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Publish the proposed rule\u8217\'3fs entire text stating the reasons for that proposed rule.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Allow and invite any and all persons to submit written data, facts, opinions, and arguments, which information shall be added to the record, and be made publicly available.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide an opportunity for an informal hearing if petitioned by ten or more persons.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Promulgate a final rule and its effective date, if appropriate, based on input from state or local officials, or interested parties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Allow, not later than sixty days after a rule is promulgated, any interested person to file a petition in the United States district court for the District of Columbia or in the federal district court where the interstate commission\u8217\'3fs principal office is located for judicial review of such rule. If the court finds that the interstate commission\u8217\'3fs action is not supported by substantial evidence in the rulemaking record, the court shall hold the rule unlawful and set it aside. For purposes of this lettered paragraph, evidence is substantial if it would be considered substantial evidence under the model state administrative procedures Act.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a majority of the legislatures of the compacting states rejects a rule, those states may, by enactment of a statute or resolution in the same manner used to adopt the compact, cause that such rule shall have no further force and effect in any compacting state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The existing rules governing the operation of the interstate compact on juveniles superseded by this compact shall be null and void twelve months after the first meeting of the interstate commission created hereunder.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon determination by the interstate commission that a state of emergency exists, it may promulgate an emergency rule which shall become effective immediately upon adoption, provided that the usual rulemaking procedures provided hereunder shall be retroactively applied to said rule as soon as reasonably possible, but no later than ninety days after the effective date of the emergency rule.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{\*\bkmkstart stylerid1_2E15_2E5_2E9_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E5_2E9_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article VII }}}{{\i\f5\fs18\hyphpar0\qj{\u8212\'3f}}}{{\i\f5\fs18\hyphpar0\qj{ Oversight, enforcement, and dispute resolution by the interstate commission.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{\*\bkmkstart stylerid1_2E15_2E5_2E9_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E5_2E9_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Oversight.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The interstate commission shall oversee the administration and operations of the interstate movement of juveniles subject to this compact in the compacting states and shall monitor such activities being administered in noncompacting states which may significantly affect compacting states.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The courts and executive agencies in each compacting state shall enforce this compact and shall take all actions necessary and appropriate to effectuate the compact\u8217\'3fs purposes and intent. The provisions of this compact and the rules promulgated hereunder shall be received by all the judges, public officers, commissions, and departments of the state government as evidence of the authorized statute and administrative rules. All courts shall take judicial notice of the compact and the rules. In any judicial or administrative proceeding in a compacting state pertaining to the subject matter of this compact which may affect the powers, responsibilities, or actions of the interstate commission, it shall be entitled to receive all service of process in any such proceeding, and shall have standing to intervene in the proceeding for all purposes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{\*\bkmkstart stylerid1_2E15_2E5_2E9_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E5_2E9_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Dispute resolution.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The compacting states shall report to the interstate commission on all issues and activities necessary for the administration of the compact as well as issues and activities pertaining to compliance with the provisions of the compact and its bylaws and rules.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The interstate commission shall attempt, upon the request of a compacting state, to resolve any disputes or other issues which are subject to the compact and which may arise among compacting states and between compacting and noncompacting states. The commission shall promulgate a rule providing for both mediation and binding dispute resolution for disputes among the compacting states.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The interstate commission, in the reasonable exercise of its discretion, shall enforce the provisions and rules of this compact using any or all means set forth in article XI of this compact.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{\*\bkmkstart stylerid1_2E15_2E5_2E1_30_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E5_2E1_30_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article VIII }}}{{\i\f5\fs18\hyphpar0\qj{\u8212\'3f}}}{{\i\f5\fs18\hyphpar0\qj{ Finance.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The interstate commission shall pay or provide for the payment of the reasonable expenses of its establishment, organization, and ongoing activities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The interstate commission shall levy on and collect an annual assessment from each compacting state to cover the cost of the internal operations and activities of the interstate commission and its staff which must be in a total amount sufficient to cover the interstate commission\u8217\'3fs annual budget as approved each year. The aggregate annual assessment amount shall be allocated based upon a formula to be determined by the interstate commission, taking into consideration the population of each compacting state and the volume of interstate movement of juveniles in each compacting state and shall promulgate a rule binding upon all compacting states which governs said assessment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The interstate commission shall not incur any obligations of any kind prior to securing the funds adequate to meet the same; nor shall the interstate commission pledge the credit of any of the compacting states, except by and with the authority of the compacting state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The interstate commission shall keep accurate accounts of all receipts and disbursements. The receipts and disbursements of the interstate commission shall be subject to the audit and accounting procedures established under its bylaws. However, all receipts and disbursements of funds handled by the interstate commission shall be audited yearly by a certified or licensed public accountant and the report of the audit shall be included in and become part of the annual report of the interstate commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{\*\bkmkstart stylerid1_2E15_2E5_2E11_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E5_2E11_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article IX }}}{{\i\f5\fs18\hyphpar0\qj{\u8212\'3f}}}{{\i\f5\fs18\hyphpar0\qj{ The state council.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each member state shall create a state council for interstate juvenile supervision. While each state may determine the membership of its own state council, its membership must include at least one representative from the legislative, judicial, and executive branches of government, victims groups, and the compact administrator, deputy compact administrator, or designee. Each compacting state retains the right to determine the qualifications of the compact administrator or deputy compact administrator. Each state council will advise and may exercise oversight and advocacy concerning that state\u8217\'3fs participation in interstate commission activities and other duties as may be determined by that state, including but not limited to development of policy concerning operations and procedures of the compact within that state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{\*\bkmkstart stylerid1_2E15_2E5_2E12_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E5_2E12_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article X }}}{{\i\f5\fs18\hyphpar0\qj{\u8212\'3f}}}{{\i\f5\fs18\hyphpar0\qj{ Compacting states, effective date, and amendment.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any state, the District of Columbia, or its designee, the Commonwealth of Puerto Rico, the United States Virgin Islands, Guam, American Samoa, and the Northern Marianas Islands as defined in article II of this compact is eligible to become a compacting state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The compact shall become effective and binding upon legislative enactment of the compact into law by no less than thirty-five of the states. The initial effective date shall be the later of July 1, 2004, or upon enactment into law by the thirty-fifth jurisdiction. Thereafter it shall become effective and binding as to any other compacting state upon enactment of the compact into law by that state. The governors of nonmember states or their designees shall be invited to participate in the activities of the interstate commission on a nonvoting basis prior to adoption of the compact by all states and territories of the United States.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The interstate commission may propose amendments to the compact for enactment by the compacting states. No amendment shall become effective and binding upon the interstate commission and the compacting states unless and until it is enacted into law by unanimous consent of the compacting states.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{\*\bkmkstart stylerid1_2E15_2E5_2E13_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E5_2E13_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article XI }}}{{\i\f5\fs18\hyphpar0\qj{\u8212\'3f}}}{{\i\f5\fs18\hyphpar0\qj{ Withdrawal, default, termination, and judicial enforcement.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{\*\bkmkstart stylerid1_2E15_2E5_2E13_2E2_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E5_2E13_2E2_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Withdrawal.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Once effective, the compact shall continue in force and remain binding upon each and every compacting state; provided that a compacting state may withdraw from the compact by specifically repealing the statute which enacted the compact into law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The effective date of withdrawal is the effective date of the repeal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The withdrawing state shall immediately notify the chairperson of the interstate commission in writing upon the introduction of legislation repealing this compact in the withdrawing state. The interstate commission shall notify the other compacting states of the withdrawing state\u8217\'3fs intent to withdraw within sixty days of its receipt thereof.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The withdrawing state is responsible for all assessments, obligations, and liabilities incurred through the effective date of withdrawal, including any obligations, the performance of which extend beyond the effective date of withdrawal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reinstatement following withdrawal of any compacting state shall occur upon the withdrawing state reenacting the compact or upon such later date as determined by the interstate commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{\*\bkmkstart stylerid1_2E15_2E5_2E13_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E5_2E13_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Technical assistance, fines, suspension, termination, and default.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the interstate commission determines that any compacting state has at any time defaulted in the performance of any of its obligations or responsibilities under this compact, or the bylaws or duly promulgated rules, the interstate commission may impose any or all of the following penalties:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Remedial training and technical assistance as directed by the interstate commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Alternative dispute resolution.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Fines, fees, and costs in such amounts as are deemed to be reasonable as fixed by the interstate commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Suspension or termination of membership in the compact, which shall be imposed only after all other reasonable means of securing compliance under the bylaws and rules have been exhausted and the interstate commission has therefore determined that the offending state is in default. Immediate notice of suspension shall be given by the interstate commission to the governor, the chief justice or the chief judicial officer of the state, the majority and minority leaders of the defaulting state\u8217\'3fs legislature, and the state council.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The grounds for default include, but are not limited to, failure of a compacting state to perform such obligations or responsibilities imposed upon it by this compact, the bylaws or duly promulgated rules, and any other grounds designated in commission bylaws and rules.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The interstate commission shall immediately notify the defaulting state in writing of the penalty imposed by the interstate commission and of the default pending a cure of the default. The commission shall stipulate the conditions and the time period within which the defaulting state must cure its default. If the defaulting state fails to cure the default within the time period specified by the commission, the defaulting state shall be terminated from the compact upon an affirmative vote of a majority of the compacting states and all rights, privileges, and benefits conferred by this compact shall be terminated from the effective date of termination.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Within sixty days of the effective date of termination of a defaulting state, the commission shall notify the governor, the chief justice or chief judicial officer, the majority and minority leaders of the defaulting state\u8217\'3fs legislature, and the state council of such termination.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The defaulting state is responsible for all assessments, obligations, and liabilities incurred through the effective date of termination including any obligations, the performance of which extends beyond the effective date of termination.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The interstate commission shall not bear any costs relating to the defaulting state unless otherwise mutually agreed upon in writing between the interstate commission and the defaulting state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(7)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reinstatement following termination of any compacting state requires both a reenactment of the compact by the defaulting state and the approval of the interstate commission pursuant to the rules.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{\*\bkmkstart stylerid1_2E15_2E5_2E13_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E5_2E13_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Judicial enforcement.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The interstate commission may, by majority vote of the members, initiate legal action in the United States district court for the District of Columbia or, at the discretion of the interstate commission, in the federal district where the interstate commission has its offices, to enforce compliance with the provisions of the compact, its duly promulgated rules and bylaws, against any compacting state in default. In the event judicial enforcement is necessary the prevailing party shall be awarded all costs of such litigation including reasonable attorney fees. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{\*\bkmkstart stylerid1_2E15_2E5_2E13_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E5_2E13_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Dissolution of compact.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The compact dissolves effective upon the date of the withdrawal or default of the compacting state, which reduces membership in the compact to one compacting state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon the dissolution of this compact, the compact becomes null and void and shall be of no further force or effect, and the business and affairs of the interstate commission shall be concluded and any surplus funds shall be distributed in accordance with the bylaws.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{\*\bkmkstart stylerid1_2E15_2E5_2E14_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E5_2E14_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article XII }}}{{\i\f5\fs18\hyphpar0\qj{\u8212\'3f}}}{{\i\f5\fs18\hyphpar0\qj{ Severability and construction.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The provisions of this compact shall be severable, and if any phrase, clause, sentence, or provision is deemed unenforceable, the remaining provisions of the compact shall be enforceable.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The provisions of this compact shall be liberally construed to effectuate its purposes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{\*\bkmkstart stylerid1_2E15_2E5_2E15_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E5_2E15_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article XIII }}}{{\i\f5\fs18\hyphpar0\qj{\u8212\'3f}}}{{\i\f5\fs18\hyphpar0\qj{ Binding effect of compact and other laws.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{\*\bkmkstart stylerid1_2E15_2E5_2E15_2E2_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E5_2E15_2E2_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Other laws.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Nothing in this compact prevents the enforcement of any other law of a compacting state that is not inconsistent with this compact.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All compacting states\u8217\'3f laws other than state constitutions and other interstate compacts conflicting with this compact are superseded to the extent of the conflict.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{\*\bkmkstart stylerid1_2E15_2E5_2E15_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E15_2E5_2E15_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Binding effect of the compact.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All lawful actions of the interstate commission, including all rules and bylaws promulgated by the interstate commission, are binding upon the compacting states.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All agreements between the interstate commission and the compacting states are binding in accordance with their terms.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon the request of a party to a conflict over meaning or interpretation of interstate commission actions, and upon a majority vote of the compacting states, the interstate commission may issue advisory opinions regarding such meaning or interpretation. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In the event any provision of this compact exceeds the constitutional limits imposed on the legislature of any compacting state, the obligations, duties, powers, or jurisdiction sought to be conferred by such provision upon the interstate commission shall be ineffective and such obligations, duties, powers, or jurisdiction shall remain in the compacting state and shall be exercised by the agency thereof to which such obligations, duties, powers, or jurisdiction are delegated by law in effect at the time this compact becomes effective.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2010 Acts, ch 1192, \'a776}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.2}}}{{\f5\fs12\hyphpar0\qj{, 232.172}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.174}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0{\f5\fs18\chcbpat2}\par}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER XI}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E16_2E2_2E2}{VOLUNTARY FOSTER CARE PLACEMENT}{\*\bkmkend stylerid1_2E16_2E2_2E2}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{232.175 through 232.183}}}{Repealed by }{{\f5\fs18\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2022/CH1098.pdf" }{\fldrslt \f5 \fs18{{2022 Acts, ch 1098, \'a790}}}}}}{{\f5\fs18\qj{2022 Acts, ch 1098, \'a790}}}{.}{\f5\fs18\qj}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{232.184 through 232.187}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0{\f5\fs18\chcbpat2}\par}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER XII}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E17_2E2_2E2}{JUVENILE JUSTICE \u8212\'3f DECATEGORIZATION AND EARLY INTERVENTION}{\*\bkmkend stylerid1_2E17_2E2_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.188}}}{\*\bkmkstart stylerid1_2E17_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E17_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Decategorization of child welfare and juvenile justice funding initiative.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E17_2E3_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E17_2E3_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Definitions.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, unless the context otherwise requires:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDecategorization governance board\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fgovernance board\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the group that enters into and implements a decategorization project agreement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDecategorization project\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the county or counties that have entered into a decategorization agreement to implement the decategorization initiative in the county or multicounty area covered by the agreement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDecategorization services funding pool\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ffunding pool\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the funding designated for a decategorization project from all sources.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E17_2E3_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E17_2E3_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Purpose.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The decategorization of the child welfare and juvenile justice funding initiative is intended to establish a system of delivering human services based upon client needs to replace a system based upon a multitude of categorical programs and funding sources, each with different service definitions and eligibility requirements. The purposes of the decategorization initiative include but are not limited to redirecting child welfare and juvenile justice funding to services which are more preventive, family-centered, and community-based in order to reduce use of restrictive approaches which rely upon institutional, out-of-home, and out-of-community services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{\*\bkmkstart stylerid1_2E17_2E3_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E17_2E3_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Implementation.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Implementation of the initiative shall be through creation of decategorization projects. A project shall consist of either a single county or a group of counties interested in jointly implementing the initiative. Representatives of the department, juvenile court services, and county government shall develop a project agreement to implement the initiative within a project.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The initiative shall include community planning activities in the area covered by a project. As part of the community planning activities, the department shall partner with other community stakeholders to develop service alternatives that provide less restrictive levels of care for children and families receiving services from the child welfare and juvenile justice systems within the project area.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The decategorization initiative shall not be implemented in a manner that limits the legal rights of children and families to receive services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{\*\bkmkstart stylerid1_2E17_2E3_2E6_2E1_2E2}{\*\bkmkend stylerid1_2E17_2E3_2E6_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Governance board.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In partnership with an interested county or group of counties which has demonstrated the commitment and involvement of the affected county department, or departments, of human services, the juvenile justice system within the project area, and board, or boards, of supervisors in order to form a decategorization project, the department shall develop a process for combining specific state and state-federal funding categories into a decategorization services funding pool for that project. A decategorization project shall be implemented by a decategorization governance board. The decategorization governance board shall develop specific, quantifiable short-term and long-term plans for enhancing the family-centered and community-based services and reducing reliance upon out-of-community care in the project area.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall work with the decategorization governance boards to best coordinate planning activities and most effectively target funding resources. The department shall work with the decategorization governance boards to support board planning and service development activities and to promote the most effective alignment of resources.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A decategorization governance board shall coordinate the project\u8217\'3fs planning and budgeting activities with the department\u8217\'3fs designee for the county or counties comprising the project area and the early childhood Iowa area board or boards for the early childhood Iowa area or areas within which the decategorization project is located.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{\*\bkmkstart stylerid1_2E17_2E3_2E7_2E1_2E2}{\*\bkmkend stylerid1_2E17_2E3_2E7_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Funding pool.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The governance board for a decategorization project has authority over the project\u8217\'3fs decategorization services funding pool and shall manage the pool to provide more flexible, individualized, family-centered, preventive, community-based, comprehensive, and coordinated service systems for children and families served in that project area. A funding pool shall also be used for child welfare and juvenile justice systems enhancements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 8.33}}}{{\f5\fs18\hyphpar0\qj{, moneys designated for a project\u8217\'3fs decategorization services funding pool that remain unencumbered or unobligated at the close of the fiscal year shall not revert but shall remain available for expenditure as directed by the project\u8217\'3fs governance board for child welfare and juvenile justice systems enhancements and other purposes of the project for the next three succeeding fiscal years. Such moneys shall be known as }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fcarryover funding\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. Moneys may be made available to a funding pool from one or more of the following sources:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Funds designated for the initiative in a state appropriation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Child welfare and juvenile justice services funds designated for the initiative by the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Juvenile justice program funds designated for the initiative by a chief juvenile court officer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Carryover funding.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any other source designating moneys for the funding pool.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The services and activities funded from a project\u8217\'3fs funding pool may vary depending upon the strategies selected by the project\u8217\'3fs governance board and shall be detailed in an annual child welfare and juvenile justice decategorization services plan developed by the governance board. A decategorization governance board shall involve community representatives and county organizations in the development of the plan for that project\u8217\'3fs funding pool. In addition, the governance board shall coordinate efforts through communication with the department regarding budget planning and decategorization service decisions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A decategorization governance board is responsible for ensuring that decategorization services expenditures from that project\u8217\'3fs funding pool do not exceed the amount of funding available. If necessary, the governance board shall reduce expenditures or discontinue specific services as necessary to manage within the funding pool resources available for a fiscal year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The annual child welfare and juvenile justice decategorization services plan developed for use of the funding pool by a decategorization governance board shall be submitted to the department and the early childhood Iowa state board. In addition, the decategorization governance board shall submit an annual progress report to the department and the early childhood Iowa state board which summarizes the progress made toward attaining the objectives contained in the plan. The progress report shall serve as an opportunity for information sharing and feedback.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{\*\bkmkstart stylerid1_2E17_2E3_2E8_2E1_2E2}{\*\bkmkend stylerid1_2E17_2E3_2E8_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Departmental role.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The departmental share of the child welfare appropriation that is not allocated by law for the decategorization initiative shall be managed by and is under the authority of the department. The department is responsible for meeting the child welfare service needs with the available funding resources.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1229, \'a718}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1206, \'a711, 20}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 111, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 190, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 192, \'a733}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1116, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 95, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1031, \'a7297}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 129, \'a790, 156}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 29, \'a754}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1098, \'a769}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7642}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7235.7}}}{{\f5\fs12\hyphpar0\qj{, 237A.1}}}{{\f5\fs12\hyphpar0\qj{, 249A.26}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.189}}}{\*\bkmkstart stylerid1_2E17_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E17_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Reasonable efforts administrative requirements.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2022 Acts, ch 1098, \'a791}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\sb0\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.190}}}{\*\bkmkstart stylerid1_2E17_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E17_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Community grant fund.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by its own terms; }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2000/CH1222.pdf" }{\fldrslt \cf5 \f5 \fs18{{2000 Acts, ch 1222, \'a714}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.191}}}{\*\bkmkstart stylerid1_2E17_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E17_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Early intervention and follow-up programs.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2022 Acts, ch 1098, \'a791}}}{{\f5\fs18\hyphpar0\qj{. See }}}{{\f5\fs18\hyphpar0\qj{\'a7232.192}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\sb0\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{232.192}}}{\*\bkmkstart stylerid1_2E17_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E17_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Early intervention and follow-up programs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Contingent on a specific appropriation for juvenile delinquent graduated sanctions services, juvenile court services shall do the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Develop or expand programs providing specific life skills and interpersonal skills training for adjudicated delinquent youth who pose a low or moderate risk to the community.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Develop or expand a school-based program addressing truancy and school behavioral problems for youth ages twelve through seventeen.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Develop or expand an intensive tracking and supervision program for adjudicated delinquent youth at risk for placement who have been released from resident facilities, which shall include telephonic or electronic tracking and monitoring and intervention by juvenile authorities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Develop or expand supervised community treatment for adjudicated delinquent youth who experience significant problems and who constitute a moderate community risk.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The supreme court shall prescribe rules to implement }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2022 Acts, ch 1098, \'a770, 92}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.52}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{232.193 and 232.194}}}{Reserved.}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0{\f5\fs18\chcbpat2}\par}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER XIII}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E18_2E2_2E2}{RUNAWAY TREATMENT PLANS}{\*\bkmkend stylerid1_2E18_2E2_2E2}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{232.195 and 232.196}}}{Repealed by }{{\f5\fs18\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2022/CH1098.pdf" }{\fldrslt \f5 \fs18{{2022 Acts, ch 1098, \'a790}}}}}}{{\f5\fs18\qj{2022 Acts, ch 1098, \'a790}}}{.}{\f5\fs18\qj}\par}}