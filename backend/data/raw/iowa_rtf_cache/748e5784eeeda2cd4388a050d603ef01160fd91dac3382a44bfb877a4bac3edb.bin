s18\hyphpar0\qj{chapter 8A, subchapter IV}}}{{\f5\fs18\hyphpar0\qj{, to administer the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall apply to all boilers and unfired steam pressure vessels in this state, except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a789.1}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 145, \'a7161}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71786}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{89.2}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{For the purpose of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ unless the context otherwise requires:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fASME code\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the boiler and pressure vessel code published by the American society of mechanical engineers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fBoard\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the boiler and pressure vessel board created in }}}{{\f5\fs18\hyphpar0\qj{section 89.14}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fBoiler\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a vessel in which water or other liquids are heated, steam or other vapors are generated, steam or other vapors are superheated, or any combination thereof, under pressure or vacuum by the direct application of heat.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDepartment\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the department of inspections, appeals, and licensing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDirector\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the director of the department of inspections, appeals, and licensing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fExhibition boiler\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a boiler which is operated in the state for nonprofit purposes including, but not limited to, exhibitions, fairs, parades, farm machinery shows, or any other event of an historical or educational nature. An }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fexhibition boiler\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes steam locomotives, traction and portable steam engines, and stationary boilers of the firetube, watertube, and returntube class, model or miniature, and may be riveted, riveted and welded, or all welded construction, if used within the state solely for nonprofit purposes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fNational board inspection code\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the manual for boiler and pressure vessel inspectors published by the national board of boiler and pressure vessel inspectors.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fObject\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a boiler or pressure vessel.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPower boiler\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a boiler in which steam or other vapor is generated at a pressure of more than fifteen pounds per square inch or a water boiler intended for operation at pressures in excess of one hundred sixty pounds per square inch or temperatures in excess of 250 degrees Fahrenheit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPublic assembly\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the assembly of people in any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A building or structure primarily used as a theater, motion picture theater, museum, arena, exhibition hall, school, college, dormitory, bowling alley, physical fitness center, family entertainment center, lodge hall, union hall, pool hall, casino, place of worship, funeral home, institution of health and custodial care, hospital, or child care or adult day services facility.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A building or structure, a portion of which is primarily used for amusement, entertainment, or instruction.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A building or structure owned by or leased to the state or any of its agencies or political subdivisions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{However, for purposes of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fpublic assembly\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include the assembly of people in buildings or structures containing only eating and drinking establishments or in any building used exclusively by an employer for training or instruction of its own employees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSpecial inspector\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an inspector who holds a commission from the director and who is not a state employee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSteam heating boiler\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a boiler operating at not more than fifteen pounds per square inch; or a hot water heating boiler operating at not more than one hundred sixty pounds per square inch and not more than 250 degrees Fahrenheit at the boiler outlet.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fUnfired steam pressure vessel\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a vessel or container used for the containment of steam pressure either internal or external in which the pressure is obtained from an external source.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C62, 66, 71, 73, 75, 77, \'a789.12; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a789.2}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 321, \'a726}}}{; }{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1098, \'a73}}}{; }{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1097, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 24, \'a726}}}{; }{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 64, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1107, \'a72, 30}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1032, \'a7201}}}{; }{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 94, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71787 \u8211\'3f 1789}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 45, \'a71}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{89.3}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Inspection made.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It shall be the duty of the director to inspect or cause to be inspected internally and externally, at least once every twelve months, except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, in order to determine whether all such equipment is in a safe and satisfactory condition, and properly constructed and maintained for the purpose for which it is used, all boilers and unfired steam pressure vessels operating in excess of fifteen pounds per square inch, all low pressure heating boilers and unfired steam pressure vessels located in places of public assembly and other appurtenances used in this state for generating or transmitting steam for power, or for using steam under pressure for heating or steaming purposes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director may enter any building or structure, public or private, for the purpose of inspecting any equipment covered by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or gathering information with reference thereto.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director may inspect boilers and tanks and other equipment stamped with the American society of mechanical engineers code symbol for other than steam pressure, manufactured in Iowa, when requested by the manufacturer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An object that meets all of the following criteria shall be inspected at least once every two years internally and externally while not under pressure, and at least once every two years externally while under pressure, unless the director determines that an earlier inspection is warranted:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The object is a boiler with one hundred thousand pounds per hour or more capacity, or the object is an unfired steam pressure vessel or a regulated appurtenance that is part of the same system as a boiler with one hundred thousand pounds per hour or more capacity.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The object contains only water subject to internal continuous water treatment under the direct supervision of a graduate engineer or chemist, or one having equivalent experience in the treatment of boiler water.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The water treatment is for the purpose of controlling and limiting serious corrosion and other deteriorating factors.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The owner or user of an object meeting the criteria in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall do the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At any time the director, a special inspector, or the supervisor of water treatment deems a hydrostatic test is necessary to determine the safety of an object, conduct the test under the supervision of the director.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Keep available for examination by the director accurate records showing the date and actual time the object is out of service and the reason it is out of service.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Keep available for examination by the director chemical physical laboratory analyses of samples of the object water taken at regular intervals of not more than forty-eight hours of operation as will adequately show the condition of the water and any elements or characteristics of the water which are capable of producing corrosion or other deterioration of the object or its parts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An object that meets all of the following criteria shall be inspected at least once each year externally while under pressure and at least once every four years internally while not under pressure, unless the director determines an earlier inspection is warranted:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The object is a boiler with one hundred thousand pounds per hour or more capacity, or the object is an unfired steam pressure vessel or a regulated appurtenance that is part of the same system as a boiler with one hundred thousand pounds per hour or more capacity.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The object contains only water subject to internal continuous water treatment under the direct supervision of a graduate engineer or chemist, or one having equivalent experience in the treatment of boiler water.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The water treatment is for the purpose of controlling and limiting serious corrosion and other deteriorating factors.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Either of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The owner or user is a participant in good standing in the Iowa occupational safety and health voluntary protection program and has achieved star status within the program, which is administered by the division of labor services in the department of inspections, appeals, and licensing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The object is an unfired steam pressure vessel and is part of or integral to the continuous operation of a process covered by and compliant with the occupational safety and health administration process safety management standard contained in }}}{{\f5\fs18\hyphpar0\qj\cf1{29 C.F.R. \'a71910.119}}}{{\f5\fs18\hyphpar0\qj{ and the owner demonstrates such compliance to a special inspector or the director. The unfired steam pressure vessel must also be included as process safety management process equipment in the owner of the unfired steam pressure vessel\u8217\'3fs process safety management program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The owner or user of an object that meets the criteria in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall do the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At any time the director, a special inspector, or the supervisor of the water treatment deems a hydrostatic test necessary to determine the safety of an object, conduct the test under the supervision of the director.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Keep available for examination by the director accurate records showing the date and actual time the object is out of service and the reason it is out of service.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Arrange for an internal inspection of the object during each planned outage by a special inspector or the director.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Keep for examination by the director accurate records showing the chemical physical laboratory analyses of samples of the object\u8217\'3fs water taken at regular intervals of not more than forty-eight hours of operation adequate to show the condition of the water and any elements or characteristics of the water that are capable of producing corrosion or other deterioration of the object or its parts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The owner of an object that meets all of the criteria in }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, may request from the director an internal inspection time period of longer than two years, but not to exceed seven years, if the object is an integral part of a continuous operation of a process that is covered by and compliant with the occupational safety and health administration process safety management standard contained in }}}{{\f5\fs18\hyphpar0\qj\cf1{29 C.F.R. \'a71910.119}}}{{\f5\fs18\hyphpar0\qj{ and has a planned outage schedule that is longer than two years.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director may grant the longer inspection interval if the owner is able to demonstrate to the director that the object is in compliance with the process safety management standard contained in }}}{{\f5\fs18\hyphpar0\qj\cf1{29 C.F.R. \'a71910.119}}}{{\f5\fs18\hyphpar0\qj{ and that the object is included as process safety management process equipment in the owner\u8217\'3fs process safety management program. In evaluating the request, the director shall also consider whether the object meets the requirements contained in the national board inspection code, the object is fit for service based on the year of fabrication and the estimated service life of the object as determined by part 2 of the national board inspection code, and the owner has implemented practices for managing consumable items and ancillary equipment of the object. Upon request by the director, the owner shall provide the director with the findings of any previous inspections of the object under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the director intends to deny the request, the director shall contact the owner prior to the denial and provide an opportunity for the owner to address the reasons for the intended denial. If the board has not adopted rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 89.14, subsection 11}}}{{\f5\fs18\hyphpar0\qj{, the lack of adoption shall not be grounds for the director not to consider a request for a longer inspection interval pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The owner of the object that is granted the longer inspection interval shall comply with the requirements contained in }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Internal inspections of cast aluminum steam, cast aluminum hot water heating, sectional cast iron steam, and cast iron hot water heating boilers shall be conducted only as deemed necessary by the director. External operating inspections shall be conducted annually.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Internal inspections of steel hot water boilers shall be conducted once every six years. External operating inspections shall be conducted annually in years other than the year in which internal inspections are conducted.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Inspections of unfired steam pressure vessels operating in excess of fifteen pounds per square inch and low pressure steam boilers shall be conducted at least once each calendar year. The inspections conducted within each two-year period shall include an external inspection conducted while the boiler is operating and an internal inspection, where construction permits. No more than one inspection shall be conducted per six-month period. An internal inspection of an unfired steam pressure vessel or low pressure steam boiler may be required at any time by the director upon the observation by an inspector of conditions, enumerated by the director through rules, warranting an internal inspection. If a low pressure steam boiler is in dry lay-up, an internal inspection shall be conducted in lieu of an external inspection. For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fdry lay-up\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a process whereby a boiler is taken out of service for a period of six months or longer, drained, dried, and cleaned, and measures to prevent corrosion are performed on the boiler. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An internal inspection shall not be required on an unfired steam pressure vessel that was manufactured without an inspection opening.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An exhibition boiler does not require an annual inspection certificate but special inspections may be requested by the owner or an event\u8217\'3fs management to be performed by the director. Upon the completion of an exhibition boiler inspection, a written condition report shall be prepared by the director regarding the condition of the exhibition boiler\u8217\'3fs boiler or pressure vessel. This report will be issued to the owner and the management of all events at which the exhibition boiler is to be operated. The event\u8217\'3fs management is responsible for the decision on whether the exhibition boiler should be operated and shall inform the department of the event\u8217\'3fs management\u8217\'3fs decision. The event\u8217\'3fs management is responsible for any injuries which result from the operation of any exhibition boiler approved for use at the event by the event\u8217\'3fs management. A repair symbol, known as the \u8220\'3fR\u8221\'3f stamp, is not required for repairs made to exhibition boilers pursuant to the rules regarding inspections and repair of exhibition boilers as adopted by the director, pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An inspection report created pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ that requires modification, alteration, or change shall be in writing and shall cite the state law or rule or the ASME code section allegedly violated.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, \'a789.2; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a789.3}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 105, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 321, \'a727}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{; }{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts//CH0000.pdf" }{\fldrslt \f5 \fs18{{\f5\fs18\hyphpar0\qj\cf5{97 Acts, ch 27, \'a71}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1107, \'a73, 30}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 135, \'a71 \u8211\'3f 3}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 94, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 179, \'a734}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1015, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 34, \'a719}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1043, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 66, \'a71, 5}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1092, \'a723}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1098, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1032, \'a719, 20}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71790}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 45, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1043, \'a738}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a789.4}}}{{\f5\fs12\hyphpar0\qj{, 89.7}}}{{\f5\fs12\hyphpar0\qj{, 89.7A}}}{{\f5\fs12\hyphpar0\qj{, 89.14}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{89.4}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Exemptions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall not apply to the following boilers:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Boilers of railway locomotives subject to federal inspection.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Boilers operated and regularly inspected by railway companies operating in interstate commerce.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Boilers under the jurisdiction and subject to inspection by the United States government.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Steam heating boilers and unfired steam pressure vessels associated with steam heating boilers and mobile power boilers used exclusively for agricultural purposes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Heating boilers in residences.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Fire engine boilers brought into the state for temporary use in times of emergency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Low pressure heating boilers used in buildings other than those for public assembly.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Hot water heating boilers used for heating pools or spas regulated by the department of inspections, appeals, and licensing pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 135I}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Water heaters used for potable water if the capacity is less than or equal to one hundred twenty gallons, the burner input is less than or equal to two hundred thousand British thermal units, and the maximum allowable working pressure is less than one hundred sixty pounds per square inch.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An electric boiler with a water capacity of six gallons or less that is used as an integral part of an espresso coffee machine, cappuccino coffee machine, or cleaning machine.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{k.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Continuous coil-type hot water boilers used only for steam vapor cleaning, to which all of the following apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The size of the tubing or pipe, with no drums or headers attached, does not exceed three-fourths of one inch in diameter.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Nominal water capacity of the boiler does not exceed six gallons.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Water temperature in the boiler does not exceed 350 degrees Fahrenheit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Steam is not generated within the coil.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Unfired steam pressure vessels not exceeding the following limitations are not required to be reported to the director and shall be exempt from regular inspection under provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vessel not greater than five cubic feet in volume and not having a pressure greater than two hundred fifty pounds per square inch.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vessel not greater than one and one-half cubic feet in volume with no limit on pressure.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Jacketed direct or indirect fired vessels built and installed in accordance with the American society of mechanical engineers code, section VIII, division 1, appendix 19, shall not be considered boilers or power boilers for purposes of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and shall not be required to meet the American society of mechanical engineers standard for controls and safety devices for automatically fired boilers. However, jacketed direct or indirect fired vessels as described in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be subject to inspection under }}}{{\f5\fs18\hyphpar0\qj{section 89.3}}}{{\f5\fs18\hyphpar0\qj{ as pressure vessels.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An object shall not be considered under pressure and shall not be within the scope of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ when there is clear evidence that the manufacturer did not intend the object to be operated at more than three pounds per square inch and the object is operating at three pounds per square inch or less.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, \'a789.3; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a789.4}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1098, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1222, \'a721, 28}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 47, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 135, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1015, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 66, \'a72, 3, 5}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1026, \'a720}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1098, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a757, 1791}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 66, \'a718}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{89.5}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Rules \u8212\'3f records.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director shall investigate and record the cause of any boiler explosion that may occur in the state, the loss of life, injuries sustained, and estimated loss of property, if any; and such other data as may be of benefit in preventing a recurrence of similar explosions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director shall keep a complete and accurate record of the name of the owner or user of each steam boiler or other equipment subject to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, giving a full description of the equipment, including the type, dimensions, age, condition, the amount of pressure allowed, and the date when last inspected.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, \'a789.4; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a789.5}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1149, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1107, \'a74, 5, 30}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1031, \'a754}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 34, \'a720}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71792}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1169, \'a713}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{89.6}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{ Notice to director.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Before any equipment included under the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ is installed by any owner, user, or lessee thereof, a ten days\u8217\'3f written notice of intention to install the equipment shall be given to the director. The notice shall designate the proposed place of installation, the type and capacity of the equipment, the use to be made thereof, the name of the company which manufactured the equipment, and whether the equipment is new or used.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Before any power boiler is converted to a low pressure boiler, the owner or user shall give to the director ten days\u8217\'3f written notice of intent to convert the boiler. The notice shall designate the boiler location, the uses of the building, and other information specified by rule by the board.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, \'a789.5; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a789.6}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2010 Acts, ch 1015, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 25, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71793}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{89.7}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Special inspectors.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The inspection required by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall not be made by the director if an owner or user of equipment specified by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ obtains an inspection by a representative of a reputable insurance company and obtains a policy of insurance upon the equipment from that insurance company.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The representative conducting the inspection shall be commissioned by the director as a special inspector for the year during which the inspection occurs and shall meet such other requirements as the director may by rule establish. The commission shall be valid for one year and the special inspector shall pay a fee for the issuance of the commission. The director shall establish the amount of the fee by rule. The director shall establish rules for the issuance and revocation of special inspector commissions. The rules are subject to the requirements of }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The insurance company shall file a notice of insurance coverage on forms approved by the director stating that the equipment is insured and that inspection shall be made in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 89.3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The special inspector shall provide the user and the director with an inspection report including the nature and extent of all defects and violations, in a format approved by the director.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The failure of a special inspector to inform the director of violations shall not subject the director to liability for any damages incurred.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, \'a789.6; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a789.7}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 102, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{87 Acts, ch 15, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1136, \'a74, 5}}}{; }{{\f5\fs18\hyphpar0\qj{91 Acts, ch 136, \'a72}}}{; }{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1107, \'a76, 30}}}{; }{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 135, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71794}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{89.7A}}}{\*\bkmkstart stylerid1_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Certificates.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director shall issue a certificate of inspection valid for the period specified in }}}{{\f5\fs18\hyphpar0\qj{section 89.3}}}{{\f5\fs18\hyphpar0\qj{ after the payment of a fee, the filing of an inspection report, and the correction or other appropriate resolution of any defects identified in the inspection report. The certificate shall be posted at a place near the location of the equipment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The owner or user of any equipment covered in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, or persons in charge of such equipment, shall not allow or permit a greater pressure in any unit than is stated in the certificate of inspection issued by the director.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director shall indicate to the user whether or not the equipment may be used without making repair or replacement of defective parts, or whether or how the equipment may be used in a limited capacity before repairs or replacements are made, and the director may permit the user a reasonable time to make such repairs or replacements.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 135, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1031, \'a729}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71795}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{89.8}}}{\*\bkmkstart stylerid1_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Boiler and pressure vessel safety fund \u8212\'3f fees appropriated.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2023 Acts, ch 108, \'a751}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\sb0\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{89.9}}}{\*\bkmkstart stylerid1_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Disposal of fees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{All fees provided for in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ shall be collected by the director and remitted to the treasurer of state, to be deposited in the licensing and regulation fund created in }{{\f5\fs18\hyphpar0\qj{section 10A.507}}}{, together with an itemized statement showing the source of collection.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, \'a789.8; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a789.9}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1107, \'a78, 30}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71797}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 108, \'a733}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{89.10}}}{\*\bkmkstart stylerid1_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Penalty.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Any person or persons, corporations and directors, managers and superintendents, and officers thereof, violating any of the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, shall be guilty of a simple misdemeanor.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, \'a789.9; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a789.10}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{89.11}}}{\*\bkmkstart stylerid1_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Injunction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to all other remedies, if any owner, user, or person in charge of any equipment covered by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ continues to use any equipment covered by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, after receiving an inspection report identifying defects and exhausting appeal rights as provided by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ without first correcting the defects or making replacements, the director may apply to the district court by petition in equity, in an action brought in the name of the state, for a writ of injunction to restrain the use of the alleged defective equipment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the director believes that the continued operation of equipment constitutes an imminent danger that could seriously injure or cause death to any person, in addition to all other remedies, the director may apply to the district court in the county in which the imminently dangerous condition exists for a temporary order to enjoin the owner, user, or person in charge from operating the equipment before the owner\u8217\'3fs, user\u8217\'3fs, or person\u8217\'3fs rights to administrative appeals have been exhausted.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, \'a789.10; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a789.11}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1107, \'a79, 30}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 135, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 133, \'a723}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71798}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{89.12}}}{\*\bkmkstart stylerid1_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Hearing }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ notice }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ decree.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The director shall notify in writing the owner or user of the equipment of the time and place of hearing of the petition as fixed by the court or judge, and shall serve the notice on the defendant at least five days prior to the hearing in the same manner as original notices are served. The general provisions relating to civil practice and procedure as may be applicable, shall govern the proceedings, except as modified in this chapter. In the event the defendant does not appear or plead to the action, default shall be entered against the defendant. The action shall be tried in equity, and the court or judge shall make such order or decree as the evidence warrants.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, \'a789.11; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a789.12}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2023 Acts, ch 19, \'a71799}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 66, \'a719}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{89.13}}}{\*\bkmkstart stylerid1_2E18_2E2_2E2}{\*\bkmkend stylerid1_2E18_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Civil penalty allowed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If upon notice and hearing the director determines that an owner has operated a facility in violation of a safety order, the director may assess a civil penalty against the owner in an amount not exceeding five hundred dollars, as determined by the director. An order assessing a civil penalty is subject to appeal to the employment appeal board and to judicial review. The director may commence an action in the district court to enforce payment of a civil penalty. Revenue from the penalty provided in }{{\f5\fs18\hyphpar0\qj{this section}}}{ shall be remitted to the treasurer of state for deposit in the general fund of the state.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1136, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71800}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{89.14}}}{\*\bkmkstart stylerid1_2E19_2E2_2E2}{\*\bkmkend stylerid1_2E19_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Boiler and pressure vessel board \u8212\'3f created \u8212\'3f duties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A boiler and pressure vessel board is created within the department to formulate definitions and rules requirements for the safe and proper installation, repair, maintenance, alteration, use, and operation of boilers and pressure vessels in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The boiler and pressure vessel board is composed of nine members as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director or the director\u8217\'3fs designee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The following eight members who shall be appointed by the governor, subject to confirmation by the senate, to four-year staggered terms beginning and ending as provided in }}}{{\f5\fs18\hyphpar0\qj{section 69.19}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{One member shall be a special inspector who is employed by an insurance company that is licensed and actively writing boiler and machinery insurance in this state and who is commissioned to inspect boiler and pressure vessels in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{One member shall be appointed from a certified employee organization and shall represent steamfitters.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{One member shall be appointed from a certified employee organization and shall represent boilermakers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Two members shall be mechanical engineers who regularly practice in the area of boilers and pressure vessels.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{One member shall be a boiler and pressure vessel distributor in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{One member shall represent boiler and pressure vessel manufacturers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(7)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{One member shall be a mechanical contractor engaged in the business of installation, renovation, and repair of boilers and pressure vessels.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vacancy in membership shall be filled in the same manner as the original appointment. The members shall serve without compensation, but shall be reimbursed for actual and necessary expenses incurred in the performance of official duties as a member.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The members of the board shall select a chairperson, vice chairperson, and secretary from their membership. However, neither the director nor the director\u8217\'3fs designee shall serve as chairperson. The board shall meet at least quarterly but may meet as often as necessary. Meetings shall be set by a majority of the board or upon the call of the chairperson, or in the chairperson\u8217\'3fs absence, upon the call of the vice chairperson. A majority of the board members shall constitute a quorum.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ necessary to administer the duties of the board. Rules adopted by the board shall be in accordance with accepted engineering standards and practices. The board shall adopt rules relating to the equipment covered by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ that are in accordance with the ASME code, which may include addenda, interpretations, and code cases, as soon as reasonably practical following publication by the American society of mechanical engineers. The board shall adopt rules to require that operation of equipment cease in the event of imminent danger.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A notice of defect or inspection report issued by the director pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ may, within thirty days after the making of the order, be appealed to the board. Board action constitutes final agency action for purposes of }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Not later than July 1, 2005, and every three years thereafter, the board shall conduct a comprehensive review of existing boiler rules, regulations, and standards, including but not limited to those relating to potable hot water supply boilers and water heaters.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall establish fees for examinations, inspections, annual statements, shop inspections, and other services. The fees shall reflect the actual costs and expenses necessary to operate the board and perform the duties of the director.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board may adopt rules governing the conversion of power boilers to low pressure boilers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board may adopt rules establishing an internal inspection interval of up to four years for objects that are subject to inspection pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 89.3, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, and are owned and operated by electric public utilities subject to rate regulation under }}}{{\f5\fs18\hyphpar0\qj{chapter 476}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall adopt rules to allow an extended internal inspection interval of up to seven years for objects that are subject to inspection pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 89.3, subsection 6}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1107, \'a710, 30}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 135, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 94, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1015, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 66, \'a74, 5}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71801 \u8211\'3f 1803}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 45, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1043, \'a739}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a789.2}}}{{\f5\fs12\hyphpar0\qj{, 89.3}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Confirmation, see }{{\f5\fs12\hyphpar0\qj{\'a72.32}}}\par}}