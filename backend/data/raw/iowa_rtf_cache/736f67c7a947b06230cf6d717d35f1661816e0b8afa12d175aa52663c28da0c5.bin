2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAnimal care provider\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person designated by a local authority to provide care to an animal which is rescued by the local authority pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 717B.5}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAnimal mistreatment\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an act described as animal abuse as provided in }}}{{\f5\fs18\hyphpar0\qj{section 717B.2}}}{{\f5\fs18\hyphpar0\qj{, animal neglect as provided in }}}{{\f5\fs18\hyphpar0\qj{section 717B.3}}}{{\f5\fs18\hyphpar0\qj{, animal torture as provided in }}}{{\f5\fs18\hyphpar0\qj{section 717B.3A}}}{{\f5\fs18\hyphpar0\qj{, abandonment of a cat or dog as provided in }}}{{\f5\fs18\hyphpar0\qj{section 717B.8}}}{{\f5\fs18\hyphpar0\qj{, or injury to or interference with a police service dog as provided in }}}{{\f5\fs18\hyphpar0\qj{section 717B.9}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Unless the context otherwise requires, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fbook\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3flist\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3frecord\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fschedule\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ kept by a county auditor, assessor, treasurer, recorder, sheriff, or other county officer means the county system as defined in }}}{{\f5\fs18\hyphpar0\qj{section 445.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCommercial establishment\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a commercial establishment as defined in }}}{{\f5\fs18\hyphpar0\qj{section 162.2}}}{{\f5\fs18\hyphpar0\qj{ that is operating under a valid authorization issued or renewed under }}}{{\f5\fs18\hyphpar0\qj{section 162.2A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fConvicted\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the entry of a judgment of conviction under }}}{{\f5\fs18\hyphpar0\qj{chapter 901}}}{{\f5\fs18\hyphpar0\qj{ or adjudicated delinquent for an act which is an indictable offense in this state or in another state under }}}{{\f5\fs18\hyphpar0\qj{chapter 232}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fConvicted\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not mean a plea, sentence, adjudication, deferred sentence, or deferred judgment which has been reversed or otherwise set aside.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDepartment\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the department of agriculture and land stewardship.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDispositional expenses\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means expenses incurred by a local authority in rescuing an animal as provided in }}}{{\f5\fs18\hyphpar0\qj{section 717B.5}}}{{\f5\fs18\hyphpar0\qj{, maintaining the animal until the conclusion of a dispositional proceeding as provided in }}}{{\f5\fs18\hyphpar0\qj{section 717B.4}}}{{\f5\fs18\hyphpar0\qj{, or disposing of the animal as provided in }}}{{\f5\fs18\hyphpar0\qj{section 717B.4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fEuthanasia\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as defined in }}}{{\f5\fs18\hyphpar0\qj{section 162.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fInjury\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an animal\u8217\'3fs disfigurement; the impairment of an animal\u8217\'3fs health; or an impairment to the functioning of an animal\u8217\'3fs limb or organ, including physical damage or harm to an animal\u8217\'3fs muscle, tissue, organs, bones, hide, or skin.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLaw enforcement officer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a regularly employed member of a police force of a city or county, including a sheriff, who is responsible for the prevention and detection of crime and the enforcement of the criminal laws of this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLocal authority\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a city as defined in }}}{{\f5\fs18\hyphpar0\qj{section 362.2}}}{{\f5\fs18\hyphpar0\qj{ or a county as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 331}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMaintenance\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means to provide on-site or off-site care to neglected animals.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fResponsible party\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person who owns or maintains an animal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSerious injury\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an injury that constitutes an animal\u8217\'3fs protracted or permanent disfigurement, the protracted or permanent impairment of an animal\u8217\'3fs health, the protracted or permanent impairment of the functioning of an animal\u8217\'3fs limb or organ, or the loss of an animal\u8217\'3fs limb or organ.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{16.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fThreatened animal\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an animal that is abused as provided in }}}{{\f5\fs18\hyphpar0\qj{section 717B.2}}}{{\f5\fs18\hyphpar0\qj{, neglected as provided in }}}{{\f5\fs18\hyphpar0\qj{section 717B.3}}}{{\f5\fs18\hyphpar0\qj{, or tortured as provided in }}}{{\f5\fs18\hyphpar0\qj{section 717B.3A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{17.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fVeterinarian\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a veterinarian licensed pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 169}}}{{\f5\fs18\hyphpar0\qj{ who practices veterinary medicine in this state.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1103, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1148, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1119, \'a7200, 201}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1130, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 90, \'a7201}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1111, \'a73, 4}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7717D.1}}}{{\f5\fs12\hyphpar0\qj{, 717F.7}}}{{\f5\fs12\hyphpar0\qj{, 717F.10}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{717B.2}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Animal abuse }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ penalties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person commits animal abuse when the person intentionally, knowingly, or recklessly acts to inflict injury, serious injury, or death on an animal by force, violence, or poisoning.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ shall not apply to any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An owner of the animal, or a person acting with the consent of the owner, who euthanizes an animal in a reasonable manner, if at the time of the euthanasia, the animal is in a state of permanent pain or suffering.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person acting to carry out an order issued by a court.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A veterinarian practicing veterinary medicine as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 169}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person acting in order to carry out another provision of law which allows the conduct.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person taking, hunting, trapping, or fishing for a wild animal as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 481A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person acting to protect the person\u8217\'3fs property from a wild animal as defined in }}}{{\f5\fs18\hyphpar0\qj{section 481A.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person acting to protect a person from injury or death caused by a wild animal as defined in }}}{{\f5\fs18\hyphpar0\qj{section 481A.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person reasonably acting to protect the person\u8217\'3fs property from damage caused by an unconfined animal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person reasonably acting to protect a person from injury or death caused by an unconfined animal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A local authority reasonably acting to destroy an animal, if at the time of the destruction, the owner of the animal is absent or unable to care for the animal, and the animal is permanently distressed by disease or injury to a degree that would result in severe and prolonged suffering.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{k.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A research facility, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 162.2}}}{{\f5\fs18\hyphpar0\qj{, if the research facility has been issued or renewed a valid authorization by the department pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 162}}}{{\f5\fs18\hyphpar0\qj{, and performs functions within the scope of accepted practices and disciplines associated with the research facility.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{l.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An act required to be carried out by a commercial establishment to care for an animal in its possession or under its control as described in }}}{{\f5\fs18\hyphpar0\qj{section 162.10A, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, provided that the commercial establishment complies with applicable standard of care requirements pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsections 1 and 2}}}{{\f5\fs18\hyphpar0\qj{ of that section.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who commits animal abuse that causes injury, other than serious injury or death, to an animal is guilty of a serious misdemeanor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who commits animal abuse that causes serious injury or death to an animal is guilty of an aggravated misdemeanor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{, a person who commits animal abuse that causes serious injury or death to an animal is guilty of a class \u8220\'3fD\u8221\'3f felony if the person has previously been convicted of committing animal abuse pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, animal neglect punishable as a serious misdemeanor or aggravated misdemeanor pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 717B.3}}}{{\f5\fs18\hyphpar0\qj{, animal torture pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 717B.3A}}}{{\f5\fs18\hyphpar0\qj{, injury to or interference with a police service dog pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 717B.9}}}{{\f5\fs18\hyphpar0\qj{, bestiality pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 717C.1}}}{{\f5\fs18\hyphpar0\qj{, or an act involving a contest event prohibited in }}}{{\f5\fs18\hyphpar0\qj{section 717D.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1103, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1058, \'a720}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1111, \'a75}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7162.10A}}}{{\f5\fs12\hyphpar0\qj{, 717B.1}}}{{\f5\fs12\hyphpar0\qj{, 717B.3}}}{{\f5\fs12\hyphpar0\qj{, 717B.3A}}}{{\f5\fs12\hyphpar0\qj{, 717B.3B}}}{{\f5\fs12\hyphpar0\qj{, 717C.1}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{717B.3}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Animal neglect }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ penalties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person commits animal neglect when the person owns or has custody of an animal, confines that animal, and fails to provide the animal with any of the following conditions for the animal\u8217\'3fs welfare: }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Access to food in an amount and quality reasonably sufficient to satisfy the animal\u8217\'3fs basic nutrition level to the extent that the animal\u8217\'3fs health or life is endangered.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Access to a supply of potable water in an amount reasonably sufficient to satisfy the animal\u8217\'3fs basic hydration level to the extent that the animal\u8217\'3fs health or life is endangered. Access to snow or ice does not satisfy this requirement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Sanitary conditions free from excessive animal waste or the overcrowding of animals to the extent that the animal\u8217\'3fs health or life is endangered.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Ventilated shelter reasonably sufficient to provide adequate protection from the elements and weather conditions suitable for the age, species, and physical condition of the animal so as to maintain the animal in a state of good health to the extent that the animal\u8217\'3fs health or life is endangered. The shelter must protect the animal from wind, rain, snow, or sun and have adequate bedding to provide reasonable protection against cold and dampness. A shelter may include a residence, garage, barn, shed, or doghouse.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Grooming, to the extent it is reasonably necessary to prevent adverse health effects or suffering.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Veterinary care deemed necessary by a reasonably prudent person to relieve an animal\u8217\'3fs distress from any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A condition caused by failing to provide for the animal\u8217\'3fs welfare as described in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An injury or illness suffered by the animal causing the animal to suffer prolonged pain and suffering.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not apply to any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{\*\bkmkstart u}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person issued or renewed an authorization to operate a commercial establishment, or a person acting under the direction or supervision of that person, if all of the following apply:}}}{\*\bkmkend u}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The animal, as described in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, was maintained as part of the commercial establishment\u8217\'3fs operation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In providing conditions for the welfare of the animal, as described in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, the person complied with the standard of care requirements provided in }}}{{\f5\fs18\hyphpar0\qj{section 162.10A, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, including any applicable rules adopted by the department applying to any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A state licensee or registrant operating pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 162.10A, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A permittee operating pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 162.10A, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A research facility, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 162.2}}}{{\f5\fs18\hyphpar0\qj{, if the research facility has been issued or renewed a valid authorization by the department pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 162}}}{{\f5\fs18\hyphpar0\qj{, and performs functions within the scope of accepted practices and disciplines associated with the research facility.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who commits animal neglect that does not cause injury, serious injury, or death to an animal is guilty of a simple misdemeanor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who commits animal neglect that causes injury, other than serious injury or death, to an animal is guilty of a serious misdemeanor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who commits animal neglect that causes serious injury or death to an animal is guilty of an aggravated misdemeanor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{, a person who commits animal neglect that causes serious injury or death to an animal is guilty of a class \u8220\'3fD\u8221\'3f felony if the person has been previously convicted of animal abuse pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 717B.2}}}{{\f5\fs18\hyphpar0\qj{, animal neglect punishable as a serious misdemeanor or aggravated misdemeanor pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, animal torture pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 717B.3A}}}{{\f5\fs18\hyphpar0\qj{, injury to or interference with a police service dog pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 717B.9}}}{{\f5\fs18\hyphpar0\qj{, bestiality pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 717C.1}}}{{\f5\fs18\hyphpar0\qj{, or an act involving a contest event prohibited in }}}{{\f5\fs18\hyphpar0\qj{section 717D.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1103, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 49, \'a725}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1058, \'a721}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1092, \'a7147}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1111, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1177, \'a720}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7162.10A}}}{{\f5\fs12\hyphpar0\qj{, 717B.1}}}{{\f5\fs12\hyphpar0\qj{, 717B.2}}}{{\f5\fs12\hyphpar0\qj{, 717B.3A}}}{{\f5\fs12\hyphpar0\qj{, 717B.3B}}}{{\f5\fs12\hyphpar0\qj{, 717C.1}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{717B.3A}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Animal torture }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ penalties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person is guilty of animal torture if the person intentionally or knowingly inflicts on an animal severe and prolonged or repeated physical pain that causes the animal\u8217\'3fs serious injury or death.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ shall not apply to any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person acting to carry out an order issued by a court.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A veterinarian practicing veterinary medicine as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 169}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person acting in order to carry out another provision of law which allows the conduct.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person taking, hunting, trapping, or fishing for a wild animal as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 481A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person acting to protect the person\u8217\'3fs property from a wild animal as defined in }}}{{\f5\fs18\hyphpar0\qj{section 481A.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person acting to protect a person from bodily harm or death caused by a wild animal as defined in }}}{{\f5\fs18\hyphpar0\qj{section 481A.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person acting reasonably to protect the person\u8217\'3fs property from damage caused by an unconfined animal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person acting reasonably to protect a person from bodily harm or death caused by an unconfined animal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A local authority acting reasonably to euthanize an animal, if at the time of the euthanasia, the owner of the animal is absent or unable to care for the animal, and the animal is permanently distressed by disease or injury to a degree that would result in severe and prolonged suffering.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A research facility, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 162.2}}}{{\f5\fs18\hyphpar0\qj{, if the research facility has been issued or renewed a valid authorization by the department pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 162}}}{{\f5\fs18\hyphpar0\qj{, and the research facility performs functions within the scope of accepted practices and disciplines associated with the research facility.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{k.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An act required to be carried out by a commercial establishment to care for an animal in its possession or under its control as described in }}}{{\f5\fs18\hyphpar0\qj{section 162.10A, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, provided that the commercial establishment complies with applicable standard of care requirements pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsections 1 and 2}}}{{\f5\fs18\hyphpar0\qj{ of that section.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The juvenile court shall have exclusive original jurisdiction in a proceeding concerning a child who is alleged to have committed animal torture, in the manner provided in }}}{{\f5\fs18\hyphpar0\qj{section 232.8}}}{{\f5\fs18\hyphpar0\qj{. The juvenile court shall not waive jurisdiction in a proceeding concerning such an offense alleged to have been committed by a child under the age of seventeen.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who commits animal torture is guilty of an aggravated misdemeanor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{, a person who commits animal torture is guilty of a class \u8220\'3fD\u8221\'3f felony if the person has previously been convicted of committing animal abuse pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 717B.2}}}{{\f5\fs18\hyphpar0\qj{, animal neglect punishable as a serious misdemeanor or aggravated misdemeanor pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 717B.3}}}{{\f5\fs18\hyphpar0\qj{, animal torture pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, injury to or interference with a police service dog pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 717B.9}}}{{\f5\fs18\hyphpar0\qj{, bestiality pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 717C.1}}}{{\f5\fs18\hyphpar0\qj{, or an act involving a contest event prohibited in }}}{{\f5\fs18\hyphpar0\qj{section 717D.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1152, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1058, \'a722}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1111, \'a77}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7162.10A}}}{{\f5\fs12\hyphpar0\qj{, 232.8}}}{{\f5\fs12\hyphpar0\qj{, 717B.1}}}{{\f5\fs12\hyphpar0\qj{, 717B.2}}}{{\f5\fs12\hyphpar0\qj{, 717B.3}}}{{\f5\fs12\hyphpar0\qj{, 717B.3B}}}{{\f5\fs12\hyphpar0\qj{, 717C.1}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{717B.3B}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Animal mistreatment }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ court order }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ evaluation and treatment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At the time of a person\u8217\'3fs conviction for committing a public offense constituting animal mistreatment, a court may enter an order requiring the person to undergo a psychological or psychiatric evaluation and to undergo any treatment that the court determines to be appropriate after due consideration of the evaluation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, the court shall enter an order described in that subsection, if the convicted person is any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A juvenile.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An adult convicted of animal abuse punishable as an aggravated misdemeanor or class \u8220\'3fD\u8221\'3f felony pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 717B.2}}}{{\f5\fs18\hyphpar0\qj{, animal neglect punishable as an aggravated misdemeanor or class \u8220\'3fD\u8221\'3f felony pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 717B.3}}}{{\f5\fs18\hyphpar0\qj{, or animal torture pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 717B.3A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The costs of undergoing a psychological or psychiatric evaluation and undergoing any treatment ordered by the court shall be borne by the convicted person, unless the person is a juvenile.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An order made under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is in addition to any other order or sentence of the court.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any violation of the court order shall be punished as contempt of court pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 665}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2020 Acts, ch 1111, \'a78}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7717C.1}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{717B.4}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Dispositional proceedings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon a petition brought by a local authority, a court in the county where an animal is maintained by a responsible party or a local authority shall determine if the animal is a threatened animal and order its disposition after a hearing.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The matter shall be heard within ten days from the filing of the petition for disposition by the local authority.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the animal has been rescued, the court may order that the animal be placed under the custody of the local authority and maintained in the same manner as a rescued animal under }}}{{\f5\fs18\hyphpar0\qj{section 717B.5}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court may continue the hearing for up to thirty days upon petition by the responsible party. However, the court shall not grant a continuance unless the animal is maintained by the local authority. The responsible party must post a bond or other security with the local authority as a condition of the continuance. The amount of the bond or other security shall be determined by the court, which shall not be more than the amount sufficient to provide maintenance of the animal for thirty days. The court may grant a subsequent continuance upon petition by the responsible party. The continuance shall be for not more than thirty days. The responsible party must post a new bond or security as a condition of the subsequent continuance in the same manner as the original bond or security or as otherwise ordered by the court. However, the court shall order the immediate disposition of the animal if the animal is permanently distressed by disease or injury to a degree that would result in severe or prolonged suffering.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The hearing to determine if the animal is a threatened animal for purposes of disposition shall be a civil proceeding. If the case is related to a criminal proceeding, the disposition shall not be part of that proceeding and shall not be considered a criminal penalty imposed on a person found in violation of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the court determines that an animal is not a threatened animal, the court shall order that the animal be returned to the custody of the responsible party. If the court determines that an animal is a threatened animal, the court shall order the local authority to dispose of the threatened animal in any manner deemed appropriate for the welfare of the animal. In addition, all of the following apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court may order the responsible party to pay an amount which shall not be more than the dispositional expenses incurred by the local authority. The court may also award the local authority court costs, reasonable attorney fees and expenses related to the investigation and prosecution of the case, which shall be taxed as part of the costs of the action.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a bond or other security was posted as a condition for a continuance of a disposition hearing as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the local authority may use the posted amount to offset the local authority\u8217\'3fs dispositional expenses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If any moneys are realized from the disposition of a threatened animal, the moneys shall be used to offset the local authority\u8217\'3fs dispositional expenses before satisfying indebtedness secured by any security interest in or lien on the threatened animal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the threatened animal is owned by more than one responsible party, the amount required to offset the local authority\u8217\'3fs dispositional expenses shall be prorated among the responsible parties based on the percentage of interest owned in the threatened animal attributable to the responsible parties as the threatened animal\u8217\'3fs titleholders. For purposes of this paragraph, a responsible party who does not own an interest in the threatened animal shall be deemed to be an owner holding a percentage interest in the animal equal to the largest percentage interest held by a landowner who is attributed an interest as the threatened animal\u8217\'3fs titleholder. If the responsible party is a landowner, the local authority may submit the amount to reimburse the local authority for its dispositional expenses to the clerk of the county board of supervisors who shall report the amount to the county treasurer. If the threatened animal is owned by more than one landowner, the amount shall be prorated among the landowners based on the percentage of interest owned in the threatened animal attributable to each landowner as the animal\u8217\'3fs titleholders. The amount shall be placed upon the tax books, and collected with interest and penalties after due, in the same manner as other unpaid property taxes. The county shall reimburse a city within thirty days from the collection of the property taxes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A threatened animal that is ordered by a court to be destroyed under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be destroyed only by euthanasia as defined in }}}{{\f5\fs18\hyphpar0\qj{section 162.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1103, \'a715}}}{; }{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1130, \'a73}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7602.6405}}}{{\f5\fs12\hyphpar0\qj{, 717B.1}}}{{\f5\fs12\hyphpar0\qj{, 717B.5}}}{{\f5\fs12\hyphpar0\qj{, 717D.5}}}{{\f5\fs12\hyphpar0\qj{, 717F.5}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{717B.5}}}{\*\bkmkstart stylerid1_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Rescue of threatened animals.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A local authority may provide for the rescue of an animal as follows:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The rescue must be made by a law enforcement officer having cause to believe that the animal is a threatened animal after consulting with a veterinarian licensed pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 169}}}{{\f5\fs18\hyphpar0\qj{. The law enforcement officer may rescue the animal by entering on public or private property, as provided in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. The officer may enter onto property of a person to rescue the animal if the officer obtains a search warrant issued by a court, or enters onto the premises in a manner consistent with the laws of this state and the United States, including }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/publications/icnst/402726.pdf#nameddest=iowaConst_art_I_sec_8" }{\fldrslt \cf5 \f5 \fs18{{Article I, section 8, of the Constitution of the State of Iowa}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{, or the }}}{{\f5\fs18\hyphpar0\qj{fourth amendment to the Constitution of the United States}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If an animal is rescued pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the local authority shall provide for the maintenance of the animal. The local authority may contract with an animal care provider for the maintenance of the animal. The local authority shall provide the responsible party for the animal with notice of the rescue. The notice may be accomplished by doing any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Delivering written notice to the responsible party\u8217\'3fs last known address by the United States postal service or personal service.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Posting a notice in a conspicuous place at the location where the animal was rescued.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The notice shall state that the animal has been rescued by the local authority pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Within ten days after the date that an animal is rescued, the local authority shall initiate a dispositional proceeding pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 717B.4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The local authority shall pay the animal care provider for the animal\u8217\'3fs maintenance regardless of proceeds received from the disposition of the animal or any reimbursement ordered by a court, pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 717B.4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1103, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1130, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 30, \'a7261}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7717B.1}}}{{\f5\fs12\hyphpar0\qj{, 717B.4}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{717B.6}}}{\*\bkmkstart stylerid1_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Destruction and disposition of wild animals.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A person may humanely destroy a wild animal as defined in }{{\f5\fs18\hyphpar0\qj{section 481A.1}}}{, if the wild animal is permanently distressed by injury or disease to a degree that results in severe and prolonged suffering. The destroyed animal shall be subject to disposition as provided by rules adopted by the natural resource commission pursuant to }{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1103, \'a717}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{717B.7}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2002/CH1130.pdf" }{\fldrslt \cf5 \f5 \fs18{{2002 Acts, ch 1130, \'a710}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{See }}}{{\f5\fs18\hyphpar0\qj{chapter 717D}}}{{\f5\fs18\hyphpar0\qj{. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{717B.8}}}{\*\bkmkstart stylerid1_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Abandonment of cats and dogs }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ penalties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person commits animal abandonment if the person owns or has custody of a cat or dog and relinquishes all rights in and duties to care for the cat or dog.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not apply to any of the following: }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The delivery of a cat or dog to another person who will accept ownership and custody of the cat or dog.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The delivery of a cat or dog to an animal shelter or pound as defined in }}}{{\f5\fs18\hyphpar0\qj{section 162.2}}}{{\f5\fs18\hyphpar0\qj{ that has been issued or renewed a valid authorization by the department under }}}{{\f5\fs18\hyphpar0\qj{chapter 162}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who relinquishes custody of a cat at a location in which the person does not hold a legal or equitable interest, if previously the person had taken custody of the cat at the same location and provided for the cat\u8217\'3fs sterilization by a veterinarian.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who commits animal abandonment that does not cause injury or death to an animal is guilty of a simple misdemeanor.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who commits animal abandonment that causes injury other than serious injury or death to an animal is guilty of a serious misdemeanor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who commits animal abandonment that causes serious injury or death to an animal is guilty of an aggravated misdemeanor.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1103, \'a719}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1111, \'a79}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7717B.1}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{717B.9}}}{\*\bkmkstart stylerid1_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Injury or interference with a police service dog.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who knowingly, and willfully or maliciously torments, strikes, administers a nonpoisonous desensitizing substance to, or otherwise interferes with a police service dog, without inflicting serious injury on the dog, commits a serious misdemeanor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who knowingly, and willfully or maliciously does any of the following commits a class \u8220\'3fD\u8221\'3f felony:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Tortures a police service dog.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Injures, so as to disfigure or disable, a police service dog.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Sets a booby trap device for purposes of injuring, so as to disfigure or disable, or killing a police service dog.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Pays or agrees to pay a bounty for purposes of injury, so as to disfigure or disable, or killing a police service dog.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Kills a police service dog.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Administers poison to a police service dog.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fpolice service dog\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a dog used by a peace officer or correctional officer in the performance of the officer\u8217\'3fs duties, whether or not the dog is on duty.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not apply to a peace officer or veterinarian who terminates the life of such a dog for the purpose of relieving the dog of undue pain or suffering, or to a person who justifiably acts in defense of self or another.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1103, \'a720}}}{; }{{\f5\fs18\hyphpar0\qj{95 Acts, ch 107, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7717B.1}}}{{\f5\fs12\hyphpar0\qj{, 717B.2}}}{{\f5\fs12\hyphpar0\qj{, 717B.3}}}{{\f5\fs12\hyphpar0\qj{, 717B.3A}}}\par}}