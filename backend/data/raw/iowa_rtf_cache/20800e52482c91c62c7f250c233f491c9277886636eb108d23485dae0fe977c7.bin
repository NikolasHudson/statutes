\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F225D}{\*\bkmkend codeChapter_5F225D}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 225D}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{AUTISM SUPPORT PROGRAM}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{225D.1}}}{\*\bkmkstart stylerid1_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{As used in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ unless the context otherwise requires:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fApplied behavioral analysis\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the design, implementation, and evaluation of environmental modifications, using behavioral stimuli and consequences, to produce socially significant improvement in human behavior or to prevent loss of attained skill or function, including the use of direct observation, measurement, and functional analysis of the relations between environment and behavior.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAutism\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means autism spectrum disorder as defined in }}}{{\f5\fs18\hyphpar0\qj{section 514C.28}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAutism service provider\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person providing applied behavioral analysis, who meets all of the following criteria:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is certified as a behavior analyst by the behavior analyst certification board, is a psychologist licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 154B}}}{{\f5\fs18\hyphpar0\qj{, or is a psychiatrist licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 148}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is a board-certified assistant behavior analyst who performs duties, identified by and based on the standards of the behavior analyst certification board, under the supervision of a board-certified behavior analyst.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is approved as a member of the provider network by the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAutism support fund\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ffund\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the autism support fund created in }}}{{\f5\fs18\hyphpar0\qj{section 225D.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fClinically relevant\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means medically necessary and resulting in the development, maintenance, or restoration, to the maximum extent practicable, of the functioning of an individual.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDepartment\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the department of health and human services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDiagnostic assessment of autism\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means medically necessary assessment, evaluations, or tests performed by a licensed child psychiatrist, developmental pediatrician, or clinical psychologist.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fEligible individual\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a child less than fourteen years of age who has been diagnosed with autism based on a diagnostic assessment of autism, is not otherwise eligible for coverage for applied behavioral analysis treatment or applied behavior analysis treatment under the medical assistance program, }}}{{\f5\fs18\hyphpar0\qj{section 514C.28}}}{{\f5\fs18\hyphpar0\qj{, section }}}{{\f5\fs18\hyphpar0\qj{514C.31}}}{{\f5\fs18\hyphpar0\qj{, or other private insurance coverage, and whose household income does not exceed five hundred percent of the federal poverty level.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fFederal poverty level\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the most recently revised poverty income guidelines published by the United States department of health and human services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fHousehold income\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means household income as determined using the modified adjusted gross income methodology pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 2002 of the federal Patient Protection and Affordable Care Act}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{Pub. L. No. 111-148}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMedical assistance\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMedicaid\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means assistance provided under the medical assistance program pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 249A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fRegional autism assistance program\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the regional autism assistance program created in }}}{{\f5\fs18\hyphpar0\qj{section 256.35}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fTreatment plan\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a plan for the treatment of autism developed by a licensed physician or licensed psychologist pursuant to a comprehensive evaluation or reevaluation performed in consultation with the patient and the patient\u8217\'3fs representative.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2013 Acts, ch 138, \'a782, 85}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 137, \'a769, 162, 163}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1139, \'a759}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 18, \'a71, 5}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 170, \'a735, 44}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1026, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7470}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{225D.2}}}{\*\bkmkstart stylerid1_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Autism support program }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall implement an autism support program beginning January 1, 2014, to provide payment for the provision of applied behavioral analysis treatment for eligible individuals. The department shall adopt rules, including standards and guidelines pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ to implement and administer the program. In adopting the rules, standards, and guidelines for the program, the department shall consult with and incorporate the recommendations of an expert panel convened by the regional autism assistance program to provide expert opinion on clinically relevant practices and guidance on program implementation and administration. The expert panel shall consist of families of individuals with autism; educational, medical, and human services specialists, professionals, and providers; and others with interest in or expertise related to autism. The program shall be implemented and administered in a manner so that payment for services is available throughout the state, including in rural and under-resourced areas.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At a minimum, the rules, standards, and guidelines for the program shall address all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A maximum annual benefit amount for an eligible individual of thirty-six thousand dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A maximum of twenty-four months of applied behavioral analysis treatment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding the age limitation for an eligible individual, a provision that if an eligible individual reaches fourteen years of age prior to completion of the maximum applied behavioral analysis treatment period specified in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the individual may complete such treatment in accordance with the individual\u8217\'3fs treatment plan, not to exceed the maximum treatment period.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A graduated schedule for cost-sharing by an eligible individual based on a percentage of the total benefit amount expended for the eligible individual, annually. Cost-sharing shall be applicable to eligible individuals with household incomes at or above two hundred percent of the federal poverty level in incrementally increased amounts up to a maximum of fifteen percent. The rules shall provide a financial hardship exemption from payment of the cost-sharing based on criteria established by rule of the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Application, approval, compliance, and appeal processes for eligible individuals as necessary to operate and manage the program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Enrollment, renewal, and reimbursement of claims provisions for autism service providers participating in the program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A requirement of family engagement and participation as part of the eligible individual\u8217\'3fs treatment plan.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A requirement that the autism service provider coordinate interventions with the school in which the eligible individual is enrolled.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A requirement that the administrator of the program utilize the regional autism assistance program to coordinate interventions between eligible individuals and their families receiving support through the autism support program with appropriate medical, educational, and treatment providers, including integrated health homes. The regional autism assistance program shall provide for family navigation and coordination and integration of services through the statewide system of regional child health specialty clinics, utilizing the community child health team model. As necessitated by the availability of resources in the community where services are delivered, telehealth may be used in delivering and coordinating interventions with appropriate providers. To the extent available and accessible to an eligible individual, the eligible individual shall be enrolled in an integrated health home that is an approved provider enrolled in the medical assistance program. Health home services that are covered services under the medical assistance program shall be reimbursed under the autism support program at rates consistent with those established under the medical assistance program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Requirements related to review of treatment plans, which may require review once every six months, subject to utilization review requirements established by rule. A more or less frequent review may be agreed upon by the eligible individual and the licensed physician or licensed psychologist developing the treatment plan.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{k.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Recognition of the results of a diagnostic assessment of autism as valid for a period of not less than twelve months, unless a licensed physician or licensed psychologist determines that a more frequent assessment is necessary.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{l.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Proof of eligibility for the autism support program that includes a written denial for coverage or a benefits summary indicating that applied behavioral analysis treatment or applied behavior analysis treatment is not a covered benefit for which the applicant is eligible, under the Medicaid program, }}}{{\f5\fs18\hyphpar0\qj{section 514C.28}}}{{\f5\fs18\hyphpar0\qj{, section }}}{{\f5\fs18\hyphpar0\qj{514C.31}}}{{\f5\fs18\hyphpar0\qj{, or other private insurance coverage.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Moneys in the autism support fund created under }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{ shall be expended only for eligible individuals who are not eligible for coverage for applied behavioral analysis treatment or applied behavior analysis treatment under the medical assistance program, }}}{{\f5\fs18\hyphpar0\qj{section 514C.28}}}{{\f5\fs18\hyphpar0\qj{, section }}}{{\f5\fs18\hyphpar0\qj{514C.31}}}{{\f5\fs18\hyphpar0\qj{, or other private insurance. Payment for applied behavioral analysis treatment through the fund shall be limited to only applied behavioral analysis treatment that is clinically relevant and only to the extent approved under the guidelines established by rule of the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ shall not be construed as granting an entitlement for any program, service, or other support for eligible individuals. Any state obligation to provide a program, service, or other support pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is limited to the extent of the funds appropriated for the purposes of the program. The department may establish a waiting list or terminate participation of eligible individuals if the department determines that moneys in the autism support fund are insufficient to cover future claims for reimbursement beyond ninety days.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An autism support fund is created in the state treasury under the authority of the department. Moneys appropriated to and all other moneys specified for deposit in the fund shall be deposited in the fund and used for the purposes of the program. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 12C.7}}}{{\f5\fs18\hyphpar0\qj{, interest or earnings on moneys in the fund shall be credited to the fund. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 8.33}}}{{\f5\fs18\hyphpar0\qj{, moneys credited to the fund that remain unexpended or unobligated at the end of a fiscal year shall not revert to any other fund.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ to administer the fund and reimbursements made from the fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Moneys in the fund are appropriated to the department and shall be used by the department for the purposes of the autism support program. The department shall be the administrator of the fund for auditing purposes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall report on the program and fund pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 217.21}}}{{\f5\fs18\hyphpar0\qj{. }}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2013 Acts, ch 138, \'a783, 85}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 137, \'a770, 71, 162, 163}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1139, \'a760}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 18, \'a72, 3, 5}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1018, \'a76, 13, 14}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7225D.1}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 amendment to subsection 5, paragraph d applies retroactively to reports due on or after January 1, 2024; }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 1018, \'a714}}}\par}}