par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{514A.1}}}{\*\bkmkstart stylerid1_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definition of accident and sickness insurance policy.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fpolicy of accident and sickness insurance\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes a policy or contract covering insurance against loss resulting from sickness, or from bodily injury or death by accident, or both. For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ the words }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fpolicy of accident and sickness insurance\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ are interchangeable without deviation of meaning with the words }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fpolicy of accident and health insurance\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or the words }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fpolicy of accident or health insurance\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This chapter}}}{{\f5\fs18\hyphpar0\qj{ applies to all individual policies of such accident and sickness insurance written by Iowa or non-Iowa companies or associations duly licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 508}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{515}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{520}}}{{\f5\fs18\hyphpar0\qj{ and, societies, orders, or associations licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 512B}}}{{\f5\fs18\hyphpar0\qj{ writing sickness and accident policies providing benefits for loss of time.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Orders, societies or associations which admit to membership only persons engaged in one or more crafts or hazardous occupations in the same or similar lines of business and the societies or auxiliaries to such orders shall not be subject to the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ nor shall any religious order be subject to the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7514A.1}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 83, \'a772, 73}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1023, \'a7115}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7514D.2}}}{{\f5\fs12\hyphpar0\qj{, 514D.3}}}{{\f5\fs12\hyphpar0\qj{, 514D.7}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{514A.2}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Form of policy.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{No policy of accident and sickness insurance shall be delivered or issued for delivery to any person in this state unless:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The entire money and other considerations therefor are expressed therein; and}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The time at which the insurance takes effect and terminates is expressed therein; and}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It purports to insure only one person, except that a policy may insure, originally or by subsequent amendment, upon the application of an adult member of a family who shall be deemed the policyholder, any two or more eligible members of that family, including husband, wife, dependent children or any children under a specified age which shall not exceed nineteen years and any other person dependent upon the policyholder; and}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The style, arrangement and over-all appearance of the policy give no undue prominence to any portion of the text, and unless every printed portion of the text of the policy and of any endorsements or attached papers is plainly printed in light-faced type of a style in general use, the size of which shall be uniform and not less than ten point with a lower-case unspaced alphabet length not less than one hundred and twenty point (the \u8220\'3ftext\u8221\'3f shall include all printed matter except the name and address of the insurer, name or title of the policy, the brief description if any, and captions and subcaptions); and}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The exceptions and reductions of indemnity are set forth in the policy and, except those which are set forth in }}}{{\f5\fs18\hyphpar0\qj{section 514A.3}}}{{\f5\fs18\hyphpar0\qj{, are printed, at the insurer\u8217\'3fs option, either included with the benefit provision to which they apply, or under an appropriate caption such as \u8220\'3fexceptions\u8221\'3f, or \u8220\'3fexceptions and reductions\u8221\'3f, provided that if an exception or reduction specifically applies only to a particular benefit of the policy, a statement of such exception or reduction shall be included with the benefit provision to which it applies; and}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each such form, including riders and endorsements, shall be identified by a form number in the lower left-hand corner of the first page thereof; and}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It contains no provision purporting to make any portion of the charter, rules, constitution, or bylaws of the insurer a part of the policy unless such portion is set forth in full in the policy, except in the case of the incorporation of, or reference to, a statement of rates or classification of risks, or short-rate table filed with the commissioner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If any policy is issued by an insurer domiciled in this state for delivery to a person residing in another state, and if the official having responsibility for the administration of the insurance laws of such other state shall have advised the commissioner that any such policy is not subject to approval or disapproval by such official, the commissioner may by ruling require that such policy meet the standards set forth in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and in }}}{{\f5\fs18\hyphpar0\qj{section 514A.3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7514A.2}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7514A.12}}}{{\f5\fs12\hyphpar0\qj{, 514D.3}}}{{\f5\fs12\hyphpar0\qj{, 514D.7}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{514A.3}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Accident and sickness policy provisions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E7_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E7_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Required provisions.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, each such policy delivered or issued for delivery to any person in this state shall contain the provisions specified in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ in the words in which the same appear in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{; provided, however, that the insurer may, at its option, substitute for one or more of such provisions corresponding provisions of different wording approved by the commissioner which are in each instance not less favorable in any respect to the insured or the beneficiary. Such provisions shall be preceded individually by the caption appearing in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ or, at the option of the insurer, by such appropriate individual or group captions or subcaptions as the commissioner may approve.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A provision as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Entire contract \u8212\'3f changes:}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{This policy, including the endorsements and the attached papers, if any, constitutes the entire contract of insurance. No change in this policy shall be valid until approved by an executive officer of the insurer and unless such approval be endorsed hereon or attached hereto. No agent has authority to change this policy or to waive any of its provisions.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A provision as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Time limit on certain defenses:}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{(1)}{{\f5\fs18\hyphpar0\qj{\~\~}}}{After two years from the date of issue of this policy no misstatements, except fraudulent misstatements, made by the applicant in the application for such policy shall be used to void the policy or to deny a claim for loss incurred or disability (as defined in the policy) commencing after the expiration of this two-year period.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{(The foregoing policy provision shall not be so construed as to affect any legal requirement for avoidance of a policy or denial of a claim during such initial two-year period, nor to limit the application of }{{\f5\fs18\hyphpar0\qj{subsection 2}}}{, paragraphs }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f, \u8220\'3fb\u8221\'3f, \u8220\'3fc\u8221\'3f, \u8220\'3fd\u8221\'3f}}}{ and }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f,}}}{ in the event of misstatement with respect to age or occupation or other insurance.)}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{(A policy which the insured has the right to continue in force subject to its terms by the timely payment of premium }{{\i\f5\fs18\hyphpar0\qj{(a)}}}{ until at least age fifty or, }{{\i\f5\fs18\hyphpar0\qj{(b)}}}{ in the case of a policy issued after age forty-four, for at least five years from its date of issue, may contain in lieu of the foregoing the following provision (from which the clause in parentheses may be omitted at the insurer\u8217\'3fs option) under the caption \u8220\'3fincontestable\u8221\'3f:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{After this policy has been in force for a period of two years during the lifetime of the insured, (excluding any period during which the insured is disabled), it shall become incontestable as to the statements contained in the application.)}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{No claim for loss incurred or disability (as defined in the policy) commencing after two years from the date of issue of this policy shall be reduced or denied on the ground that a disease or physical condition not excluded from coverage by name or specific description effective on the date of loss had existed prior to the effective date of coverage of this policy.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A provision as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Grace period:}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{A grace period of }{{\f5\fs18\hyphpar0\qj{............}}}{ (insert a number not less than \u8220\'3f7\u8221\'3f for weekly premium policies, \u8220\'3f10\u8221\'3f for monthly premium policies and \u8220\'3f31\u8221\'3f for all other policies) days will be granted for the payment of each premium falling due after the first premium, during which grace period the policy shall continue in force.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{(A policy which contains a cancellation provision may add, at the end of the above provision, subject to the right of the insurer to cancel in accordance with the cancellation provision hereof.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A policy in which the insurer reserves the right to refuse any renewal shall have, at the beginning of the above provision,}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Unless not less than five days prior to the premium due date the insurer has delivered to the insured or has mailed to the insured\u8217\'3fs last address as shown by the records of the insurer written notice of its intention not to renew this policy beyond the period for which the premium has been accepted.)}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A provision as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Reinstatement:}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{If any renewal premium be not paid within the time granted the insured for payment, a subsequent acceptance of premium by the insurer or by any agent duly authorized by the insurer to accept such premium, without requiring in connection therewith an application for reinstatement, shall reinstate the policy; provided, however, that if the insurer or such agent requires an application for reinstatement and issues a conditional receipt for the premium tendered, the policy will be reinstated upon approval of such application by the insurer or, lacking such approval, upon the forty-fifth day following the date of such conditional receipt unless the insurer has previously notified the insured in writing of its disapproval of such application. The reinstated policy shall cover only loss resulting from such accidental injury as may be sustained after the date of reinstatement and loss due to such sickness as may begin more than ten days after such date. In all other respects the insured and insurer shall have the same rights thereunder as they had under the policy immediately before the due date of the defaulted premium, subject to any provisions endorsed hereon or attached hereto in connection with the reinstatement. Any premium accepted in connection with a reinstatement shall be applied to a period for which premium has not been previously paid, but not to any period more than sixty days prior to the date of reinstatement.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{(The last sentence of the above provision may be omitted from any policy which the insured has the right to continue in force subject to its terms by the timely payment of premiums (1) until at least age fifty or, (2) in the case of a policy issued after age forty-four, for at least five years from its date of issue.)}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A provision as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Notice of claim:}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{Written notice of claim must be given to the insurer within twenty days after the occurrence or commencement of any loss covered by the policy, or as soon thereafter as is reasonably possible. Notice given by or on behalf of the insured or the beneficiary to the insurer at }{{\f5\fs18\hyphpar0\qj{............}}}{ (insert the location of such office as the insurer may designate for the purpose), or to any authorized agent of the insurer, with information sufficient to identify the insured, shall be deemed notice to the insurer.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{(In a policy providing a loss-of-time benefit which may be payable for at least two years, an insurer may at its option insert the following between the first and second sentences of the above provision:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Subject to the qualifications set forth below, if the insured suffers loss of time on account of disability for which indemnity may be payable for at least two years, the insured shall, at least once in every six months after having given notice of claim, give to the insurer notice of continuance of said disability, except in the event of legal incapacity. The period of six months following any filing of proof by the insured or any payment by the insurer on account of such claim or any denial of liability in whole or in part by the insurer shall be excluded in applying this provision. Delay in the giving of such notice shall not impair the insured\u8217\'3fs right to any indemnity which would otherwise have accrued during the period of six months preceding the date on which such notice is actually given.)}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A provision as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Claim forms:}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{The insurer, upon receipt of a notice of claim, will furnish to the claimant such forms as are usually furnished by it for filing proofs of loss. If such forms are not furnished within fifteen days after the giving of such notice the claimant shall be deemed to have complied with the requirements of this policy as to proof of loss upon submitting, within the time fixed in the policy for filing proofs of loss, written proof covering the occurrence, the character and the extent of the loss for which claim is made.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A provision as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Proofs of loss:}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{Written proof of loss must be furnished to the insurer at its said office in case of claim for loss for which this policy provides any periodic payment contingent upon continuing loss within ninety days after the termination of the period for which the insurer is liable and in case of claim for any other loss within ninety days after the date of such loss. Failure to furnish such proof within the time required shall not invalidate nor reduce any claim if it was not reasonably possible to give proof within such time, provided such proof is furnished as soon as reasonably possible and in no event, except in the absence of legal capacity, later than one year from the time proof is otherwise required.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A provision as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Time of payment of claims:}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{Indemnities payable under this policy for any loss other than loss for which this policy provides any periodic payment will be paid immediately upon receipt of due written proof of such loss. Subject to due written proof of loss, all accrued indemnities for loss for which this policy provides periodic payment will be paid }{{\f5\fs18\hyphpar0\qj{............}}}{ (insert period for payment which must not be less frequently than monthly) and any balance remaining unpaid upon the termination of liability will be paid immediately upon receipt of due written proof.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A provision as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Payment of claims:}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{Indemnity for loss of life will be payable in accordance with the beneficiary designation and the provisions respecting such payment which may be prescribed herein and effective at the time of payment. If no such designation or provision is then effective, such indemnity shall be payable to the estate of the insured. Any other accrued indemnities unpaid at the insured\u8217\'3fs death may, at the option of the insurer, be paid either to such beneficiary or to such estate. All other indemnities will be payable to the insured.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{(The following provisions, or either of them, may be included with the foregoing provision at the option of the insurer:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If any indemnity of this policy shall be payable to the estate of the insured, or to an insured or beneficiary who is a minor or otherwise not competent to give a valid release, the insurer may pay such indemnity, up to an amount not exceeding $}{{\f5\fs18\hyphpar0\qj{........}}}{ (insert an amount which shall not exceed one thousand dollars), to any relative by blood or connection by marriage of the insured or beneficiary who is deemed by the insurer to be equitably entitled thereto. Any payment made by the insurer in good faith pursuant to this provision shall fully discharge the insurer to the extent of such payment.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Subject to any written direction of the insured in the application or otherwise all or a portion of any indemnities provided by this policy on account of hospital, nursing, medical, or surgical services may, at the insurer\u8217\'3fs option and unless the insured requests otherwise in writing not later than the time of filing proofs of such loss, be paid directly to the hospital or person rendering such services; but it is not required that the service be rendered by a particular hospital or person.)}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A provision as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Physical examinations and autopsy:}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{The insurer at its own expense shall have the right and opportunity to examine the person of the insured when and as often as it may reasonably require during the pendency of a claim hereunder and to make an autopsy in case of death where it is not forbidden by law.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{k.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A provision as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Legal actions:}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{No action at law or in equity shall be brought to recover on this policy prior to the expiration of sixty days after written proof of loss has been furnished in accordance with the requirements of this policy. No such action shall be brought after the expiration of three years after the time written proof of loss is required to be furnished.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{l.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A provision as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Change of beneficiary:}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{Unless the insured makes an irrevocable designation of beneficiary, the right to change of beneficiary is reserved to the insured and the consent of the beneficiary or beneficiaries shall not be requisite to surrender or assignment of this policy or to any change of beneficiary or beneficiaries, or to any other changes in this policy.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{(The first clause of this provision, relating to the irrevocable designation of beneficiary, may be omitted at the insurer\u8217\'3fs option.)}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{m.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A provision as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Right to return policy:}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{The insured has the right, within ten days after receipt of this policy, to return it to the company at its home office or branch office or to the agent through whom it was purchased, and if so returned the premium paid will be refunded and the policy will be void from the beginning and the parties shall be in the same position as if a policy had not been issued.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The foregoing provision shall be prominently printed on the first page of the policy or attached to the policy.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The provisions of this paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fm\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall apply to any insurance policy which is delivered or issued for delivery or renewed in this state on or after July 1, 1978.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E7_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E7_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Other provisions.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, no such policy delivered or issued for delivery to any person in this state shall contain provisions respecting the matters set forth below unless such provisions are in the words in which the same appear in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{; provided, however, that the insurer may, at its option, use in lieu of any such provision a corresponding provision of different wording approved by the commissioner which is not less favorable in any respect to the insured or the beneficiary. Any such provision contained in the policy shall be preceded individually by the appropriate caption appearing in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ or, at the option of the insurer, by such appropriate individual or group captions or subcaptions as the commissioner may approve.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A provision as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Change of occupation:}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{If the insured be injured or contract sickness after having changed the insured\u8217\'3fs occupation to one classified by the insurer as more hazardous than that stated in this policy or while doing for compensation anything pertaining to an occupation so classified, the insurer will pay only such portion of the indemnities provided in this policy as the premium paid would have purchased at the rates and within the limits fixed by the insurer for such more hazardous occupation. If the insured changes the insured\u8217\'3fs occupation to one classified by the insurer as less hazardous than that stated in this policy, the insurer, upon receipt of proof of such change of occupation, will reduce the premium rate accordingly, and will return the excess pro rata unearned premium from the date of change of occupation or from the policy anniversary date immediately preceding receipt of such proof, whichever is the more recent. In applying this provision, the classification of occupational risk and the premium rates shall be such as have been last filed by the insurer prior to the occurrence of the loss for which the insurer is liable or prior to date of proof of change in occupation with the state official having supervision of insurance in the state where the insured resided at the time this policy was issued; but if such filing was not required, then the classification of occupational risk and the premium rates shall be those last made effective by the insurer in such state prior to the occurrence of the loss or prior to the date of proof of change in occupation.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A provision as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Misstatement of age:}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{If the age of the insured has been misstated, all amounts payable under this policy shall be such as the premium paid would have purchased at the correct age.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A provision as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Other insurance in this insurer:}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{If an accident or sickness or accident and sickness policy or policies previously issued by the insurer to the insured be in force concurrently herewith, making the aggregate indemnity for }{{\f5\fs18\hyphpar0\qj{............}}}{ (insert type of coverage or coverages) in excess of $}{{\f5\fs18\hyphpar0\qj{............}}}{ (insert maximum limit of indemnity or indemnities) the excess insurance shall be void and all premiums paid for such excess shall be returned to the insured or to the insured\u8217\'3fs estate.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Or, in lieu thereof:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Insurance effective at any one time on the insured under a like policy or policies in this insurer is limited to the one such policy elected by the insured, or the insured\u8217\'3fs beneficiary or estate, as the case may be, and the insurer will return all premiums paid for all other such policies.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A provision as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Insurance with other insurers:}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{If there be other valid coverage, not with this insurer, providing benefits for the same loss on a provision of service basis or on an expense incurred basis and of which this insurer has not been given written notice prior to the occurrence or commencement of loss, the only liability under any expense incurred coverage of this policy shall be for such proportion of the loss as the amount which would otherwise have been payable hereunder plus the total of the like amounts under all such other valid coverages for the same loss of which this insurer had notice bears to the total like amounts under all valid coverages for such loss, and for the return of such portion of the premiums paid as shall exceed the pro rata portion for the amount so determined. For the purpose of applying this provision when other coverage is on a provision of service basis, the \u8220\'3flike amount\u8221\'3f of such other coverage shall be taken as the amount which the services rendered would have cost in the absence of such coverage.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{(If the foregoing policy provision is included in a policy which also contains the next following policy provision there shall be added to the caption of the foregoing provision the phrase \u8220\'3f}{\f5\fs18\hyphpar0\qj}{ \u8212\'3f expense incurred benefits\u8221\'3f. The insurer may, at its option, include in this provision a definition of \u8220\'3fother valid coverage\u8221\'3f, approved as to form by the commissioner, which definition shall be limited in subject matter to coverage provided by organizations subject to regulation by insurance law or by insurance authorities of this or any other state of the United States or any province of Canada, and by hospital or medical service organizations, and to any other coverage the inclusion of which may be approved by the commissioner. In the absence of such definition such term shall not include group insurance, automobile medical payments insurance, or coverage provided by hospital or medical service organizations or by union welfare plans or employer or employee benefit organizations. For the purpose of applying the foregoing policy provision with respect to any insured, any amount of benefit provided for such insured pursuant to any compulsory benefit statute (including any workers\u8217\'3f compensation or employer\u8217\'3fs liability statute) whether provided by a governmental agency or otherwise shall in all cases be deemed to be \u8220\'3fother valid coverage\u8221\'3f of which the insurer has had notice. In applying the foregoing policy provision no third party liability coverage shall be included as \u8220\'3fother valid coverage\u8221\'3f.)}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A provision as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Insurance with other insurers:}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{If there be other valid coverage, not with this insurer, providing benefits for the same loss on other than an expense incurred basis and of which this insurer has not been given written notice prior to the occurrence or commencement of loss, the only liability for such benefits under this policy shall be for such proportion of the indemnities otherwise provided hereunder for such loss as the like indemnities of which the insurer had notice (including the indemnities under this policy) bear to the total amount of all like indemnities for such loss, and for the return of such portion of the premium paid as shall exceed the pro rata portion for the indemnities thus determined.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{(If the foregoing policy provision is included in a policy which also contains the next preceding policy provision there shall be added to the caption of the foregoing provision the phrase \u8220\'3f}{\f5\fs18\hyphpar0\qj}{ \u8212\'3f other benefits\u8221\'3f. The insurer may, at its option, include in this provision a definition of \u8220\'3fother valid coverage\u8221\'3f, approved as to form by the commissioner, which definition shall be limited in subject matter to coverage provided by organizations subject to regulation by insurance law or by insurance authorities of this or any other state of the United States or any province of Canada, and to any other coverage the inclusion of which may be approved by the commissioner. In the absence of such definition such term shall not include group insurance, or benefits provided by union welfare plans or by employer or employee benefit organizations. For the purpose of applying the foregoing policy provision with respect to any insured, any amount of benefit provided for such insured pursuant to any compulsory benefit statute (including any workers\u8217\'3f compensation or employer\u8217\'3fs liability statute) whether provided by a governmental agency or otherwise shall in all cases be deemed to be \u8220\'3fother valid coverage\u8221\'3f of which the insurer has had notice. In applying the foregoing policy provision no third party liability coverage shall be included as \u8220\'3fother valid coverage\u8221\'3f.)}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A provision as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Relation of earnings to insurance:}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{If the total monthly amount of loss of time benefits promised for the same loss under all valid loss of time coverage upon the insured, whether payable on a weekly or monthly basis, shall exceed the monthly earnings of the insured at the time disability commenced or the insured\u8217\'3fs average monthly earnings for the period of two years immediately preceding a disability for which claim is made, whichever is the greater, the insurer will be liable only for such proportionate amount of such benefits under this policy as the amount of such monthly earnings or such average monthly earnings of the insured bears to the total amount of monthly benefits for the same loss under all such coverage upon the insured at the time such disability commences and for the return of such part of the premiums paid during such two years as shall exceed the pro rata amount of the premiums for the benefits actually paid hereunder; but this shall not operate to reduce the total monthly amount of benefits payable under all such coverage upon the insured below the sum of two hundred dollars or the sum of the monthly benefits specified in such coverages, whichever is the lesser, nor shall it operate to reduce benefits other than those payable for loss of time.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{(The foregoing policy provision may be inserted only in a policy which the insured has the right to continue in force subject to its terms by the timely payment of premiums (1) until at least age fifty or, (2) in the case of a policy issued after age forty-four, for at least five years from its date of issue. The insurer may, at its option, include in this provision a definition of \u8220\'3fvalid loss of time coverage\u8221\'3f, approved as to form by the commissioner, which definition shall be limited in subject matter to coverage provided by governmental agencies or by organizations subject to regulation by insurance law or by insurance authorities of this or any other state of the United States or any province of Canada, or to any other coverage the inclusion of which may be approved by the commissioner or any combination of such coverages. In the absence of such definition such term shall not include any coverage provided for such insured pursuant to any compulsory benefit statute (including any workers\u8217\'3f compensation or employer\u8217\'3fs liability statute), or benefits provided by union welfare plans or by employer or employee benefit organizations.)}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A provision as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Unpaid premium:}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{Upon the payment of a claim under this policy, any premium then due and unpaid or covered by any note or written order may be deducted therefrom.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A provision as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Cancellation:}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{The insurer may cancel this policy at any time by written notice delivered to the insured, or mailed to the insured\u8217\'3fs last address as shown by the records of the insurer, stating when, not less than five days thereafter, such cancellation shall be effective; and after the policy has been continued beyond its original term the insured may cancel this policy at any time by written notice delivered or mailed to the insurer, effective upon receipt or on such later date as may be specified in such notice. In the event of cancellation, the insurer will return promptly the unearned portion of any premium paid. If the insured cancels, the earned premium shall be computed by the use of the short-rate table last filed with the state official having supervision of insurance in the state where the insured resided when the policy was issued. If the insurer cancels, the earned premium shall be computed pro rata. Cancellation shall be without prejudice to any claim originating prior to the effective date of cancellation.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A provision as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Conformity with state statutes:}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{Any provision of this policy which, on its effective date, is in conflict with the statutes of the state in which the insured resides on such date is hereby amended to conform to the minimum requirements of such statutes.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A provision as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Illegal occupation:}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{The insurer shall not be liable for any loss to which a contributing cause was the insured\u8217\'3fs commission of or attempt to commit a felony or to which a contributing cause was the insured\u8217\'3fs being engaged in an illegal occupation.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{k.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A provision as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Intoxicants and narcotics:}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{The insurer shall not be liable for any loss sustained or contracted in consequence of the insured\u8217\'3fs being intoxicated or under the influence of any narcotic unless administered on the advice of a physician. This provision shall not be used with respect to a medical expense policy. For purposes of this provision, }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fmedical expense policy\u8221\'3f}}}{ means an accident and sickness insurance policy that provides hospital, medical, and surgical expense coverage.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{\*\bkmkstart stylerid1_2E7_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E7_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Inapplicable or inconsistent provisions.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If any provision of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is in whole or in part inapplicable to or inconsistent with the coverage provided by a particular form of policy, the insurer, with the approval of the commissioner, shall omit from such policy any inapplicable provision or part of a provision, and shall modify any inconsistent provision or part of the provision in such manner as to make the provision as contained in the policy consistent with the coverage provided by the policy.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{\*\bkmkstart stylerid1_2E7_2E6_2E1_2E2}{\*\bkmkend stylerid1_2E7_2E6_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Order of certain policy provisions.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The provisions which are the subject of }}}{{\f5\fs18\hyphpar0\qj{subsections 1 and 2}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, or any corresponding provisions which are used in lieu thereof in accordance with such subsections, shall be printed in the consecutive order of the provisions in such subsections or, at the option of the insurer, any such provision may appear as a unit in any part of the policy, with other provisions to which it may be logically related, provided the resulting policy shall not be in whole or in part unintelligible, uncertain, ambiguous, abstruse, or likely to mislead a person to whom the policy is offered, delivered or issued.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{\*\bkmkstart stylerid1_2E7_2E7_2E1_2E2}{\*\bkmkend stylerid1_2E7_2E7_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Third party ownership.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The word }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3finsured\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, as used in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, shall not be construed as preventing a person other than the insured with a proper insurable interest from making application for and owning a policy covering the insured or from being entitled under such a policy to any indemnities, benefits and rights provided therein.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{\*\bkmkstart stylerid1_2E7_2E8_2E1_2E2}{\*\bkmkend stylerid1_2E7_2E8_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Requirements of other jurisdictions.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any policy of a foreign or alien insurer, when delivered or issued for delivery to any person in this state, may contain any provision which is not less favorable to the insured or the beneficiary than the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and which is prescribed or required by the law of the state under which the insurer is organized.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any policy of a domestic insurer may, when issued for delivery in any other state or country, contain any provision permitted or required by the laws of such other state or country.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{\*\bkmkstart stylerid1_2E7_2E9_2E1_2E2}{\*\bkmkend stylerid1_2E7_2E9_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Filing procedure.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commissioner may make such reasonable rules and regulations concerning the procedure for the filing or submission of policies subject to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ as are necessary, proper or advisable to the administration of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. This provision shall not abridge any other authority granted the commissioner by law.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71820; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{8775;}}}{ C46, 50, \'a7511.36; C54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7514A.3}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1234, \'a731}}}{; }{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1111, \'a715}}}{; }{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1119, \'a768}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 64, \'a780, 81}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7514A.2}}}{{\f5\fs12\hyphpar0\qj{, 514A.4}}}{{\f5\fs12\hyphpar0\qj{, 514A.12}}}{{\f5\fs12\hyphpar0\qj{, 514D.3}}}{{\f5\fs12\hyphpar0\qj{, 514D.6}}}{{\f5\fs12\hyphpar0\qj{, 514D.7}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{514A.3A}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Refund of unearned premium upon death of insured.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{In the event of the death of the insured of any policy covered by }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, the insurer, upon receipt of notice of the insured\u8217\'3fs death supported by a certified copy of a valid death certificate and a request for a pro rata refund by a party entitled to claim such a refund, shall refund the unearned premium prorated to the month of the insured\u8217\'3fs death. Refund of the premium and termination of the coverage shall be without prejudice to any claim originating prior to the date of the insured\u8217\'3fs death. The commissioner of insurance shall adopt by rule the minimum amount required for issuance of a refund.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1110, \'a739}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7514D.3}}}{{\f5\fs12\hyphpar0\qj{, 514D.7}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{514A.3B}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Additional requirements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An insurer which accepts an individual for coverage under an individual policy or contract of accident and health insurance shall waive any time period applicable to a preexisting condition exclusion or limitation period requirement of the policy or contract with respect to particular services in an individual health benefit plan for the period of time the individual was previously covered by qualifying previous coverage as defined in }}}{{\f5\fs18\hyphpar0\qj{section 513C.3}}}{{\f5\fs18\hyphpar0\qj{, by }}}{{\f5\fs18\hyphpar0\qj{chapter 249A}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{514I}}}{{\f5\fs18\hyphpar0\qj{, or by Medicare coverage provided pursuant to Tit. XVIII of the federal Social Security Act that provided benefits with respect to such services, provided that the coverage was continuous to a date not more than sixty-three days prior to the effective date of the new policy or contract.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An insurer issuing an individual policy or contract of accident and health insurance which provides coverage for children of the insured shall permit continuation of existing coverage or reenrollment in previously existing coverage for an individual who meets the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 513B.2, subsection 14}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and who is an unmarried child of an insured or enrollee who so elects, at least through the policy anniversary date on or after the date the child marries, ceases to be a resident of this state, or attains the age of twenty-five years old, whichever occurs first, or so long as the unmarried child maintains full-time status as a student in an accredited institution of postsecondary education.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of any policies of accident and sickness insurance issued in this state, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fcreditable coverage\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means health benefits or coverage provided to an individual under any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A group health plan.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Health insurance coverage.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Part A or Part B Medicare pursuant to Tit. XVIII of the federal Social Security Act.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Medicaid pursuant to Tit. XIX of the federal Social Security Act, other than coverage consisting solely of benefits under section 1928 of that Act.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10 U.S.C. ch. 55.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A health or medical care program provided through the Indian health service or a tribal organization.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A state health benefits risk pool.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A health plan offered under 5 U.S.C. ch. 89.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A public health plan as defined under federal regulations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A health benefit plan under section 5(e) of the federal Peace Corps Act, 22 U.S.C. \'a72504(e).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{k.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A short-term limited duration policy.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{l.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The Hawki program authorized by }}}{{\f5\fs18\hyphpar0\qj{chapter 514I}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1188, \'a742, 43}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 118, \'a79, 11, 21, 22}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 148, \'a760}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71192}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7514D.3}}}{{\f5\fs12\hyphpar0\qj{, 514D.7}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{514A.4}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Conforming to statute.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E1_30_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E1_30_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Other policy provisions.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A policy provision which is not subject to }}}{{\f5\fs18\hyphpar0\qj{section 514A.3}}}{{\f5\fs18\hyphpar0\qj{ shall not make a policy, or any portion of a policy, less favorable in any respect to the insured or the beneficiary than the provisions of the policy which are subject to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E1_30_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E1_30_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Policy conflicting with }}}{{\i\f5\fs18\hyphpar0\qj{this chapter}}}{{\i\f5\fs18\hyphpar0\qj{.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A policy delivered or issued for delivery to any person in this state in violation of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall be held valid but shall be construed as provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. When any provision in a policy subject to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ is in conflict with any provision of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, the rights, duties and obligations of the insurer, the insured and the beneficiary shall be governed by the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7514A.4}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2019 Acts, ch 59, \'a7185}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7514A.12}}}{{\f5\fs12\hyphpar0\qj{, 514D.3}}}{{\f5\fs12\hyphpar0\qj{, 514D.7}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{514A.5}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Application.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The insured shall not be bound by any statement made in an application for a policy unless a copy of such application is endorsed on the policy when issued as a part thereof or is furnished to the policyholder within thirty days after the policy is issued. If any such policy delivered or issued for delivery to any person in this state shall be reinstated or renewed, and the insured or the beneficiary or assignee of such policy shall make written request to the insurer for a copy of the application, if any, for such reinstatement or renewal, the insurer shall within fifteen days after the receipt of such request at its home office or any branch office of the insurer, deliver or mail to the person making such request, a copy of such application. If such copy shall not be so delivered or mailed, the insurer shall be precluded from introducing such application as evidence in any action or proceeding based upon or involving such policy or its reinstatement or renewal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{No alteration of any written application for any such policy shall be made by any person other than the applicant without the applicant\u8217\'3fs written consent, except that insertions may be made by the insurer, for administrative purposes only, in such manner as to indicate clearly that such insertions are not to be ascribed to the applicant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The falsity of any statement in the application for any policy covered by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ may not bar the right to recovery thereunder unless such false statement materially affected either the acceptance of the risk or the hazard assumed by the insurer.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7514A.5}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 70, \'a712}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7514D.3}}}{{\f5\fs12\hyphpar0\qj{, 514D.7}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{514A.6}}}{\*\bkmkstart stylerid1_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Notice \u8212\'3f waiver.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The acknowledgment by any insurer of the receipt of notice given under any policy covered by }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, or the furnishing of forms for filing proofs of loss, or the acceptance of such proofs, or the investigation of any claim thereunder shall not operate as a waiver of any of the rights of the insurer in defense of any claim arising under such policy.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7514A.6}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7514D.3}}}{{\f5\fs12\hyphpar0\qj{, 514D.7}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{514A.7}}}{\*\bkmkstart stylerid1_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Age limit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If any such policy contains a provision establishing, as an age limit or otherwise, a date after which the coverage provided by the policy will not be effective, and if such date falls within a period for which premium is accepted by the insurer or if the insurer accepts a premium after such date, the coverage provided by the policy will continue in force subject to any right of cancellation until the end of the period for which premium has been accepted. In the event the age of the insured has been misstated and if, according to the correct age of the insured, the coverage provided by the policy would not have become effective, or would have ceased prior to the acceptance of such premium or premiums, then the liability of the insurer shall be limited to the refund, upon request, of all premiums paid for the period not covered by the policy.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7514A.7}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7514D.3}}}{{\f5\fs12\hyphpar0\qj{, 514D.7}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{514A.8}}}{\*\bkmkstart stylerid1_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Nonapplication to certain policies.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Nothing in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ shall apply to or affect any of the following:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any policy of workers\u8217\'3f compensation insurance or any policy of liability insurance with or without supplementary expense coverage therein.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any policy or contract of reinsurance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any blanket or group policy of insurance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Life insurance, endowment or annuity contracts, or contracts supplemental thereto which contain only such provisions relating to accident and sickness insurance as provide additional benefits in case of death or dismemberment or loss of sight by accident, or as operate to safeguard such contracts against lapse, or to give a special surrender value or special benefit or an annuity in the event that the insured or annuitant shall become totally and permanently disabled, as defined by the contract or supplemental contract.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7514A.8}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2018 Acts, ch 1041, \'a7102}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7514D.3}}}{{\f5\fs12\hyphpar0\qj{, 514D.7}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{514A.9}}}{\*\bkmkstart stylerid1_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Violation.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2004/CH1110.pdf" }{\fldrslt \cf5 \f5 \fs18{{2004 Acts, ch 1110, \'a771}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{514A.10}}}{\*\bkmkstart stylerid1_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Judicial review.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Judicial review of the actions of the commissioner may be sought in accordance with the terms of the Iowa administrative procedure Act, }{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7514A.10}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 44, \'a7114}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7514D.3}}}{{\f5\fs12\hyphpar0\qj{, 514D.7}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{514A.11}}}{\*\bkmkstart stylerid1_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Inconsistent acts not applicable.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{All Acts or parts of Acts inconsistent with }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ shall not apply to the provisions hereof to the extent of said inconsistency.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7514A.11}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7514D.3}}}{{\f5\fs12\hyphpar0\qj{, 514D.7}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{514A.12}}}{\*\bkmkstart stylerid1_2E18_2E2_2E2}{\*\bkmkend stylerid1_2E18_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Title and effective date of chapter.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This chapter}}}{ may be cited as the }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fUniform Individual Accident and Sickness Act.\u8221\'3f}}}{ }{{\f5\fs18\hyphpar0\qj{This chapter}}}{ shall take effect on the fourth day of July, 1951. A policy, filed with and approved by the insurance commissioner prior to the effective date of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ for use, delivery, or issue for delivery to any person in this state, may continue to be used, or delivered, or issued for delivery to any person in this state for a period of five years from and after said effective date without being subject to the provisions of }{{\f5\fs18\hyphpar0\qj{sections 514A.2}}}{, }{{\f5\fs18\hyphpar0\qj{514A.3}}}{ and }{{\f5\fs18\hyphpar0\qj{514A.4}}}{; and any rider or endorsement filed with and approved by the insurance commissioner at any time may be used, or delivered, or issued for delivery to any person holding such a policy without being subject to the provisions of }{{\f5\fs18\hyphpar0\qj{sections 514A.2}}}{, }{{\f5\fs18\hyphpar0\qj{514A.3}}}{ and }{{\f5\fs18\hyphpar0\qj{514A.4}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7514A.12}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7514D.3}}}{{\f5\fs12\hyphpar0\qj{, 514D.7}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{514A.13}}}{\*\bkmkstart stylerid1_2E19_2E2_2E2}{\*\bkmkend stylerid1_2E19_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Filing requirement \u8212\'3f prior approval.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A policy of insurance against loss or expense from sickness or from the bodily injury or death by accident of the insured shall not be issued or delivered to any person in this state and an application, rider, or endorsement shall not be used in connection with the policy until a copy of the policy form and of the classification of risks and the premium rates, or, in the case of cooperatives or assessment companies the estimated costs pertaining to the policy, have been filed with and approved by the commissioner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A filing is deemed to be approved unless disapproved by the commissioner within thirty days of receipt of the filing by the commissioner. Subsequent rate changes are also subject to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 213, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1162, \'a720}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1041, \'a7127}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7514A.14}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{514A.14}}}{\*\bkmkstart stylerid1_2E2_30_2E2_2E2}{\*\bkmkend stylerid1_2E2_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Disapproval of filing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commissioner shall notify an insurer which has filed a policy form pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 514A.13}}}{{\f5\fs18\hyphpar0\qj{ that does not comply with }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{chapter 514D}}}{{\f5\fs18\hyphpar0\qj{, or rules adopted pursuant to those chapters. The notice shall inform the insurer that it is unlawful for the insurer to issue the form or use it in connection with any policy, if the commissioner finds upon review of the form, either of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The benefits provided are unreasonable in relation to the premium charged.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The form contains a provision which is unjust, unfair, inequitable, misleading, deceptive, or which encourages misrepresentation of the policy.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In a notice provided under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, the commissioner shall specify the reasons for disapproval and state that a hearing will be granted within twenty days after request in writing by the insurer.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 213, \'a718}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7514A.15}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{514A.15}}}{\*\bkmkstart stylerid1_2E21_2E2_2E2}{\*\bkmkend stylerid1_2E21_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Withdrawal of approval.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The commissioner may at any time, after opportunity for hearing, withdraw the commissioner\u8217\'3fs previously given approval of any such form on any of the grounds stated in }{{\f5\fs18\hyphpar0\qj{section 514A.14}}}{. It shall be unlawful for the insurer to issue a form or use the form in connection with any policy after the effective date of the withdrawal of approval. The notice of any hearing granted under }{{\f5\fs18\hyphpar0\qj{this section}}}{ shall specify the matters to be considered at the hearing. Any decision affirming disapproval or directing withdrawal of approval under }{{\f5\fs18\hyphpar0\qj{this section}}}{ shall be in writing and shall specify the reasons for the disapproval or withdrawal of approval.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 213, \'a719}}}\par}}