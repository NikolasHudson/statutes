\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F476C}{\*\bkmkend codeChapter_5F476C}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 476C}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{RENEWABLE ENERGY TAX CREDIT}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a72.48}}}{{\f5\fs12\qc{, 422.11J}}}{{\f5\fs12\qc{, 422.11L}}}{{\f5\fs12\qc{, 422.33}}}{{\f5\fs12\qc{, 422.60}}}{{\f5\fs12\qc{, 423.4}}}{{\f5\fs12\qc{, 432.12E}}}{{\f5\fs12\qc{, 437A.17B}}}{{\f5\fs12\qc{, 476.48}}}\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{476C.1}}}{\*\bkmkstart stylerid1_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{For purposes of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, unless the context otherwise requires:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAnaerobic digester system\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a system of components that processes plant or animal materials based on the absence of oxygen and produces methane or other biogas used to generate electricity, hydrogen fuel, or heat for a commercial purpose.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fBiogas recovery facility\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an anaerobic digester system that is located in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fBiomass conversion facility\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a facility in this state that converts plant-derived organic matter including, but not limited to, agricultural food and feed crops, crop wastes and residues, wood wastes and residues, or aquatic plants to generate electricity, hydrogen fuel, or heat for a commercial purpose.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCommission\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the utilities commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDepartment\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the department of revenue.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fEligible renewable energy facility\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a wind energy conversion facility, a biogas recovery facility, a biomass conversion facility, a methane gas recovery facility, a solar energy conversion facility, or a refuse conversion facility that meets all of the following requirements:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is located in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is at least fifty-one percent owned by one or more of any combination of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A resident of this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any of the following as defined in }}}{{\f5\fs18\hyphpar0\qj{section 9H.1}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An authorized farm corporation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An authorized limited liability company.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An authorized trust.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A family farm corporation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(e)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A family farm limited liability company.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(f)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A family trust.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(g)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A revocable trust.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(h)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A testamentary trust.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A small business as defined in }}}{{\f5\fs18\hyphpar0\qj{section 15.102}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An electric cooperative association organized pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 499}}}{{\f5\fs18\hyphpar0\qj{ that sells electricity to end users located in this state, a municipally owned city utility as defined in }}}{{\f5\fs18\hyphpar0\qj{section 362.2}}}{{\f5\fs18\hyphpar0\qj{, or a public utility subject to rate regulation pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 476}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An electric cooperative association that has one or more members organized pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 499}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A cooperative corporation organized pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 497}}}{{\f5\fs18\hyphpar0\qj{ or a limited liability company organized pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 489}}}{{\f5\fs18\hyphpar0\qj{ whose shares and membership are held by an entity that is not prohibited from owning agricultural land under }}}{{\f5\fs18\hyphpar0\qj{chapter 9H}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(7)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A school district located in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Has at least one owner that meets the requirements of paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ for each two and one-half megawatts of nameplate generating capacity or the energy production capacity equivalent for hydrogen fuel or heat for a commercial purpose of the otherwise eligible renewable energy facility.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Was initially placed into service on or after July 1, 2005, and before January 1, 2018.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For applications filed on or after July 1, 2011, is a facility of not less than three-fourths megawatts of nameplate generating capacity or the energy production capacity equivalent if all or a portion of the renewable energy produced is for on-site consumption by the producer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For applications filed on or after July 1, 2011, except for wind energy conversion facilities, is a facility of no greater than sixty megawatts of nameplate generating capacity or the energy production capacity equivalent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fEnergy production capacity equivalent\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the amount of energy in a standard cubic foot of hydrogen gas or the number of British thermal units that are equal to the energy in a kilowatt-hour of electricity. For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, one kilowatt-hour shall be deemed equivalent to three thousand three hundred thirty-three British thermal units of heat or ten and forty-five one hundredths of standard cubic feet of hydrogen gas.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fHeat for a commercial purpose\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the heat in British thermal unit equivalents from refuse-derived fuel, methane, or other biogas produced in this state either for commercial use by a producer for on-site consumption or sold to a purchaser of renewable energy for use for a commercial purpose in this state or for use by an institution in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fHydrogen fuel\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means hydrogen produced in this state from a renewable source that is used in a fuel cell or hydrogen-powered internal combustion engine.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMethane gas recovery facility\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a facility in this state which is used in connection with a sanitary landfill or which uses wastes that would otherwise be deposited in a sanitary landfill, that collects methane gas or other gases and converts the gas into energy to generate electricity, hydrogen fuel, or heat for a commercial purpose.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fProducer of renewable energy\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person who owns an eligible renewable energy facility.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPurchaser of renewable energy\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person who buys electric energy, hydrogen fuel, methane gas or other biogas used to generate electricity, or heat for a commercial purpose from an eligible renewable energy facility.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fRefuse conversion facility\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a facility in this state that converts solid waste into fuel that can be burned to generate heat for a commercial purpose in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSolar energy conversion facility\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a solar energy facility in this state that collects and converts incident solar radiation into energy to generate electricity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fWind energy conversion facility\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a wind energy conversion system in this state that collects and converts wind into energy to generate electricity.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 160, \'a77, 14}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1135, \'a75 \u8211\'3f 8, 12}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1162, \'a7136, 154, 155}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 115, \'a73 \u8211\'3f 5}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 118, \'a733, 89}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1122, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 124, \'a75, 9, 10}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1128, \'a710, 16, 21}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72685}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1170, \'a7369}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7437A.3}}}{{\f5\fs12\hyphpar0\qj{, 476C.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{476C.2}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Tax credit amount \u8212\'3f limitations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A producer or purchaser of renewable energy may receive renewable energy tax credits under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ in an amount equal to one and one-half cents per kilowatt-hour of electricity, or four dollars and fifty cents per million British thermal units of heat for a commercial purpose, or four dollars and fifty cents per million British thermal units of methane gas or other biogas used to generate electricity, or one dollar and forty-four cents per one thousand standard cubic feet of hydrogen fuel generated by and purchased from an eligible renewable energy facility or used for on-site consumption by the producer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The renewable energy tax credit shall not be allowed for any kilowatt-hour of electricity, British thermal unit of heat for a commercial purpose, British thermal unit of methane gas or other biogas used to generate electricity, or standard cubic foot of hydrogen fuel that is purchased from an eligible renewable energy facility by a related person. For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, persons shall be treated as related to each other if either person owns an eighty percent or more equity interest in the other person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A taxpayer who is eligible to claim a renewable energy tax credit under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall not be eligible to claim a solar energy system tax credit under }}}{{\f5\fs18\hyphpar0\qj{section 422.11L}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{422.33}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 160, \'a78, 14}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 115, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1121, \'a79 \u8211\'3f 11}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{476C.3}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Determination of eligibility.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A producer or purchaser of renewable energy may apply to the commission for a written determination regarding whether a facility is an eligible renewable energy facility by submitting to the commission a written application containing all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Information regarding the ownership of the facility including the percentage of equity interest held by each owner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The nameplate generating capacity of the facility or energy production capacity equivalent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Information regarding the facility\u8217\'3fs initial placement in service.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Information regarding the type of facility and what type of renewable energy the facility will produce.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{ Except when the renewable energy is produced for on-site consumption by the producer, a copy of the power purchase agreement or other agreement to purchase electricity, hydrogen fuel, methane or other biogas, or heat for a commercial purpose which shall designate either the producer or purchaser of renewable energy as eligible to apply for the renewable energy tax credit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any other information the commission may require.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall review the application and supporting information and shall make a preliminary determination regarding whether the facility is an eligible renewable energy facility. The commission shall notify the applicant of the approval or denial of the application within thirty days of receipt of the application and information required. If the commission fails to notify the applicant of the approval or denial within thirty days, the application shall be deemed denied unless the application is placed on a waiting list as described in }}}{{\f5\fs18\hyphpar0\qj{subsection 6}}}{{\f5\fs18\hyphpar0\qj{. An applicant who receives a determination denying an application may file an appeal with the commission within thirty days from the date of the denial pursuant to the provisions of }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{. In the absence of a timely appeal, the preliminary determination shall be final. If the application is incomplete, the commission may grant an extension of time for the provision of additional information.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A facility that is not operational within thirty months after issuance of an approval for the facility by the commission shall cease to be an eligible renewable energy facility. However, a wind energy conversion facility that is approved as eligible under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ but is not operational within eighteen months due to the unavailability of necessary equipment shall be granted an additional twenty-four months to become operational.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A facility which notifies the commission prior to the expiration of the time periods specified in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ that the facility intends to become operational and wishes to preserve its eligibility shall be granted a twelve-month extension. An extension may be renewed for succeeding twelve-month periods if the commission is notified prior to the expiration of the extension of the continued intention to become operational during the succeeding period of extension.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the owner of a facility discontinues efforts to achieve operational status, the owner shall notify the commission. Upon receipt of such notification, the commission shall no longer consider the facility as an eligible renewable energy facility under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A facility that is granted and thereafter loses approval may reapply to the commission for a new determination.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The maximum amount of nameplate generating capacity of all wind energy conversion facilities the commission may find eligible under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall not exceed three hundred sixty-three megawatts of nameplate generating capacity.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The maximum amount of energy production capacity equivalent of all other facilities the commission may find eligible under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall not exceed a combined output of sixty-three megawatts of nameplate generating capacity and, annually, one hundred sixty-seven billion British thermal units of heat for a commercial purpose.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Of the maximum amount of energy production capacity equivalent of all other facilities found eligible under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, no more than ten megawatts of nameplate generating capacity or energy production capacity equivalent shall be allocated to any one facility.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Of the maximum amount of energy production capacity equivalent of all other facilities found eligible under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, fifty-five billion British thermal units of heat for a commercial purpose shall be reserved annually for an eligible facility that is a refuse conversion facility for processed, engineered fuel from a multicounty solid waste management planning area. The maximum amount of energy production capacity the commission may find eligible for a single refuse conversion facility is, annually, fifty-five billion British thermal units of heat for a commercial purpose.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Of the maximum amount of energy production capacity equivalent of all other facilities found eligible under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, ten megawatts of nameplate generating capacity or energy production equivalent shall be reserved for solar energy conversion facilities that meet all of the following requirements:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The facility has a generating capacity of one and one-half megawatts or less.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The facility is owned, in whole or in part, directly or indirectly, or is contracted for, by utilities described in }}}{{\f5\fs18\hyphpar0\qj{section 476C.1, subsection 6}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraphs (4) and (5).}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(iii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The facility is located in this state.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(iv)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The facility meets the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 476C.1, subsection 6}}}{{\f5\fs18\hyphpar0\qj{, paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ through }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ff\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A solar energy conversion facility that meets the requirements of and is found eligible under subparagraph division (a) shall be considered an }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3feligible renewable energy facility\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ for purposes of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, notwithstanding any contrary provisions of }}}{{\f5\fs18\hyphpar0\qj{section 476C.1, subsection 6}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding the definition of }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3feligible renewable energy facility\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ in }}}{{\f5\fs18\hyphpar0\qj{section 476C.1, subsection 6}}}{{\f5\fs18\hyphpar0\qj{, unnumbered paragraph 1, of the maximum amount of energy production capacity equivalent of all other facilities found eligible pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, an amount equivalent to ten megawatts of nameplate generating capacity shall be reserved for natural gas, methane and landfill gas, or biogas cogeneration facilities incorporated within or associated with an ethanol plant to assist the ethanol plant in meeting a low carbon fuel standard. Thermal heat generated by the cogeneration facility and used for a commercial purpose may be counted toward satisfying the ten megawatt reservation requirement.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A facility that has been granted eligibility pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ for a natural gas cogeneration facility incorporated within or associated with an ethanol plant prior to July 1, 2014, shall not be required to submit a new application if the facility constructs or utilizes methane and landfill gas or biogas cogeneration facilities on or after that date and does not make any other significant changes to the facility or to its status as an eligible facility under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall maintain a waiting list of facilities that may have been found eligible under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ but for the maximum capacity restrictions of }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{. The priority of the waiting list shall be maintained in the order the applications were received by the commission. The commission shall remove from the waiting list any facility that has subsequently been found ineligible under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. If additional capacity becomes available within the capacity restrictions of }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{, the commission shall grant approval to facilities according to the priority of the waiting list before granting approval to new applications. An owner of a facility on the waiting list shall provide the commission each year by August 31 with a sworn statement of verification stating that the information contained in the application for eligibility remains true and correct or stating that the information has changed and providing the new information.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An owner meeting the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 476C.1, subsection 6}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, shall not be an owner of more than two eligible renewable energy facilities. A person that has an equity interest equal to or greater than fifty-one percent in an eligible renewable energy facility shall not have an equity interest greater than ten percent in any other eligible renewable energy facility. This paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall not apply to facilities described in }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (3).}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An entity described in }}}{{\f5\fs18\hyphpar0\qj{section 476C.1, subsection 6}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraphs (4) or (5), shall not have an ownership interest in more than four facilities described in }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (3).}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 160, \'a79, 14}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1135, \'a79, 12, 13}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1171, \'a78, 9}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 80, \'a75, 6}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 115, \'a77 \u8211\'3f 9}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 118, \'a734, 89}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1138, \'a732, 33}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1122, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 124, \'a76, 9, 10}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1128, \'a711, 12, 16, 22, 23}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1170, \'a7369}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7476C.4}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{476C.4}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Tax credit certificate procedure.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A producer or purchaser of renewable energy may apply to the commission for the renewable energy tax credit by submitting to the commission all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A completed application in a form prescribed by the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A copy of the determination granting approval of the facility as an eligible renewable energy facility by the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A copy of a signed power purchase agreement or other agreement to purchase electricity, hydrogen fuel, methane or other biogas, or heat for a commercial purpose from an eligible renewable energy facility which shall designate either the producer or purchaser of renewable energy as eligible to apply for the renewable energy tax credit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Sufficient documentation that the electricity, heat for a commercial purpose, methane gas or other biogas, or hydrogen fuel has been generated by the eligible renewable energy facility and sold to the purchaser of renewable energy.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To the extent the produced electricity, hydrogen fuel, methane or other biogas, or heat for a commercial purpose is used for on-site consumption, the requirements of paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall not be applicable. For such renewable energy production, the owner must submit a certification under penalty of perjury that the claimed amount of electricity, hydrogen fuel, methane or other biogas, or heat for a commercial purpose was produced by the eligible facility and consumed by the owner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any other information the commission deems necessary.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall notify the department of the amount of kilowatt-hours, British thermal units of heat for a commercial purpose, British thermal units of methane gas or other biogas used to generate electricity, or standard cubic feet of hydrogen fuel generated and purchased from an eligible renewable energy facility or generated and used by the producer for on-site consumption. The department shall calculate the amount of the tax credit for which the applicant is eligible and shall issue the tax credit certificate for that amount or notify the applicant in writing of its refusal to do so. An applicant whose application is denied may file an appeal with the department within sixty days from the date of the denial pursuant to the provisions of }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each tax credit certificate shall contain the person\u8217\'3fs name, address, and tax identification number, the amount of tax credits, the first taxable year the certificate may be used, the type of tax to which the tax credits shall be applied, and any other information required by the department. The tax credit certificate shall only list one type of tax to which the amount of the tax credit may be applied. Once issued by the department, the tax credit certificate shall not be terminated or rescinded.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A tax credit certificate may be filed pursuant to any of the following, to the extent applicable:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the tax credit application is filed by a partnership, limited liability company, S corporation, estate, trust, or other reporting entity all of the income of which is taxed directly to its equity holders or beneficiaries, for the taxes imposed under }}}{{\f5\fs18\hyphpar0\qj{chapter 422, subchapter II or III}}}{{\f5\fs18\hyphpar0\qj{, the tax credit certificate shall be issued directly to equity holders or beneficiaries of the applicant in proportion to their pro rata share of the income of such entity. The applicant shall, in the application made under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, identify its equity holders or beneficiaries, and the percentage of such entity\u8217\'3fs income that is allocable to each equity holder or beneficiary.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the tax credit applicant under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is eligible to receive renewable electricity production credits authorized under section 45 of the Internal Revenue Code, as amended, and the tax credit applicant is a partnership, limited liability company, S corporation, estate, trust, or other reporting entity all of the income of which is taxed directly to its equity holders or beneficiaries, for the taxes imposed under }}}{{\f5\fs18\hyphpar0\qj{chapter 422, subchapter II or III}}}{{\f5\fs18\hyphpar0\qj{, the tax credit certificate may be issued to a partner if the business is a partnership, a shareholder if the business is an S corporation, or a member if the business is a limited liability company in the amounts designated by the eligible partnership, S corporation, or limited liability company. In absence of such designation, the credits under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall flow through to the partners, shareholders, or members in accordance with their pro rata share of the income of the entity.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant shall, in the application made under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, identify the equity holders or beneficiaries that are to receive the tax credit certificates and the percentage of the tax credit that is allocable to each equity holder or beneficiary.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If an applicant under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is eligible to receive renewable electricity production credits authorized under section 45 of the Internal Revenue Code, as amended, and the tax credit applicant is a partnership, limited liability company, S corporation, estate, trust, or other reporting entity all of the income of which is taxed directly to its equity holders or beneficiaries, for the taxes imposed under }}}{{\f5\fs18\hyphpar0\qj{chapter 422, subchapter II or III}}}{{\f5\fs18\hyphpar0\qj{, the tax credit certificates and all future rights to the tax credit in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ may be distributed to an equity holder or beneficiary as a liquidating distribution or portion thereof, of a holder or beneficiary\u8217\'3fs interest in the applicant entity.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant shall, in the application made under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, designate the percentage of the tax credit allocable to the liquidating equity holder or beneficiary that is to receive the current and future tax credit certificates under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the tax credit application is filed by a partnership, limited liability company, S corporation, estate, trust, or other reporting entity, all of the income of which is taxed directly to its equity holders or beneficiaries for the taxes imposed under }}}{{\f5\fs18\hyphpar0\qj{chapter 422, subchapter V}}}{{\f5\fs18\hyphpar0\qj{, or under }}}{{\f5\fs18\hyphpar0\qj{chapter 423}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{432}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{437A}}}{{\f5\fs18\hyphpar0\qj{, the tax credit certificate shall be issued directly to the partnership, limited liability company, S corporation, estate, trust, or other reporting entity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall not issue a tax credit certificate if the facility approved by the commission as an eligible renewable energy facility is not operational within eighteen months after the approval is issued, subject to the extension provisions of }}}{{\f5\fs18\hyphpar0\qj{section 476C.3, subsection 3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall not issue a tax credit certificate to any person who has received a tax credit pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 476B}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Once a tax credit certificate is issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the tax credit may only be claimed against the type of tax reflected on the certificate.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 160, \'a710, 14}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1135, \'a710, 12}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 25, \'a7143}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 115, \'a710, 11}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1021, \'a792}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1011, \'a786}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1062, \'a794}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1170, \'a7369}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7476C.6}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{476C.5}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Certificate issuance period.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A producer or purchaser of renewable energy shall receive renewable energy tax credit certificates for a ten-year period for each eligible renewable energy facility under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{. The ten-year period for issuance of the tax credit certificates begins with the date the purchaser of renewable energy first purchases electricity, hydrogen fuel, methane gas or other biogas used to generate electricity, or heat for commercial purposes from the eligible renewable energy facility for which a tax credit is issued under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, or the date the producer of the renewable energy first uses the energy produced by the eligible renewable energy facility for on-site consumption. Renewable energy tax credit certificates shall not be issued for renewable energy purchased or produced for on-site consumption after December 31, 2027.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 160, \'a711, 14}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1135, \'a711, 12}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 115, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1122, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 124, \'a77, 9, 10}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1128, \'a713, 16, 21}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{476C.6}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Transferability and use of tax credit certificates \u8212\'3f registration.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Renewable energy tax credit certificates issued under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ may be transferred to any person. A tax credit certificate shall only be transferred once. However, for purposes of this transfer provision, a decision between a producer and purchaser of renewable energy regarding who claims the tax credit issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall not be considered a transfer and must be set forth in the application for the tax credit pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 476C.4}}}{{\f5\fs18\hyphpar0\qj{. Within thirty days of transfer, the transferee must submit the transferred tax credit certificate to the department along with a statement containing the transferee\u8217\'3fs name, tax identification number, and address, and the denomination that each new certificate is to carry and any other information required by the department. Within thirty days of receiving the transferred tax credit certificate and the transferee\u8217\'3fs statement, the department shall issue one or more replacement tax credit certificates to the transferee. Each replacement tax credit certificate must contain the information required under }}}{{\f5\fs18\hyphpar0\qj{section 476C.4, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, and must have the same effective taxable year and the same expiration date that appeared in the transferred tax credit certificate. Tax credit certificate amounts of less than the minimum amount established by rule shall not be transferable. A tax credit shall not be claimed by a transferee under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ until a replacement tax credit certificate identifying the transferee as the proper holder has been issued. The replacement tax credit certificate may reflect a different type of tax than the type of tax noted on the original tax credit certificate.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The transferee may use the amount of the tax credit transferred against taxes imposed under }}}{{\f5\fs18\hyphpar0\qj{chapter 422, subchapters II, III, and V}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{chapter 432}}}{{\f5\fs18\hyphpar0\qj{ for any tax year the original transferor could have claimed the tax credit. The transferee may claim a refund under }}}{{\f5\fs18\hyphpar0\qj{chapter 423}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{437A}}}{{\f5\fs18\hyphpar0\qj{ for any tax year within the time period set forth in }}}{{\f5\fs18\hyphpar0\qj{section 423.47}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{437A.14}}}{{\f5\fs18\hyphpar0\qj{ for which the original transferor could have claimed the refund. Any consideration received for the transfer of the tax credit shall not be included as income under }}}{{\f5\fs18\hyphpar0\qj{chapter 422, subchapters II, III, and V}}}{{\f5\fs18\hyphpar0\qj{. Any consideration paid for the transfer of the tax credit shall not be deducted from income under }}}{{\f5\fs18\hyphpar0\qj{chapter 422, subchapters II, III, and V}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To claim a renewable energy tax credit under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, a taxpayer must include one or more tax credit certificates with the taxpayer\u8217\'3fs tax return, or if used against taxes imposed under }}}{{\f5\fs18\hyphpar0\qj{chapter 423}}}{{\f5\fs18\hyphpar0\qj{, the taxpayer shall comply with }}}{{\f5\fs18\hyphpar0\qj{section 423.4, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, or if used against taxes imposed under }}}{{\f5\fs18\hyphpar0\qj{chapter 437A}}}{{\f5\fs18\hyphpar0\qj{, the taxpayer shall comply with }}}{{\f5\fs18\hyphpar0\qj{section 437A.17B}}}{{\f5\fs18\hyphpar0\qj{. A tax credit certificate shall not be used or included with a return filed for a taxable year beginning prior to July 1, 2006. The tax credit certificate or certificates included with the taxpayer\u8217\'3fs tax return shall be issued in the taxpayer\u8217\'3fs name, expire on or after the last day of the taxable year for which the taxpayer is claiming the tax credit, and show a tax credit amount equal to or greater than the tax credit claimed on the taxpayer\u8217\'3fs tax return. Any tax credit in excess of the taxpayer\u8217\'3fs tax liability for the taxable year may be credited to the taxpayer\u8217\'3fs tax liability for the following seven tax years or until the credit is depleted, whichever is earlier. If the tax credit is applied against the taxes imposed under }}}{{\f5\fs18\hyphpar0\qj{chapter 423}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{437A}}}{{\f5\fs18\hyphpar0\qj{, any credit in excess of the taxpayer\u8217\'3fs tax liability is carried over and can be filed with the refund claim for the following seven tax years or until depleted, whichever is earlier. However, the certificate shall not be used to reduce tax liability for a tax period ending after the expiration date of the certificate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall develop a system for the registration of the renewable energy tax credit certificates issued or transferred under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and a system that permits verification that any tax credit claimed on a tax return is valid and that transfers of the tax credit certificates are made in accordance with the requirements of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. The tax credit certificates issued under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall not be classified as a security pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 502}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 160, \'a712, 14}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 25, \'a7143}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1093, \'a718}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1062, \'a794}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{476C.7}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Rules.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department and the commission may adopt rules pursuant to }{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{ for the administration and enforcement of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 160, \'a713, 14}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1170, \'a7369}}}\par}}