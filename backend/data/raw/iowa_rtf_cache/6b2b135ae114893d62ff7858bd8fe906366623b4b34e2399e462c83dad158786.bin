j{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{For purposes of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fNo-contact order\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a court order issued in a criminal proceeding requiring the defendant to have no contact with the alleged victim, persons residing with the alleged victim, or members of the alleged victim\u8217\'3fs immediate family, and to refrain from harassing the alleged victim, persons residing with the alleged victim, or members of the alleged victim\u8217\'3fs family.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fProtective order\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a protective order issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 232}}}{{\f5\fs18\hyphpar0\qj{, a court order or court-approved consent agreement entered pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{chapter 235F}}}{{\f5\fs18\hyphpar0\qj{, a court order or court-approved consent agreement entered pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 236}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{236A}}}{{\f5\fs18\hyphpar0\qj{, including a valid foreign protective order under }}}{{\f5\fs18\hyphpar0\qj{section 236.19, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{section 236A.19, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, a temporary or permanent protective order or order to vacate the homestead under }}}{{\f5\fs18\hyphpar0\qj{chapter 598}}}{{\f5\fs18\hyphpar0\qj{, or an order that establishes conditions of release or is a protective order or sentencing order in a criminal prosecution arising from a domestic abuse assault under }}}{{\f5\fs18\hyphpar0\qj{section 708.2A}}}{{\f5\fs18\hyphpar0\qj{ or older individual assault under }}}{{\f5\fs18\hyphpar0\qj{section 708.2D}}}{{\f5\fs18\hyphpar0\qj{, or a civil injunction issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 915.22}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fVictim\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person who has suffered physical, emotional, or financial harm as a result of a public offense, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 701.2}}}{{\f5\fs18\hyphpar0\qj{, committed in this state.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1101, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 180, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1107, \'a722}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 121, \'a726}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1132, \'a712}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{664A.2}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Applicability.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This chapter}}}{{\f5\fs18\hyphpar0\qj{ applies to no-contact orders issued for violations or alleged violations of }}}{{\f5\fs18\hyphpar0\qj{sections 708.2A}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{708.2D}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{708.7}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{708.11}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{709.2}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{709.3}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{709.4}}}{{\f5\fs18\hyphpar0\qj{, and any other public offense for which there is a victim.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A protective order issued in a civil proceeding shall be issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 232}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{235F}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{236}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{236A}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{598}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{915}}}{{\f5\fs18\hyphpar0\qj{. Punishment for a violation of a protective order shall be imposed pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 664A.7}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1101, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 180, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1107, \'a723}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 121, \'a727}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1132, \'a713}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7664A.3}}}{{\f5\fs12\hyphpar0\qj{, 664A.5}}}{{\f5\fs12\hyphpar0\qj{, 664A.7}}}{{\f5\fs12\hyphpar0\qj{, 664A.8}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{664A.3}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Entry of temporary no-contact order.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When a person is taken into custody for contempt proceedings pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 236.11}}}{{\f5\fs18\hyphpar0\qj{, taken into custody pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 236A.12}}}{{\f5\fs18\hyphpar0\qj{, or arrested for any public offense referred to in }}}{{\f5\fs18\hyphpar0\qj{section 664A.2, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, and the person is brought before a magistrate for initial appearance, the magistrate shall enter a no-contact order if the magistrate finds both of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Probable cause exists to believe that any public offense referred to in }}}{{\f5\fs18\hyphpar0\qj{section 664A.2, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, or a violation of a no-contact order, protective order, or consent agreement has occurred.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The presence of or contact with the defendant poses a threat to the safety of the alleged victim, persons residing with the alleged victim, or members of the alleged victim\u8217\'3fs family.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{chapters 804}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{805}}}{{\f5\fs18\hyphpar0\qj{, a person taken into custody pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 236.11}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{236A.12}}}{{\f5\fs18\hyphpar0\qj{ or arrested pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 236.12}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{709.2}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{709.3}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{709.4}}}{{\f5\fs18\hyphpar0\qj{ may be released on bail or otherwise only after initial appearance before a magistrate as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 804}}}{{\f5\fs18\hyphpar0\qj{ and the rules of criminal procedure or }}}{{\f5\fs18\hyphpar0\qj{section 236.11}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{236A.12}}}{{\f5\fs18\hyphpar0\qj{, whichever is applicable.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A no-contact order issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be issued in addition to any other conditions of release imposed by a magistrate pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 811.2}}}{{\f5\fs18\hyphpar0\qj{. The no-contact order has force and effect until it is modified or terminated by subsequent court action in a contempt proceeding or criminal or juvenile court action and is reviewable in the manner prescribed in }}}{{\f5\fs18\hyphpar0\qj{section 811.2}}}{{\f5\fs18\hyphpar0\qj{. Upon final disposition of the criminal or juvenile court action, the court shall terminate or modify the no-contact order pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 664A.5}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A no-contact order requiring the defendant to have no contact with the alleged victim\u8217\'3fs children shall prevail over any existing order which may be in conflict with the no-contact order.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A no-contact order issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall restrict the defendant from having contact with the victim, persons residing with the victim, or the victim\u8217\'3fs immediate family.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A no-contact order issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall specifically include notice that the person may be required to relinquish all firearms, offensive weapons, and ammunition upon the issuance of a permanent no-contact order pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 664A.5}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1101, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 180, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1083, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 121, \'a728, 29}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1043, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7664A.5}}}{{\f5\fs12\hyphpar0\qj{, 709.22}}}{{\f5\fs12\hyphpar0\qj{, 915.50}}}{{\f5\fs12\hyphpar0\qj{, 915.50A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{664A.4}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Notice of no-contact order.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The clerk of the district court or other person designated by the court shall provide a copy of the no-contact order to the victim pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{chapter 915}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The clerk of the district court shall provide a notice and copy of the no-contact order to the appropriate law enforcement agencies and the twenty-four-hour dispatcher for the law enforcement agencies in the same manner as provided in }}}{{\f5\fs18\hyphpar0\qj{section 235F.6}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{236.5}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{236A.7}}}{{\f5\fs18\hyphpar0\qj{, as applicable. The clerk of the district court shall provide a notice and copy of a modification or vacation of a no-contact order in the same manner.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1101, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1107, \'a724}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 121, \'a730}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{664A.4A}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Short-form notification }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ no-contact order or protective order.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In lieu of personal service of a no-contact order or a protective order on a person whose activities are restrained by the order, a sheriff of any county in this state or any peace officer or corrections officer in this state may serve the person with a short-form notification pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ to effectuate service of an unserved no-contact order or protective order.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Service of a short-form notification under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be allowed during traffic stops and other contacts with the person by a sheriff, peace officer, or corrections officer in this state in the course of performing official duties. The person may be detained for a reasonable period of time to complete the short-form notification process.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When the short-form notification process is complete, the sheriff, peace officer, or corrections officer serving the notification shall file a copy of the notification with the clerk of the district court. The filing shall indicate the date and time the notification was served on the person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The short-form notification shall be on a form prescribed by the state court administrator. The state court administrator shall prescribe rules relating to the content and distribution of the form to appropriate law enforcement agencies in this state. The form shall include but not be limited to all of the following statements:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person shall have no contact with the protected party.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person is responsible for obtaining a full copy of the no-contact order or the protective order from the county sheriff of the county in which the order was entered or from the clerk of the district court.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The terms and conditions of the no-contact order or protective order are enforceable, and the person is subject to arrest for violating the no-contact order or the protective order.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2013 Acts, ch 16, \'a72, 3}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7235F.2}}}{{\f5\fs12\hyphpar0\qj{, 236.3}}}{{\f5\fs12\hyphpar0\qj{, 236A.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{664A.5}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Modification }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ entry of permanent no-contact order.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If a defendant is convicted of, receives a deferred judgment for, or pleads guilty to a public offense referred to in }{{\f5\fs18\hyphpar0\qj{section 664A.2, subsection 1}}}{, or is held in contempt for a violation of a no-contact order issued under }{{\f5\fs18\hyphpar0\qj{section 664A.3}}}{ or for a violation of a protective order issued pursuant to }{{\f5\fs18\hyphpar0\qj{chapter 232}}}{, }{{\f5\fs18\hyphpar0\qj{235F}}}{, }{{\f5\fs18\hyphpar0\qj{236}}}{, }{{\f5\fs18\hyphpar0\qj{236A}}}{, }{{\f5\fs18\hyphpar0\qj{598}}}{, or }{{\f5\fs18\hyphpar0\qj{915}}}{, the court shall either terminate or modify the temporary no-contact order issued by the magistrate. The court may enter a no-contact order or continue the no-contact order already in effect for a period of five years from the date the judgment is entered or the deferred judgment is granted, regardless of whether the defendant is placed on probation.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1101, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 180, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1107, \'a725}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 121, \'a731}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7664A.3}}}{{\f5\fs12\hyphpar0\qj{, 708.2A}}}{{\f5\fs12\hyphpar0\qj{, 708.2D}}}{{\f5\fs12\hyphpar0\qj{, 726.24}}}{{\f5\fs12\hyphpar0\qj{, 726.25}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{664A.6}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Mandatory arrest for violation of no-contact order \u8212\'3f immunity for actions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a peace officer has probable cause to believe that a person has violated a no-contact order issued under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, the peace officer shall take the person into custody and shall take the person without unnecessary delay before the nearest or most accessible magistrate in the judicial district in which the person was taken into custody.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the peace officer is investigating a domestic abuse assault pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 708.2A}}}{{\f5\fs18\hyphpar0\qj{, the officer shall also comply with }}}{{\f5\fs18\hyphpar0\qj{sections 236.11}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{236.12}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A peace officer shall not be held civilly or criminally liable for acting pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ provided the peace officer acts in good faith and on reasonable grounds and the peace officer\u8217\'3fs acts do not constitute a willful or wanton disregard for the rights or safety of another.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1101, \'a710}}}{; }{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 180, \'a78}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{664A.7}}}{\*\bkmkstart stylerid1_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Violation of no-contact order or protective order \u8212\'3f contempt or simple misdemeanor penalties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Violation of a no-contact order issued under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or a protective order issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 232}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{235F}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{236}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{236A}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{598}}}{{\f5\fs18\hyphpar0\qj{, including a modified no-contact order, is punishable by summary contempt proceedings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A hearing in a contempt proceeding brought pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be held not less than five and not more than fifteen days after the issuance of a rule to show cause, as determined by the court.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If convicted of or held in contempt for a violation of a no-contact order or a modified no-contact order for a public offense referred to in }}}{{\f5\fs18\hyphpar0\qj{section 664A.2, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, or held in contempt of a no-contact order issued during a contempt proceeding brought pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 236.11}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{236A.12}}}{{\f5\fs18\hyphpar0\qj{, the person shall be confined in the county jail for a minimum of seven days. A jail sentence imposed pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be served on consecutive days. No portion of the mandatory minimum term of confinement imposed by }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be deferred or suspended. A deferred judgment, deferred sentence, or suspended sentence shall not be entered for a violation of a no-contact order, modified no-contact order, or protective order and the court shall not impose a fine in lieu of the minimum sentence, although a fine may be imposed in addition to the minimum sentence.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If convicted or held in contempt for a violation of a civil protective order referred to in }}}{{\f5\fs18\hyphpar0\qj{section 664A.2}}}{{\f5\fs18\hyphpar0\qj{, the person shall serve a jail sentence. A jail sentence imposed pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be served on consecutive days. A person who is convicted of or held in contempt for a violation of a protective order referred to in }}}{{\f5\fs18\hyphpar0\qj{section 664A.2}}}{{\f5\fs18\hyphpar0\qj{ may be ordered by the court to pay the plaintiff\u8217\'3fs attorney\u8217\'3fs fees and court costs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Violation of a no-contact order entered for the offense or alleged offense of domestic abuse assault in violation of }}}{{\f5\fs18\hyphpar0\qj{section 708.2A}}}{{\f5\fs18\hyphpar0\qj{ or for the offense or alleged offense of older individual assault in violation of }}}{{\f5\fs18\hyphpar0\qj{section 708.2D}}}{{\f5\fs18\hyphpar0\qj{, or a violation of a protective order issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 232}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{235F}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{236}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{236A}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{598}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{915}}}{{\f5\fs18\hyphpar0\qj{ constitutes a public offense and is punishable as a simple misdemeanor. Alternatively, the court may hold a person in contempt of court for such a violation, as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not be held in contempt or convicted of violations under multiple no-contact orders, protective orders, or consent agreements, for the same set of facts and circumstances that constitute a single violation.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1101, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 180, \'a79, 10}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1107, \'a726}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 121, \'a732}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1132, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 66, \'a7148}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7598.41}}}{{\f5\fs12\hyphpar0\qj{, 598C.305}}}{{\f5\fs12\hyphpar0\qj{, 664A.2}}}{{\f5\fs12\hyphpar0\qj{, 907.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{664A.8}}}{\*\bkmkstart stylerid1_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Extension of no-contact order.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Upon the filing of an application by the state or by the victim of any public offense referred to in }{{\f5\fs18\hyphpar0\qj{section 664A.2, subsection 1}}}{ which is filed within ninety days prior to the expiration of a modified no-contact order, the court shall modify and extend the no-contact order for an additional period of five years, unless the court finds that the defendant no longer poses a threat to the safety of the victim, persons residing with the victim, or members of the victim\u8217\'3fs family. The number of modifications extending the no-contact order permitted by }{{\f5\fs18\hyphpar0\qj{this section}}}{ is not limited.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1101, \'a712}}}{; }{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 180, \'a711}}}\par}}