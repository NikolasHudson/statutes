s18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{216A.166}}}{\*\bkmkstart stylerid1_2E15_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Office of Native American affairs.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2024 Acts, ch 1170, \'a7464}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\sb0\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{216A.167}}}{\*\bkmkstart stylerid1_2E15_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Limitations on authority.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board and department shall not have the authority to do any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Implement or administer the duties of the state of Iowa under the federal }}}{{\f5\fs18\hyphpar0\qj{Indian Gaming Regulatory Act}}}{{\f5\fs18\hyphpar0\qj{, shall not have any authority to recommend, negotiate, administer, or enforce any agreement or compact entered into between the state of Iowa and Indian tribes located in the state pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 10A.104}}}{{\f5\fs18\hyphpar0\qj{, and shall not have any authority relative to Indian gaming issues.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Administer the duties of the state under the federal }}}{{\f5\fs18\hyphpar0\qj{National Historic Preservation Act}}}{{\f5\fs18\hyphpar0\qj{, the federal }}}{{\f5\fs18\hyphpar0\qj{Native American Graves Protection and Repatriation Act}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{chapter 263B}}}{{\f5\fs18\hyphpar0\qj{. The board shall also not interfere with the advisory role of a separate Indian advisory council or committee established by the state archeologist by rule for the purpose of consultation on matters related to ancient human skeletal remains and associated artifacts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This subchapter}}}{{\f5\fs18\hyphpar0\qj{ shall not diminish or inhibit the right of any tribal government to interact directly with the state or any of its departments or agencies for any purpose which a tribal government desires to conduct its business or affairs as a sovereign governmental entity.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1184, \'a745}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1031, \'a7166, 167, 170}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1170, \'a7463}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{216A.168 through 216A.170}}}{Repealed by }{{\f5\fs18\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2010/CH1031.pdf" }{\fldrslt \f5 \fs18{{2010 Acts, ch 1031, \'a7168, 170}}}}}}{{\f5\fs18\qj{2010 Acts, ch 1031, \'a7168, 170}}}{.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}}