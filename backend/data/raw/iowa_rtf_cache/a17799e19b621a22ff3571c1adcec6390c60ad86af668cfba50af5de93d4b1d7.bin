\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F446}{\*\bkmkend codeChapter_5F446}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 446}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{TAX SALES}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a7306.22}}}{{\f5\fs12\qc{, 331.559}}}{{\f5\fs12\qc{, 384.2}}}{{\f5\fs12\qc{, 419.11}}}{{\f5\fs12\qc{, 427.2}}}{{\f5\fs12\qc{, 435.24}}}{{\f5\fs12\qc{, 435.25}}}{{\f5\fs12\qc{, 437A.11}}}{{\f5\fs12\qc{, 437B.7}}}{{\f5\fs12\qc{, 445.1}}}{{\f5\fs12\qc{, 445.36A}}}{{\f5\fs12\qc{, 447.1}}}{{\f5\fs12\qc{, 461A.25}}}\par}{}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\ri1445\li1445{\f5\fs12\qc}\par}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb0\ri1445\li1445\sa146{ }\par}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\ri1445\li1445{For definitions applicable to chapter,}\par}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\ri1445\li1445\sa0\par}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\ri1445\li1445{see }{{\f5\fs12\qc{\'a7445.1}}}\par}{\pard\plain\keep\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{446.1}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Sale shown.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The county treasurer shall designate on the county system each parcel sold for taxes and not redeemed, by noting on the county system the year in which it was sold.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, \'a7842; C97, \'a71386; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7238;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81}}}{, }{{\f5\fs18\hyphpar0\qj{S81, \'a7446.1}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a71224}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 191, \'a758}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{446.2}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Notice of sale.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{For each parcel sold, the county treasurer shall notify the party in whose name the parcel was taxed, according to the treasurer\u8217\'3fs records at the time of sale, that the parcel was sold at tax sale. The notice of sale shall be sent by regular mail within fifteen days from the date of the annual tax sale or any adjourned tax sale. Failure to receive a mailed notice is not a defense to payment of the total amount due.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, \'a7847; C97, \'a71392; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7239;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7446.2}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 191, \'a759}}}{; }{{\f5\fs18\hyphpar0\qj{93 Acts, ch 73, \'a77}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1107, \'a727}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{446.3 through 446.6}}}{Repealed by 91 Acts, ch 191, \'a7123, 124. }{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{446.7}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Annual tax sale.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Annually, on the third Monday in June the county treasurer shall offer at public sale all parcels on which taxes are delinquent. The treasurer shall not, however, offer for sale any parcel that is subject to a pending action as the result of a municipal infraction citation under }}}{{\f5\fs18\hyphpar0\qj{section 364.22}}}{{\f5\fs18\hyphpar0\qj{, a petition filed under }}}{{\f5\fs18\hyphpar0\qj{chapter 657}}}{{\f5\fs18\hyphpar0\qj{, or a petition filed under }}}{{\f5\fs18\hyphpar0\qj{chapter 657A}}}{{\f5\fs18\hyphpar0\qj{, if such municipal infraction citation or petition is indexed under }}}{{\f5\fs18\hyphpar0\qj{section 617.10}}}{{\f5\fs18\hyphpar0\qj{ and noted in the county system as defined in }}}{{\f5\fs18\hyphpar0\qj{section 445.1}}}{{\f5\fs18\hyphpar0\qj{. The sale shall be made for the total amount of taxes, interest, fees, and costs due. If for good cause the treasurer cannot hold the annual tax sale on the third Monday of June, the treasurer may designate a different date in June for the sale.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Parcels against which the county holds a tax sale certificate or a municipality holds a tax sale certificate acquired under }}}{{\f5\fs18\hyphpar0\qj{section 446.19}}}{{\f5\fs18\hyphpar0\qj{, parcels of municipal and political subdivisions of the state of Iowa, or parcels of the state or its agencies, shall not be offered or sold at tax sale and a tax sale of those parcels is void from its inception. When taxes are owing against parcels owned or claimed by a municipal or political subdivision of the state of Iowa, or parcels of the state or its agencies, the treasurer shall give notice to the appropriate governing body which shall then pay the total amount due. If the governing body fails to pay the total amount due, the board of supervisors shall abate the total amount due.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7496; R60, \'a7763; C73, \'a7871; C97, \'a71418; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7244;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7446.7}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 101, \'a791}}}{{\f5\fs18\hyphpar0\qj{; 83 Acts, ch 123, \'a7182, 209}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1221, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 191, \'a760}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 73, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 4, \'a71, 4}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 54, \'a737}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1050, \'a73}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7364.22}}}{{\f5\fs12\hyphpar0\qj{, 447.1}}}{{\f5\fs12\hyphpar0\qj{, 657.2A}}}{{\f5\fs12\hyphpar0\qj{, 657A.12}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{446.8}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{446.9}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Notice of sale \u8212\'3f service \u8212\'3f publication \u8212\'3f costs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A notice of the date, time, and place of the annual tax sale shall be served upon the person in whose name the parcel subject to sale is taxed. The county treasurer shall serve the notice by sending it by regular first class mail to the person\u8217\'3fs last known address not later than May 1 of each fiscal year. However, in those instances when May 1 is a Saturday or Sunday, the notice shall be served not later than the first business day of May. The notice shall contain a description of the parcel to be sold which is clear, concise, and sufficient to distinguish the parcel to be sold from all other parcels. It shall also contain the amount of delinquent taxes for which the parcel is liable each year, the amount of the interest and fees, and the amount of the service fee as provided in }}}{{\f5\fs18\hyphpar0\qj{section 446.10, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, all to be incorporated as a single sum. The notice shall contain a statement that, after the sale, if the parcel is not redeemed within the period provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 447}}}{{\f5\fs18\hyphpar0\qj{, the right to redeem expires and a deed may be issued.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Publication of the date, time, and place of the annual tax sale shall be made once by the treasurer in at least one official newspaper in the county as selected by the board of supervisors and designated by the treasurer at least one week, but not more than three weeks, before the day of sale. The publication shall contain a description of the parcel to be sold that is clear, concise, and sufficient to distinguish the parcel to be sold from all other parcels. All items offered for sale pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 446.18}}}{{\f5\fs18\hyphpar0\qj{ may be indicated by an }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fs\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or by an asterisk. The publication shall also contain the name of the person in whose name the parcel to be sold is taxed and the amount delinquent for which the parcel is liable each year, the amount of the interest and fees, and the amount of the service fee as provided in }}}{{\f5\fs18\hyphpar0\qj{section 446.10, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, all to be incorporated as a single sum. The publication shall contain a statement that, after the sale, if the parcel is not redeemed within the period provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 447}}}{{\f5\fs18\hyphpar0\qj{, the right to redeem expires and a deed may be issued.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to the notice required by }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ and the publication required by }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, the treasurer shall send, at least one week but not more than three weeks before the day of sale, a notice of sale in the form prescribed by }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, by regular first class mail to any mortgagee having a lien upon the parcel, a vendor of the parcel under a recorded contract of sale, a lessor of the parcel who has a recorded lease or memorandum of a recorded lease, and to any other person who has an interest of record in the parcel, if the mortgagee, vendor, lessor, or other person having an interest of record has done both of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Requested on a form prescribed by the treasurer that notice of sale be sent to the person.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Filed the request form with the treasurer at least one month prior to the date of sale, together with a fee of twenty-five dollars per parcel.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The request for notice is valid for a period of five years from the date of filing with the treasurer. The request for notice may be renewed for additional periods of five years by the procedure specified in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notice required by }}}{{\f5\fs18\hyphpar0\qj{subsections 1 and 3}}}{{\f5\fs18\hyphpar0\qj{ shall be deemed completed when the notice is enclosed in a sealed envelope with the proper postage on the envelope, is addressed to the person entitled to receive it at the person\u8217\'3fs last known mailing address, and is deposited in a mail receptacle provided by the United States postal service. Failure to receive a mailed notice is not a defense to the payment of the total amount due.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If, for good cause, a parcel is not included in the publication specified in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, notice shall be given by publication or by posting a description of the parcel and the date, time, and place of the tax sale in the treasurer\u8217\'3fs office for two weeks before the regular or any adjourned tax sale and, at the time of the publication or posting, by mailing the notice required in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7498; R60, \'a7764; C73, \'a7872 \u8211\'3f 874, 3833; C97, \'a71419; S13, \'a71419; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7246;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7446.9}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1221, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1139, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 214, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 191, \'a761}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1016, \'a724}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 121, \'a718}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1107, \'a728}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 4, \'a72, 4}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1043, \'a77, 8}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 44, \'a764}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1070, \'a722}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 25, \'a7143}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7435.24}}}{{\f5\fs12\hyphpar0\qj{, 445.2}}}{{\f5\fs12\hyphpar0\qj{, 445.3}}}{{\f5\fs12\hyphpar0\qj{, 446.19B}}}{{\f5\fs12\hyphpar0\qj{, 446.20}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{446.10}}}{\*\bkmkstart stylerid1_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Publication costs and service fees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The compensation for publication shall not exceed four dollars for each separately described parcel and shall be paid by the county.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A service fee not to exceed four dollars shall be collected as a fee for sale notice preparation and deposited into the county general fund. If the taxes are paid before the date of sale, the service fee shall be included as a part of the costs of collecting the taxes.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7498; R60, \'a7764; C73, \'a7873, 3833; C97, \'a71419; S13, \'a71419; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7247;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7446.10}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1139, \'a75}}}{; }{{\f5\fs18\hyphpar0\qj{91 Acts, ch 191, \'a762}}}{; }{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1043, \'a79}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7446.9}}}{{\f5\fs12\hyphpar0\qj{, 446.11}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{446.11}}}{\*\bkmkstart stylerid1_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Substituted service.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If the county treasurer cannot procure the publication of the notice for the sum specified in }{{\f5\fs18\hyphpar0\qj{section 446.10}}}{, the notice may be given by posting it in the treasurer\u8217\'3fs office for two weeks.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7498; R60, \'a7764; C73, \'a7873, 3833; C97, \'a71419; S13, \'a71419; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7248;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7446.11}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 191, \'a763}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{446.12}}}{\*\bkmkstart stylerid1_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Certificate of publication.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The county treasurer shall obtain a copy of the notice of sale with a certificate of its publication from the printer or publisher, and file it in the office of the treasurer. The certificate shall be substantially in the following form:}\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\sb80\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~}}}{I, }{{\f5\fs18\hyphpar0\qj{................................}}}{, publisher (or printer) of the }{{\f5\fs18\hyphpar0\qj{................................}}}{, a newspaper printed and published in the county of }{{\f5\fs18\hyphpar0\qj{............................}}}{ and state of Iowa, certify that the foregoing notice and list were published in that newspaper on the }{{\f5\fs18\hyphpar0\qj{............}}}{ day of }{{\f5\fs18\hyphpar0\qj{........................}}}{, }{{\f5\fs18\hyphpar0\qj{................}}}{, and that copies of each issue of the paper in which the notice and list were published were delivered by carrier or transmitted by mail to each of the subscribers to the paper.}\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{........................................................}}}\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{Signature of publisher (or printer)}\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{State of Iowa,}{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{)}\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{........................}}}{ County.}{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{)}{{\f5\fs18\hyphpar0\qj{\~\~}}}{ss.}\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~}}}{The above certificate of publication was subscribed and sworn to before me by the above named }{{\f5\fs18\hyphpar0\qj{................................}}}{, who is personally known to me to be the identical person described in the certificate, on the }{{\f5\fs18\hyphpar0\qj{........................}}}{ day of }{{\f5\fs18\hyphpar0\qj{........................}}}{, }{{\f5\fs18\hyphpar0\qj{................}}}\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{....................................................}}}\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{Notary}\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{............................}}}{ County, Iowa.}\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keep\f5\fs8\hyphpar0\qj\fi0\ri1084\li1084\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7500; R60, \'a7771; C73, \'a7881; C97, \'a71420; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7249;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7446.12}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1139, \'a76}}}{; }{{\f5\fs18\hyphpar0\qj{91 Acts, ch 191, \'a764}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{446.13}}}{\*\bkmkstart stylerid1_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Method of describing parcels, etc.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{In entries required to be made by the county auditor, county treasurer, or other officer, letters and figures may be used to denote townships, ranges, sections, parts of sections, lots, blocks, dates, and the amount of taxes, interest, fees, and costs.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a7770; C73, \'a7880; C97, \'a71421; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7250;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7446.13}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 191, \'a765}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{446.14}}}{\*\bkmkstart stylerid1_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Irregularities in advertisement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{An irregularity or informality in the advertisement does not affect the legality of the sale or the title to a parcel conveyed by the county treasurer\u8217\'3fs deed under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ and }{{\f5\fs18\hyphpar0\qj{chapters 447}}}{ and }{{\f5\fs18\hyphpar0\qj{448}}}{, and in all cases its provisions shall be sufficient notice to the owners of the sale of the parcel.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a7770; C73, \'a7880; C97, \'a71421; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7251;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7446.14}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 191, \'a766}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{446.15}}}{\*\bkmkstart stylerid1_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Offer for sale.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The county treasurer shall offer for sale, on the day of the sale, each parcel separately for the total amount due against each parcel advertised for sale.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7499; R60, \'a7765; C73, \'a7875; C97, \'a71422; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7252;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7446.15}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 191, \'a767}}}{; }{{\f5\fs18\hyphpar0\qj{95 Acts, ch 57, \'a716}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{446.16}}}{\*\bkmkstart stylerid1_2E18_2E2_2E2}{\*\bkmkend stylerid1_2E18_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Bid \u8212\'3f purchaser \u8212\'3f bidder registration fee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person who offers to pay the total amount due, which is a lien on any parcel, for the smallest percentage of the parcel is the purchaser, and when the purchaser designates the percentage of any parcel for which the purchaser will pay the total amount due, the percentage thus designated shall give the person an undivided interest upon the issuance of a treasurer\u8217\'3fs deed, as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 448}}}{{\f5\fs18\hyphpar0\qj{. If two or more persons have placed an equal bid and the bids are the smallest percentage offered, the county treasurer shall use a random selection process to select the bidder to whom a certificate of purchase will be issued. The percentage that may be designated by any purchaser under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not be less than one percent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The treasurer may establish and collect a reasonable registration fee from each registered bidder at the tax sale. The fee shall not be assessed against a county or municipality. The total of the fees collected shall not exceed the total costs of the tax sale. Registration fees collected shall be deposited in the general fund of the county.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The delinquent tax lien transfers with the tax sale certificate, whether held by the county or purchased by an individual, through assignment or direct purchase at the tax sale. The delinquent tax sale lien expires when the tax sale certificate expires.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Only those persons as defined in }}}{{\f5\fs18\hyphpar0\qj{section 4.1}}}{{\f5\fs18\hyphpar0\qj{ are authorized to register to bid or to bid at the tax sale or to own a tax sale certificate by purchase, assignment, or otherwise. To be authorized to register to bid or to bid at a tax sale or to own a tax sale certificate, a person, other than an individual, must have a federal tax identification number and either a designation of agent for service of process on file with the secretary of state or a verified statement meeting the requirements of }}}{{\f5\fs18\hyphpar0\qj{chapter 547}}}{{\f5\fs18\hyphpar0\qj{ on file with the county recorder of the county in which the person wishes to register to bid or to bid at tax sale or of the county where the property that is the subject of the tax sale certificate is located.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7501; R60, \'a7766; C73, \'a7876; C97, \'a71423; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7253;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7446.16}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1203, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{91 Acts, ch 191, \'a768}}}{; }{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1016, \'a725}}}{; }{{\f5\fs18\hyphpar0\qj{95 Acts, ch 57, \'a717}}}{; }{{\f5\fs18\hyphpar0\qj{97 Acts, ch 121, \'a719}}}{; }{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1092, \'a78}}}{; }{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 34, \'a715, 26}}}{; }{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 11, \'a71, 2}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7420.246}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{446.17}}}{\*\bkmkstart stylerid1_2E19_2E2_2E2}{\*\bkmkend stylerid1_2E19_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Sale continued.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county treasurer shall continue the sale from day to day as long as there are bidders or until all delinquent parcels have been offered for sale.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If notice of annual tax sale has been published under }}}{{\f5\fs18\hyphpar0\qj{section 446.9, Code 1991}}}{{\f5\fs18\hyphpar0\qj{, the notice is valid and further notice is not required for an adjourned sale held under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, unless it is a public bidder sale.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7499; R60, \'a7767; C73, \'a7877; C97, \'a71424; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7254;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7446.17}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 191, \'a769}}}{; }{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1016, \'a726}}}{; }{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 22, \'a777}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{446.18}}}{\*\bkmkstart stylerid1_2E2_30_2E2_2E2}{\*\bkmkend stylerid1_2E2_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{\u8220\'3fPublic bidder sale\u8221\'3f \u8212\'3f notice.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Each county treasurer shall, on the day of the regular tax sale each year or any continuance or adjournment of the tax sale, offer and sell at public sale all parcels which remain liable to sale for delinquent taxes, which have previously been advertised, offered for one year or more, and remain unsold for want of bidders. Notice of the sale shall be given at the same time and in the same manner as that given of the regular sale.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a71425; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7255;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7446.18}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 191, \'a770}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.46}}}{{\f5\fs12\hyphpar0\qj{, 446.9}}}{{\f5\fs12\hyphpar0\qj{, 446.19}}}{{\f5\fs12\hyphpar0\qj{, 446.19A}}}{{\f5\fs12\hyphpar0\qj{, 447.9}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{446.19}}}{\*\bkmkstart stylerid1_2E21_2E2_2E2}{\*\bkmkend stylerid1_2E21_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{County or city as purchaser.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When a parcel is offered at a tax sale under }}}{{\f5\fs18\hyphpar0\qj{section 446.18}}}{{\f5\fs18\hyphpar0\qj{, and no bid is received, or if the bid received is less than the total amount due, the county in which the parcel is located, through its county treasurer, shall bid for the parcel a sum equal to the total amount due. Money shall not be paid by the county or other tax-levying or tax-certifying body for the purchase, but each of the tax-levying and tax-certifying bodies having any interest in the taxes shall be charged with the total amount due the tax-levying or tax-certifying body as its just share of the purchase price.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not prohibit a governmental agency or political subdivision from bidding at the sale for a parcel to protect its interests. When a bid is received from a city in which the parcel is located, money shall not be paid by the city, but each of the tax-levying and tax-certifying bodies having any interest in the taxes shall be charged with the total amount due the tax-levying or tax-certifying body as its just share of the purchase price.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C27, 31, 35, \'a77255-b1; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7255.1;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7446.19}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 191, \'a771}}}{; }{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1163, \'a786}}}{; }{{\f5\fs18\hyphpar0\qj{95 Acts, ch 57, \'a718}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.361}}}{{\f5\fs12\hyphpar0\qj{, 445.3}}}{{\f5\fs12\hyphpar0\qj{, 445.16}}}{{\f5\fs12\hyphpar0\qj{, 446.7}}}{{\f5\fs12\hyphpar0\qj{, 446.20}}}{{\f5\fs12\hyphpar0\qj{, 446.21}}}{{\f5\fs12\hyphpar0\qj{, 447.1}}}{{\f5\fs12\hyphpar0\qj{, 459.505}}}{{\f5\fs12\hyphpar0\qj{, 459.506}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Acquisition of title by municipal corporations, }{{\f5\fs12\hyphpar0\qj{chapter 569}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{446.19A}}}{\*\bkmkstart stylerid1_2E22_2E2_2E2}{\*\bkmkend stylerid1_2E22_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Purchase by county or city for use as housing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of supervisors of a county may adopt an ordinance authorizing the county and each city in the county to bid on and purchase delinquent taxes and to assign tax sale certificates of abandoned property or vacant lots. }}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ may only be used by a county or by a city in the county if such an ordinance is in effect.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On the day of the regular tax sale or any continuance or adjournment of the tax sale, the county or a city may bid for abandoned property assessed as residential property or as commercial multifamily housing property or for a vacant lot a sum equal to the total amount due. Money shall not be paid by the county or city for the purchase, but each of the tax-levying and tax-certifying bodies having any interest in the taxes shall be charged with the total amount due the tax-levying or tax-certifying body as its just share of the purchase price. Prior to the purchase, the county or city shall file with the county treasurer a verified statement that a parcel to be purchased is abandoned property and that the parcel is suitable for use as housing following rehabilitation or that a parcel to be purchased is a vacant lot.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If after the date that a parcel is sold pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, or after the date that a parcel is sold under }}}{{\f5\fs18\hyphpar0\qj{section 446.18}}}{{\f5\fs18\hyphpar0\qj{, the parcel assessed as residential property or as commercial multifamily housing property is identified as abandoned or as a vacant lot pursuant to a verified statement filed with the county treasurer by a city or county in the form set forth in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, a city or county may require the assignment of the tax sale certificate that had been issued for such parcel by paying to the holder of such certificate the total amount due on the date the assignment of the certificate is made to the county or city and recorded with the county treasurer. If a certificate holder fails to assign the certificate of purchase to the city or county, the county treasurer is authorized to issue a duplicate certificate of purchase, which shall take the place of the original certificate, and assign the duplicate certificate to the city or county. If the certificate is not assigned by the county or city pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{, the county or city, whichever is applicable, is liable for the tax sale interest that was due the certificate holder pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 447.1}}}{{\f5\fs18\hyphpar0\qj{, as of the date of assignment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The city or county may assign the tax sale certificate obtained pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. Persons who purchase certificates from the city or county under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ are liable for the total amount due the certificate holder pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 447.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All persons who purchase certificates from the city or county under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall demonstrate the intent to rehabilitate the abandoned property for habitation or build a residential structure on the vacant lot if the property is not redeemed. In the alternative, the county or city may, if title to the property has vested in the county or city under }}}{{\f5\fs18\hyphpar0\qj{section 448.1}}}{{\f5\fs18\hyphpar0\qj{, dispose of the property in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 331.361}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{364.7}}}{{\f5\fs18\hyphpar0\qj{, as applicable.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAbandoned property\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a lot or parcel containing a building which is used or intended to be used for residential purposes and which has remained vacant and has been in violation of the housing code of the city in which the property is located or of the housing code applicable in the county in which the property is located if outside the limits of a city, for a period of six consecutive months.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fVacant lot\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a lot or parcel located in a city or outside the limits of a city in a county that contains no buildings or structures and that is zoned to allow for residential structures.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1204, \'a731}}}{; }{{\f5\fs18\hyphpar0\qj{99 Acts, ch 29, \'a71, 3}}}{; }{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1165, \'a75 \u8211\'3f 7, 11, 12}}}{; }{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 34, \'a716, 17, 26}}}{; }{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 54, \'a738}}}{; }{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 126, \'a772}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7446.19B}}}{{\f5\fs12\hyphpar0\qj{, 447.9}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{446.19B}}}{\*\bkmkstart stylerid1_2E23_2E2_2E2}{\*\bkmkend stylerid1_2E23_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Public nuisance tax sale \u8212\'3f rehabilitation for use as housing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of supervisors of a county may adopt an ordinance authorizing the county treasurer to separately offer and sell at the annual tax sale delinquent taxes on parcels that are abandoned property and are assessed as residential property or as commercial multifamily housing property and that are, or are likely to become, a public nuisance. }}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ may only be used by a county or by a city in the county if such an ordinance is in effect.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On or before May 15, the county or city may file with the county treasurer a verified statement containing a listing of parcels and a declaration that each parcel is abandoned property, each parcel is assessed as residential property or as commercial multifamily housing property, each parcel is, or is likely to become, a public nuisance, and that each parcel is suitable for use as housing following rehabilitation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The verified statement shall be published at the same time and in the same manner as the notice of the annual tax sale and the requirements in }}}{{\f5\fs18\hyphpar0\qj{section 446.9, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, for publication of notice of the annual tax sale also apply to publication of the verified statement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On the day of the regular tax sale, or any continuance or adjournment of the tax sale, the treasurer shall separately offer and sell those parcels listed in a verified statement timely received and properly published and which remain liable to sale for delinquent taxes. This sale shall be known as the \u8220\'3fpublic nuisance tax sale\u8221\'3f. Notwithstanding any provision to the contrary, the percentage interest that may be purchased in a parcel offered for sale under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not be less than one hundred percent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To be eligible to bid on parcels under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, a prospective bidder shall enter into a rehabilitation agreement with the county, or with the city if the property is located within a city, to demonstrate the intent to rehabilitate the property for use as housing if the property is not redeemed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If after issuance of a tax sale deed to the holder of a certificate of purchase at the public nuisance tax sale, the tax sale deed holder determines that a building, structure, or other improvement located on the parcel cannot be rehabilitated for habitation, the tax sale deed holder may request approval from the board of supervisors, or the city council if the property is located within a city, to remove, dismantle, or demolish the building, structure, or other improvement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When a parcel is offered at public nuisance tax sale and no bid is received, or if the bid received is less than the total amount due, the county in which the parcel is located, through its county treasurer, shall bid for the parcel a sum equal to the total amount due. Money shall not be paid by the county or city for the purchase, but each of the tax-levying and tax-certifying bodies having any interest in the taxes shall be charged with the total amount due the tax-levying or tax-certifying body as its just share of the purchase price.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The tax sale certificate holder may assign the tax sale certificate obtained pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fabandoned property\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as defined in }}}{{\f5\fs18\hyphpar0\qj{section 446.19A}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fpublic nuisance\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as defined in }}}{{\f5\fs18\hyphpar0\qj{section 657A.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1070, \'a723}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7446.31}}}{{\f5\fs12\hyphpar0\qj{, 446.37}}}{{\f5\fs12\hyphpar0\qj{, 447.9}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{446.20}}}{\*\bkmkstart stylerid1_2E24_2E2_2E2}{\*\bkmkend stylerid1_2E24_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Remedies.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Without limiting the county\u8217\'3fs rights under }}}{{\f5\fs18\hyphpar0\qj{section 445.3}}}{{\f5\fs18\hyphpar0\qj{, once a certificate is issued to a county, a county may collect the total amount due by the alternative remedy provided in }}}{{\f5\fs18\hyphpar0\qj{section 445.3}}}{{\f5\fs18\hyphpar0\qj{ by converting the total amount due to a personal judgment. Entrance of the judgment shall be shown on the county system. Collection of the judgment may then be initiated as provided in }}}{{\f5\fs18\hyphpar0\qj{section 445.4}}}{{\f5\fs18\hyphpar0\qj{. The county attorney shall, upon request of the county treasurer, assist in prosecution of action authorized under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{sections 445.3}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{445.4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The remedies associated with tax sale and personal judgment may be simultaneously pursued until such time as the total amount due has been collected or otherwise discharged. If the total amount due is collected pursuant to a personal judgment, the tax sale shall be canceled by the treasurer. If a tax deed is issued, any personal judgment shall be released and a satisfaction of judgment shall be filed with the clerk of the appropriate district court.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the board or council determines that any property located on a parcel purchased by the county or city pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 446.19}}}{{\f5\fs18\hyphpar0\qj{ requires removal, dismantling, or demolition, the board or council shall, at the same time and in the same manner that the notice of expiration of right of redemption is served, cause to be served on the person in possession of the parcel and also upon the person in whose name the parcel is taxed a separate notice stating that if the parcel is not redeemed within the time period specified in the notice of expiration of right of redemption, the property described in the notice shall be removed, dismantled, or demolished. The notice shall further state that the costs of removal, dismantling, or demolition shall be assessed against the person in whose name the parcel is taxed and a lien for the costs shall be placed against any other parcel taxed in that person\u8217\'3fs name within the county.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Service of the notice shall also be made by mail on any mortgagee having a lien upon the parcel, a vendor of the parcel under a recorded contract of sale, a lessor who has a recorded lease or memorandum of a recorded lease, and any other person who has an interest of record, at the person\u8217\'3fs last known address, if the mortgagee, vendor, lessor, or other person has filed a request for notice, as prescribed in }}}{{\f5\fs18\hyphpar0\qj{section 446.9, subsection 3}}}{{\f5\fs18\hyphpar0\qj{. The notice shall also be served on any city where the parcel is situated. Failure to receive a mailed notice is not a defense to the payment of the total amount due.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ is remedial and shall apply to all delinquent taxes included in a tax sale certificate of purchase issued to a county. Upon assignment of a county-held tax sale certificate, }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not apply to the assignee.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 191, \'a772}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1016, \'a727}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 57, \'a719}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1107, \'a729}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1010, \'a7115}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 126, \'a773}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 25, \'a7143}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{446.21}}}{\*\bkmkstart stylerid1_2E25_2E2_2E2}{\*\bkmkend stylerid1_2E25_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Assignment of certificate to bondholder.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{In tax sales made under }{{\f5\fs18\hyphpar0\qj{section 446.19}}}{, a holder of a special assessment certificate against a parcel, a holder of a bond payable in whole or in part out of a special assessment against a parcel, or a city within which a parcel is situated, which parcel has been sold, is entitled to an assignment of any certificate of tax sale of the parcel, upon tender to the holder or to the county treasurer of the amount to which the holder of the tax sale certificate would be entitled in case of redemption.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a7816; S13, \'a7792-f, 816; C24, 27, 31, \'a76041; C35, \'a76041, 7255-g2; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6041, 7255.3;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7391.68, 446.21; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81}}}{, }{{\f5\fs18\hyphpar0\qj{S81, \'a7446.21}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a71225}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 191, \'a773}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7446.45}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{446.22}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{446.23}}}{\*\bkmkstart stylerid1_2E27_2E2_2E2}{\*\bkmkend stylerid1_2E27_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Resale.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The person purchasing a tax sale certificate against any parcel shall immediately pay to the county treasurer the total amount bid. Upon failure to do so the parcel is again offered as if no such sale had been made. These payments may be made in the funds receivable in payment of taxes.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7502; R60, \'a7768; C73, \'a7878; C97, \'a71426; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7257;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7446.23}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 191, \'a774}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{446.24}}}{\*\bkmkstart stylerid1_2E28_2E2_2E2}{\*\bkmkend stylerid1_2E28_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Record of sales.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The county treasurer or a designee shall attend all tax sales and keep a record in the county system of the sales, describing each parcel on which the total amount due was paid by the purchaser, as they are described in the copy of the notice on file in the treasurer\u8217\'3fs office. The county system shall include a statement of the amount, kind of tax, interest, fees, and costs for each parcel, to whom sold, and the date of sale.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a7772; C73, \'a7882; C97, \'a71427; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7258;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81}}}{, }{{\f5\fs18\hyphpar0\qj{S81, \'a7446.24}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a71226}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 191, \'a775}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{446.25}}}{\*\bkmkstart stylerid1_2E29_2E2_2E2}{\*\bkmkend stylerid1_2E29_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Sale adjourned.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{When all the parcels advertised for sale have been offered and parcels remain unsold for want of bidders, the county treasurer shall adjourn the sale to some day not exceeding two months from adjournment, due notice of which day shall be given at the time of adjournment, and by keeping the notice posted in a conspicuous place in the treasurer\u8217\'3fs office. Further notice is not necessary. On the day fixed by the adjournment, the same proceedings shall occur as in the first instance. Further adjournments shall be made, not exceeding intervals of two months, and the sales continue until the next regular annual sale or until all the parcels are sold.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a7773; C73, \'a7883; C97, \'a71428; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7259;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7446.25}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 191, \'a776}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7420.219}}}{{\f5\fs12\hyphpar0\qj{, 445.10}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{446.26}}}{\*\bkmkstart stylerid1_2E3_30_2E2_2E2}{\*\bkmkend stylerid1_2E3_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Responsibility of treasurer to attend tax sale.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A county treasurer failing to attend a tax sale in person, by a deputy treasurer, or by another designated employee is guilty of a simple misdemeanor.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a7774; C73, \'a7884; C97, \'a71429; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7260;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81}}}{, }{{\f5\fs18\hyphpar0\qj{S81, \'a7446.26}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a71227}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 191, \'a777}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{446.27}}}{\*\bkmkstart stylerid1_2E31_2E2_2E2}{\*\bkmkend stylerid1_2E31_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Liability of treasurer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the county treasurer, deputy treasurer, or other designated employee sells or assists in selling any parcel, knowing it is not subject to taxation or that the amount for which it is sold has been paid, or knowingly and willfully sells or assists in selling a parcel to defraud the owner, or knowingly and willfully executes a deed for such a parcel sold, the treasurer, deputy treasurer, or designated employee is guilty of a serious misdemeanor and liable to pay the injured party all damages sustained as a result of the illegal sale.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the treasurer, deputy treasurer, or designated person is directly or indirectly concerned in the purchase of a parcel sold at tax sale, the treasurer and the treasurer\u8217\'3fs sureties are liable on the treasurer\u8217\'3fs official bond for all damages sustained by the owner of the parcel. In addition, the treasurer, deputy treasurer, or designated person, as the case may be, is guilty of a fraudulent practice.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Sales made in violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ are void.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a7775; C73, \'a7885; C97, \'a71430; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7261;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81}}}{, }{{\f5\fs18\hyphpar0\qj{S81, \'a7446.27}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a71228}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 191, \'a778}}}{; }{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1016, \'a728}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Fraudulent practices, see }{{\f5\fs12\hyphpar0\qj{\'a7714.8 }}}{{\f5\fs12\hyphpar0\qj{\u8211\'3f}}}{{\f5\fs12\hyphpar0\qj{ 714.14}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{446.28}}}{\*\bkmkstart stylerid1_2E32_2E2_2E2}{\*\bkmkend stylerid1_2E32_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Subsequent sale.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If for good cause, a parcel cannot be advertised and offered for sale on the third Monday of June or on another date in June designated by the treasurer, the county treasurer shall make the sale on the third Monday of the next succeeding month in which the required notice can be given.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a7776; C73, \'a7886; C97, \'a71431; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7262;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7446.28}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 191, \'a779}}}{; }{{\f5\fs18\hyphpar0\qj{99 Acts, ch 4, \'a73, 4}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7445.10}}}{{\f5\fs12\hyphpar0\qj{, 447.1}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{446.29}}}{\*\bkmkstart stylerid1_2E33_2E2_2E2}{\*\bkmkend stylerid1_2E33_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Certificate of purchase.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The county treasurer shall prepare, sign, and deliver to the purchaser of any parcel or part of a parcel sold a certificate of purchase, describing the parcel or part of the parcel as shown in the county system identifying the parcel or part of the parcel sold, the total amount due for each parcel as described, and that payment has been made. Not more than one parcel shall be entered upon each certificate of purchase. The certificate fee is the amount specified in }{{\f5\fs18\hyphpar0\qj{section 331.552, subsection 23}}}{. The delinquent tax lien transfers with the tax sale certificate, whether held by the county or purchased by an individual through assignment or direct purchase at the tax sale. The delinquent tax lien expires when the tax sale certificate expires.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7503; R60, \'a7777; C73, \'a7887; C97, \'a71432; S13, \'a71432; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7263;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7446.29}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1104, \'a725}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1203, \'a72}}}{; }{{\f5\fs18\hyphpar0\qj{91 Acts, ch 191, \'a780}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{446.30}}}{\*\bkmkstart stylerid1_2E34_2E2_2E2}{\*\bkmkend stylerid1_2E34_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Loss of certificate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If a certificate of purchase is lost or destroyed, the owner of record, may, by filing an affidavit of the loss or destruction with the county treasurer, receive a duplicate of the certificate, which shall take the place of the original certificate and have the same force and effect in law and be subject to the same laws. The cost of a duplicate certificate of purchase is the same as the cost of the original certificate as provided in }{{\f5\fs18\hyphpar0\qj{section 331.552, subsection 23}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71432; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7264;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7446.30}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 191, \'a781}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{446.31}}}{\*\bkmkstart stylerid1_2E35_2E2_2E2}{\*\bkmkend stylerid1_2E35_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Assignment \u8212\'3f presumption from deed recitals.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The certificate of purchase is assignable by endorsement and entry in the county system in the office of county treasurer of the county from which the certificate was issued, and when the assignment is so entered and the assignment transaction fee paid, it shall vest in the assignee or legal representatives of the assignee all the right and title of the assignor. The statement in the treasurer\u8217\'3fs deed of the fact of the assignment is presumptive evidence of that fact. For each assignment transaction, the treasurer shall charge the assignee an assignment transaction fee of one hundred dollars, or ten dollars in the case of an assignment by an estate, to be deposited in the county general fund. The assignment transaction fee shall not be added to the amount necessary to redeem.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When the county acquires a certificate of purchase, the county may assign the certificate for the total amount due as of the date of assignment or compromise the total amount due and assign the certificate. An assignment or a compromise and assignment shall be by written agreement. A copy of the agreement shall be filed with the treasurer. For each assignment transaction, the treasurer shall collect from the assignee an assignment transaction fee of ten dollars to be deposited in the county general fund. The assignment transaction fee shall not be added to the amount necessary to redeem. All money received from the assignment of county-held certificates of purchase shall be apportioned to the tax-levying and certifying bodies in proportion to their interests in the taxes for which the parcel was sold with all interest, fees, and costs deposited in the county general fund. After assignment of a certificate of purchase which is held by the county, }}}{{\f5\fs18\hyphpar0\qj{section 446.37}}}{{\f5\fs18\hyphpar0\qj{ applies. In that instance, the date of cancellation shall be three years from the date the assignment is recorded by the treasurer in the county system. However, in the case of a tax sale certificate issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 446.19B}}}{{\f5\fs18\hyphpar0\qj{ and assigned by the county, the date of cancellation shall be one year from the date the assignment is recorded by the treasurer in the county system. When the assignment is entered and the assignment transaction fee is paid, all of the rights and title of the assignor shall vest in the assignee or the legal representative of the assignee. The statement in the treasurer\u8217\'3fs deed of the fact of the assignment is presumptive evidence of that fact.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A certificate of purchase for a parcel shall not be assigned to a person, other than a municipality, who is entitled to redeem that parcel.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a7778; C73, \'a7888; C97, \'a71433; S13, \'a71433; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7265;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7446.31}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 191, \'a782}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1016, \'a729}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 73, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 57, \'a720}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 121, \'a720}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1070, \'a724}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1041, \'a7127}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.361}}}{{\f5\fs12\hyphpar0\qj{, 446.45}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{446.32}}}{\*\bkmkstart stylerid1_2E36_2E2_2E2}{\*\bkmkend stylerid1_2E36_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Payment of subsequent taxes by purchaser.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The county treasurer shall provide to the purchaser of a parcel sold at tax sale a receipt for the total amount paid by the purchaser after the date of purchase for a subsequent year. Taxes for a subsequent year may be paid by the purchaser beginning one month and fourteen days following the date from which an installment becomes delinquent as provided in }{{\f5\fs18\hyphpar0\qj{section 445.37}}}{. Notwithstanding any provision to the contrary, a subsequent payment must be received and recorded by the treasurer in the county system or entered through the county treasurer\u8217\'3fs authorized internet site no later than 5:00 p.m. on the last business day of the month for interest for that month to accrue and be added to the amount due under }{{\f5\fs18\hyphpar0\qj{section 447.1}}}{. However, the treasurer may establish a deadline for receipt of subsequent payments that is other than 5:00 p.m. on the last business day of the month to allow for timely processing of the subsequent payments. Late interest shall be calculated through the date that the subsequent payment is recorded by the treasurer in the county system or entered through the county treasurer\u8217\'3fs authorized internet site. In no instance shall the date of postmark of a subsequent payment be used by a treasurer either to calculate interest or to determine whether interest shall accrue on the subsequent payment.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, \'a7889; C97, \'a71434; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7266;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81}}}{, }{{\f5\fs18\hyphpar0\qj{S81, \'a7446.32}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a71229}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 191, \'a783}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 73, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1070, \'a725, 31}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1138, \'a7106}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 92, \'a74}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7420.246}}}{{\f5\fs12\hyphpar0\qj{, 446.45}}}{{\f5\fs12\hyphpar0\qj{, 447.1}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{446.33}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{446.34}}}{\*\bkmkstart stylerid1_2E38_2E2_2E2}{\*\bkmkend stylerid1_2E38_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{School, agricultural college, or university land.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{When any school, agricultural college, or university land sold on credit is sold for taxes, the purchaser shall acquire only the interest of the original purchaser therein, and no sale of any such lands for taxes shall prejudice the rights of the state, agricultural college, or university. In all cases where the real estate is mortgaged or otherwise encumbered to the school, agricultural college, or university fund, the interest of the person who holds the fee shall alone be sold for taxes, and in no case shall the lien or interest of the state be affected by any sale thereof. The foregoing provision shall include all lands exempt from taxation by law, and any legal or equitable estate therein held, possessed, or claimed for any public purpose, and no assessment or taxation of such lands, nor the payment of any such tax by any person, or the sale and conveyance for taxes of any such lands, shall in any manner affect the right or title of the public therein, or confer upon the purchaser or person who pays such taxes any right or interest in such land.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a7810, 811; C73, \'a7900; C97, \'a71435; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7268;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7446.34}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{446.35}}}{\*\bkmkstart stylerid1_2E39_2E2_2E2}{\*\bkmkend stylerid1_2E39_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Assessment to wrong person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A sale of a parcel through tax sale is not invalid if taxed in any other name than that of the rightful owner, if it is in other respects sufficiently described.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a7787; C73, \'a7904; C97, \'a71450; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7269;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7446.35}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 191, \'a784}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7420.245}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{446.36}}}{\*\bkmkstart stylerid1_2E4_30_2E2_2E2}{\*\bkmkend stylerid1_2E4_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Certified copies of records as evidence.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The information in the county system of the office of the county treasurer, or a copy properly certified, is sufficient evidence to prove the sale of a parcel at tax sale, the redemption of the parcel, or the payment of taxes on it.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a7788; C73, \'a7905; C97, \'a71451; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7270;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81}}}{, }{{\f5\fs18\hyphpar0\qj{S81, \'a7446.36}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a71230}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 191, \'a785}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7420.245}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Similar provision, }{{\f5\fs12\hyphpar0\qj{\'a7622.43}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{446.37}}}{\*\bkmkstart stylerid1_2E41_2E2_2E2}{\*\bkmkend stylerid1_2E41_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Cancellation of sale.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{After three years have elapsed from the time of any tax sale, or after one year has elapsed from the time of any tax sale under }{{\f5\fs18\hyphpar0\qj{section 446.19B}}}{, and the holder of a certificate has not filed an affidavit of service of notice of expiration of right of redemption under }{{\f5\fs18\hyphpar0\qj{section 447.12}}}{, the county treasurer shall cancel the sale from the county system. However, if the filing of affidavit of service is stayed by operation of law, the time period for the filing of the affidavit shall not expire until the later of six months after the stay has been lifted or three years from the time of the tax sale, and in the case of a tax sale under }{{\f5\fs18\hyphpar0\qj{section 446.19B}}}{, the time period for the filing of the affidavit shall not expire until the later of six months after the stay has been lifted or one year from the time of the tax sale. }{{\f5\fs18\hyphpar0\qj{This section}}}{ does not apply to certificates of purchase at tax sale which are held by a county.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a71452; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7271;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81}}}{, }{{\f5\fs18\hyphpar0\qj{S81, \'a7446.37}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a71231}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 191, \'a786}}}{; }{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 34, \'a718, 26}}}{; }{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1070, \'a726}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.552}}}{{\f5\fs12\hyphpar0\qj{, 420.247}}}{{\f5\fs12\hyphpar0\qj{, 446.31}}}{{\f5\fs12\hyphpar0\qj{, 446.45}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{446.38}}}{\*\bkmkstart stylerid1_2E42_2E2_2E2}{\*\bkmkend stylerid1_2E42_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Suspended taxes of supplementary assistance recipients.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2007/CH0126.pdf" }{\fldrslt \cf5 \f5 \fs18{{2007 Acts, ch 126, \'a7115}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{446.39}}}{\*\bkmkstart stylerid1_2E43_2E2_2E2}{\*\bkmkend stylerid1_2E43_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Iowa finance authority statement.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2007/CH0054.pdf" }{\fldrslt \cf5 \f5 \fs18{{2007 Acts, ch 54, \'a745}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{446.40 through 446.44}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{446.45}}}{\*\bkmkstart stylerid1_2E45_2E2_2E2}{\*\bkmkend stylerid1_2E45_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Applicable law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Sections 446.21}}}{, }{{\f5\fs18\hyphpar0\qj{446.31}}}{, }{{\f5\fs18\hyphpar0\qj{446.32}}}{, and }{{\f5\fs18\hyphpar0\qj{446.37}}}{, as amended by 1991 Iowa Acts, ch. 191, \'a773, 82, 83, and 86, only apply if associated with a tax sale that occurred on or after April 1, 1992. For tax sales occurring prior to April 1, 1992, the provisions of }{{\f5\fs18\hyphpar0\qj{sections 446.21}}}{, }{{\f5\fs18\hyphpar0\qj{446.31}}}{, }{{\f5\fs18\hyphpar0\qj{446.32}}}{, and }{{\f5\fs18\hyphpar0\qj{446.37}}}{ in effect on the date of the tax sale apply.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1016, \'a731}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1026, \'a7143}}}\par}}