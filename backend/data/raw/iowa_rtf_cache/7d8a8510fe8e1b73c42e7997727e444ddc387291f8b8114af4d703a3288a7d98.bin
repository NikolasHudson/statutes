\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F521B}{\*\bkmkend codeChapter_5F521B}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 521B}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{CREDIT FOR REINSURANCE}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a787.4}}}{{\f5\fs12\qc{, 296.7}}}{{\f5\fs12\qc{, 331.301}}}{{\f5\fs12\qc{, 364.4}}}{{\f5\fs12\qc{, 505.28}}}{{\f5\fs12\qc{, 505.29}}}{{\f5\fs12\qc{, 518.17}}}{{\f5\fs12\qc{, 518A.44}}}{{\f5\fs12\qc{, 521J.14}}}{{\f5\fs12\qc{, 669.14}}}{{\f5\fs12\qc{, 670.7}}}\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{521B.1 through 521B.5}}}{Repealed by }{{\f5\fs18\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2013/CH0039.pdf" }{\fldrslt \f5 \fs18{{2013 Acts, ch 39, \'a77, 8, 11}}}}}}{{\f5\fs18\qj{2013 Acts, ch 39, \'a77, 8, 11}}}{.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{521B.101}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Purpose }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ legislative intent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The purpose of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ is to protect the interests of insureds, claimants, ceding insurers, assuming insurers, and the public generally.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The general assembly declares its intent to ensure adequate regulation of insurers and reinsurers and adequate protection for those to whom insurers and reinsurers owe obligations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The general assembly declares that the matters contained in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ are fundamental to the business of insurance in accordance with }}}{{\f5\fs18\hyphpar0\qj{15 U.S.C. \'a71011 }}}{{\f5\fs18\hyphpar0\qj{\u8211\'3f}}}{{\f5\fs18\hyphpar0\qj{ 1012}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2013 Acts, ch 39, \'a71, 11}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{521B.101A}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{For purposes of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, unless the context otherwise requires:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCommissioner\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the commissioner of insurance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fNAIC\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the national association of insurance commissioners.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2020 Acts, ch 1008, \'a71, 27}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section applies to all cessions under reinsurance agreements that have an inception, anniversary, or renewal date on or after July 1, 2020; }{{\f5\fs12\hyphpar0\qj{2020 Acts, ch 1008, \'a727}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{521B.102}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Credit allowed certain domestic ceding insurers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Credit for reinsurance shall be allowed a domestic ceding insurer as either an asset or a reduction from liability on account of reinsurance ceded only when the reinsurer meets the requirements of }{{\f5\fs18\hyphpar0\qj{subsection 1, 2, 3, 4, 5, 6, or 7}}}{. The commissioner may adopt rules pursuant to }{{\f5\fs18\hyphpar0\qj{section 521B.105}}}{ specifying additional requirements related to the valuation of assets or reserve credits, the amount and forms of security supporting reinsurance arrangements described in }{{\f5\fs18\hyphpar0\qj{section 521B.105}}}{, and the circumstances pursuant to which credit shall be reduced or eliminated. Credit shall be allowed under }{{\f5\fs18\hyphpar0\qj{subsection 1, 2, or 3}}}{ only respecting cessions of those kinds or classes of business which the assuming insurer is licensed or otherwise permitted to write or assume in the assuming insurer\u8217\'3fs state of domicile or, in the case of a United States branch of an alien assuming insurer, in the state through which the alien assuming insurer is entered and licensed to transact insurance or reinsurance. Credit shall be allowed under }{{\f5\fs18\hyphpar0\qj{subsection 3 or 4}}}{ only if the applicable requirements of }{{\f5\fs18\hyphpar0\qj{subsection 8}}}{ have been satisfied.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Credit shall be allowed when the reinsurance is ceded to an assuming insurer that is licensed to transact insurance or reinsurance in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Credit shall be allowed when the reinsurance is ceded to an assuming insurer that is accredited by the commissioner as a reinsurer in this state. In order to be eligible for accreditation, an assuming insurer must do all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{File with the commissioner evidence of the assuming insurer\u8217\'3fs submission to this state\u8217\'3fs jurisdiction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Submit to this state\u8217\'3fs authority to examine the assuming insurer\u8217\'3fs books and records.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Be licensed to transact insurance or reinsurance in at least one state, or in the case of a United States branch of an alien assuming insurer, be entered through and licensed to transact insurance or reinsurance in at least one state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{File annually with the commissioner a copy of the assuming insurer\u8217\'3fs annual statement filed with the insurance department of the assuming insurer\u8217\'3fs state of domicile and a copy of the assuming insurer\u8217\'3fs most recent audited financial statement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Demonstrate to the satisfaction of the commissioner that the assuming insurer has adequate financial capacity to meet the assuming insurer\u8217\'3fs reinsurance obligations and is otherwise qualified to assume reinsurance from domestic insurers. An assuming insurer is deemed to meet this requirement as of the time of the assuming insurer\u8217\'3fs application if the assuming insurer maintains a surplus as regards policyholders in an amount of not less than twenty million dollars and the assuming insurer\u8217\'3fs accreditation has not been denied by the commissioner within ninety calendar days after submission of the assuming insurer\u8217\'3fs application.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Credit shall be allowed when the reinsurance is ceded to an assuming insurer that is domiciled in, or in the case of a United States branch of an alien assuming insurer is entered through, a state that employs standards regarding credit for reinsurance that are substantially similar to those applicable under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and the assuming insurer or United States branch of an alien assuming insurer does all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Maintains a surplus as regards policyholders in an amount of not less than twenty million dollars.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Submits to the authority of this state to examine the assuming insurer\u8217\'3fs books and records.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The requirement of paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (1), does not apply to reinsurance ceded and assumed pursuant to pooling arrangements among insurers in the same holding company system.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Credit shall be allowed when the reinsurance is ceded to an assuming insurer that maintains a trust fund in a qualified United States financial institution, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 521B.104, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, for payment of the valid claims of the assuming insurer\u8217\'3fs United States ceding insurers, their assigns, and successors in interest. To enable the commissioner to determine the sufficiency of the trust fund, the assuming insurer shall report annually to the commissioner information substantially the same as that required to be reported by licensed insurers on the NAIC annual statement form. The assuming insurer shall submit to examination of the assuming insurer\u8217\'3fs books and records by the commissioner and bear the expense of examination.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Credit for reinsurance shall not be granted under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ unless all of the following conditions are satisfied:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The form of the trust and any amendments to the trust have been approved by either of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commissioner of the state where the trust is domiciled.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commissioner of another state who, pursuant to the terms of the trust instrument, has accepted principal regulatory oversight of the trust.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The form of the trust and any trust amendments are filed with the commissioner of every state in which the ceding insurer beneficiaries of the trust are domiciled. The trust instrument shall provide that contested claims are valid and enforceable upon the final order of any court of competent jurisdiction in the United States. The trust shall vest legal title to the trust\u8217\'3fs assets in its trustees for the benefit of the assuming insurer\u8217\'3fs United States ceding insurers, their assigns, and successors in interest. The trust and the assuming insurer shall be subject to examination as determined by the commissioner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The trust remains in effect for as long as the assuming insurer has outstanding obligations due under the reinsurance agreements subject to the trust. No later than February 28 of each year, the trustee of the trust shall report to the commissioner in writing the balance of the trust and list the trust\u8217\'3fs investments at the preceding year-end, and shall certify the date of termination of the trust, if so planned, or certify that the trust will not expire prior to the following December 31.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The following requirements apply to the following categories of assuming insurer:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The trust fund for a single assuming insurer shall consist of funds in trust in an amount not less than the assuming insurer\u8217\'3fs liabilities attributable to reinsurance ceded by United States ceding insurers, and in addition, the assuming insurer shall maintain a trusteed surplus of not less than twenty million dollars, except as provided in subparagraph (2).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At any time after an assuming insurer has permanently discontinued underwriting new business secured by the trust for at least three full years, the commissioner with principal regulatory oversight of the trust may authorize a reduction in the required trusteed surplus, but only after a finding, based on an assessment of the risk, that the new required trusteed surplus level is adequate for the protection of United States ceding insurers, policyholders, and claimants in light of reasonably foreseeable adverse loss development. The risk assessment may involve an actuarial review, including an independent analysis of reserves and cash flows, and shall consider all material risk factors, including, when applicable, the lines of business involved, the stability of the incurred loss estimates, and the effect of the surplus requirements on the assuming insurer\u8217\'3fs liquidity or solvency. The minimum required trusteed surplus shall not be reduced to an amount less than thirty percent of the assuming insurer\u8217\'3fs liabilities attributable to reinsurance ceded by United States ceding insurers covered by the trust.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In the case of a group including incorporated and individual unincorporated underwriters, all of the following requirements are met:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For reinsurance ceded under reinsurance agreements with an inception, amendment, or renewal date on or after January 1, 1993, the trust shall consist of a trusteed account in an amount not less than the respective underwriters\u8217\'3f several liabilities attributable to business ceded by United States domiciled ceding insurers to any underwriter of the group.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For reinsurance ceded under reinsurance agreements with an inception date on or before December 31, 1992, and not amended or renewed after that date, notwithstanding the other provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, the trust shall consist of a trusteed account in an amount not less than the respective underwriters\u8217\'3f several insurance and reinsurance liabilities attributable to business written in the United States.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to the trusts described in subparagraph divisions (a) and (b), the group shall maintain in trust a trusteed surplus of which one hundred million dollars shall be held jointly for the benefit of the United States domiciled ceding insurers of any member of the group for all years of account.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The incorporated members of the group shall not be engaged in any business other than underwriting as a member of the group and shall be subject to the same level of regulation and solvency control by the group\u8217\'3fs domiciliary regulator as are the unincorporated members of the group.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(e)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Within ninety calendar days after its financial statements are due to be filed with the group\u8217\'3fs domiciliary regulator, the group shall provide to the commissioner an annual certification by the group\u8217\'3fs domiciliary regulator of the solvency of each underwriter member, or if a certification is unavailable, financial statements, prepared by independent public accountants, of each underwriter member of the group.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In the case of a group of incorporated underwriters under common administration, the group shall meet all of the following requirements:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Have continuously transacted an insurance business outside the United States for at least three years immediately prior to making application for accreditation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Maintain aggregate policyholders\u8217\'3f surplus of at least ten billion dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Maintain a trust fund in an amount not less than the group\u8217\'3fs several liabilities attributable to business ceded by United States domiciled ceding insurers to any member of the group pursuant to reinsurance contracts issued in the name of the group.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition, maintain a joint trusteed surplus of which one hundred million dollars shall be held jointly for the benefit of United States domiciled ceding insurers of any member of the group as additional security for these liabilities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(e)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Within ninety calendar days after the group\u8217\'3fs financial statements are due to be filed with the group\u8217\'3fs domiciliary regulator, make available to the commissioner an annual certification of each underwriter member\u8217\'3fs solvency by the member\u8217\'3fs domiciliary regulator and financial statements of each underwriter member of the group prepared by the group\u8217\'3fs independent public accountant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Credit shall be allowed when the reinsurance is ceded to an assuming insurer that has been certified by the commissioner as a reinsurer in this state and the assuming reinsurer secures its obligations in accordance with the following requirements:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In order to be eligible for certification, the assuming insurer shall meet all of the following requirements:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The assuming insurer shall be domiciled and licensed to transact insurance or reinsurance in a qualified jurisdiction, as determined by the commissioner pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The assuming insurer shall maintain minimum capital and surplus, or its equivalent, in an amount to be determined by the commissioner pursuant to rule.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The assuming insurer shall maintain financial strength ratings from two or more rating agencies deemed acceptable by the commissioner pursuant to rule.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The assuming insurer shall agree to submit to the jurisdiction of this state, to appoint the commissioner as the assuming insurer\u8217\'3fs agent for service of process in this state, and to provide security for one hundred percent of the assuming insurer\u8217\'3fs liabilities attributable to reinsurance ceded by United States ceding insurers, if the assuming insurer resists enforcement of a final United States judgment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The assuming insurer shall agree to meet applicable information filing requirements as determined by the commissioner, both with respect to an initial application for certification and on an ongoing basis.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The assuming insurer shall satisfy any other requirements for certification deemed relevant by the commissioner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An association including incorporated and individual unincorporated underwriters may be a certified reinsurer. In order to be eligible for certification, the association shall satisfy the requirements of paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and in addition satisfy all of the following requirements:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The association shall satisfy the association\u8217\'3fs minimum capital and surplus requirements through the capital and surplus equivalents, net of liabilities, of the association and its members, which shall include a joint central fund that may be applied to any unsatisfied obligation of the association or any of its members, in an amount determined by the commissioner to provide adequate protection.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The incorporated members of the association shall not be engaged in any business other than underwriting as a member of the association and shall be subject to the same level of regulation and solvency control by the association\u8217\'3fs domiciliary regulator as are the unincorporated members of the association.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Within ninety calendar days after the association\u8217\'3fs financial statements are due to be filed with the association\u8217\'3fs domiciliary regulator, the association shall provide to the commissioner an annual certification by the association\u8217\'3fs domiciliary regulator of the solvency of each underwriter member, or if a certification is unavailable, financial statements, prepared by an independent public accountant, of each underwriter member of the association.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commissioner shall create and publish a list of qualified jurisdictions under which an assuming insurer licensed and domiciled in such jurisdiction is eligible to be considered for certification by the commissioner as a certified reinsurer.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In order to determine whether the domiciliary jurisdiction of a non-United States assuming insurer is eligible to be recognized as a qualified jurisdiction, the commissioner shall evaluate the appropriateness and effectiveness of the reinsurance supervisory system of the jurisdiction, both initially and on an ongoing basis, and consider the rights, benefits, and the extent of reciprocal recognition afforded by the non-United States jurisdiction to reinsurers licensed and domiciled in the United States. In order to be recognized as a qualified jurisdiction, a jurisdiction must agree to share information and to cooperate with the commissioner with respect to all certified reinsurers domiciled within that jurisdiction. A jurisdiction shall not be recognized as a qualified jurisdiction if the commissioner has determined that the jurisdiction does not adequately and promptly enforce final United States judgments and arbitration awards. Additional factors may be considered in the discretion of the commissioner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A list of qualified jurisdictions shall be published through the NAIC committee process. The commissioner shall consider this list in determining qualified jurisdictions. If the commissioner recognizes a jurisdiction as qualified that does not appear on the NAIC list of qualified jurisdictions, the commissioner shall provide thoroughly documented justification for the recognition in accordance with criteria as specified in rules adopted by the commissioner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{United States jurisdictions that meet the requirements for accreditation under the NAIC financial standards and accreditation program shall be recognized as qualified jurisdictions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a certified reinsurer\u8217\'3fs domiciliary jurisdiction ceases to be a qualified jurisdiction, the commissioner may, in the commissioner\u8217\'3fs discretion, suspend the reinsurer\u8217\'3fs certification indefinitely, in lieu of revocation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commissioner shall assign a rating to each certified reinsurer, giving due consideration to the financial strength ratings that have been assigned by rating agencies deemed acceptable to the commissioner pursuant to rule. The commissioner shall publish a list of all certified reinsurers and their ratings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A certified reinsurer shall secure obligations assumed from United States ceding insurers under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ at a level consistent with the certified reinsurer\u8217\'3fs rating, as specified in rules adopted by the commissioner.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In order for a domestic ceding insurer to qualify for full financial statement credit for reinsurance ceded to a certified reinsurer, the certified reinsurer shall maintain security in a form acceptable to the commissioner and consistent with the provisions of }}}{{\f5\fs18\hyphpar0\qj{section 521B.103}}}{{\f5\fs18\hyphpar0\qj{, or in a multibeneficiary trust in accordance with }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{, except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a certified reinsurer maintains a trust to fully secure its obligations subject to }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{, and chooses to secure its obligations incurred as a certified reinsurer in the form of a multibeneficiary trust, the certified reinsurer shall maintain separate trust accounts for its obligations incurred under reinsurance agreements issued or renewed as a certified reinsurer with reduced security as permitted by }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ or comparable laws of other United States jurisdictions and for its obligations subject to }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{. It shall be a condition to the grant of certification under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ that the certified reinsurer shall bind itself, by the language of the trust and by agreement with the commissioner which has principal regulatory oversight of each such trust account, to fund, upon termination of any such trust account, any deficiency of any other trust account out of the remaining surplus of the terminated trust account.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The minimum trusteed surplus requirements provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{ are not applicable with respect to a multibeneficiary trust maintained by a certified reinsurer for the purpose of securing obligations under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, except that such a multibeneficiary trust shall maintain a minimum trusteed surplus of ten million dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{With respect to obligations incurred by a certified reinsurer under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, if the security is insufficient, the commissioner shall reduce the allowable credit by an amount proportionate to the deficiency, and the commissioner has the discretion to impose further reductions in allowable credit upon finding that there is a material risk that the certified reinsurer\u8217\'3fs obligations will not be paid in full when due.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, a certified reinsurer whose certification has been terminated for any reason shall be treated as a certified reinsurer required to secure all of its obligations.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, the term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fterminated\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes revocation, suspension, voluntary surrender, and inactive status.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the commissioner continues to assign a higher rating to a certified reinsurer as permitted by other provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, this requirement does not apply to a certified reinsurer in inactive status or to a reinsurer whose certification has been suspended.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If an assuming insurer applying for certification as a reinsurer in this state has been certified as a reinsurer in another jurisdiction accredited by the NAIC, the commissioner has the discretion to defer to that jurisdiction\u8217\'3fs certification, and has the discretion to defer to the rating assigned by that jurisdiction, and the assuming insurer shall be considered to be a certified reinsurer in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A certified reinsurer that ceases to assume new business in this state may request to maintain the reinsurer\u8217\'3fs certification in inactive status in order to qualify for a reduction in the amount of security required for the reinsurer\u8217\'3fs in-force business. An inactive certified reinsurer shall continue to comply with all applicable requirements of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, and the commissioner shall assign the reinsurer a rating that takes into account, if relevant, the reasons why the reinsurer is not assuming new business.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Credit shall be allowed when the reinsurance is ceded to an assuming insurer that meets all of the following conditions:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The assuming insurer must have its head office located in or be domiciled in, as applicable, and be licensed in, a reciprocal jurisdiction. For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, a }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3freciprocal jurisdiction\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ is a jurisdiction that meets at least one of the following requirements:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A non-United States jurisdiction that is subject to an in-force covered agreement with the United States, each within its legal authority, or, in the case of a covered agreement between the United States and the European Union, is a member state of the European Union. For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, a }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fcovered agreement\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ is an agreement entered into pursuant to Tit. V, \'a7502(a)(3), }}}{{\f5\fs18\hyphpar0\qj{31 U.S.C. \'a7313-314}}}{{\f5\fs18\hyphpar0\qj{, of the }}}{{\f5\fs18\hyphpar0\qj{Dodd-Frank Wall Street Reform and Consumer Protection Act}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{Pub. L. No. 111-203}}}{{\f5\fs18\hyphpar0\qj{, that is currently in effect or in a period of provisional application and that addresses the elimination, under specified conditions, of collateral requirements as a condition for entering into any reinsurance agreement with a ceding insurer domiciled in this state or for allowing the ceding insurer to recognize credit for reinsurance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A United States jurisdiction that meets the requirements for accreditation under the NAIC financial regulation standards and accreditation program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A qualified jurisdiction, as determined by the commissioner pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, which is not otherwise described in this paragraph or paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and that meets certain additional requirements consistent with the terms and conditions of an in-force covered agreement as specified in rules adopted by the commissioner.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The assuming insurer must have and maintain, on an ongoing basis, minimum capital and surplus, or its equivalent, calculated according to the methodology of the assuming insurer\u8217\'3fs domiciliary jurisdiction, in an amount specified in rules adopted by the commissioner. If the assuming insurer is an association, including incorporated and individual unincorporated underwriters, the assuming insurer must have and maintain, on an ongoing basis, minimum capital and surplus equivalents, net of liabilities, calculated according to the methodology applicable in the assuming insurer\u8217\'3fs domiciliary jurisdiction, and a central fund containing a balance in an amount as specified in rules adopted by the commissioner.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The assuming insurer must have and maintain, on an ongoing basis, a minimum solvency or capital ratio, as applicable, as specified in rules adopted by the commissioner. If the assuming insurer is an association, including incorporated and individual unincorporated underwriters, the assuming insurer must have and maintain, on an ongoing basis, a minimum solvency or capital ratio in the reciprocal jurisdiction where the assuming insurer has its head office or is domiciled, as applicable, and where the assuming insurer is also licensed.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The assuming insurer must agree and shall provide to the commissioner, in the form and manner specified by the commissioner, adequate assurance of all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prompt written notice and explanation if the assuming insurer falls below the minimum requirements set forth in subparagraph (2) or (3) of this paragraph, or if any regulatory action is taken against the assuming insurer for serious noncompliance with any applicable law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Written consent that the assuming insurer shall submit to the jurisdiction of the courts of this state and to the appointment of the commissioner as agent for service of process. The commissioner may also require that consent for service of process be included in each reinsurance agreement entered into by the assuming insurer. This subparagraph division shall not limit or alter the capacity of the parties to a reinsurance agreement to agree to alternative dispute resolution, except to the extent such alternative dispute resolution is unenforceable under applicable insolvency or delinquency laws.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Written agreement that the assuming insurer shall pay all final judgments, wherever enforcement is sought, obtained against the assuming insurer by a ceding insurer, or the ceding insurer\u8217\'3fs legal successor, that have been declared enforceable in the jurisdiction in which the final judgment is obtained.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each reinsurance agreement must include a provision requiring the assuming insurer to provide security in an amount equal to one hundred percent of the assuming insurer\u8217\'3fs liabilities attributable to reinsurance ceded pursuant to that reinsurance agreement if the assuming insurer resists enforcement of a final judgment that is enforceable under the law of the jurisdiction in which the final judgment is obtained or under an enforceable arbitration award, whether obtained by the ceding insurer or by the ceding insurer\u8217\'3fs legal successor on behalf of the ceding insurer\u8217\'3fs resolution estate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(e)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Written confirmation that the assuming insurer is not presently participating in any solvent scheme of arrangement which involves this state\u8217\'3fs ceding insurers, and written agreement that the assuming insurer shall notify the ceding insurer and the commissioner and shall provide security in an amount equal to one hundred percent of the assuming insurer\u8217\'3fs liabilities to the ceding insurer, should the assuming insurer enter into such a solvent scheme of arrangement. Such security shall be in a form consistent with the provisions of }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{section 521B.103}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The assuming insurer or the assuming insurer\u8217\'3fs legal successor shall provide to the commissioner, on behalf of itself and any legal predecessors, any documentation required pursuant to rules adopted by the commissioner.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Pursuant to rules adopted by the commissioner, the assuming insurer shall maintain prompt payment of claims under all reinsurance agreements.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(7)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The assuming insurer\u8217\'3fs supervisory authority shall annually confirm to the commissioner that as of the preceding December 31, or as of the annual date otherwise statutorily reported to the reciprocal jurisdiction, the assuming insurer complies with the requirements set forth in subparagraphs (2) and (3) of this paragraph.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(8)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An assuming insurer shall not be precluded from voluntarily providing any information to the commissioner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commissioner shall timely create and publish a list of reciprocal jurisdictions.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commissioner\u8217\'3fs list shall include any reciprocal jurisdiction as defined under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (1), subparagraph divisions (a) and (b), and the commissioner shall consider any other reciprocal jurisdiction included on the list of reciprocal jurisdictions published through the NAIC committee process. Pursuant to criteria established by rules adopted by the commissioner, the commissioner may approve a jurisdiction that does not appear on the NAIC list of reciprocal jurisdictions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commissioner may remove a jurisdiction from the list of reciprocal jurisdictions upon a determination that the jurisdiction no longer meets the requirements of a reciprocal jurisdiction, pursuant to a process established by rules adopted by the commissioner, except that the commissioner shall not remove a reciprocal jurisdiction as defined under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (1), subparagraph divisions (a) and (b). Upon removal of a reciprocal jurisdiction from the list of reciprocal jurisdictions, credit for reinsurance ceded to an assuming insurer which has its home office in or is domiciled in that reciprocal jurisdiction shall be allowed if otherwise allowed pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commissioner shall timely create and publish a list of assuming insurers that have satisfied the conditions in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ and to which cessions shall be granted credit pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. The commissioner may add an assuming insurer to the list if a NAIC accredited jurisdiction has added the assuming insurer to the NAIC accredited jurisdiction\u8217\'3fs list of assuming insurers or if, upon initial eligibility, the assuming insurer submits the information required under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (4), to the commissioner and complies with any additional requirements pursuant to rules adopted by the commissioner, except to the extent that any of those rules conflict with an applicable covered agreement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the commissioner determines that an assuming insurer no longer meets one or more of the requirements under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, the commissioner may revoke or suspend the eligibility of the assuming insurer for recognition under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ in accordance with procedures established by rules adopted by the commissioner.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{While an assuming insurer\u8217\'3fs eligibility is suspended, any reinsurance agreement issued, amended, or renewed after the effective date of the suspension does not qualify for credit except to the extent that the assuming insurer\u8217\'3fs obligations under the reinsurance agreement are secured in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 521B.103}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If an assuming insurer\u8217\'3fs eligibility is revoked, credit for reinsurance shall not be granted after the effective date of the revocation with respect to any reinsurance agreements entered into by the assuming insurer, including reinsurance agreements entered into prior to the date of revocation, except to the extent that the assuming insurer\u8217\'3fs obligations under the reinsurance agreement are secured in a form acceptable to the commissioner and consistent with the provisions of }}}{{\f5\fs18\hyphpar0\qj{section 521B.103}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If subject to a legal process of rehabilitation, liquidation, or conservation, as applicable, the ceding insurer or the ceding insurer\u8217\'3fs representative may seek, and if determined appropriate by the court in which such legal process is pending, may obtain an order requiring that the assuming insurer post security for all outstanding ceded liabilities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not limit or alter the capacity of the parties to a reinsurance agreement to agree on requirements for security or other terms in the reinsurance agreement, except as expressly prohibited by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or any other applicable law or regulation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Credit may be taken under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ only for reinsurance agreements entered into, amended, or renewed on or after July 1, 2020, and only with respect to losses incurred and reserves reported on or after the later of the date on which the assuming insurer has met all eligibility requirements pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, and the effective date of the new reinsurance agreement, amendment, or renewal.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This paragraph shall not alter or impair a ceding insurer\u8217\'3fs right to take credit for reinsurance, to the extent that credit is not available under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, as long as the reinsurance qualifies for credit under any other applicable provision of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not authorize an assuming insurer to withdraw or reduce the security provided under any reinsurance agreement except as permitted by the terms of the reinsurance agreement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not limit or alter the capacity of parties to any reinsurance agreement to renegotiate the reinsurance agreement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Credit shall be allowed when reinsurance is ceded to an assuming insurer that does not meet the requirements of }}}{{\f5\fs18\hyphpar0\qj{subsection 1, 2, 3, 4, 5, or 6,}}}{{\f5\fs18\hyphpar0\qj{ but only as to the insurance of risks located in jurisdictions where the reinsurance is required by applicable law or regulation of that jurisdiction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the assuming insurer is not licensed, accredited, or certified to transact insurance or reinsurance in this state, the credit permitted by }}}{{\f5\fs18\hyphpar0\qj{subsections 3 and 4}}}{{\f5\fs18\hyphpar0\qj{ shall not be allowed unless the assuming insurer agrees in the reinsurance agreement to do all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In the event of the failure of the assuming insurer to perform its obligations under the terms of the reinsurance agreement, the assuming insurer, at the request of the ceding insurer, shall submit to the jurisdiction of any court of competent jurisdiction in any state of the United States, shall comply with all requirements necessary to give the court jurisdiction, and shall abide by the final decision of the court or of any appellate court in the event of any appeal, concerning such failure.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The assuming insurer shall designate the commissioner or a designated attorney as its true and lawful attorney to receive lawful process in any action, suit, or proceeding instituted by or on behalf of the ceding insurer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ is not intended to conflict with or override the obligation of the parties to a reinsurance agreement to arbitrate a dispute if the obligation for the parties to arbitrate disputes is created in the reinsurance agreement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the assuming insurer does not meet the requirements of }}}{{\f5\fs18\hyphpar0\qj{subsection 1, 2, 3, or 6,}}}{{\f5\fs18\hyphpar0\qj{ the credit permitted by }}}{{\f5\fs18\hyphpar0\qj{subsection 4 or 5}}}{{\f5\fs18\hyphpar0\qj{ shall not be allowed unless the assuming insurer agrees in a trust agreement to satisfy the following conditions:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any other provisions contained in the trust instrument, if the trust fund is inadequate because the trust fund contains an amount less than the amount required by }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, or if the grantor of the trust has been declared insolvent or has been placed into receivership, rehabilitation, liquidation, or similar proceedings under the laws of the trust\u8217\'3fs state or country of domicile, the trustee shall comply with an order of the commissioner with regulatory oversight over the trust or with an order of a court of competent jurisdiction directing the trustee to transfer all of the assets of the trust fund to the commissioner with regulatory oversight over the trust.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The assets of the trust shall be distributed, and claims shall be filed and valued, by the commissioner with regulatory oversight over the trust in accordance with the laws of the state in which the trust is domiciled that are applicable to the liquidation of domestic insurance companies.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the commissioner with regulatory oversight over the trust determines that the assets of the trust fund or any part of the trust fund are not necessary to satisfy the claims of the United States ceding insurers of the grantor of the trust, the assets of the trust or any part of those assets shall be returned by the commissioner with regulatory oversight over the trust to the trustee for distribution in accordance with the trust agreement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The grantor shall waive any right otherwise available to the grantor under United States law that is inconsistent with the provisions of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If an accredited or certified reinsurer ceases to meet the requirements for accreditation or certification pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the commissioner may suspend or revoke the reinsurer\u8217\'3fs accreditation or certification.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commissioner shall give the reinsurer notice and opportunity for hearing prior to such suspension or revocation. The suspension or revocation shall not take effect until after the commissioner\u8217\'3fs order on hearing unless one of the following applies:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The reinsurer waives its right to hearing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commissioner\u8217\'3fs order is based on regulatory action by the reinsurer\u8217\'3fs domiciliary jurisdiction or by the voluntary surrender or termination of the reinsurer\u8217\'3fs eligibility to transact insurance or reinsurance business in the reinsurer\u8217\'3fs domiciliary jurisdiction or in the primary certifying state of the reinsurer under }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ff\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commissioner finds that an emergency requires immediate action and a court of competent jurisdiction has not stayed the commissioner\u8217\'3fs action.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{While a reinsurer\u8217\'3fs accreditation or certification is suspended, a reinsurance contract issued or renewed after the effective date of the suspension does not qualify for credit except to the extent that the reinsurer\u8217\'3fs obligations under the reinsurance contract are secured in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 521B.103}}}{{\f5\fs18\hyphpar0\qj{. If a reinsurer\u8217\'3fs accreditation or certification is revoked, credit for reinsurance shall not be granted after the effective date of the revocation except to the extent that the reinsurer\u8217\'3fs obligations under the reinsurance contract are secured in accordance with }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{section 521B.103}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A domestic ceding insurer shall take steps to manage its reinsurance recoverables proportionate to its own book of business. A domestic ceding insurer shall notify the commissioner within thirty calendar days after reinsurance recoverables from any single assuming insurer, or group of affiliated assuming insurers, exceeds fifty percent of the domestic ceding insurer\u8217\'3fs last reported surplus to policyholders, or after the domestic ceding insurer has determined that reinsurance recoverables from any single assuming insurer, or group of affiliated assuming insurers, is likely to exceed this limit. The notification shall demonstrate that the exposure is safely managed by the domestic ceding insurer.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A domestic ceding insurer shall take steps to diversify its reinsurance program. A domestic ceding insurer shall notify the commissioner within thirty calendar days after ceding to any single assuming insurer, or group of affiliated assuming insurers, more than twenty percent of the domestic ceding insurer\u8217\'3fs gross written premium in the prior calendar year, or after the domestic ceding insurer has determined that the reinsurance ceded to any single assuming insurer, or group of affiliated assuming insurers, is likely to exceed this limit. The notification shall demonstrate that the exposure is safely managed by the domestic ceding insurer.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2013 Acts, ch 39, \'a72, 11}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1026, \'a7116}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 7, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1008, \'a72 \u8211\'3f 19, 27}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7508.33A}}}{{\f5\fs12\hyphpar0\qj{, 521A.1}}}{{\f5\fs12\hyphpar0\qj{, 521B.103}}}{{\f5\fs12\hyphpar0\qj{, 521B.105}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2020 amendments to section apply to all cessions under reinsurance agreements that have an inception, anniversary, or renewal date on or after July 1, 2020; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2020/CH1008.pdf" }{\fldrslt \cf5 \f5 \fs12{{2020 Acts, ch 1008, \'a727}}}}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{521B.103}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Limited credit allowed other domestic ceding insurers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An asset or a reduction from liability for reinsurance ceded by a domestic insurer to an assuming insurer not meeting the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 521B.102}}}{{\f5\fs18\hyphpar0\qj{, shall be allowed in an amount not exceeding the liabilities carried by the ceding insurer. The commissioner may adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 521B.105}}}{{\f5\fs18\hyphpar0\qj{ specifying requirements related to the valuation of assets or reserve credits, the amount and forms of security supporting reinsurance arrangements described in }}}{{\f5\fs18\hyphpar0\qj{section 521B.105}}}{{\f5\fs18\hyphpar0\qj{, and the circumstances pursuant to which credit shall be reduced or eliminated. The reduction shall be in the amount of funds held by or on behalf of the ceding insurer, including funds held in trust for the ceding insurer, under a reinsurance contract with the assuming insurer as security for the payment of obligations under the reinsurance contract, if the security is held in the United States subject to withdrawal solely by, and under the exclusive control of, the ceding insurer, or in the case of a trust, held in a qualified United States financial institution as defined in }}}{{\f5\fs18\hyphpar0\qj{section 521B.104, subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The security may be in the form of any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Cash.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A security listed by the securities valuation office of the NAIC, including those securities deemed exempt from filing as defined by the purposes and procedures manual of the securities valuation office and those securities qualifying as admitted assets.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Clean, irrevocable, unconditional letters of credit, issued or confirmed by a qualified United States financial institution, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 521B.104, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, effective no later than December 31 of the year for which the filing is being made, and in the possession of, or in trust for, the ceding insurer on or before the filing date of the ceding insurer\u8217\'3fs annual statement.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A letter of credit meeting applicable standards of issuer acceptability as of the date of the issuance or confirmation of the letter of credit shall, notwithstanding the issuing or confirming institution\u8217\'3fs subsequent failure to meet applicable standards of issuer acceptability, continue to be acceptable as security until the expiration, extension, renewal, modification, or amendment of the letter of credit, whichever occurs first.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any other form of security acceptable to the commissioner.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2013 Acts, ch 39, \'a73, 11}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 7, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1008, \'a720, 27}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7521B.102}}}{{\f5\fs12\hyphpar0\qj{, 521B.104}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2020 amendment applies to all cessions under reinsurance agreements that have an inception, anniversary, or renewal date on or after July 1, 2020; }{{\f5\fs12\hyphpar0\qj{2020 Acts, ch 1008, \'a727}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{521B.104}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Qualified United States financial institutions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{section 521B.103, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, a }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fqualified United States financial institution\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an institution that meets all of the following requirements:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is organized, or in the case of a United States office of a foreign banking organization is licensed, under the laws of the United States or of any state of the United States.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is regulated, supervised, and examined by United States federal or state authorities having regulatory authority over banks and trust companies.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Has been determined by either the commissioner or the securities valuation office of the NAIC to meet the standards of financial condition and standing as are considered necessary and appropriate to regulate the quality of financial institutions whose letters of credit will be acceptable to the commissioner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of those provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ specifying the institutions that are eligible to act as a fiduciary of a trust, a }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fqualified United States financial institution\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an institution that meets all of the following requirements:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is organized, or in the case of a United States branch or agency office of a foreign banking organization is licensed, under 