\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F273}{\*\bkmkend codeChapter_5F273}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 273}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{AREA EDUCATION AGENCIES}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a774.1}}}{{\f5\fs12\qc{, 256.82}}}{{\f5\fs12\qc{, 257.36}}}{{\f5\fs12\qc{, 279.23}}}{{\f5\fs12\qc{, 280.8}}}{{\f5\fs12\qc{, 280A.1}}}{{\f5\fs12\qc{, 282.3}}}{{\f5\fs12\qc{, 514C.35}}}\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER I}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E5_2E1_2E2}{GENERAL PROVISIONS}{\*\bkmkend stylerid1_2E5_2E1_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{273.1}}}{\*\bkmkstart stylerid1_2E5_2E2_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E2_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Intent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{It is the intent of the general assembly to provide an effective, efficient, and economical means of identifying and serving children from under five years of age through grade twelve who require special education and any other children requiring special education as defined in }{{\f5\fs18\hyphpar0\qj{section 256B.2}}}{; to provide for media services and other programs and services for pupils in grades kindergarten through twelve and children requiring special education as defined in }{{\f5\fs18\hyphpar0\qj{section 256B.2}}}{; to provide a method of financing the programs and services; to provide services to school districts under a contract with those school districts; to improve student achievement; and to close student achievement gaps.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7273.1}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{87 Acts, ch 224, \'a744}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1002, \'a74}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7256B.9}}}{{\f5\fs12\hyphpar0\qj{, 273.2}}}{{\f5\fs12\hyphpar0\qj{, 273.3}}}{{\f5\fs12\hyphpar0\qj{, 273.23}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{273.2}}}{\*\bkmkstart stylerid1_2E5_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Area education agencies established \u8212\'3f powers \u8212\'3f services and programs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{There are established throughout the state nine area education agencies, each of which is under the general supervision of the director of the department of education, except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. Each area education agency shall have an area education agency board of directors that shall serve in an advisory capacity. The boundaries of an area education agency shall not divide a school district. The director of the department of education shall change boundaries of area education agencies to take into account mergers of local school districts and changes in boundaries of local school districts, when necessary to maintain the policy of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ that a local school district shall not be a part of more than one area education agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An area education agency established under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ is a body politic as a school corporation for the purpose of exercising powers granted under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, and may sue and be sued. An area education agency may hold property and execute purchase agreements within two years of a disaster as defined in }}}{{\f5\fs18\hyphpar0\qj{section 29C.2, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, and lease-purchase agreements pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 273.3, subsection 7}}}{{\f5\fs18\hyphpar0\qj{, and if the lease-purchase agreement exceeds ten years or the purchase price of the property to be acquired pursuant to a purchase or lease-purchase agreement exceeds the amount stated in }}}{{\f5\fs18\hyphpar0\qj{section 26.3, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, the area education agency shall conduct a public hearing on the proposed purchase or lease-purchase agreement and receive approval from the area education agency board of directors and the state board of education or its designee before entering into the agreement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The area education agency shall furnish educational services and programs as provided in }}}{{\f5\fs18\hyphpar0\qj{ section 273.1}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{sections 273.3 through 273.8}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{chapter 256B}}}{{\f5\fs18\hyphpar0\qj{ to pupils enrolled in public or nonpublic schools which are on the list of accredited schools pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 256.11}}}{{\f5\fs18\hyphpar0\qj{, which request to receive such services. The programs and services provided shall be at least commensurate with programs and services existing on July 1, 1974. The programs and services provided to pupils enrolled in nonpublic schools shall be comparable to programs and services provided to pupils enrolled in public schools within constitutional guidelines.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The area education agency may furnish evidence-based professional development services to public or nonpublic schools which are on the list of accredited schools pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 256.11}}}{{\f5\fs18\hyphpar0\qj{ if any of the following requirements are satisfied:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The professional development service is included on the list developed by the director of the department of education pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 256.9, subsection 36}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director of the department of education grants approval to the area education agency to furnish the evidence-based professional development services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The area education agency shall provide for special education services and media services for school districts and shall encourage and assist school districts to establish programs for gifted and talented children. The area education agency shall assist in facilitating interlibrary loans of materials between school districts and other libraries.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The area education agency may furnish services under }}}{{\f5\fs18\hyphpar0\qj{subsection 3 or 4}}}{{\f5\fs18\hyphpar0\qj{ to public or nonpublic schools located within its boundaries, or within the boundaries of a contiguous area education agency, which are on the list of accredited schools pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 256.11}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the area education agency may furnish services under }}}{{\f5\fs18\hyphpar0\qj{subsection 3 or 4}}}{{\f5\fs18\hyphpar0\qj{ to a public school located within the boundaries of an area education agency that is not contiguous if the school district shares a superintendent with another school district, pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 257.11, subsection 5}}}{{\f5\fs18\hyphpar0\qj{, that receives services from the area education agency pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The area education agency board may provide for the following programs and services to local school districts, and at the request of local school districts to providers of child development services who have received grants under }}}{{\f5\fs18\hyphpar0\qj{chapter 256A}}}{{\f5\fs18\hyphpar0\qj{ from the child development coordinating council, within the limits of funds available:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In-service training programs for employees of school districts and area education agencies, provided at the time programs and services are established they do not duplicate programs and services available in that area from the universities under the state board of regents and from other universities and four-year institutions of higher education in Iowa. The in-service training programs shall include but are not limited to regular training concerning mental or emotional disorders which may afflict children and the impact children with such disorders have upon their families.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Educational data processing pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 256.9, subsection 11}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Research, demonstration projects and models, and educational planning for children under five years of age through grade twelve and children requiring special education as defined in }}}{{\f5\fs18\hyphpar0\qj{section 256B.2}}}{{\f5\fs18\hyphpar0\qj{ as approved by the state board of education.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Auxiliary services for nonpublic school pupils as provided in }}}{{\f5\fs18\hyphpar0\qj{section 256.12}}}{{\f5\fs18\hyphpar0\qj{. However, if auxiliary services are provided their funding shall be based on the type of service provided.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Other educational programs and services for children under five years through grade twelve and children requiring special education as defined in }}}{{\f5\fs18\hyphpar0\qj{section 256B.2}}}{{\f5\fs18\hyphpar0\qj{ and for employees of school districts and area education agencies as approved by the state board of education.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of directors of an area education agency shall not establish programs and services which duplicate programs and services which are or may be provided by the community colleges under the provisions of }}}{{\f5\fs18\hyphpar0\qj{chapter 260C}}}{{\f5\fs18\hyphpar0\qj{. An area education agency shall contract, whenever practicable, with other school corporations for the use of personnel, buildings, facilities, supplies, equipment, programs, and services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of an area education agency or a consortium of two or more area education agencies shall contract with one or more licensed dietitians for the support of nutritional provisions in individual education plans developed in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapter 256B}}}{{\f5\fs18\hyphpar0\qj{ and to provide information to support school nutrition coordinators.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The area education agency board shall collaborate with the department of education to provide a statewide infrastructure for educational data to create cost efficiencies, provide storage and disaster mitigation, and improve interconnectivity between schools and school districts. In addition, the area education agency boards shall work with the department to provide systemwide coordination in the implementation of the statewide longitudinal data system consistent with the federal }}}{{\f5\fs18\hyphpar0\qj{American Recovery and Reinvestment Act of 2009}}}{{\f5\fs18\hyphpar0\qj{. The area education agencies shall provide support to school districts\u8217\'3f information technology infrastructure that is consistent with the statewide infrastructure for the educational data collaborative.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The area education agency boards shall jointly develop a three-year statewide strategic plan that supports goals adopted by the state board of education pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 256.7, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, and the accreditation standards established pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 256.11}}}{{\f5\fs18\hyphpar0\qj{; establish performance goals; and clearly identify the statewide efforts to improve student learning and create efficiencies in management operations for area education agencies and school districts. The statewide strategic plan shall be approved by the state board of education. The area education agency boards shall jointly provide the state board with annual updates on the performance measures.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The area education agency board is encouraged to employ a child welfare liaison to provide services and guidance to local school districts to facilitate the efficient and effective transfer and enrollment of a child adjudicated under }}}{{\f5\fs18\hyphpar0\qj{chapter 232}}}{{\f5\fs18\hyphpar0\qj{ or receiving foster care services to another school district, including but not limited to guidance relating to the transfer of credit earned for coursework taken by the student, enrollment transition planning, facilitating information sharing between education and child welfare agencies, and developing systems designed to ameliorate the transition issues faced by a child adjudicated under }}}{{\f5\fs18\hyphpar0\qj{chapter 232}}}{{\f5\fs18\hyphpar0\qj{ or receiving foster care services who is transferring to and enrolling in a school district.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subject to an appropriation by the general assembly for such purpose, the area education agency board shall, by July 1, 2024, dedicate at least one full-time equivalent position to maintain a dyslexia specialist. The area education agency board may hire such a specialist or may provide appropriate training to qualify an existing employee as a specialist on dyslexia. The specialist shall provide technical guidance and assistance, including but not limited to professional development, strategies, and materials to school districts and accredited nonpublic schools relating to identification of and instruction for students with characteristics of dyslexia. The specialist shall be highly trained in dyslexia and have a minimum of three years of field experience in screening, identifying, and treating dyslexia and related disorders. In the absence of an appropriation, each area education agency board is encouraged to employ a highly qualified dyslexia specialist.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The area education agency shall charge reasonable costs that are consistent with current market rates for the educational services, special education services, professional development services, and media services established by the area education agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The area education agency shall provide an annual report by January 1 of each year to the department of education, and to public schools and nonpublic schools located within the area education agency\u8217\'3fs boundaries which are on the list of accredited schools pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 256.11}}}{{\f5\fs18\hyphpar0\qj{, a detailed description of the educational services, special education programs and services, professional development services, and media services that the area education agency provides, and the cost associated with purchasing such programs and services from the area education agency.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, \'a7280A.25(3); C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7273.2}}}{, }{{\f5\fs18\hyphpar0\qj{280A.25(3)}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1006, \'a71, 2}}}{, }{{\f5\fs18\hyphpar0\qj{ch 1136, \'a71}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1103, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 195, \'a730}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1245, \'a71457}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 115, \'a739}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 135, \'a757}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 182, \'a720}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 158, \'a723}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1187, \'a7143}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 65, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1031, \'a7270}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 132, \'a763, 106}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1023, \'a738}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1138, \'a761}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1091, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1048, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1063, \'a7124}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 25, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1002, \'a75, 6, 22}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7256.9}}}{{\f5\fs12\hyphpar0\qj{, 256.32A}}}{{\f5\fs12\hyphpar0\qj{, 256B.9}}}{{\f5\fs12\hyphpar0\qj{, 256I.8}}}{{\f5\fs12\hyphpar0\qj{, 273.3}}}{{\f5\fs12\hyphpar0\qj{, 273.6}}}{{\f5\fs12\hyphpar0\qj{, 273.11}}}{{\f5\fs12\hyphpar0\qj{, 273.23}}}{{\f5\fs12\hyphpar0\qj{, 280.29}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 amendment to subsections 3 and 4 applies to school years beginning on or after July 1, 2025; }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 1002, \'a722}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 5 applies to school years beginning on or after July 1, 2025; }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 1002, \'a722}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{273.3}}}{\*\bkmkstart stylerid1_2E5_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Duties and powers of area education agency board }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ additional powers of area education agencies.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The board in carrying out the provisions of }{{\f5\fs18\hyphpar0\qj{section 273.2}}}{ shall:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Advise and consult with the area education agency on policies and procedures for providing programs and services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Be authorized to receive and expend money for providing programs and services as provided in }}}{{\f5\fs18\hyphpar0\qj{sections 273.1}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{273.2}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{sections 273.4 through 273.8}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{chapters 256B}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{257}}}{{\f5\fs18\hyphpar0\qj{. All costs incurred in providing the programs and services, including administrative costs, shall be paid from funds received pursuant to }}}{{\f5\fs18\hyphpar0\qj{sections 273.1}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{273.2}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{sections 273.4 through 273.8}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{chapters 256B}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{257}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide data and prepare reports as directed by the director of the department of education.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide for advisory committees as deemed necessary.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Area education agencies are authorized, subject to rules of the state board of education, to provide directly or by contractual arrangement with public or private agencies for special education programs and services, media services, and educational programs and services requested by the local boards of education as provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, including but not limited to contracts for the area education agency to provide programs or services to the local school districts and contracts for local school districts, other educational agencies, and public and private agencies to provide programs and services to the local school districts in the area education agency in lieu of the area education agency providing the services. Contracts may be made with public or private agencies located outside the state if the programs and services comply with the rules of the state board. Rules adopted by the state board of education shall be consistent with rules, adopted by the board of educational examiners, relating to licensing of practitioners.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Area education agencies may cooperate and contract between themselves and with other public agencies to provide special education programs and services, media services, and educational services to schools and children residing within their respective areas. Area education agencies may provide print and nonprint materials to public and private colleges and universities that have teacher education programs approved by the state board of education.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Area education agencies are authorized to lease, purchase, or lease-purchase, subject to the approval of the state board of education or its designee and to receive by gift and operate and maintain facilities and buildings necessary to provide authorized programs and services. However, a lease for less than ten years and with an annual cost of less than the amount stated in }}}{{\f5\fs18\hyphpar0\qj{section 26.3, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, does not require the approval of the state board. The state board shall not approve a lease, purchase, or lease-purchase until the state board is satisfied by investigation that public school corporations within the area do not have suitable facilities available. A purchase of property that is not a lease-purchase may be made only within two years of a disaster as defined in }}}{{\f5\fs18\hyphpar0\qj{section 29C.2, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, and subject to the requirements of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Area education agencies are authorized, subject to the approval of the director of the department of education, to enter into agreements for the joint use of personnel, buildings, facilities, supplies, and equipment with school corporations as deemed necessary to provide authorized programs and services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Area education agencies are authorized to make application for, accept, and expend state and federal funds that are available for programs of educational benefit approved by the director of the department of education, and cooperate with the department in the manner provided in federal-state plans or department rules in the effectuation and administration of programs approved by the director, or approved by other educational agencies, which agencies have been approved as state educational authorities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Be authorized to perform all other acts necessary to carry out the provisions and intent of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Employ personnel to carry out the functions of the area education agency, which shall include the employment of an administrator who shall possess a license issued under }}}{{\f5\fs18\hyphpar0\qj{chapter 256, subchapter VII, part 3}}}{{\f5\fs18\hyphpar0\qj{. The administrator shall be employed pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 279.20}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{sections 279.23}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{279.24}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{279.25}}}{{\f5\fs18\hyphpar0\qj{. The salary for an area education agency administrator shall be established by the board based upon the previous experience and education of the administrator; provided, however, that the salary for an area education agency administrator shall not exceed one hundred twenty-five percent of the average salary of all superintendents of the school districts that are located within the boundaries of the area education agency at the time the employment agreement is entered into or renewed between an area education agency and an area education agency administrator. }}}{{\f5\fs18\hyphpar0\qj{Section 279.13}}}{{\f5\fs18\hyphpar0\qj{ applies to the area education agency board and to all teachers employed by the area education agency. }}}{{\f5\fs18\hyphpar0\qj{Sections 279.23}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{279.24}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{279.25}}}{{\f5\fs18\hyphpar0\qj{ apply to the area education board and to all administrators employed by the area education agency. }}}{{\f5\fs18\hyphpar0\qj{Section 279.69}}}{{\f5\fs18\hyphpar0\qj{ applies to the area education agency board and employees of the board, including part-time, substitute, or contract employees, who provide services to a school or school district.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Area education agencies shall prepare an annual budget estimating income and expenditures for programs and services as provided in }}}{{\f5\fs18\hyphpar0\qj{sections 273.1}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{273.2}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{sections 273.4 through 273.8}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{chapter 256B}}}{{\f5\fs18\hyphpar0\qj{ within the limits of funds provided under }}}{{\f5\fs18\hyphpar0\qj{section 256B.9}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{chapter 257}}}{{\f5\fs18\hyphpar0\qj{. The board shall submit the proposed budget to the director of the department of education for approval not later than March 1 of each year, and the director shall either approve or reject the proposed budget for changes within ten days after submission. The proposed budget as approved by the director of the department of education shall then be submitted to the state board of education, on forms provided by the department, no later than March 15 preceding the next fiscal year for approval. The state board shall review the proposed budget of each area education agency and shall before May 1, either grant approval or return the budget without approval with comments of the state board included. An unapproved budget shall be resubmitted to the state board for final approval not later than May 15. The state board shall give final approval only to budgets submitted by area education agencies accredited by the state board or that have been given conditional accreditation by the state board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Be authorized to pay, out of funds available to the board reasonable annual dues to an Iowa association of school boards. Membership shall be limited to those duly elected members of the area education agency board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board may establish a plan, in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 403(b) of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 422.3}}}{{\f5\fs18\hyphpar0\qj{, for employees, which plan shall consist of one or more investment contracts, on a group or individual basis, acquired from a company, or a salesperson for that company, that is authorized to do business in this state.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The selection of investment contracts to be included within the plan established by the board shall be made either pursuant to a competitive bidding process conducted by the board, in coordination with employee organizations representing employees eligible to participate in the plan, or pursuant to an agreement with the department of administrative services to make available investment contracts included in a deferred compensation or similar plan established by the department pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 8A.438}}}{{\f5\fs18\hyphpar0\qj{, which plan meets the requirements of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. The determination of whether to select investment contracts for the plan pursuant to a competitive bidding process or by agreement with the department of administrative services shall be made by agreement between the board and the employee organizations representing employees eligible to participate in the plan.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board may make elective deferrals in accordance with the plan as authorized by an eligible employee for the purpose of making contributions to the investment contract on behalf of the employee. The deferrals shall be made in the manner which will qualify contributions to the investment contract for the benefits under }}}{{\f5\fs18\hyphpar0\qj{section 403(b) of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 422.3}}}{{\f5\fs18\hyphpar0\qj{. In addition, the board may make nonelective employer contributions to the plan.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, unless the context otherwise requires, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3finvestment contract\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall mean a custodial account utilizing mutual funds or an annuity contract which meets the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 403(b) of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 422.3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Be authorized to establish and pay all or any part of the cost of group health insurance plans, nonprofit group medical service plans and group life insurance plans adopted by the board for the benefit of employees of the area education agency, from funds available to the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{16.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Meet at least annually with the members of the boards of directors of the merged areas in which the area education agency is located to discuss coordination of programs and services and other matters of mutual interest to the boards.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{17.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Be authorized to issue warrants and anticipatory warrants pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 74}}}{{\f5\fs18\hyphpar0\qj{. The applicable rate of interest shall be determined pursuant to }}}{{\f5\fs18\hyphpar0\qj{sections 74A.2}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{74A.3}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{74A.7}}}{{\f5\fs18\hyphpar0\qj{. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not be construed to authorize a board to levy a tax.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{18.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Be authorized to issue school credit cards allowing area education agency employees to pay for the actual and necessary expenses incurred in the performance of work-related duties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{19.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Pursuant to rules adopted by the state board of education, be authorized to charge user fees for certain materials and services that are not required by law or by rules of the state board of education and are specifically requested by a school district or accredited nonpublic school.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{20.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Be authorized to purchase equipment as provided in }}}{{\f5\fs18\hyphpar0\qj{section 279.48}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{21.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Be authorized to sell, lease, or dispose of, in whole or in part, property belonging to the area education agency. Before the area education agency may sell property belonging to the agency, the board of directors shall comply with the requirements set forth in }}}{{\f5\fs18\hyphpar0\qj{section 297.22}}}{{\f5\fs18\hyphpar0\qj{. Before the board of directors of an area education agency may lease property belonging to the agency, the board shall obtain the approval of the director of the department of education.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{22.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Meet annually with the members of the boards of directors of the school districts located within its boundaries if requested by the school district boards.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{23.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{By October 1 of each year, submit to the department of education the following information:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The contracted salary including bonus wages and benefits, annuity payments, or any other benefit for the administrators of the area education agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The contracted salary and benefits and any other expenses related to support for governmental affairs efforts, including expenditures for lobbyists and lobbying activities for the area education agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{24.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Be authorized to sell software and support services, professional development programs and materials, online professional development, and online training to entities other than school districts within the state and to school districts and other public agencies located outside of the state. The board may also sell to school districts within this state software and support services, professional development programs and materials, online professional development, and online training which the area education agency is not otherwise required to provide to a school district under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{chapter 256B}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{257}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{25.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Require, by July 1, 2024, any person employed by the area education agency who holds a license, certificate, statement of recognition, or authorization other than a coaching authorization, issued by the board of educational examiners under }}}{{\f5\fs18\hyphpar0\qj{chapter 256, subchapter VII, part 3}}}{{\f5\fs18\hyphpar0\qj{, to complete the Iowa reading research center dyslexia overview module. Such persons employed after July 1, 2024, shall complete the module within one year of the employee\u8217\'3fs initial date of hire.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{26.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On a quarterly basis, the area education agency shall prepare and submit to each school district that receives services from the area education agency a report that includes all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A monetary accounting of payments the area education agency received from the school district, including payments under }}}{{\f5\fs18\hyphpar0\qj{section 257.35}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A description of all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The special education services provided by the area education agency to the school district.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The services provided by the area education agency under part C of the federal }}}{{\f5\fs18\hyphpar0\qj{Individuals with Disabilities Education Act}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The services provided by the area education agency that are related to the child find process for special education.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The services provided by the area education agency to accredited nonpublic schools and charter schools.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7417; R60, \'a7648, 2074; C73, \'a7771, 1776; C97, \'a72742, 2831, 2832; S13, \'a72742, 2831, 2832; SS15, \'a72734-b; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4122, 4456 \u8211\'3f 4458, 5232 \u8211\'3f 5234;}}}{ C46, \'a7273.4, 301.12 \u8211\'3f 301.14, 340.13 \u8211\'3f 340.15; C50, 54, 58, 62, \'a7273.12, 273.13; C66, \'a7273.12, 273.13, 273.22; C71, 73, \'a7273.12, 273.13, 273.22, 273.24; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7273.3}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 87, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1080, \'a71}}}{, }{{\f5\fs18\hyphpar0\qj{ch 1136, \'a72, 3}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 2, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1010, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1315, \'a734}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 138, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 212, \'a721}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1213, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1245, \'a71458}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1246, \'a7133}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 115, \'a740}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 233, \'a7474, 475}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 135, \'a758}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 265, \'a734}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1050, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1227, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1089, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1175, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1183, \'a763}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1215, \'a747, 48}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 184, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1171, \'a764, 68}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 65, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 179, \'a7161}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1023, \'a739}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 30, \'a766}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 88, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 141, \'a719}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1135, \'a723}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1048, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1063, \'a7125}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 25, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72581}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1002, \'a77, 8, 20}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7256B.2}}}{{\f5\fs12\hyphpar0\qj{, 256B.9}}}{{\f5\fs12\hyphpar0\qj{, 257.9}}}{{\f5\fs12\hyphpar0\qj{, 257.10}}}{{\f5\fs12\hyphpar0\qj{, 273.2}}}{{\f5\fs12\hyphpar0\qj{, 273.9}}}{{\f5\fs12\hyphpar0\qj{, 273.23}}}{{\f5\fs12\hyphpar0\qj{, 280.7A}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 amendment to subsection 11 applies to employment agreements entered into or renewed between an area education agency and an area education agency administrator on or after July 1, 2024; }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 1002, \'a720}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section not amended; editorial change applied}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{273.4}}}{\*\bkmkstart stylerid1_2E5_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Duties of administrator.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Under direction of the board of directors of the area education agency, the administrator of the area education agency shall, in addition to other duties:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Cooperate with boards of directors of local school districts of the area education agency in considering and developing plans for the improvement of the educational programs and services in the area education agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When requested, provide such other assistance as possible to school districts of the area education agency for the general improvement of their educational programs and operations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Submit program plans each year to the department of education, for approval by the director of the department, to reflect the needs of the area education agency for media services as provided in }}}{{\f5\fs18\hyphpar0\qj{section 273.6}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a71148; R60, \'a72066 \u8211\'3f 2068, 2071, 2073; C73, \'a71766 \u8211\'3f 1768, 1770, 1772, 1774, 1775; C97, \'a72734 \u8211\'3f 2740; S13, \'a72734-f, -l, -m, -p, 2738, 2739; SS15, \'a72734-b, -c; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4106;}}}{ C46, \'a7271.11; C50, 54, 58, 62, 66, 71, 73, \'a7273.18; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7273.4}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1245, \'a71459}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7256B.9}}}{{\f5\fs12\hyphpar0\qj{, 273.2}}}{{\f5\fs12\hyphpar0\qj{, 273.3}}}{{\f5\fs12\hyphpar0\qj{, 273.9}}}{{\f5\fs12\hyphpar0\qj{, 273.23}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{273.5}}}{\*\bkmkstart stylerid1_2E5_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Special education.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{There shall be established a division of special education of the area education agency which shall provide for special education programs and services to the local school districts. The division of special education shall be headed by a director of special education who meets certification standards of the department of education. The director of special education shall be an employee of the division of special education of the department of education. The director of special education shall not be an employee of the area education agency, shall not receive compensation from the area education agency, shall not supervise or manage employees of the area education agency, and shall not directly provide special education services for the agency. The director of special education\u8217\'3fs primary job duties and responsibilities to the area education agency are to provide oversight of the area education agency\u8217\'3fs special education services. The director of special education shall also have the responsibility for implementation of state regulations and guidelines relating to special education programs and services. The director of special education shall have the following powers and duties:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Properly identify children requiring special education.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Insure that each child requiring special education in the area receives an appropriate special education program or service.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Assign appropriate weights for each child requiring special education programs or services as provided in }}}{{\f5\fs18\hyphpar0\qj{section 256B.9}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Supervise special education support personnel.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide each school district within the area served and the department of education with a special education weighted enrollment count, including the additional enrollment because of special education for December 1 of each year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Submit to the department of education special education instructional and support program plans and applications, subject to criteria listed in }}}{{\f5\fs18\hyphpar0\qj{chapter 256B}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, for approval by February 15 of each year for the school year commencing the following July 1.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Coordinate the special education program within the area served.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7273.5}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 135, \'a759}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1002, \'a79}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7256B.9}}}{{\f5\fs12\hyphpar0\qj{, 256B.11}}}{{\f5\fs12\hyphpar0\qj{, 273.2}}}{{\f5\fs12\hyphpar0\qj{, 273.3}}}{{\f5\fs12\hyphpar0\qj{, 273.9}}}{{\f5\fs12\hyphpar0\qj{, 273.23}}}{{\f5\fs12\hyphpar0\qj{, 280.15}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{273.6}}}{\*\bkmkstart stylerid1_2E5_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Media centers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The media centers required under }}}{{\f5\fs18\hyphpar0\qj{section 273.2}}}{{\f5\fs18\hyphpar0\qj{ shall contain:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A materials lending library, consisting of print and nonprint materials.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A professional library.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A curriculum laboratory, including textbooks and correlated print and audiovisual materials.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Capability for production of media-oriented instructional materials.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Qualified media personnel.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Appropriate physical facilities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Other materials and equipment deemed necessary by the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Program plans submitted by the area education agency to the department of education for approval by the state board of media centers under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall include all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Evidence that the services proposed are based upon an analysis of the needs of the local school districts in the area.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Description of the manner in which the services of the area education agency media center will be coordinated with other agencies and programs providing educational media.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Description of the means for delivery of circulation materials.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Evidence that the media center fulfills the requirements of }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7273.6}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7256B.9}}}{{\f5\fs12\hyphpar0\qj{, 257.37}}}{{\f5\fs12\hyphpar0\qj{, 273.2}}}{{\f5\fs12\hyphpar0\qj{, 273.3}}}{{\f5\fs12\hyphpar0\qj{, 273.4}}}{{\f5\fs12\hyphpar0\qj{, 273.9}}}{{\f5\fs12\hyphpar0\qj{, 273.23}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{273.7}}}{\*\bkmkstart stylerid1_2E5_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Additional services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If sixty percent of the number of local school boards located in an area education agency, or if local school boards representing sixty percent of the enrollment in the school districts located in the agency, request in writing to the area education agency board that an additional service be provided them, for pupils in grades kindergarten through twelve or children requiring special education as defined in }{{\f5\fs18\hyphpar0\qj{section 256B.2}}}{ or for employees or board members of school districts or area education agencies, the area education agency board shall arrange for the service to be provided to all school districts in the area within the financial capabilities of the area education agency.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7273.7}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7256B.9}}}{{\f5\fs12\hyphpar0\qj{, 273.2}}}{{\f5\fs12\hyphpar0\qj{, 273.3}}}{{\f5\fs12\hyphpar0\qj{, 273.23}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{273.7A}}}{\*\bkmkstart stylerid1_2E5_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Services to school districts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of an area education agency may provide services to school districts located in the area education agency under contract with the school districts. These services may include, but are not limited to, superintendency services, personnel services, business management services, specialized maintenance services, and transportation services. In addition, the board of the area education agency may provide for furnishing expensive and specialized equipment for school districts. School districts shall pay to area education agencies the cost of providing the services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of an area education agency may also provide services authorized to be performed by area education agencies to other area education agencies in this state and to provide a method of payment for these services.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{87 Acts, ch 224, \'a745}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7256B.9}}}{{\f5\fs12\hyphpar0\qj{, 273.2}}}{{\f5\fs12\hyphpar0\qj{, 273.3}}}{{\f5\fs12\hyphpar0\qj{, 273.23}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{273.8}}}{\*\bkmkstart stylerid1_2E5_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Area education agency board of directors.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E5_2E1_30_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E1_30_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Board of directors.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of directors of an area education agency shall consist of nine members. Each director shall serve a four-year term, which commences at the organization meeting.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Five members of the board of directors of an area education agency must be residents of and elected in the manner provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ from a director district that is approximately equal in population to the other director districts in the area education agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Four members of the board of directors of an area education agency must be appointed by the majority vote of the superintendents of school districts located within the boundaries of the area education agency. A member appointed pursuant to this paragraph must be a superintendent of a school district located within the boundaries of the area education agency; provided, however, that a superintendent appointed pursuant to this paragraph may designate any individual to serve for all, or the remainder of, the superintendent\u8217\'3fs term.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E5_2E1_30_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E1_30_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Election of directors.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{, the board of directors of an area education agency shall be elected by a vote of the members of the boards of directors of the local school districts located within the director district. The procedure for conducting the elections shall be as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notice of the election shall be published by the area education agency administrator not later than September 15 of the odd-numbered year in at least one newspaper of general circulation in the director district. The cost of publication shall be paid by the area education agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A candidate for election to the area education agency board shall file a statement of candidacy with the area education agency secretary not later than October 15 of the odd-numbered year, on forms prescribed by the department of education. The statement of candidacy shall include the candidate\u8217\'3fs name, address, and school district. The list of candidates shall be sent by the secretary of the area education agency in ballot form by certified mail to the presidents of the boards of directors of all school districts within the director district not later than November 1. In order for the ballot to be counted, the ballot must be received in the secretary\u8217\'3fs office by the end of the normal business day on November 30 or be clearly postmarked by an officially authorized postal service not later than November 29 and received by the secretary not later than noon on the first Monday following November 30.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of each separate school district that is located entirely or partially inside an area education agency director district shall cast a vote for director of the area education agency board described in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, based upon the ratio that the population of the school district, or portion of the school district, in the director district bears to the total population in the director district. The population of each school district or portion shall be determined by the department of education. The member of the area education agency board described in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, to be elected may be a member of a local school district board of directors and shall be an elector and a resident of the director district, but shall not be a school district employee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vacancy, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 277.29}}}{{\f5\fs18\hyphpar0\qj{, in a membership position of the area education agency board described in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, shall be filled for the unexpired portion of the term at a director district convention called and conducted in the manner provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vacancy, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 277.29}}}{{\f5\fs18\hyphpar0\qj{, in a membership position of the area education agency board described in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, shall be filled for the unexpired portion of the term by an individual who is appointed by the majority vote of the superintendents of school districts located within the boundaries of the area education agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{\*\bkmkstart stylerid1_2E5_2E1_30_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E1_30_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Director district convention.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If no candidate files with the area education agency secretary by the deadline specified in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, or a vacancy occurs, or if otherwise required as provided in }}}{{\f5\fs18\hyphpar0\qj{section 273.23, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, a director district convention, attended by members of the boards of directors of the local school districts located within the director district, shall be called to elect a board member described in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, for that director district. The convention location shall be determined by the area education agency administrator. Notice of the time, date, and place of a director district convention shall be published by the area education agency administrator in at least one newspaper of general circulation in the director district at least thirty days prior to the day of the convention. The cost of publication shall be paid by the area education agency. A candidate for election to the area education agency board shall file a statement of candidacy with the area education agency secretary at least ten days prior to the date of the director district convention on forms prescribed by the department of education, or nominations may be made at the convention by a delegate from a board of directors of a school district located within the director district. A statement of candidacy shall include the candidate\u8217\'3fs name, address, and school district. Delegates to director district conventions shall not be bound by a school board or any school board member to pledge their votes to any candidate prior to the date of the convention.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{\*\bkmkstart stylerid1_2E5_2E1_30_2E6_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E1_30_2E6_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Organization.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of directors of each area education agency shall meet and organize at the first regular meeting in December following the regular school election at a suitable place designated by the president. Directors whose terms commence at the organizational meeting shall qualify by taking the oath of office required by }}}{{\f5\fs18\hyphpar0\qj{section 277.28}}}{{\f5\fs18\hyphpar0\qj{ at or before the organizational meeting.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The provisions of }}}{{\f5\fs18\hyphpar0\qj{section 260C.12}}}{{\f5\fs18\hyphpar0\qj{ relating to organization, officers, appointment of secretary and treasurer, and meetings of the merged area board apply to the area education agency board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{\*\bkmkstart stylerid1_2E5_2E1_30_2E7_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E1_30_2E7_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Quorum.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A majority of the members of the board of directors of the area education agency shall constitute a quorum.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{\*\bkmkstart stylerid1_2E5_2E1_30_2E8_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E1_30_2E8_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Change in directors.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of an area education agency may change the number of directors on the board and shall make corresponding changes in the boundaries of director districts. Changes shall be completed not later than September 1 of the odd-numbered year for the director district conventions to be held the following November.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{\*\bkmkstart stylerid1_2E5_2E1_30_2E9_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E1_30_2E9_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Boundary line changes.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To the extent possible the board shall provide that changes in the boundary lines of director districts of area education agencies shall not lengthen or diminish the term of office of a director of an area education agency board. Initial terms of office shall be set by the board so that as nearly as possible the terms of one-half of the members expire biennially.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{\*\bkmkstart stylerid1_2E5_2E1_30_2E1_30_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E1_30_2E1_30_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Census changes.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of the area education agency shall redraw boundary lines of director districts in the area education agency after each census to compensate for changes in population if changes in population have taken place.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Where feasible, boundary lines of director districts shall coincide with the boundary lines of school districts and the boundary lines of election precincts established pursuant to }}}{{\f5\fs18\hyphpar0\qj{sections 49.3 through 49.6}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72833; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4119, 4121;}}}{ C46, \'a7273.1, 273.3; C50, 54, 58, 62, \'a7273.4, 273.5, 273.9, 273.10; C66, 71, 73, \'a7273.4, 273.5, 273.9, 273.10, 280A.23(2); C75, 77, \'a7273.8, 280A.23(2); C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7273.8}}}{, }{{\f5\fs18\hyphpar0\qj{280A.28}}}{, }{{\f5\fs18\hyphpar0\qj{280A.29}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1088, \'a71}}}{, }{{\f5\fs18\hyphpar0\qj{ch 1136, \'a74 \u8211\'3f 6}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1219, \'a713, 14}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 138, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 180, \'a719, 20}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1115, \'a77 \u8211\'3f 9, 21}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 41, \'a7108}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7180}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 155, \'a75 \u8211\'3f 7, 9, 10}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 59, \'a778}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1002, \'a710 \u8211\'3f 12, 21}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7256B.9}}}{{\f5\fs12\hyphpar0\qj{, 273.2}}}{{\f5\fs12\hyphpar0\qj{, 273.3}}}{{\f5\fs12\hyphpar0\qj{, 273.21}}}{{\f5\fs12\hyphpar0\qj{, 273.23}}}{{\f5\fs12\hyphpar0\qj{, 273.27}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 amendments to section apply to the election of directors and vacancies occurring under this section on or after July 1, 2024; }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 1002, \'a721}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section not amended; editorial change applied}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{273.9}}}{\*\bkmkstart stylerid1_2E5_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Funding.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{School districts shall pay for the programs and services provided through the area education agency and shall include expenditures for the programs and services in their budgets, in accordance with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{School districts shall pay the costs of special education instructional programs with the moneys available to the districts for each child requiring special education, by application of the special education weighting plan in }}}{{\f5\fs18\hyphpar0\qj{section 256B.9}}}{{\f5\fs18\hyphpar0\qj{. Special education instructional programs shall be provided at the local level if practicable, or otherwise by contractual arrangements with the area education agency board as provided in }}}{{\f5\fs18\hyphpar0\qj{section 273.3, subsection 5}}}{{\f5\fs18\hyphpar0\qj{, but in each case the total money available through }}}{{\f5\fs18\hyphpar0\qj{section 256B.9}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{chapter 257}}}{{\f5\fs18\hyphpar0\qj{ because of weighted enrollment for each child requiring special education instruction shall be made available to the district or agency which provides the special education instructional program to the child, subject to adjustments for transportation or other costs which may be paid by the school district in which the child is enrolled. Each district shall cooperate with its area education agency to provide an appropriate special education instructional program for each child who requires special education instruction, as identified and counted within the certification by the area director of special education or as identified by the area director of special education subsequent to the certification, and shall not provide a special education instructional program to a child who has not been so identified and counted within the certification or identified subsequent to the certification.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The costs of special education support services provided through the area education agency shall be funded as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 257}}}{{\f5\fs18\hyphpar0\qj{. Special education support services shall not be funded until the program plans submitted by the special education directors of each area education agency as required by }}}{{\f5\fs18\hyphpar0\qj{section 273.5}}}{{\f5\fs18\hyphpar0\qj{ are modified as necessary and approved by the director of the department of education according to the criteria and limitations of }}}{{\f5\fs18\hyphpar0\qj{chapters 256B}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{257}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The costs of media services provided through the area education agency shall not be funded until the program plans submitted by the administrators of each area education agency as required by }}}{{\f5\fs18\hyphpar0\qj{section 273.4}}}{{\f5\fs18\hyphpar0\qj{ are modified as necessary and approved by the director of the department of education according to the criteria of }}}{{\f5\fs18\hyphpar0\qj{section 273.6}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state board of education shall adopt rules under }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ relating to the approval of program plans under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7417; R60, \'a7648, 2074; C73, \'a7771, 1776; C97, \'a72742, 2831, 2832; S13, \'a72742, 2831, 2832; SS15, \'a72734-b; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4456 \u8211\'3f 4458, 5232 \u8211\'3f 5234;}}}{ C46, \'a7301.12 \u8211\'3f 301.14, 340.13 \u8211\'3f 340.15; C50, 54, 58, 62, 66, 71, 73, \'a7273.13; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7273.9}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1245, \'a71460}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 135, \'a760}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 97, \'a738}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a795}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1023, \'a7157}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7256B.2}}}{{\f5\fs12\hyphpar0\qj{, 256B.8}}}{{\f5\fs12\hyphpar0\qj{, 256B.9}}}{{\f5\fs12\hyphpar0\qj{, 273.23}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{273.10}}}{\*\bkmkstart stylerid1_2E5_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Accreditation of area education programs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of education shall develop, in consultation with the area education agencies, and establish an accreditation process for area education agencies by July 1, 1997. At a minimum, the accreditation process shall consist of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The timely submission by an area education agency of information required by the department on forms provided by the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The use of an accreditation team appointed by the director of the department of education to conduct an evaluation, including an on-site visit of each area education agency. The team shall include, but is not limited to, department staff members, representatives from the school districts served by the area education agency being evaluated, area education agency staff members from area education agencies other than the area education agency that conducts the programs being evaluated for accreditation, and other team members with expertise as deemed appropriate by the director.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prior to a visit to an area education agency, the accreditation team shall have access to that area education agency\u8217\'3fs program audit report filed with the department. After a visit to an area education agency, the accreditation team shall determine whether the accreditation standards for a program, including but not limited to standards established pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 256.9, subsection 54}}}{{\f5\fs18\hyphpar0\qj{, have been met and shall make a report to the director and the state board, together with a recommendation as to whether the programs of the area education agency should receive initial accreditation or remain accredited. The accreditation team shall report strengths and weaknesses, if any, for each accreditation standard and shall advise the area education agency of available resources and technical assistance to further enhance the strengths and improve areas of weakness. An area education agency may respond to the accreditation team\u8217\'3fs report.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state board of education shall determine whether a program of an area education agency shall receive initial accreditation or shall remain accredited.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Approval of area education agency programs by the state board shall be based upon the recommendation of the director of the department of education after a study of the factual and evaluative evidence on record about each area education agency program in terms of the accreditation standards adopted by the state board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Approval, if granted, shall be for a term of five years. However, the state board may grant conditional approval for a term of less than five years if conditions warrant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the state board of education determines that an area education agency\u8217\'3fs program does not meet accreditation standards, the director of the department of education, in cooperation with the board of directors of the area education agency, shall establish a remediation plan prescribing the procedures that must be taken to correct deficiencies in meeting the program standards, and shall establish a deadline date for correction of the deficiencies. The remediation plan is subject to the approval of the state board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The area education agency program shall remain accredited during the implementation of the remediation plan. The accreditation team shall visit the area education agency and shall determine whether the deficiencies in the standards for the program have been corrected and shall make a report and recommendation to the director and the state board of education. The state board shall review the report and recommendation and shall determine whether the deficiencies in the program have been corrected.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the deficiencies in an area education program have not been corrected, the director of the department of education shall take one of the following actions within sixty days from removal of accreditation:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Merge the deficient program with a program from another accredited area education agency.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Contract with another area education agency or other public educational institution for purposes of program delivery.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The rules developed by the state board of education for the accreditation process shall include provisions for removal of accreditation, including provisions for proper notice to the administrator of the area education agency, each member of the board of directors of the area education agency, the department of education, and the superintendents and administrators of the schools of the districts served by the area education agency.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1215, \'a749}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 114, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 41, \'a7263}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1031, \'a7271}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1002, \'a713, 19}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7273.23}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 amendment to subsection 6 effective July 1, 2025; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2024/CH1002.pdf" }{\fldrslt \cf5 \f5 \fs12{{2024 Acts, ch 1002, \'a719}}}}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{273.11}}}{\*\bkmkstart stylerid1_2E5_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Standards for accrediting area education programs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state board of education, in consultation with the division of special education of the department of education, shall develop standards and rules for the accreditation of area education agencies. Standards shall be general in nature, but at a minimum shall identify requirements addressing the services provided by each division, as well as identifying indicators of quality that will permit area education agencies, school districts, the division of special education of the department of education, and the general public to judge accurately the effectiveness of area education agency services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Standards developed shall include but are not limited to the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Support for school-community planning, including a means of assessing needs, developing collaborative relationships among community agencies, establishing shared direction, and implementing program plans and reporting progress toward goals for all students, including students with disabilities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Evidence-based professional development programs that respond to current needs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Support for curriculum development, instruction, and assessment services that address the areas of reading, language arts, math, and science, using research-based methodologies, for all students, including students with disabilities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Special education support.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Management services, including financial reporting and purchasing as requested and funded by local districts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Support for instructional media services that supplement and support local district media centers and services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Support for school technology planning and staff development for implementing instructional technologies.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A program and services evaluation and reporting system that includes information related to special education.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Support for school district libraries in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 273.2, subsection 4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Support for early childhood service coordination for families and children, age birth through three years, to meet health, safety, and learning needs, including service coordination.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{k.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Timely submission of required reports and documents to the state board of education, the department of education, and the division of special education of the department of education.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{l.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Support for schools and school districts in analyzing student achievement data related to the learning environment, comparing data to the external knowledge base, and using that information to guide schools and school districts in setting goals and implementing actions to improve student learning for all students, including students with disabilities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{m.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Support for addressing the diverse learning needs of all children and youths, including children and youths who are eligible for special education through services that include direct services to students with disabilities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{n.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Support for schools and school districts to ensure compliance with rules adopted by the state board of education related to special education.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{o.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Support necessary to implement effective instruction for all students, including students with disabilities, through school technology services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{p.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Support for students using educational programs and services in a manner that is consistent with the educational standards established pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 256.11}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{q.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Support for staff development and adult learners utilizing evidence-based professional development in a manner that meets the professional needs of staff and adult learners consistent with standards adopted by the state board of education.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{r.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Compliance with all relevant federal and state laws in the provision of services and supports to students with disabilities.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1215, \'a750}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 158, \'a724}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1031, \'a7272}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 34, \'a772}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1002, \'a714, 19}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7273.23}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 amendment to section effective July 1, 2025; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2024/CH1002.pdf" }{\fldrslt \cf5 \f5 \fs12{{2024 Acts, ch 1002, \'a719}}}}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{273.12}}}{\*\bkmkstart stylerid1_2E5_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Funds \u8212\'3f use restricted.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Funds generated for educational services shall not be expended by an area education agency for the purpose of assisting either a public employer or employee organization in collective bargaining negotiations under }{{\f5\fs18\hyphpar0\qj{chapter 20}}}{ if the public employer is a school district, or the employee organization consists of employees of a school district, located within the boundaries of the area education agency.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7273.12}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 135, \'a761}}}{; }{{\f5\fs18\hyphpar0\qj{91 Acts, ch 97, \'a739}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{273.13}}}{\*\bkmkstart stylerid1_2E5_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Administrative expenditures.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{ The administrative expenditures as a percent of an area education agency\u8217\'3fs general fund for a base year shall not exceed five percent. Annually, the board of directors shall certify to the department of education the amounts of the area education agency\u8217\'3fs expenditures and its general fund. For the purposes of }{{\f5\fs18\hyphpar0\qj{this section}}}{, }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fbase year\u8221\'3f}}}{ means the same as defined in }{{\f5\fs18\hyphpar0\qj{section 257.2}}}{, and }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fadministrative expenditures\u8221\'3f}}}{ means expenditures for executive administration.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1226, \'a719}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1158, \'a755}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 135, \'a762}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 88, \'a712}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{273.14}}}{\*\bkmkstart stylerid1_2E5_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Emergency repairs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{When emergency repairs costing more than the competitive bid threshold in }{{\f5\fs18\hyphpar0\qj{section 26.3}}}{, or the adjusted competitive bid threshold established in }{{\f5\fs18\hyphpar0\qj{section 314.1B, subsection 2}}}{, are necessary in order to ensure the use of an area education agency facility, the provisions of law with reference to advertising for bids shall not apply within two years of a disaster as defined in }{{\f5\fs18\hyphpar0\qj{section 29C.2, subsection 2}}}{, and the area education agency board may contract for such emergency repairs without advertising for bids. However, before such emergency repairs can be made to an area education agency facility, the state board of education or its designee must certify that such emergency repairs are necessary to ensure the use of the area education agency facility.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 65, \'a77}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{273.15}}}{\*\bkmkstart stylerid1_2E5_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Advisory group.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2024 Acts, ch 1170, \'a7368}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\sb0\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{273.16}}}{\*\bkmkstart stylerid1_2E5_2E18_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E18_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Online learning program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subject to an appropriation of funds by the general assembly for this purpose, the area education agencies may offer, separately or in collaboration with other area education agencies, or in partnership with school districts and accredited nonpublic schools, to provide an online learning program to deliver distance education to Iowa\u8217\'3fs secondary students, including students receiving competent private instruction under }}}{{\f5\fs18\hyphpar0\qj{chapter 299A}}}{{\f5\fs18\hyphpar0\qj{. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Coursework offered under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ must meet the requirements established by rule pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 256.7, subsection 32}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To participate in an online learning program offered by an area education agency, a student must be enrolled in a participating school district or accredited nonpublic school or be receiving private instruction under }}}{{\f5\fs18\hyphpar0\qj{chapter 299A}}}{{\f5\fs18\hyphpar0\qj{ as described in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{. The school district or accredited nonpublic school in which the student is enrolled is responsible for recording a student\u8217\'3fs program coursework grades in the student\u8217\'3fs permanent record, awarding high school credit for program coursework, and issuing a high school diploma to a student enrolled in the district or school who participates and completes coursework under the program. Each school that participates in the program shall identify a site coordinator to serve as a student advocate and as a liaison between the program staff and teachers and the school district or accredited nonpublic school. The individual providing instruction to a student under }}}{{\f5\fs18\hyphpar0\qj{chapter 299A}}}{{\f5\fs18\hyphpar0\qj{ as described in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ shall receive the student\u8217\'3fs score for completed program coursework.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{School districts and accredited nonpublic schools shall pay to area education agencies the cost of providing coursework under an online learning program offered in accordance with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2020 Acts, ch 1107, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 88, \'a72}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7256.11}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{273.17 through 273.19}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER II}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E6_2E1_2E2}{REORGANIZATION OR DISSOLUTION}{\*\bkmkend stylerid1_2E6_2E1_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{273.20}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{When used in }{{\f5\fs18\hyphpar0\qj{this subchapter}}}{, unless the context otherwise requires:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAffected area education agency\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3faffected agency\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an area education agency whose board of directors is contemplating or engaged in reorganization efforts in accordance with }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAffected board\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the board of directors of an area education agency that is contemplating or engaged in reorganization efforts in accordance with }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDepartment\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the department of education.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fState board\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the state board of education.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 114, \'a72}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{273.21}}}{\*\bkmkstart stylerid1_2E6_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Voluntary reorganization.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Two or more area education agencies may voluntarily reorganize under this }}}{{\f5\fs18\hyphpar0\qj{subchapter}}}{{\f5\fs18\hyphpar0\qj{ if the area education agencies are contiguous, a majority of the members of each of the affected boards approve the reorganization, and the reorganization plan submitted to the state board pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{ is approved by the state board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If twenty percent or more of the school districts within an affected area education agency file a petition by December 1 with the affected area education agency board to consider reorganization, the affected board shall consider the request and vote on the petition. If a majority of the affected board members vote to study the reorganization of the affected area education agency, the affected board shall immediately begin the study to consider reorganization effective by July 1 of the next year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The affected boards contemplating a voluntary reorganization shall do the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Develop detailed studies of the facilities, property, services, staffing necessities, equipment, programs, and other capabilities available in each of the affected area education agencies for the purpose of providing for the reorganization of the area education agencies in order to effect more economical operation and the attainment of higher standards of educational services for the schools.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Survey the school districts within the affected area education agencies to determine the districts\u8217\'3f current and future programs and services, professional development, and technology needs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Consult with the officials of school districts within the affected area and other citizens and periodically hold public hearings during the development of a plan for reorganization, as well as a public hearing on the final plan to be submitted to the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Consult with the director of the department of education in the development of surveys and plans. The director of the department of education shall provide assistance and advice to the affected area education agency boards as requested.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Develop a reorganization plan that demonstrates improved efficiency and effectiveness of programs to meet accreditation standards, includes a preliminary budget for reorganized areas, documents public comment from the public hearings held pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and provides for a board of directors, and the number of members that the board shall consist of, in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 273.8}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Set forth the assets and liabilities of the affected area education agencies, which shall become the responsibility of the board of directors of the newly formed area education agency on the effective date of the reorganization.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Transmit the completed plan to the state board by July 15. Plans received by the state board after July 15 shall be considered for area education agency reorganization taking effect no sooner than July 1 after the next succeeding fiscal year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state board shall review the reorganization plan and shall, prior to September 30, either approve the plan as submitted, approve the plan contingent upon compliance with the state board\u8217\'3fs recommendations, or disapprove the plan. A contingently approved plan shall be resubmitted with modifications to the department not later than October 30. An approved plan shall take effect on July 1 of the fiscal year following the date of approval by the state board.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 114, \'a73}}}{; }{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1029, \'a71, 2, 8}}}{; }{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 180, \'a721 \u8211\'3f 23}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7273.22}}}{{\f5\fs12\hyphpar0\qj{, 273.23}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{273.22}}}{\*\bkmkstart stylerid1_2E6_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Contracts of new area education agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The terms of employment of the administrator and staff of affected area education agencies for the school year beginning with the effective date of the formation of the new area education agency shall not be affected by the formation of the new area education agency, except in accordance with the provisions of }}}{{\f5\fs18\hyphpar0\qj{sections 279.15 through 279.18,}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{279.24}}}{{\f5\fs18\hyphpar0\qj{, and the authority and responsibility to offer new contracts or to continue, modify, or terminate existing contracts pursuant to }}}{{\f5\fs18\hyphpar0\qj{sections 279.12}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{279.13}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{279.15 through 279.21}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{279.23}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{279.24}}}{{\f5\fs18\hyphpar0\qj{ for the school year beginning with the effective date of the reorganization shall be transferred from the boards of the existing area education agencies to the board of the new area education agency following approval of the reorganization plan by the state board as provided in }}}{{\f5\fs18\hyphpar0\qj{section 273.21, subsection 4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The collective bargaining agreement of the area education agency with the largest basic enrollment, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 257.6}}}{{\f5\fs18\hyphpar0\qj{, for the year prior to the year the reorganization is effective, shall serve as the base agreement in the new area education agency and the employees of the other area education agencies involved in the formation of the new area education agency shall automatically be accreted to the bargaining unit of that collective bargaining agreement for purposes of negotiating the contracts for the following years without further action by the employment appeal board. If only one collective bargaining agreement is in effect among the area education agencies that are party to the reorganization, that agreement shall serve as the base agreement, and the employees of the other agencies involved in the formation of the new area education agency shall automatically be accreted to the bargaining unit of that collective bargaining agreement for purposes of negotiating the contracts for the following years without further action by the employment appeal board.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of the newly formed area education agency, using the base agreement as its existing contract, shall bargain with the combined employees of the affected agencies for the school year that begins on the effective date of the reorganization. The bargaining shall be completed by the dates specified in }}}{{\f5\fs18\hyphpar0\qj{section 20.17}}}{{\f5\fs18\hyphpar0\qj{ prior to the school year in which the reorganization becomes effective or within one hundred eighty days after the organization of the new board, whichever is later. If a bargaining agreement was already concluded by the board and employees of the affected agency with the contract serving as the base agreement for the school year beginning with the effective date of the reorganization, that agreement shall be void. However, if the base agreement contains multiyear provisions affecting school years subsequent to the effective year of the reorganization, the base agreement shall remain in effect as specified in the agreement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The provisions of the base agreement shall apply to the offering of new contracts or continuation, modification, or termination of existing contracts as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The terms of a contract between the board of directors of a school district and the board of directors of an affected area education agency shall be carried out by the school board and the board of directors of the newly formed area education agency except as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of directors of a school district that is under a contract with an affected area education agency may petition the boards of directors of the affected area education agencies for release from the contract. If the petition receives a majority of the votes cast by the members of the boards of the affected area education agencies, the petition is approved and the contract shall be terminated on the effective date of the area education agency reorganization.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Not later than fifteen days after the state board notifies an area education agency of its approval of the area education agency\u8217\'3fs reorganization plan or dissolution proposal, the area education agency shall notify, by certified mail, the school districts located within the area education agency boundaries, the school districts and area education agencies that are contiguous to its boundaries, and any other school district under contract with the area education agency, of the state board\u8217\'3fs approval of the plan or proposal, and shall provide the department of education with a copy of any notice sent in accordance with }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. A petition to join an area education agency or for release from a contract with an area education agency, in accordance with }}}{{\f5\fs18\hyphpar0\qj{subsections 4, 6, and 7}}}{{\f5\fs18\hyphpar0\qj{, shall be filed not later than forty-five days after the state board approves a reorganization plan or dissolution proposal in accordance with }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Within forty-five days of the state board\u8217\'3fs approval, the board of directors of a school district that is contiguous to a newly reorganized area education agency may petition the board of directors of their current area education agency and the newly reorganized area education agency to join the newly reorganized area education agency. If the initial, or new board if established in time under }}}{{\f5\fs18\hyphpar0\qj{section 273.23, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, and the board of the contiguous area education agency approve the petition, the reorganization, including any school district whose petition to join the newly reorganized area education agency has been approved, shall take effect in accordance with the dates established under }}}{{\f5\fs18\hyphpar0\qj{section 273.21, subsection 4}}}{{\f5\fs18\hyphpar0\qj{. Both the initial, or new, and the contiguous area education agency boards must act within forty-five days of the deadline, as set forth in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, for the filing of the school district\u8217\'3fs petition. Within ten days of an area education agency board\u8217\'3fs action, a school district may appeal to the state board the decision of an area education agency board to deny the school district\u8217\'3fs petition.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Within forty-five days of the state board\u8217\'3fs approval, the board of directors of a school district that is within a newly reorganized area education agency and whose school district is contiguous to another area education agency not included in the newly reorganized area education agency may petition the board of directors of the newly reorganized area education agency and the contiguous area education agency to join that area education agency. If the initial, or new board if established in time under }}}{{\f5\fs18\hyphpar0\qj{section 273.23, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, and the board of the contiguous area education agency approve the petition, the reorganization, excluding any school district whose petition to join an area education agency contiguous to the newly reorganized area education agency has been approved, shall take effect in accordance with the dates established under }}}{{\f5\fs18\hyphpar0\qj{section 273.21, subsection 4}}}{{\f5\fs18\hyphpar0\qj{. Both the initial, or new, and the contiguous area education agency boards must act within forty-five days of the deadline, as set forth in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, for the filing of the school district\u8217\'3fs petition. Within ten days of an area education agency board\u8217\'3fs action, a school district may appeal to the state board the decision of an area education agency board to deny the school district\u8217\'3fs petition.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 114, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 176, \'a736, 37}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1029, \'a73, 4, 8}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 180, \'a724 \u8211\'3f 26}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1101, \'a796, 102}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1152, \'a733}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a796}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1170, \'a7298}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7273.23}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{273.23}}}{\*\bkmkstart stylerid1_2E6_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Initial board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A petition filed under }}}{{\f5\fs18\hyphpar0\qj{section 273.21}}}{{\f5\fs18\hyphpar0\qj{ shall state the number of directors on the initial board, which shall be either seven or nine directors. The petition shall specify the number of directors to be retained from each area, and those numbers shall be proportionate to the populations of the agencies. If the proportionate balance of directors among the affected agencies specified in the plan is affected by school districts petitioning to be excluded from the reorganization, or if the proposal specified in the plan does not comply with the requirement for proportionate representation, the state board shall modify the proposal. However, all area education agencies affected shall retain at least one member.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prior to the organization meeting of the board of directors of the newly formed area education agency, the boards of the former area education agencies shall designate directors to be retained as members to serve on the initial board of the newly formed area education agency. A vacancy occurs if an insufficient number of former board members reside within the newly formed area education agency\u8217\'3fs boundaries or if an insufficient number of former board members are willing to serve on the board of the newly formed area education agency. Vacancies, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 277.29}}}{{\f5\fs18\hyphpar0\qj{, in the membership of the newly formed area education agency board shall be filled for the unexpired portion of the term at a director district convention called and conducted in the manner provided in }}}{{\f5\fs18\hyphpar0\qj{section 273.8}}}{{\f5\fs18\hyphpar0\qj{ for director district conventions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Not later than January 15 of the calendar year in which the reorganization takes effect, the initial board shall call a director district convention under the provisions of }}}{{\f5\fs18\hyphpar0\qj{section 273.8, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, for the purpose of electing a board for the reorganized area education agency. The new board shall have control of the employment of all personnel for the newly formed area education agency for the ensuing school year. Following the organization of the new board, the board shall have authority to establish policy, enter into contracts, and complete such planning and take such action as is essential for the efficient management of the newly formed area education agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The initial board of the newly formed district shall appoint an acting administrator and an acting board secretary. The appointment of the acting administrator shall not be subject to the continuing contract provisions of }}}{{\f5\fs18\hyphpar0\qj{sections 279.20}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{279.23}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{279.24}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The initial board, or new board if established in time under }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{, of the newly formed agency shall prepare an annual budget estimating income and expenditures for programs and services as provided in }}}{{\f5\fs18\hyphpar0\qj{sections 273.1 through 273.9}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{chapter 256B}}}{{\f5\fs18\hyphpar0\qj{ within the limits of funds provided under }}}{{\f5\fs18\hyphpar0\qj{section 256B.9}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{chapter 257}}}{{\f5\fs18\hyphpar0\qj{. The board shall give notice of a public hearing on the proposed budget by publication in an official county newspaper in each county in the territory of the area education agency in which the principal place of business of a school district that is a part of the area education agency is located. The notice shall specify the date, which shall not be later than March 1, the time, and the location of the public hearing. The proposed budget as approved by the board shall be submitted to the state board, on forms provided by the department, no later than March 15 for approval. The state board shall review the proposed budget of the newly formed area education agency and shall, before May 1, either grant approval or return the budget without approval with comments of the state board included. An unapproved budget shall be resubmitted to the state board for final approval not later than May 15. The state board shall give final approval only to budgets submitted by area education agencies accredited by the state board or that have been given conditional accreditation by the state board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the school year beginning on the effective date of an area education agency reorganization as provided in }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{, the media services cost per pupil as determined under }}}{{\f5\fs18\hyphpar0\qj{section 257.37}}}{{\f5\fs18\hyphpar0\qj{ for all districts in a newly formed area education agency for the budget year shall be the highest amount of media services cost per pupil for any of the affected area education agencies.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the school year beginning on the effective date of an area education agency reorganization as provided in }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{, the educational services cost per pupil as determined under }}}{{\f5\fs18\hyphpar0\qj{section 257.37}}}{{\f5\fs18\hyphpar0\qj{ for all districts in a newly formed area education agency for the budget year shall be the highest amount of educational services cost per pupil for any of the affected area education agencies.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the school year beginning on the effective date of an area education agency reorganization as provided in }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{, the special education support services cost per pupil shall be based upon the combined base year budgets for special education support services of the area education agencies that reorganized to form the newly formed area education agency, divided by the total of the weighted enrollment for special education support services in the reorganized area education agency for the base year plus the supplemental state aid amount per pupil for special education support services for the budget year as calculated in }}}{{\f5\fs18\hyphpar0\qj{section 257.8}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Within one year of the effective date of the reorganization, a newly formed area education agency shall meet the accreditation requirements set forth in }}}{{\f5\fs18\hyphpar0\qj{section 273.10}}}{{\f5\fs18\hyphpar0\qj{, and the standards set forth in }}}{{\f5\fs18\hyphpar0\qj{section 273.11}}}{{\f5\fs18\hyphpar0\qj{. The newly formed area education agency shall be considered accredited for purposes of budget approval by the state board pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 273.3}}}{{\f5\fs18\hyphpar0\qj{. The state board shall inform the newly formed area education agency of the accreditation on-site visit schedule.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The special education support cost per pupil, the media cost per pupil, and the educational services cost per pupil for a school district petitioning into an area education agency shall be the special education support cost per pupil, media cost per pupil, and educational services cost per pupil of the area education agency into which it petitions if the petition is approved.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Unless the reorganization of an area education agency takes effect less than two years before the taking of the next federal decennial census, a newly formed area education agency shall, within one year of the effective date of the reorganization, redraw the boundary lines of director districts in the area education agency if a petition filed by a school district to join the newly formed area education agency, or for release from the newly formed area education agency, in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 273.22, subsections 4, 6, and 7}}}{{\f5\fs18\hyphpar0\qj{, was approved. Until the boundaries are redrawn, the boundaries for the newly formed area education agency shall be as provided in the reorganization plan approved by the state board in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 273.21}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 114, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1029, \'a75 \u8211\'3f 8}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 180, \'a727, 28}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1101, \'a797, 102}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 88, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 121, \'a740, 42}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7273.8}}}{{\f5\fs12\hyphpar0\qj{, 273.22}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section not amended; editorial change applied}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{273.24}}}{\*\bkmkstart stylerid1_2E6_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Commission to dissolve area education agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As an alternative to area education agency reorganization prescribed in }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{, the board of directors of an area education agency may establish an area education agency dissolution commission to prepare a proposal of dissolution of the area education agency and attachment of all of the area education agency to one or more contiguous area education agencies and to include in the proposal a division of the assets and liabilities of the dissolving area education agency. If twenty percent or more of the school districts within an area education agency file a petition by March 1 with the area education agency board to consider dissolving, the area education agency board shall consider the request and vote on the petition. If a majority of the board members vote to study dissolving the area education agency, the agency board shall immediately begin a study to consider such action effective by July 1 of the next calendar year, or the area education agency board may establish a dissolution commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An area education agency dissolution commission established by the board of directors of an area education agency shall consist of a minimum of seven members appointed by the board of directors of the area education agency for a term of office ending either with a report to the board that no proposal can be approved or on the date of the vote on the proposal. Members of the dissolution commission must be board members of school districts within the area served, not more than three of whom may be members of the board of directors of the area education agency. Members shall be appointed from throughout the area served and should represent the various school districts present in the area served.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Members of the dissolution commission shall serve without compensation and may be appointed to a subsequent commission. A vacancy on the commission shall be filled in the same manner as the original appointment was made.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of the area education agency shall certify to the department of education that a commission has been formed, the names and addresses of commission members, and that the commission members represent the various geographic areas and socioeconomic elements present in the school districts that the area serves.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 114, \'a76}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{273.25}}}{\*\bkmkstart stylerid1_2E6_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Dissolution commission meetings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall hold an organizational meeting not more than fifteen days after its appointment and shall elect a chairperson and vice chairperson from its membership. Thereafter the commission may meet as often as deemed necessary upon the call of the chairperson or a majority of the commission members.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall request statements from contiguous area education agencies outlining each agency\u8217\'3fs willingness to accept attachments of the affected area education agency to the contiguous agencies and what conditions, if any, the contiguous agency recommends. The commission shall meet with boards of contiguous area education agencies and with boards of directors of the affected school districts to the extent possible in drawing up the dissolution proposal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission may seek assistance from the department of education.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 114, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1041, \'a772}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{273.26}}}{\*\bkmkstart stylerid1_2E6_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Dissolution proposal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Not later than one year following the date of the organizational meeting of the commission, the commission shall send a copy of its dissolution proposal to the affected area education agency board or shall inform the affected area education agency board that it cannot agree upon a dissolution proposal. The commission shall also send a copy of the dissolution proposal by certified mail to the boards of directors of all school districts and other area education agencies affected. If the board of a school district or the board of an area education agency affected by the dissolution proposal objects to the proposal, either board shall send its objections in writing to the commission within ten days following receipt of the dissolution proposal. The commission may consider the objections and may modify the dissolution proposal. If the dissolution proposal is modified, the commission shall notify by certified mail the boards of directors of all area education agencies to which an area of the affected area education agency will be attached and shall notify by certified mail the board of directors of all school districts in the affected area education agencies.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the commission cannot agree upon a dissolution proposal prior to the expiration of its term, the affected area education agency board may appoint a new commission.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 114, \'a78}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{273.27}}}{\*\bkmkstart stylerid1_2E6_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Hearing \u8212\'3f vote \u8212\'3f state board approval.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Within ten days following the filing of the dissolution proposal with the affected area education agency board, the affected board shall fix a date for a hearing on the proposal, which shall not be more than sixty days after the dissolution petition was filed with the affected board. The affected board shall publish notice of the date, time, and location of the hearing at least ten days prior to the date of the hearing by one publication in a newspaper in general circulation in the area. The notice shall include the contents of the dissolution proposal.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Representatives of school districts in the area served may present evidence and arguments at the hearing. The president of the affected board shall preside at the hearing. The affected board shall review testimony from the hearing and shall adopt or amend and adopt the dissolution proposal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The affected board shall notify by certified mail the boards of directors of all school districts in the affected area education agency and the contiguous area education agencies to which the districts of the affected area education agency will be attached and the director of the department of education of the contents of the dissolution proposal adopted by the affected board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Within thirty days of the hearing, the affected board shall call a director district convention in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 273.8, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, which shall include the boards of directors in the area served by the area education agencies to which an area of the affected area education agency will be attached under the dissolution proposal, for the purpose of voting on the dissolution proposal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the dissolution proposal is approved by a majority of all directors voting on the proposal, the proposal shall be forwarded to the state board by November 1. The state board shall review the dissolution plan proposal and shall, prior to January 1, either grant approval for the proposal or return the proposal with recommendations. An unapproved proposal may be resubmitted with modifications to the state board not later than February 1. A proposal shall take effect on July 1 of the fiscal year following the date of approval by the state board.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 114, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 180, \'a729}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7180}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section not amended; editorial change applied}\par}}