\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F29C}{\*\bkmkend codeChapter_5F29C}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 29C}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{EMERGENCY MANAGEMENT AND SECURITY}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a78.55}}}{{\f5\fs12\qc{, 30.2}}}{{\f5\fs12\qc{, 163.3A}}}{{\f5\fs12\qc{, 163.3D}}}{{\f5\fs12\qc{, 331.424}}}{{\f5\fs12\qc{, 331.427}}}{{\f5\fs12\qc{, 384.12}}}{{\f5\fs12\qc{, 455B.381}}}{{\f5\fs12\qc{, 455B.385}}}{{\f5\fs12\qc{, 456A.37}}}{{\f5\fs12\qc{, 622.10}}}{{\f5\fs12\qc{, 669.2}}}\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{29C.1}}}{\*\bkmkstart stylerid1_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Statement of policy.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Because of existing and increasing possibility of the occurrence of disasters, and in order to insure that preparations of this state will be adequate to deal with such disasters, and to provide for the common defense and to protect the public peace, health and safety, and to preserve the lives and property of the people of the state, it is the policy of this state:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To establish a department of homeland security and emergency management and to authorize the establishment of local organizations for emergency management in the political subdivisions of the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To confer upon the governor and upon the executive heads or governing bodies of the political subdivisions of the state the emergency powers provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To provide for the rendering of mutual aid among the political subdivisions of the state and with other states, to cooperate with the federal government with respect to the carrying out of emergency management functions, and to ensure the state government and its departments and agencies facilitate the rapid response of businesses and workers in the state and other states to a disaster.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C62, \'a728A.3; C66, 71, 73, 75, \'a729C.3; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a729C.1}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1139, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 179, \'a7157}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1023, \'a7157}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 29, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1095, \'a71, 14}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{29C.2}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCommission\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a local emergency management commission or joint emergency management commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDepartment\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the department of homeland security and emergency management.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDirector\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the director of the department of homeland security and emergency management.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDisaster\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means man-made and natural occurrences, such as fire, flood, drought, earthquake, tornado, windstorm, hazardous substance or nuclear power plant accident or incident, which threaten the public peace, health, and safety of the people or which damage and destroy public or private property. The term includes attack, sabotage, or other hostile action from within or without the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fHomeland security\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the detection, prevention, preemption, deterrence of, and protection from attacks targeted at state territory, population, and infrastructure.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLocal administrative entity\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a countywide provider, or a provider of a statewide program with local offices throughout the state, contracted for the administration of the disaster aid individual assistance grant program and the disaster case advocacy program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLocal emergency management agency\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a countywide joint county-municipal public safety agency organized to administer }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ under the authority of a commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMass notification and emergency messaging system\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a system which disseminates emergency and public safety-related information to the public by various means including but not limited to telephone, wireless communications service, dual party relay service or telecommunications device, text messaging, electronic mail, and facsimile, and which integrates with federal emergency messaging systems.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPublic disorder\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means such substantial interference with the public peace as to constitute a significant threat to the health and safety of the people or a significant threat to public or private property. The term includes insurrection, rioting, looting, and persistent violent civil disobedience.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a729C.2}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 32, \'a71}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1139, \'a72}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{; }{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts//CH0000.pdf" }{\fldrslt \f5 \fs18{{\f5\fs18\hyphpar0\qj\cf5{2001 Acts, 2nd Ex, ch 1, \'a720, 21, 28}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 69, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 29, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1136, \'a724}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 29, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 136, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1173, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a78D.9}}}{{\f5\fs12\hyphpar0\qj{, 24.6}}}{{\f5\fs12\hyphpar0\qj{, 29A.7}}}{{\f5\fs12\hyphpar0\qj{, 34A.2}}}{{\f5\fs12\hyphpar0\qj{, 34A.3}}}{{\f5\fs12\hyphpar0\qj{, 34A.8}}}{{\f5\fs12\hyphpar0\qj{, 135.140}}}{{\f5\fs12\hyphpar0\qj{, 256.9}}}{{\f5\fs12\hyphpar0\qj{, 257.31}}}{{\f5\fs12\hyphpar0\qj{, 273.2}}}{{\f5\fs12\hyphpar0\qj{, 273.3}}}{{\f5\fs12\hyphpar0\qj{, 273.14}}}{{\f5\fs12\hyphpar0\qj{, 298.3}}}{{\f5\fs12\hyphpar0\qj{, 331.441}}}{{\f5\fs12\hyphpar0\qj{, 384.3A}}}{{\f5\fs12\hyphpar0\qj{, 384.24}}}{{\f5\fs12\hyphpar0\qj{, 613.17}}}{{\f5\fs12\hyphpar0\qj{, 669.2}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{29C.3}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Proclamation of state of public disorder by governor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The governor may, after finding a state of public disorder exists, proclaim a state of public disorder emergency. This proclamation shall be in writing, indicate the area affected and the facts upon which it is based, be signed by the governor, and be filed with the secretary of state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notice of a proclamation of a state of public disorder emergency shall be given by the secretary of state by publication in a newspaper of general circulation in the area affected, by broadcast through radio and television serving the area affected, and by posting signs at conspicuous places within this area. The exercise of the special powers by the governor under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not be precluded by the lack of giving notice if the giving of notice has been diligently attempted. All orders and rules promulgated under the proclamation shall be given public notice by the governor in the area affected.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A state of public disorder emergency shall continue for ten days, unless sooner terminated by the governor. The general assembly may, by concurrent resolution, rescind a proclamation of a state of public disorder emergency. If the general assembly is not in session, the legislative council may, by a majority vote, rescind this proclamation. Rescission shall be effective upon filing of the concurrent resolution or resolution of the legislative council with the secretary of state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The governor may, during the existence of a state of public disorder emergency, prohibit:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any person being in a public place during the hours declared by the governor to be a period of curfew if this period does not exceed twelve hours in any one day and if its area of its application is specifically designated.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Public gatherings of a designated number of persons within a designated area.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The manufacture, use, possession, or transportation of any device or object designed to explode or produce uncontained combustion.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The possession of any flammable or explosive liquids or materials in a glass or uncapped container, except in connection with normal operation of motor vehicles or normal home and commercial use.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The sale, purchase, or dispensing of alcoholic beverages.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The sale, purchase, or dispensing of such other commodities as are designated by the governor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The use of certain streets or highways by the public.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Such other activities as the governor reasonably believes should be prohibited to help maintain life, health, property, or the public peace.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a729C.3}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2017 Acts, ch 54, \'a776}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 69, \'a734}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a768A.405A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{29C.4}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Judicial protections.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The supreme court shall promulgate rules for emergency proceedings to be effective upon the declaration of a state of public disorder emergency in order that the constitutional rights of all persons taken into custody shall be adequately protected.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a729C.4}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{29C.5}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{ Department of homeland security and emergency management.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department of homeland security and emergency management is created. The department of homeland security and emergency management shall be responsible for the administration of emergency planning matters, including emergency resource planning in this state, cooperation with, support of, funding for, and tasking of the civil air patrol for missions not qualifying for federal mission status as described in }{{\f5\fs18\hyphpar0\qj{section 29A.3A}}}{ in accordance with operational and funding criteria developed with the adjutant general and coordinated with the civil air patrol, homeland security activities, and coordination of available services and resources in the event of a disaster to include those services and resources of the federal government and private entities. }\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C62, \'a728A.1; C66, 71, 73, 75, \'a729C.1; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a729C.5}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1139, \'a73}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{; }{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2001/CH0001.pdf" }{\fldrslt \f5 \fs18{{\f5\fs18\hyphpar0\qj\cf5{2001 Acts, 2nd Ex, ch 1, \'a722, 28}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 179, \'a7157}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 119, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 29, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 28, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a77E.5}}}{{\f5\fs12\hyphpar0\qj{, 8.57D}}}{{\f5\fs12\hyphpar0\qj{, 29A.3A}}}{{\f5\fs12\hyphpar0\qj{, 418A.1}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{29C.6}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Proclamation of disaster emergency by governor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{In exercising the governor\u8217\'3fs powers and duties under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ and to effect the policy and purpose, the governor may:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{After finding a disaster exists or is threatened, proclaim a state of disaster emergency. This proclamation shall be in writing, indicate the area affected and the facts upon which it is based, be signed by the governor, and be filed with the secretary of state. If the state of disaster emergency specifically constitutes a public health disaster as defined in }}}{{\f5\fs18\hyphpar0\qj{section 135.140}}}{{\f5\fs18\hyphpar0\qj{, the written proclamation shall include a statement to that effect. A state of disaster emergency shall continue for thirty days, unless sooner terminated or extended in writing by the governor. The general assembly may, by concurrent resolution, rescind this proclamation. If the general assembly is not in session, the legislative council may, by majority vote, rescind this proclamation. Rescission shall be effective upon filing of the concurrent resolution or resolution of the legislative council with the secretary of state. A proclamation of disaster emergency shall activate the disaster response and recovery aspect of the state, local, and interjurisdictional disaster emergency plans applicable to the political subdivision or area in question and be authority for the deployment and use of any forces to which the plan applies, and for use or distribution of any supplies, equipment, and materials and facilities assembled, stockpiled, or arranged to be made available.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When, at the request of the governor, the president of the United States has declared a major disaster to exist in this state, enter into purchase, lease, or other arrangements with any agency of the United States for temporary housing units to be occupied by disaster victims and to make such units available to any political subdivision of the state, to assist any political subdivision of this state which is the locus of temporary housing for disaster victims, to acquire sites necessary for such temporary housing and to do all things required to prepare such sites to receive and utilize temporary housing units, by advancing or lending funds available to the governor from any appropriation made by the legislature or from any other source, allocating funds made available by any agency, public or private, or becoming a copartner with the political subdivision for the execution and performance of any temporary housing for disaster victims project. Any political subdivision of this state is expressly authorized to acquire, temporarily or permanently, by purchase, lease, or otherwise, sites required for installation of temporary housing units for disaster victims, and to enter into whatever arrangements are necessary to prepare or equip such sites to utilize the housing units. The governor may temporarily suspend or modify, for not to exceed sixty days, any public health, safety, zoning, transportation, or other requirement of law or regulation within this state when by proclamation, the governor deems such suspension or modification essential to provide temporary housing for disaster victims.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When the president of the United States has declared a major disaster to exist in the state and upon the governor\u8217\'3fs determination that a local government of the state will suffer a substantial loss of tax and other revenues from a major disaster and has demonstrated a need for financial assistance to perform its governmental functions, apply to the federal government, on behalf of the local government for a loan, receive and disburse the proceeds of any approved loan to any applicant local government, determine the amount needed by any applicant local government to restore or resume its governmental functions, and certify the same to the federal government; however, no application amount shall exceed twenty-five percent of the annual operating budget of the applicant for the fiscal year in which the major disaster occurs. The governor may recommend to the federal government, based upon the governor\u8217\'3fs review, the cancellation of all or any part of repayment when, in the first three full fiscal year period following the major disaster, the revenues of the local government are insufficient to meet its operating expenses, including additional disaster-related expenses of a municipal operation character.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When a disaster emergency is proclaimed, notwithstanding any other provision of law, through the use of state agencies or the use of any of the political subdivisions of the state, clear or remove from publicly or privately owned land or water, debris and wreckage which may threaten public health or safety or public or private property. The governor may accept funds from the federal government and utilize such funds to make grants to any local government for the purpose of removing debris or wreckage from publicly or privately owned land or water. Authority shall not be exercised by the governor unless the affected local government, corporation, organization, or individual shall first present an additional authorization for removal of such debris or wreckage from public and private property and, in the case of removal of debris or wreckage from private property, such corporation, organization, or individual shall first agree to hold harmless the state or local government against any claim arising from such removal. The state and any of its officers or employees who are engaged in the removal of debris or wreckage on public property shall not be liable to the affected local government on account of any act or omission in good faith while so engaged or on account of the maintenance or use of any equipment or supplies in connection with the removal of debris or wreckage. For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fgood faith\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall not include willful misconduct, gross negligence, or recklessness. When the governor provides for clearance of debris or wreckage, employees of the designated state agencies or individuals appointed by the state may enter upon private land or waters and perform any tasks necessary to the removal or clearance operation. Any state employee or agent complying with orders of the governor and performing duties pursuant to such orders under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall be considered to be acting within the scope of employment within the meaning specified in }}}{{\f5\fs18\hyphpar0\qj{chapter 669}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When the president of the United States has declared a major disaster to exist in the state and upon the governor\u8217\'3fs determination that financial assistance is essential to meet disaster-related necessary expenses or serious needs of individuals or families adversely affected by a major disaster that cannot be otherwise adequately met from other means of assistance, accept a grant by the federal government to fund such financial assistance, subject to such terms and conditions as may be imposed upon the grant and enter into an agreement with the federal government pledging the state to participate in the funding of the financial assistance authorized in an amount not to exceed twenty-five percent thereof, and, if state funds are not otherwise available to the governor, accept an advance of the state share from the federal government to be repaid when the state is able to do so.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Suspend the provisions of any regulatory statute prescribing the procedures for conduct of state business, or the orders or rules, of any state agency, if strict compliance with the provisions of any statute, order, or rule would in any way prevent, hinder, or delay necessary action in coping with the emergency by stating in a proclamation such reasons. Upon the request of a local governing body, the governor may also suspend statutes limiting local governments in their ability to provide services to aid disaster victims.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On behalf of this state, enter into mutual aid arrangements with other states, including mutual aid arrangements with other states that extend the terms and conditions set forth in the interstate emergency management assistance compact described in }}}{{\f5\fs18\hyphpar0\qj{section 29C.21}}}{{\f5\fs18\hyphpar0\qj{ to situations in which an emergency or disaster proclamation has not been made by the governor of an affected state, and to coordinate mutual aid plans between political subdivisions of this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Delegate any administrative authority vested in the governor under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and provide for the subdelegation of any such authority.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Cooperate with the president of the United States and the heads of the armed forces, the emergency management agencies of the United States and other appropriate federal officers and agencies and with the officers and agencies of other states in matters pertaining to emergency management of the state and nation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Utilize all available resources of the state government as reasonably necessary to cope with the disaster emergency and of each political subdivision of the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Transfer the direction, personnel, or functions of state departments and agencies or units thereof for the purpose of performing or facilitating emergency management.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subject to any applicable requirements for compensation, commandeer or utilize any private property if the governor finds this necessary to cope with the disaster emergency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Direct the evacuation of all or part of the population from any stricken or threatened area within the state if the governor deems this action necessary for the preservation of life or other disaster mitigation, response, or recovery.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prescribe routes, modes of transportation, and destinations in connection with evacuation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Control ingress and egress to and from a disaster area, the movement of persons within the area, and the occupancy of premises in such area.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{16.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Suspend or limit the sale, dispensing, or transportation of alcoholic beverages, explosives, and combustibles.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{17.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When the president of the United States has declared a major disaster to exist in the state or any other emergency financial assistance is provided by the federal government, and upon the governor\u8217\'3fs determination that financial assistance is essential to meet disaster-related necessary expenses or serious needs of local and state government adversely affected by a major disaster or emergency that cannot be otherwise adequately met from other means of assistance, accept a grant by the federal government to fund the financial assistance, subject to terms and conditions imposed upon the grant, and enter into an agreement with the federal government pledging the state to participate in the funding of the financial assistance authorized to local government and eligible private nonprofit agencies in an amount not to exceed ten percent of the total eligible expenses, with the applicant providing the balance of any participation amount. If financial assistance is granted by the federal government for state disaster or emergency financial assistance-related expenses or serious needs, the state shall participate in the funding of the financial assistance authorized in an amount not to exceed twenty-five percent of the total eligible expenses. If financial assistance is granted by the federal government for hazard mitigation, the state may participate in the funding of the financial assistance authorized to a local government in an amount not to exceed ten percent of the eligible expenses, with the applicant providing the balance of any participation amount. If financial assistance is granted by the federal government for state-related hazard mitigation, the state may participate in the funding of the financial assistance authorized, not to exceed fifty percent of the total eligible expenses. If state funds are not otherwise available to the governor, an advance of the state share may be accepted from the federal government to be repaid when the state is able to do so.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{State participation in funding financial assistance under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ is contingent upon the local government having on file a state-approved, comprehensive emergency plan which meets the standards adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 29C.9, subsection 8}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{18.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Direct the disbursement of moneys by the department of management under }}}{{\f5\fs18\hyphpar0\qj{section 8.55, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ff\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, with the approval of the executive council.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C62, \'a728A.3; C66, 71, 73, 75, \'a729C.3; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a729C.6}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 32, \'a72}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 53, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1139, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 86, \'a73, 4}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 33, \'a77, 11}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 69, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1014, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 54, \'a776}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 69, \'a735}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1081, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 66, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1043, \'a731}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1069, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 28, \'a783}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a78.55}}}{{\f5\fs12\hyphpar0\qj{, 8D.9}}}{{\f5\fs12\hyphpar0\qj{, 16.57B}}}{{\f5\fs12\hyphpar0\qj{, 16.194}}}{{\f5\fs12\hyphpar0\qj{, 16.194A}}}{{\f5\fs12\hyphpar0\qj{, 16.196}}}{{\f5\fs12\hyphpar0\qj{, 29C.7}}}{{\f5\fs12\hyphpar0\qj{, 29C.8}}}{{\f5\fs12\hyphpar0\qj{, 29C.24}}}{{\f5\fs12\hyphpar0\qj{, 53.2}}}{{\f5\fs12\hyphpar0\qj{, 68A.405A}}}{{\f5\fs12\hyphpar0\qj{, 100D.13}}}{{\f5\fs12\hyphpar0\qj{, 135.140}}}{{\f5\fs12\hyphpar0\qj{, 135.144}}}{{\f5\fs12\hyphpar0\qj{, 135M.1}}}{{\f5\fs12\hyphpar0\qj{, 135M.3}}}{{\f5\fs12\hyphpar0\qj{, 135M.4}}}{{\f5\fs12\hyphpar0\qj{, 161A.75}}}{{\f5\fs12\hyphpar0\qj{, 418.4}}}{{\f5\fs12\hyphpar0\qj{, 423.6}}}{{\f5\fs12\hyphpar0\qj{, 455B.262A}}}{{\f5\fs12\hyphpar0\qj{, 613.17}}}{{\f5\fs12\hyphpar0\qj{, 670.4}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Emergency care or assistance rendered during disasters, see }{{\f5\fs12\hyphpar0\qj{\'a7613.17}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{NEW subsection 18}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{29C.7}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Hazard mitigation financial assistance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If financial assistance is granted by the federal government under the federal }}}{{\f5\fs18\hyphpar0\qj{Robert T. Stafford Disaster Relief and Emergency Assistance Act}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{Pub. L. No. 93-288, as amended}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{42 U.S.C. \'a75121 et seq.}}}{{\f5\fs18\hyphpar0\qj{ or the federal }}}{{\f5\fs18\hyphpar0\qj{National Flood Insurance Reform Act of 1994}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{Pub. L. No. 103-325}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{42 U.S.C. \'a74001 et seq.}}}{{\f5\fs18\hyphpar0\qj{ for hazard mitigation and }}}{{\f5\fs18\hyphpar0\qj{section 29C.6}}}{{\f5\fs18\hyphpar0\qj{ is not applicable, the state may participate in the funding of the financial assistance authorized to a local government in an amount not to exceed ten percent of the eligible expenses, with the applicant providing the balance of any participation amount. If financial assistance is granted by the federal government as described in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ for state-related hazard mitigation, the state may participate in the funding of the financial assistance authorized, not to exceed fifty percent of the total eligible expenses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{State participation in funding financial assistance to local government under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ is contingent upon the local government having on file a state-approved, comprehensive emergency plan which meets the standards adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 29C.9, subsection 8}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2020 Acts, ch 1041, \'a71}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{29C.8}}}{\*\bkmkstart stylerid1_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Powers and duties of director.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of homeland security and emergency management shall be under the management of a director who shall be appointed by the governor, subject to confirmation by the senate, and who shall serve at the pleasure of the governor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director shall be vested with the authority to administer emergency management and homeland security affairs in this state and shall be responsible for preparing and executing the emergency management and homeland security programs of this state subject to the direction of the governor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director, upon the direction of the governor, shall:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prepare a comprehensive emergency plan and emergency management program for homeland security, disaster preparedness, response, recovery, mitigation, emergency operation, and emergency resource management of this state. The plan and program shall be integrated into and coordinated with the homeland security and emergency plans of the federal government and of other states to the fullest possible extent. The director shall also coordinate the preparation of plans and programs for emergency management of the political subdivisions and various state departments of this state. The plans shall be integrated into and coordinated with a comprehensive state homeland security and emergency program for this state as coordinated by the director to the fullest possible extent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Make such studies and surveys of the industries, resources, and facilities in this state as may be necessary to ascertain the vulnerabilities of critical state infrastructure and assets to attack and the capabilities of the state for disaster recovery, disaster planning and operations, and emergency resource management, and to plan for the most efficient emergency use thereof.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide technical assistance to any commission requiring the assistance in the development of an emergency management or homeland security program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Implement planning and training for emergency response teams as mandated by the federal government under the }}}{{\f5\fs18\hyphpar0\qj{Comprehensive Environmental Response, Compensation, and Liability Act of 1980}}}{{\f5\fs18\hyphpar0\qj{ as amended by the }}}{{\f5\fs18\hyphpar0\qj{Superfund Amendments and Reauthorization Act of 1986}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{42 U.S.C. \'a79601 et seq}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prepare a critical asset protection plan that contains an inventory of infrastructure, facilities, systems, other critical assets, and symbolic landmarks; an assessment of the criticality, vulnerability, and level of threat to the assets; and information pertaining to the mobilization, deployment, and tactical operations involved in responding to or protecting the assets.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Approve and support the development and ongoing operations of homeland security and emergency response teams to be deployed as a resource to supplement and enhance disrupted or overburdened local emergency and disaster operations and deployed as available to provide assistance to other states pursuant to the interstate emergency management assistance compact described in }}}{{\f5\fs18\hyphpar0\qj{section 29C.21}}}{{\f5\fs18\hyphpar0\qj{. The following shall apply to homeland security and emergency response teams:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A member of a homeland security and emergency response team acting under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ upon the directive of the director or pursuant to a governor\u8217\'3fs disaster emergency proclamation as provided in }}}{{\f5\fs18\hyphpar0\qj{section 29C.6}}}{{\f5\fs18\hyphpar0\qj{ shall be considered an employee of the state for purposes of }}}{{\f5\fs18\hyphpar0\qj{section 29C.21}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{chapter 669}}}{{\f5\fs18\hyphpar0\qj{ and shall be afforded protection as an employee of the state under }}}{{\f5\fs18\hyphpar0\qj{section 669.21}}}{{\f5\fs18\hyphpar0\qj{. Disability, workers\u8217\'3f compensation, and death benefits for team members working under the authority of the director or pursuant to the provisions of }}}{{\f5\fs18\hyphpar0\qj{section 29C.6}}}{{\f5\fs18\hyphpar0\qj{ shall be paid by the state in a manner consistent with the provisions of }}}{{\f5\fs18\hyphpar0\qj{chapter 85}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{410}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{411}}}{{\f5\fs18\hyphpar0\qj{ as appropriate, depending on the status of the member, provided that the member is registered with the department as a member of an approved team and is participating as a team member in a response or recovery operation initiated by the director or governor pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ or in a training or exercise activity approved by the director.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each approved homeland security and emergency management response team shall establish standards for team membership, shall provide the department with a listing of all team members, and shall update the list each time a member is removed from or added to the team. Individuals so identified as team members shall be considered to be registered as team members for purposes of subparagraph (1).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon notification of a compensable loss to a member of a homeland security and emergency management response team, the department of administrative services shall process the claim and seek authorization from the executive council to pay as an expense paid from the appropriations addressed in }}}{{\f5\fs18\hyphpar0\qj{section 7D.29}}}{{\f5\fs18\hyphpar0\qj{ those costs associated with covered benefits.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Implement and support the national incident management system as established by the United States department of homeland security to be used by state agencies and local and tribal governments to facilitate efficient and effective assistance to those affected by emergencies and disasters.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Carry out duties related to the flood mitigation program and the flood mitigation board under }}}{{\f5\fs18\hyphpar0\qj{chapter 418}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director, with the approval of the governor, may employ a deputy director and such technical, clerical, stenographic, and other personnel and make such expenditures within the appropriation or from other funds made available to the department, as may be necessary to administer }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department may charge fees for the repair, calibration, or maintenance of radiological detection equipment and may expend funds in addition to funds budgeted for the servicing of the radiological detection equipment. The department shall adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ providing for the establishment and collection of fees for radiological detection equipment repair, calibration, or maintenance services and for entering into agreements with other public and private entities to provide the services. Fees collected for repair, calibration, or maintenance services shall be treated as appropriated receipts as defined in }}}{{\f5\fs18\hyphpar0\qj{section 8.2}}}{{\f5\fs18\hyphpar0\qj{ and shall be used for the operation of the department\u8217\'3fs radiological maintenance facility or radiation incident response training.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C62, \'a728A.4, 28A.5; C66, 71, 73, 75, \'a729C.4, 29C.5; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a729C.8}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1190, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1139, \'a76 \u8211\'3f 8}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 86, \'a72}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{; }{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts//CH0000.pdf" }{\fldrslt \f5 \fs18{{\f5\fs18\hyphpar0\qj\cf5{2001 Acts, 2nd Ex, ch 1, \'a723, 24, 28}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1117, \'a754, 56}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 179, \'a7104, 157}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 119, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1185, \'a762}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 69, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 131, \'a722, 158}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1094, \'a71, 18}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 29, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1014, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72163}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1185, \'a7111}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a78.55}}}{{\f5\fs12\hyphpar0\qj{, 22.7(45)}}}{{\f5\fs12\hyphpar0\qj{, 29C.20}}}{{\f5\fs12\hyphpar0\qj{, 135.141}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Confirmation, see }{{\f5\fs12\hyphpar0\qj{\'a72.32}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{29C.8A}}}{\*\bkmkstart stylerid1_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Emergency response fund created.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An emergency response fund is created in the state treasury. The first one hundred thousand dollars received annually by the treasurer of state for the civil penalties and fines imposed by the court pursuant to }}}{{\f5\fs18\hyphpar0\qj{sections 455B.146}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{455B.191}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{455B.386}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{455B.477}}}{{\f5\fs18\hyphpar0\qj{ shall be deposited in the waste volume reduction and recycling fund created in }}}{{\f5\fs18\hyphpar0\qj{section 455D.15}}}{{\f5\fs18\hyphpar0\qj{. The next hundred thousand dollars shall be deposited in the emergency response fund and any additional moneys shall be deposited in the household hazardous waste account. All moneys received annually by the treasurer of the state for the fines imposed by }}}{{\f5\fs18\hyphpar0\qj{sections 716B.2}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{716B.3}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{716B.4}}}{{\f5\fs18\hyphpar0\qj{ shall also be deposited in the emergency response fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The emergency response fund shall be administered by the department to carry out planning and training for the emergency response teams.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1190, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1260, \'a721}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1139, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 179, \'a7157}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 9, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 29, \'a718}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7455E.11}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{29C.9}}}{\*\bkmkstart stylerid1_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Local emergency management commissions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county boards of supervisors, city councils, and the sheriff in each county shall cooperate with the department to establish a commission to carry out the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall be composed of a member of the board of supervisors, the sheriff, and the mayor from each city within the county. A commission member may designate an alternate to represent the designated entity. For any activity relating to }}}{{\f5\fs18\hyphpar0\qj{section 29C.17, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{chapter 24}}}{{\f5\fs18\hyphpar0\qj{, participation shall only be by a commission member or a designated alternate that is an elected official from the same designated entity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The name used by the commission shall be \u8220\'3f(county name) county emergency management commission\u8221\'3f. The name used by the office of the commission shall be \u8220\'3f(county name) county emergency management agency\u8221\'3f.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, a commission is a municipality as defined in }}}{{\f5\fs18\hyphpar0\qj{section 670.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall model its bylaws and conduct its business according to the guidelines provided in the department\u8217\'3fs administrative rules.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall determine the mission of its agency and program and provide direction for the delivery of the emergency management services of planning, administration, coordination, training, and support for local governments and their departments. The commission shall coordinate its services in the event of a disaster. The commission may also provide joint emergency response communications services through an agreement entered into under }}}{{\f5\fs18\hyphpar0\qj{chapter 28E}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall delegate to the emergency management coordinator the authority to fulfill the commission duties as described in the department\u8217\'3fs administrative rules. Each commission shall appoint a local emergency management coordinator who shall meet the qualifications specified in the administrative rules by the director. Additional emergency management personnel may be appointed at the discretion of the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall develop, adopt, and submit for approval by local governments within the commission\u8217\'3fs jurisdiction, a comprehensive emergency plan which meets standards adopted by the department in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{. If an approved comprehensive emergency plan has not been prepared according to established standards and the director finds that satisfactory progress is not being made toward the completion of the plan, or if the director finds that a commission has failed to appoint a qualified emergency management coordinator as provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, the director shall notify the governing bodies of the counties and cities affected by the failure and the governing bodies shall not appropriate any moneys to the local emergency management fund until the comprehensive emergency plan is prepared and approved or a qualified emergency management coordinator is appointed. If the director finds that a commission has appointed an unqualified emergency management coordinator, the director shall notify the commission citing the qualifications which are not met and the commission shall not approve the payment of the salary or expenses of the unqualified emergency management coordinator.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall encourage local officials to support and participate in exercise programs which test proposed or established jurisdictional emergency plans and capabilities. During emergencies when lives are threatened and extensive damage has occurred to property, the county and all cities involved shall fully cooperate with the emergency management agency to provide assistance in order to coordinate emergency management activities including gathering of damage assessment data required by state and federal authorities for the purposes of emergency declarations and disaster assistance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall, if agreed to by a two-thirds majority of the commission and a two-thirds majority of the joint 911 service board, be responsible for the activities of a joint 911 service board if substituted for a joint 911 service board pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 34A.3, subsection 4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Two or more commissions may, upon review by the director and with the approval of their respective boards of supervisors and cities, enter into agreements pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 28E}}}{{\f5\fs18\hyphpar0\qj{ for the joint coordination and administration of emergency management services throughout the multicounty area.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C62, \'a728A.7; C66, 71, 73, 75, \'a729C.7; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a729C.9}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 123, \'a740, 209}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1139, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 179, \'a7157}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 149, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 69, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1071, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 29, \'a719}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1073, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 64, \'a79}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a78D.13}}}{{\f5\fs12\hyphpar0\qj{, 29C.6}}}{{\f5\fs12\hyphpar0\qj{, 29C.7}}}{{\f5\fs12\hyphpar0\qj{, 29C.17}}}{{\f5\fs12\hyphpar0\qj{, 29C.22}}}{{\f5\fs12\hyphpar0\qj{, 34A.3}}}{{\f5\fs12\hyphpar0\qj{, 34A.8}}}{{\f5\fs12\hyphpar0\qj{, 331.381}}}{{\f5\fs12\hyphpar0\qj{, 331.653}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{29C.10}}}{\*\bkmkstart stylerid1_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Emergency management coordinator.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall appoint an emergency management coordinator who shall serve at the pleasure of the commission, shall be responsible for the development of the comprehensive emergency plan, shall coordinate emergency planning activities, and shall provide technical assistance to political subdivisions comprising the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When an emergency or disaster occurs, the emergency management coordinator shall provide coordination and assistance to the governing officials of the political subdivisions comprising the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission and its members shall cooperate with the president of the United States and the heads of the armed forces and other appropriate federal, state, and local officers and agencies and with the officers and agencies of adjoining states in matters pertaining to comprehensive emergency management for political subdivisions comprising the commission.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, \'a729C.7; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a729C.10}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1139, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 69, \'a76}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a78D.13}}}{{\f5\fs12\hyphpar0\qj{, 331.381}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{29C.11}}}{\*\bkmkstart stylerid1_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Local mutual aid arrangements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The local emergency management commission shall, in collaboration with other public and private agencies within this state, develop mutual aid arrangements for reciprocal disaster services and recovery aid and assistance in case of disaster too great to be dealt with unassisted. The arrangements shall be consistent with the department plan and program, and in time of emergency each local emergency management agency shall render assistance in accordance with the provisions of the mutual aid arrangements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The chairperson of a commission may, subject to the approval of the governor, enter into mutual aid arrangements with emergency management agencies or organizations in other states for reciprocal emergency services and recovery aid and assistance in case of disaster too great to be dealt with unassisted.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a729C.11}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1139, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 179, \'a7157}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 69, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 29, \'a720}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.381}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{29C.12}}}{\*\bkmkstart stylerid1_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Use of existing facilities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{In carrying out the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, the governor, the director, and the executive officers or governing boards of political subdivisions of the state shall utilize, to the maximum extent practicable, the services, equipment, supplies, and facilities of existing departments, officers, and agencies of the state and of political subdivisions at their respective levels of responsibility.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C62, \'a728A.8; C66, 71, 73, 75, \'a729C.8; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a729C.12}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2013 Acts, ch 29, \'a721}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.381}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{29C.12A}}}{\*\bkmkstart stylerid1_2E18_2E2_2E2}{\*\bkmkend stylerid1_2E18_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Participation in funding disaster recovery facility.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{All state government departments and agencies may participate in sharing the cost of the design, construction, and operation of a disaster recovery facility located in the joint forces headquarters armory at Camp Dodge. State departments and agencies may use funds from any source, including but not limited to user fees and appropriations for operational or capital purposes, to participate in the facility.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 263, \'a736}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 29, \'a722}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.381}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{29C.13}}}{\*\bkmkstart stylerid1_2E19_2E2_2E2}{\*\bkmkend stylerid1_2E19_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Funds by grants or gifts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the federal government or any agency or officer of the federal government offers to the state or through the state to any political subdivision of the state, services, equipment, supplies, materials, or funds by way of gift, grant, or loan, for purposes of emergency management, the governor or the political subdivision, acting with the consent of the governor and through its executive officer or governing body, may authorize any officer of the state or of the political subdivision to receive the services, equipment, supplies, materials, or funds on behalf of the state or the political subdivision, and subject to the terms of the offer and rules of the agency making the offer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If any person offers to the state or to any political subdivision of the state, services, equipment, supplies, materials, or funds by way of gift, grant, or loan, for purposes of emergency management, the governor or executive officer of the political subdivision may accept the offer and, upon acceptance, the governor of the state or executive officer or governing body of the political subdivision may authorize any officer of the state or of the political subdivision to receive such services, equipment, supplies, materials, or funds on behalf of the state or the political subdivision, and subject to the terms of the offer.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, \'a729C.9; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a729C.13}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1139, \'a713}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.381}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{29C.14}}}{\*\bkmkstart stylerid1_2E2_30_2E2_2E2}{\*\bkmkend stylerid1_2E2_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Director of the department of administrative services to issue warrants.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The director of the department of administrative services shall draw warrants on the treasurer of state for the purposes specified in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, upon duly itemized and verified vouchers that have been approved by the director of the department of homeland security and emergency management.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C62, \'a728A.9; C66, 71, 73, 75, \'a729C.10; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a729C.14}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1139, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 145, \'a7286}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 179, \'a7157}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 29, \'a723}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{29C.15}}}{\*\bkmkstart stylerid1_2E21_2E2_2E2}{\*\bkmkend stylerid1_2E21_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Tax-exempt purchases.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{All purchases under the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ shall be exempt from the taxes imposed by }{{\f5\fs18\hyphpar0\qj{sections 423.2}}}{ and }{{\f5\fs18\hyphpar0\qj{423.5}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C62, \'a728A.10; C66, 71, 73, 75, \'a729C.11; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a729C.15}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2003 Acts, 1st Ex, ch 2, \'a7156, 205}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{29C.16}}}{\*\bkmkstart stylerid1_2E22_2E2_2E2}{\*\bkmkend stylerid1_2E22_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Prohibited political activities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A person employed by any organization for emergency management established under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ shall not:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{During working hours or when performing official duties or when using public equipment or at any time on public property, take part in any way in soliciting any contribution for any political party or any person seeking political office. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Seek or attempt to use any political endorsement in connection with any appointment to a position created under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Use any official authority or influence for the purpose of interfering with an election or affecting the results of an election.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C62, \'a728A.11; C66, 71, 73, 75, \'a729C.12; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a729C.16}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1139, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1045, \'a71}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{29C.17}}}{\*\bkmkstart stylerid1_2E23_2E2_2E2}{\*\bkmkend stylerid1_2E23_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Local emergency management fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A local emergency management fund is created in the office of the county treasurer. Revenues provided and collected shall be deposited in the fund. An unencumbered balance in the fund shall not revert to county general revenues. Any reimbursement, matching funds, moneys received from sale of property, or moneys obtained from any source in connection with the local emergency management program shall be deposited in the local emergency management fund. The commission shall be the fiscal authority and the chairperson or vice chairperson of the commission is the certifying official.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes consistent with }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, the local emergency management agency\u8217\'3fs approved budget shall be funded by one or any combination of the following options, as determined by the commission:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A countywide special levy pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 331.424, subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Per capita allocation funded from city and county general funds or by a combination of city and county special levies which may be apportioned among the member jurisdictions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An allocation computed as each jurisdiction\u8217\'3fs relative share of the total assessed valuation within the county.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A voluntary share allocation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Other funding sources allowed by law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A political subdivision may appropriate additional funds for the purpose of supporting commission expenses relating to special or unique matters extending beyond the resources of the agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Joint emergency response communications services under }}}{{\f5\fs18\hyphpar0\qj{section 29C.9, subsection 6}}}{{\f5\fs18\hyphpar0\qj{, shall be funded as provided for in the agreement entered into pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 28E}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Expenditures from the local emergency management fund shall be made on warrants drawn by the county auditor, supported by claims and vouchers signed by the emergency management coordinator or chairperson of the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subject to }}}{{\f5\fs18\hyphpar0\qj{chapter 24}}}{{\f5\fs18\hyphpar0\qj{, the commission shall adopt, certify, and provide a budget, on or before February 28 of each year, to the funding entities determined pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{. The form of the budget shall be as prescribed by the department of management. Any portion of a tax levied by a county or city to support the local emergency management agency shall be identified separately on tax statements issued by the county treasurer.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C62, \'a728A.12; C66, 71, 73, 75, \'a729C.13; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a729C.17}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1139, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 69, \'a78, 9}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1071, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 30, \'a711}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a729C.9}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{29C.17A}}}{\*\bkmkstart stylerid1_2E24_2E2_2E2}{\*\bkmkend stylerid1_2E24_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Mass notification and emergency messaging system fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A mass notification and emergency messaging system fund is created in the state treasury under the control of the department. The fund shall consist of moneys appropriated by the general assembly and any other moneys available to and obtained or accepted by the department for placement in the fund. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 12C.7}}}{{\f5\fs18\hyphpar0\qj{, interest or earnings on moneys in the fund shall be credited to the fund. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 8.33}}}{{\f5\fs18\hyphpar0\qj{, moneys credited to the fund that remain unexpended or unobligated at the end of a fiscal year shall not revert to any other fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Amounts contained in the fund shall be used exclusively to provide for the purchase and ongoing operation of a system capable of providing mass notification and emergency messaging to the public. The system shall be purchased from a vendor selected by the department pursuant to a competitive bidding process, and shall, once purchased, be under the control of the department. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Information disseminated to the public through the mass notification and emergency messaging system shall be limited to imminent emergency and public safety-related issues. The department may provide access to the system for use at the county and local level. Access by a county or local government shall be at the department\u8217\'3fs sole discretion, and if approved by the department, shall be under the control of the local commission. The commission shall establish an operational plan and procedure which meets standards adopted by the department by rule, and shall submit the operational plan and procedure for approval by the department prior to access being granted. Additional access criteria and procedures for administering the fund shall be established by the department by rule.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All personal information collected for use in the mass notification and emergency messaging system, including but not limited to the names and contact information of emergency messaging recipients, shall be considered confidential records under }}}{{\f5\fs18\hyphpar0\qj{section 22.7}}}{{\f5\fs18\hyphpar0\qj{. The director may, however, provide all or part of such confidential information to state or local governmental agencies possessing emergency planning or response functions if the director is satisfied that the need to know the information and its intended use are reasonable. An agency receiving confidential information pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not redisseminate the information in any form without prior approval by the director. The release of confidential information by the department, a county or local government, or a state or local governmental agency other than as authorized pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, and the sale of such confidential information, is strictly prohibited.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2014 Acts, ch 1136, \'a725}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a734A.8}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{29C.18}}}{\*\bkmkstart stylerid1_2E25_2E2_2E2}{\*\bkmkend stylerid1_2E25_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Enforcement duties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Every organization for homeland security and emergency management established pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and its officers shall execute and enforce the orders or rules made by the governor, or under the governor\u8217\'3fs authority and the orders or rules made by subordinate organizations and not contrary or inconsistent with the orders or rules of the governor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A peace officer, when in full and distinctive uniform or displaying a badge or other insignia of authority, may arrest without a warrant any person violating or attempting to violate in such officer\u8217\'3fs presence any order or rule, made pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. This authority shall be limited to those rules which affect the public generally.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, \'a729C.15; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a729C.18}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1139, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 29, \'a724}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{29C.19}}}{\*\bkmkstart stylerid1_2E26_2E2_2E2}{\*\bkmkend stylerid1_2E26_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Rules and order exempted.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Any order issued or rule promulgated by a state agency during a declared disaster emergency and pursuant to the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ shall be exempt from being issued or promulgated as provided in }{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a729C.19}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{29C.20}}}{\*\bkmkstart stylerid1_2E27_2E2_2E2}{\*\bkmkend stylerid1_2E27_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Contingent fund \u8212\'3f disaster aid.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A contingent fund is created in the state treasury for the use of the executive council. Funding for the contingent fund, if authorized by the executive council, shall be paid from the appropriations addressed in }}}{{\f5\fs18\hyphpar0\qj{section 7D.29}}}{{\f5\fs18\hyphpar0\qj{. Moneys in the contingent fund may be expended for the following purposes:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Paying the expenses of suppressing an insurrection or riot, actual or threatened, when state aid has been rendered by order of the governor.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repairing, rebuilding, or restoring state property injured, destroyed, or lost by fire, storm, theft, or unavoidable cause.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repairing, rebuilding, or restoring state property that is fiberoptic cable and that is injured or destroyed by a wild animal.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Purchasing a police service dog for the department of corrections when such a dog is injured or destroyed.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Paying the expenses incurred by and claims of a homeland security and emergency response team when acting under the authority of }}}{{\f5\fs18\hyphpar0\qj{section 29C.8}}}{{\f5\fs18\hyphpar0\qj{, public health response teams when acting under the provisions of }}}{{\f5\fs18\hyphpar0\qj{section 135.143}}}{{\f5\fs18\hyphpar0\qj{, and a party state rendering assistance under the provisions of }}}{{\f5\fs18\hyphpar0\qj{section 29C.21}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Aiding any governmental subdivision in an area declared by the governor to be a disaster area due to natural disasters or to expenditures necessitated by the governmental subdivision toward averting or lessening the impact of the potential disaster, where the effect of the disaster or action on the governmental subdivision is the immediate financial inability to meet the continuing requirements of local government.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon application by a governmental subdivision in such an area, accompanied by a showing of obligations and expenditures necessitated by an actual or potential disaster in a form and with further information the executive council requires, the aid may be made in the discretion of the executive council and, if made, shall be in the nature of a loan up to a limit of seventy-five percent of the showing of obligations and expenditures. The loan, without interest, shall be repaid by the maximum annual emergency levy authorized by }}}{{\f5\fs18\hyphpar0\qj{section 24.6}}}{{\f5\fs18\hyphpar0\qj{, or by the appropriate levy authorized for a governmental subdivision not covered by }}}{{\f5\fs18\hyphpar0\qj{section 24.6}}}{{\f5\fs18\hyphpar0\qj{. The aggregate total of loans shall not exceed one million dollars during a fiscal year. A loan shall not be for an obligation or expenditure occurring more than two years previous to the application.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When a state department or agency requests that moneys from the contingent fund be expended to repair, rebuild, or restore state property injured, destroyed, or lost by fire, storm, theft, or unavoidable cause, or to repair, rebuild, or restore state property that is fiberoptic cable and that is injured or destroyed by a wild animal, or to purchase a police service dog for the department of corrections when such a dog is injured or destroyed, or for payment of the expenses incurred by and claims of a homeland security and emergency response team when acting under the authority of }}}{{\f5\fs18\hyphpar0\qj{section 29C.8}}}{{\f5\fs18\hyphpar0\qj{, the executive council shall consider the original source of the funds for acquisition of the property before authorizing the expenditure. If the original source was other than the general fund of the state, the department or agency shall be directed to utilize moneys from the original source if possible. The executive council shall not authorize the repairing, rebuilding, or restoring of the property from the disaster aid contingent fund if it determines that moneys from the original source are available to finance the project.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The proceeds of such loan shall be applied toward the payment of costs and obligations necessitated by such actual or potential disaster and the reimbursement of local funds from which such expenditures have been made. Any such project for repair, rebuilding or restoration of state property for which no specific appropriation has been made, shall, before work is begun, be subject to approval or rejection by the executive council.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the president of the United States, at the request of the governor, has declared a major disaster to exist in this state, or any other emergency financial assistance is provided by the federal government, the executive council may make financial grants to meet disaster or emergency funding-related necessary expenses, serious needs, or hazard mitigation projects of local governments and eligible private nonprofit agencies adversely affected by the major disaster or emergency if those expenses or needs cannot otherwise be met from other means of assistance. The amount of the grant shall not exceed ten percent of the total eligible expenses and is conditional upon the federal government providing at least seventy-five percent for public assistance grants and at least fifty percent for hazard mitigation grants of the eligible expenses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the president, at the request of the governor, has declared a major disaster to exist in this state, the executive council may make financial grants to meet disaster-related necessary expenses or serious needs of individuals or families adversely affected by a major disaster which cannot otherwise adequately be met from other means of assistance. The amount of a financial grant shall not exceed the maximum federal authorization in the aggregate to an individual or family in any single major disaster declared by the president. All grants authorized to individuals and families will be subject to the federal government providing no less than seventy-five percent of each grant and the declaration of a major disaster in the state by the president of the United States.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the president, at the request of the governor, has declared a major disaster to exist in this state, the executive council may lease or purchase sites and develop such sites to accommodate temporary housing units for disaster victims.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fgovernmental subdivision\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any political subdivision of this state.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, \'a7120; C97, \'a7170; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{286;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, \'a719.7; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a729C.20}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 53, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 195, \'a76}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{; }{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts//CH0000.pdf" }{\fldrslt \f5 \fs18{{\f5\fs18\hyphpar0\qj\cf5{89 Acts, ch 315, \'a727}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1139, \'a718}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 210, \'a719}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 155, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 179, \'a7105}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 89, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1185, \'a763, 64}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 131, \'a723, 158}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1028, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1069, \'a72}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a77D.29}}}{{\f5\fs12\hyphpar0\qj{, 29A.27}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{29C.20A}}}{\*\bkmkstart stylerid1_2E28_2E2_2E2}{\*\bkmkend stylerid1_2E28_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Disaster aid individual assistance grant fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A disaster aid individual assistance grant fund is created in the state treasury for the use of the executive council. Moneys in the fund may be expended following the governor\u8217\'3fs proclamation of a state of disaster emergency. The executive council may make financial grants to meet disaster-related expenses or serious needs of individuals or families adversely affected by a disaster which cannot otherwise be met by other means of financial assistance. The aggregate total of grants awarded shall not be more than one million dollars during a fiscal year. However, within the same fiscal year, additional funds may be specifically authorized by the executive council to meet additional needs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The grant funds shall be administered by the department. The department shall adopt rules to create the Iowa disaster aid individual assistance grant program. The rules shall specify the eligibility of applicants and eligible items for grant funding. The executive council shall use grant funds to reimburse the department for its actual expenses associated with the administration of the grants. The department may implement an ongoing contract with a local administrative entity for the grant program so that the program can be implemented with minimal delay when a disaster occurs in a local area. The rules adopted by the department for the program shall include but are not limited to all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a local administrative entity is under contract with the state to provide other services or is implementing a state or federal program and the contract contains a sufficient surety bond or other adequate financial responsibility provision, the department shall accept the existing surety bond or financial responsibility provision in lieu of applying a new or additional surety bond or financial responsibility requirement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the president of the United States has declared a major disaster to exist in this state and federal aid is made available to provide assistance grants to individuals similar to that provided by the Iowa disaster aid individual assistance grant program, the Iowa program shall be discontinued.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Authorization for the local administrative entity to draw grant funding to pay valid claims on at least a weekly basis.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To be eligible for a grant, an applicant shall have an annual household income that is less than two hundred percent of the federal poverty level based on the number of people in the applicant\u8217\'3fs household as defined by the most recently revised poverty income guidelines published by the United States department of health and human services. The amount of a grant for a household shall not exceed seven thousand dollars. Expenses eligible for grant funding shall be limited to personal property, home repair, food assistance, and temporary housing assistance. An applicant for a grant shall sign an affidavit committing to refund any part of the grant that is duplicated by any other assistance, such as but not limited to insurance or assistance from community development groups, charities, the small business administration, and the federal emergency management agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A recipient of grant funding shall receive reimbursement for expenses upon presenting a receipt for an eligible expense or shall receive a voucher through a voucher system developed by the department and administered locally within the designated disaster area. A voucher system shall ensure sufficient data collection to discourage and prevent fraud. The department shall consult with long-term disaster recovery committees and disaster recovery case management committees in developing a voucher system.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall submit an annual report, by January 1 of each year, to the legislative fiscal committee and the general assembly\u8217\'3fs standing committees on government oversight concerning the activities of the grant program in the previous fiscal year.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 145, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1078, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 86, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1150, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 69, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1078, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1138, \'a714, 42, 45}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72164}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1173, \'a72, 3}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a77D.29}}}{{\f5\fs12\hyphpar0\qj{, 29C.26}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{29C.20B}}}{\*\bkmkstart stylerid1_2E29_2E2_2E2}{\*\bkmkend stylerid1_2E29_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Disaster case advocacy grant fund and program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A disaster case advocacy grant fund is created in the state treasury for the use of the executive council. Moneys in the fund shall be available following the governor\u8217\'3fs proclamation of a state of disaster emergency or the declaration of a major disaster by the president of the United States.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The executive council may make financial grants to meet disaster-related case advocacy needs of disaster-affected individuals. The aggregate total of grants awarded shall not be more than one million dollars during a fiscal year. However, within the same fiscal year, additional funds may be specifically authorized by the executive council to meet additional needs. Upon request of the department, the executive council may make available up to one hundred thousand dollars, or so much as is necessary, for contract entity staff support and case advocacy training.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall work with representatives of selected nonprofit, voluntary, and faith-based organizations active in disaster recovery and response to establish a statewide system of disaster case advocacy to be activated following the governor\u8217\'3fs proclamation of a disaster emergency or the declaration of a major disaster by the president of the United States for individual assistance purposes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall administer disaster case advocacy grants. The department shall establish a disaster case advocacy program and adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ necessary to administer the program. The executive council shall use grant moneys to reimburse the department for actual expenses associated with the administration of the grants. Under the program, the department shall coordinate case advocacy services locally through one or more contracted entities. The department may implement an ongoing contract with a local administrative entity for the grant program to allow implementation of the program with minimal delay following a governor\u8217\'3fs proclamation of a state of disaster emergency or a declaration of a major disaster by the president of the United States.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department in consultation with representatives of the Iowa voluntary organizations active in disaster, shall adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ to create coordination mechanisms and standards for the establishment and implementation of a statewide system of disaster case advocacy. The rules adopted by the department for the program shall include but are not limited to all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a local administrative entity is under contract with the state to provide other services or is implementing a state or federal program and the contract contains adequate financial responsibility provisions, the department shall accept the existing surety bond or financial responsibility provisions in lieu of applying a new or additional financial responsibility requirement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Authorization for the local administrative entity to draw down grant funding to pay valid claims on at least a weekly basis.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Disaster case advocacy standards.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Disaster case advocacy policies.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reporting requirements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Eligibility criteria.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Coordination mechanisms necessary to carry out the services provided.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Development of formal working relationships with agencies and creation of interagency agreements for those considered to provide disaster case advocacy services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Establishment of nonduplication of benefits policies and mechanisms.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Referral to all known available services for individuals from multiple agencies in coordinated service locations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{By January 1 of each year, the department shall submit an annual written report to the legislative fiscal committee and the general assembly\u8217\'3fs standing committees on government oversight concerning the activities of the grant program during the previous fiscal year.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2010 Acts, ch 1096, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 25, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 69, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 122, \'a729, 30}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 129, \'a783, 156}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1021, \'a735}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 29, \'a725}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1110, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72165}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1173, \'a74, 5}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a716.57B}}}{{\f5\fs12\hyphpar0\qj{, 29C.26}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{29C.20C}}}{\*\bkmkstart stylerid1_2E3_30_2E2_2E2}{\*\bkmkend stylerid1_2E3_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Immunity }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ licensed architects and professional engineers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{An architect licensed pursuant to }{{\f5\fs18\hyphpar0\qj{chapter 544A}}}{ or a professional engineer licensed pursuant to }{{\f5\fs18\hyphpar0\qj{chapter 542B}}}{ who, during a disaster emergency as proclaimed by the governor or a major disaster as declared by the president of the United States, in good faith and at the request of or with the approval of a national, state, or local public official, law enforcement official, public safety official, or building inspection official believed by the licensed architect or professional engineer to be acting in an official capacity, voluntarily and without compensation provides architectural, engineering, structural, electrical, mechanical, or other design professional services related to the disaster emergency or major disaster shall not be liable for civil damages for any acts or omissions resulting from the services provided, unless such acts or omissions constitute recklessness or willful and wanton misconduct. A licensed architect or professional engineer who receives expense reimbursement for the performance of services described in }{{\f5\fs18\hyphpar0\qj{this section}}}{ shall not be considered to have received compensation for such services.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2019 Acts, ch 89, \'a78, 22, 24}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 111, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 80, \'a7379, 380}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{29C.21}}}{\*\bkmkstart stylerid1_2E31_2E2_2E2}{\*\bkmkend stylerid1_2E31_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Emergency management assistance compact.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The interstate emergency management assistance compact is entered into with all other states which enter into the compact in substantially the following form:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E31_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E31_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article I \u8212\'3f Purpose and authorities.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This compact is made and entered into by and between the participating member states which enact this compact, hereinafter called party states. For the purposes of this agreement, the term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fstates\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ is taken to mean the several states, the Commonwealth of Puerto Rico, the District of Columbia, and all United States territorial possessions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The purpose of this compact is to provide for mutual assistance between the states entering into this compact in managing any emergency or disaster that is duly declared by the governor of the affected state, whether arising from natural disaster, technological hazard, man-made disaster, civil emergency aspects of resource shortages, community disorders, insurgency, or enemy attack.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This compact shall also provide for mutual cooperation in emergency-related exercises, testing, or other training activities using equipment and personnel simulating performance of any aspect of the giving and receiving of aid by party states or subdivisions of party states during emergencies, such actions occurring outside actual declared emergency periods. Mutual assistance in this compact may include the use of the states\u8217\'3f national guard forces, either in accordance with the national guard mutual assistance compact or by mutual agreement between states.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E31_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E31_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article II \u8212\'3f General implementation.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each party state entering into this compact recognizes many emergencies transcend political jurisdictional boundaries and that intergovernmental coordination is essential in managing these and other emergencies under this compact. Each state further recognizes that there will be emergencies which require immediate access and present procedures to apply outside resources to make a prompt and effective response to such an emergency. This is because few, if any, individual states have all the resources they may need in all types of emergencies or the capability of delivering resources to areas where emergencies exist.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The prompt, full, and effective utilization of resources of the participating states, including any resources on hand or available from the federal government or any other source, that are essential to the safety, care, and welfare of the people in the event of any emergency or disaster declared by a party state, shall be the underlying principle on which all articles of this compact shall be understood.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On behalf of the governor of each state participating in the compact, the legally designated state official who is assigned responsibility for emergency management will be responsible for formulation of the appropriate interstate mutual aid plans and procedures necessary to implement this compact.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{\*\bkmkstart stylerid1_2E31_2E6_2E1_2E2}{\*\bkmkend stylerid1_2E31_2E6_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article III \u8212\'3f Party state responsibilities.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It shall be the responsibility of each party state to formulate procedural plans and programs for interstate cooperation in the performance of the responsibilities listed in this article. In formulating such plans, and in carrying them out, the party states, insofar as practical, shall:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Review individual state hazards analyses and, to the extent reasonably possible, determine all those potential emergencies the party states might jointly suffer, whether due to natural disaster, technological hazard, man-made disaster, emergency aspects of resource shortages, civil disorders, insurgency, or enemy attack.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Review party states\u8217\'3f individual emergency plans and develop a plan which will determine the mechanism for the interstate management and provision of assistance concerning any potential emergency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Develop interstate procedures to fill any identified gaps and to resolve any identified inconsistencies or overlaps in existing or developed plans.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Assist in warning communities adjacent to or crossing the state boundaries.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Protect and assure uninterrupted delivery of services, medicines, water, food, energy and fuel, search and rescue, and critical lifeline equipment, services, and resources, both human and material.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Inventory and set procedures for the interstate loan and delivery of human and material resources, together with procedures for reimbursement or forgiveness.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(7)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide, to the extent authorized by law, for temporary suspension of any statutes or ordinances that restrict the implementation of the above responsibilities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The authorized representative of a party state may request assistance of another party state by contacting the authorized representative of that state. The provisions of this agreement shall only apply to requests for assistance made by and to authorized representatives. Requests may be verbal or in writing. If verbal, the request shall be confirmed in writing within thirty days of the verbal request. Requests shall provide all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A description of the emergency service function for which assistance is needed, such as but not limited to fire services, law enforcement, emergency medical, transportation, communications, public works and engineering, building inspection, planning and information assistance, mass care, resource support, health and medical services, and search and rescue.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amount and type of personnel, equipment, materials and supplies needed, and a reasonable estimate of the length of time they will be needed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The specific place and time for staging of the assisting party\u8217\'3fs response and a point of contact at that location.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{There shall be frequent consultation between state officials who have assigned emergency management responsibilities and other appropriate representatives of the party states with affected jurisdictions and the United States government, with free exchange of information, plans, and resource records relating to emergency capabilities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{\*\bkmkstart stylerid1_2E31_2E7_2E1_2E2}{\*\bkmkend stylerid1_2E31_2E7_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article IV \u8212\'3f Limitations.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any party state requested to render mutual aid or conduct exercises and training for mutual aid shall take such action as is necessary to provide and make available the resources covered by this compact in accordance with the terms hereof, provided that it is understood that the state rendering aid may withhold resources to the extent necessary to provide reasonable protection for such state. Each party state shall afford to the emergency forces of any party state, while operating within its state limits under the terms and conditions of this compact, the same powers, except that of arrest unless specifically authorized by the receiving state, duties, rights, and privileges as are afforded forces of the state in which they are performing emergency services. Emergency forces will continue under the command and control of their regular leaders, but the organizational units will come under the operational control of the emergency services authorities of the state receiving assistance. These conditions may be activated, as needed, only subsequent to a declaration of a state of emergency or disaster by the governor of the party state that is to receive assistance or commencement of exercises or training for mutual aid and shall continue so long as the exercises or training for mutual aid are in progress, the state of emergency or disaster remains in effect, or loaned resources remain in the receiving state, whichever is longer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{\*\bkmkstart stylerid1_2E31_2E8_2E1_2E2}{\*\bkmkend stylerid1_2E31_2E8_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article V \u8212\'3f Licenses and permits.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Whenever any person holds a license, certificate, or other permit issued by any state party to the compact evidencing the meeting of qualifications for professional, mechanical, or other skills, and when such assistance is requested by the receiving party state, such person shall be deemed licensed, certified, or permitted by the state requesting assistance to render aid involving such skill to meet a declared emergency or disaster, subject to such limitations and conditions as the governor of the requesting state may prescribe by executive order or otherwise.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{\*\bkmkstart stylerid1_2E31_2E9_2E1_2E2}{\*\bkmkend stylerid1_2E31_2E9_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article VI \u8212\'3f Liability.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Officers or employees of a party state rendering aid in another state pursuant to this compact shall be considered agents of the requesting state for tort liability and immunity purposes; and no party state or its officers or employees rendering aid in another state pursuant to this compact shall be liable on account of any act or omission in good faith on the part of such forces while so engaged or on account of the maintenance or use of any equipment or supplies in connection therewith. Good faith in this article shall not include willful misconduct, gross negligence, or recklessness.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{\*\bkmkstart stylerid1_2E31_2E1_30_2E1_2E2}{\*\bkmkend stylerid1_2E31_2E1_30_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article VII \u8212\'3f Supplementary agreements.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Inasmuch as it is probable that the pattern and detail of the machinery for mutual aid among two or more states may differ from that among the states that are party hereto, this instrument contains elements of a broad base common to all states, and nothing herein contained shall preclude any state from entering into supplementary agreements with another state or affect any other agreements already in force between states. Supplementary agreements may comprehend, but shall not be limited to, provisions for evacuation and reception of injured and other persons and the exchange of medical, fire, police, public utility, reconnaissance, welfare, transportation and communications personnel, and equipment and supplies.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{\*\bkmkstart stylerid1_2E31_2E11_2E1_2E2}{\*\bkmkend stylerid1_2E31_2E11_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article VIII \u8212\'3f Compensation.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each party state shall provide for the payment of compensation and death benefits to injured members of the emergency forces of that state and representatives of deceased members of such forces in case such members sustain injuries or are killed while rendering aid pursuant to this compact, in the same manner and on the same terms as if the injury or death were sustained within their own state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{\*\bkmkstart stylerid1_2E31_2E12_2E1_2E2}{\*\bkmkend stylerid1_2E31_2E12_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article IX \u8212\'3f Reimbursement.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any party state rendering aid in another state pursuant to this compact shall be reimbursed by the party state receiving such aid for any loss or damage to or expense incurred in the operation of any equipment and the provision of any service in answering a request for aid and for the costs incurred in connection with such requests; provided that any aiding party state may assume in whole or in part such loss, damage, expense, or other cost, or may loan such equipment or donate such services to the receiving party state without charge or cost; and provided further, that any two or more party states may enter into supplementary agreements establishing a different allocation of costs among those states. Article VIII expenses shall not be reimbursable under this provision.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{\*\bkmkstart stylerid1_2E31_2E13_2E1_2E2}{\*\bkmkend stylerid1_2E31_2E13_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article X \u8212\'3f Evacuation.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Plans for the orderly evacuation and interstate reception of portions of the civilian population as the result of any emergency or disaster of sufficient proportions to so warrant, shall be worked out and maintained between the party states and the emergency management or services directors of the various jurisdictions where any type of incident requiring evacuations might occur. Such plans shall be put into effect by request of the state from which evacuees come and shall include the manner of transporting such evacuees, the number of evacuees to be received in different areas, the manner in which food, clothing, housing, and medical care will be provided, the registration of the evacuees, the providing of facilities for the notification of relatives or friends, and the forwarding of such evacuees to other areas or the bringing in of additional materials, supplies, and all other relevant factors. Such plans shall provide that the party state receiving evacuees and the party state from which the evacuees come shall mutually agree as to reimbursement of out-of-pocket expenses incurred in receiving and caring for such evacuees, for expenditures for transportation, food, clothing, medicines and medical care, and like items. Such expenditures shall be reimbursed as agreed by the party state from which the evacuees come. After the termination of the emergency or disaster, the party state from which the evacuees come shall assume the responsibility for the ultimate support of repatriation of such evacuees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{\*\bkmkstart stylerid1_2E31_2E14_2E1_2E2}{\*\bkmkend stylerid1_2E31_2E14_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article XI \u8212\'3f Implementation.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This compact shall become operative immediately upon its enactment into law by any two states; thereafter, this compact shall become effective as to any other state upon its enactment by such state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any party state may withdraw from this compact by enacting a statute repealing the same, but no such withdrawal shall take effect until thirty days after the governor of the withdrawing state has given notice in writing of such withdrawal to the governors of all other party states. Such action shall not relieve the withdrawing state from obligations assumed hereunder prior to the effective date of withdrawal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Duly authenticated copies of this compact and of such supplementary agreements as may be entered into shall, at the time of their approval, be deposited with each of the party states and with the federal emergency management agency and other appropriate agencies of the United States government.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{\*\bkmkstart stylerid1_2E31_2E15_2E1_2E2}{\*\bkmkend stylerid1_2E31_2E15_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article XII \u8212\'3f Validity.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This compact shall be construed to effectuate the purposes stated in article I hereof. If any provision of this compact is declared unconstitutional, or the applicability thereof to any person or circumstances is held invalid, the constitutionality of the remainder of this compact and the applicability thereof to other persons and circumstances shall not be affected thereby.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{\*\bkmkstart stylerid1_2E31_2E16_2E1_2E2}{\*\bkmkend stylerid1_2E31_2E16_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article XIII }}}{{\i\f5\fs18\hyphpar0\qj{\u8212\'3f}}}{{\i\f5\fs18\hyphpar0\qj{ Additional provisions.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Nothing in this compact shall authorize or permit the use of military force by the national guard of a state at any place outside that state in any emergency for which the president is authorized by law to call into federal active duty the militia, or for any purpose for which the use of the army or the air force would in the absence of express statutory authorization be prohibited under }}}{{\f5\fs18\hyphpar0\qj{18 U.S.C. \'a71385}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C62, \'a728A.3; C66, 71, 73, 75, \'a729C.3; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a729C.21}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 129, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1032, \'a7201}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1072, \'a725}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a729C.6}}}{{\f5\fs12\hyphpar0\qj{, 29C.8}}}{{\f5\fs12\hyphpar0\qj{, 29C.20}}}{{\f5\fs12\hyphpar0\qj{, 135.143}}}{{\f5\fs12\hyphpar0\qj{, 669.2}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{29C.22}}}{\*\bkmkstart stylerid1_2E32_2E2_2E2}{\*\bkmkend stylerid1_2E32_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Statewide mutual aid compact.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{This statewide mutual aid compact is entered into with all other emergency management commissions established pursuant to }{{\f5\fs18\hyphpar0\qj{section 29C.9}}}{, counties, cities, and other political subdivisions that enter into this compact in substantially the following form:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E32_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E32_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article I \u8212\'3f Purpose and authorities.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This compact is made and entered into by and between the participating emergency management commissions established pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 29C.9}}}{{\f5\fs18\hyphpar0\qj{, counties, cities, and political subdivisions which enact this compact. For the purposes of this agreement, the term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fparticipating governments\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means emergency management commissions, counties, cities, townships, and other political subdivisions of the state which have not, through ordinance or resolution of the governing body, acted to withdraw from this compact. The inclusion of emergency management commissions in the term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fparticipating governments\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall not convey taxing authority or other legal authority to emergency management commissions that is not otherwise granted in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The purpose of this compact is to provide for mutual assistance between the participating governments entering into this compact in managing any emergency or disaster that is declared in accordance with a comprehensive emergency plan or by the governor, whether arising from natural disaster, technological hazard, man-made disaster, community disorder, insurgency, terrorism, or enemy attack.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This compact shall also provide for mutual cooperation in emergency-related exercises, testing, or other training activities using equipment and personnel simulating performance of any aspect of the giving and receiving of aid by participating governments during emergencies, such actions occurring outside actual declared emergency periods.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E32_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E32_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article II \u8212\'3f General implementation.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each participating government entering into this compact recognizes many emergencies transcend political jurisdictional boundaries and that intergovernmental coordination is essential in managing these and other emergencies under this compact. Each participating government further recognizes that there will be emergencies which require immediate access and present procedures to apply outside resources to make a prompt and effective response to the emergency. This is because few, if any, individual governments have all the resources they may need in all types of emergencies or the capability of delivering resources to areas where emergencies exist.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The prompt, full, and effective use of resources of the participating governments, including any resources on hand or available from any source, that are essential to the safety, care, and welfare of the people in the event of any emergency or disaster declared by the governor or any participating government, shall be the underlying principle on which all articles of this compact shall be understood.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On behalf of the participating government in the compact, the legally designated official who is assigned responsibility for emergency management will be responsible for formulation of the appropriate intrastate mutual aid plans and procedures necessary to implement this compact.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{\*\bkmkstart stylerid1_2E32_2E6_2E1_2E2}{\*\bkmkend stylerid1_2E32_2E6_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article III \u8212\'3f Participating government responsibilities.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It shall be the responsibility of each participating government to formulate procedural plans and programs for intrastate cooperation in the performance of the responsibilities listed in this article. In formulating the plans, and in carrying them out, the participating governments, insofar as practical, shall:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Review individual hazards analyses and, to the extent reasonably possible, determine all those potential emergencies the participating governments might jointly suffer, whether due to natural disaster, technological hazard, man-made disaster, civil disorders, insurgency, terrorism, or enemy attack.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Review the participating governments\u8217\'3f individual emergency plans and develop a plan that will determine the mechanism for the intrastate management and provision of assistance concerning any potential emergency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Develop intrastate procedures to fill any identified gaps and to resolve any identified inconsistencies or overlaps in existing or developed plans.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Assist in warning communities adjacent to or crossing the participating governments\u8217\'3f boundaries.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Protect and ensure uninterrupted delivery of services, medicines, water, food, energy and fuel, search and rescue, and critical lifeline equipment, services, and resources, both human and material.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Inventory and set procedures for the intrastate loan and delivery of human and material resources, together with procedures for reimbursement or forgiveness.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(7)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide, to the extent authorized by law, for temporary suspension of any ordinances that restrict the implementation of the above responsibilities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The authorized representative of a participating government may request assistance of another participating government by contacting the authorized representative of that participating government. The provisions of this compact shall only apply to requests for assistance made by and to authorized representatives. Requests may be verbal or in writing. If verbal, the request shall be confirmed in writing within thirty days of the verbal request. Requests shall provide all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A description of the emergency service function for which assistance is needed, such as but not limited to fire services, law enforcement, emergency medical, transportation, communications, public works and engineering, building inspection, planning and information assistance, mass care, resource support, health and medical services, and search and rescue.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amount and type of personnel, equipment, materials, and supplies needed, and a reasonable estimate of the length of time that the personnel, equipment, materials, and supplies will be needed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The specific place and time for staging of the assisting participating government\u8217\'3fs response and a point of contact at that location.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The authorized representative of a participating government may initiate a request by contacting the department of homeland security and emergency management. When a request is received by the department, the department shall directly contact other participating governments to coordinate the provision of mutual aid.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Frequent consultation shall occur between officials who have been assigned emergency management responsibilities and other appropriate representatives of the participating governments with affected jurisdictions and state government, with free exchange of information, plans, and resource records relating to emergency capabilities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fauthorized representative of a participating government\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a mayor or the mayor\u8217\'3fs designee, a member of the county board of supervisors or a representative of the board, an emergency management coordinator or the coordinator\u8217\'3fs designee, or the elected chief executive officer of the participating government or the elected chief executive officer\u8217\'3fs designee authorized to enter into contracts on behalf of the participating government.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{\*\bkmkstart stylerid1_2E32_2E7_2E1_2E2}{\*\bkmkend stylerid1_2E32_2E7_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article IV \u8212\'3f Limitations.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any participating government requested to render mutual aid or conduct exercises and training for mutual aid shall take the necessary action to provide and make available the resources covered by this compact in accordance with the terms of the compact. However, it is understood that the participating government rendering aid may withhold resources to the extent necessary to provide reasonable protection for the participating government. Each participating government shall afford to the emergency forces of any other participating government, while operating within its jurisdictional limits under the terms and conditions of this compact, the same powers, except that of arrest unless specifically authorized by the receiving participating government, duties, rights, and privileges as are afforded forces of the participating government in which the emergency forces are performing emergency services. Emergency forces shall continue under the command and control of their regular leaders, but the organizational units shall come under the operational control of the emergency services authorities of the participating government receiving assistance. These conditions may be activated, as needed, only subsequent to a declaration of a state of emergency or disaster by the governor or by competent authority of the participating government that is to receive assistance, or commencement of exercises or training for mutual aid, and shall continue so long as the exercises or training for mutual aid are in progress, the state of emergency or disaster remains in effect, or loaned resources remain in the receiving jurisdiction, whichever is longer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{\*\bkmkstart stylerid1_2E32_2E8_2E1_2E2}{\*\bkmkend stylerid1_2E32_2E8_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article V \u8212\'3f Licenses and permits.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a person holds a license, certificate, or other permit issued by any participating government to this compact evidencing the meeting of qualifications for professional, mechanical, or other skills, and when the assistance is requested by another participating government, the person shall be deemed licensed, certified, or permitted by the participating government requesting assistance to render aid involving the skill to meet a declared emergency or disaster, subject to the limitations and conditions as the governor may prescribe by executive order or otherwise.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{\*\bkmkstart stylerid1_2E32_2E9_2E1_2E2}{\*\bkmkend stylerid1_2E32_2E9_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article VI \u8212\'3f Liability.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Officers or employees of a participating government rendering aid in another participating government jurisdiction pursuant to this compact shall be considered agents of the requesting participating government for tort liability and immunity purposes and a participating government or its officers or employees rendering aid in another jurisdiction pursuant to this compact shall not be liable on account of any act or omission in good faith on the part of the forces while so engaged or on account of the maintenance or use of any equipment or supplies in connection with the aid. Good faith in this article shall not include willful misconduct, gross negligence, or recklessness.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{\*\bkmkstart stylerid1_2E32_2E1_30_2E1_2E2}{\*\bkmkend stylerid1_2E32_2E1_30_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article VII \u8212\'3f Supplementary agreements.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Because it is probable that the pattern and detail of the machinery for mutual aid among two or more participating governments may differ from that among other participating governments, this compact contains elements of a broad base common to all political subdivisions, and this compact shall not preclude any political subdivision from entering into supplementary agreements with another political subdivision or affect any other agreements already in force between political subdivisions. Supplementary agreements may include, but shall not be limited to, provisions for evacuation and reception of injured and other persons and the exchange of medical, fire, police, public utility, reconnaissance, welfare, transportation and communications personnel, and equipment and supplies.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{\*\bkmkstart stylerid1_2E32_2E11_2E1_2E2}{\*\bkmkend stylerid1_2E32_2E11_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article VIII \u8212\'3f Workers\u8217\'3f compensation.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each participating government shall provide for the payment of workers\u8217\'3f compensation and death benefits to injured members of the emergency forces of that participating government and representatives of deceased members of the emergency forces in case the members sustain injuries or are killed while rendering aid pursuant to this compact, in the same manner and on the same terms as if the injury or death were sustained within their own jurisdiction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{\*\bkmkstart stylerid1_2E32_2E12_2E1_2E2}{\*\bkmkend stylerid1_2E32_2E12_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article IX \u8212\'3f Reimbursement.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any participating government rendering aid in another jurisdiction pursuant to this compact shall be reimbursed by the participating government receiving the emergency aid for any loss or damage to or expense incurred in the operation of any equipment and the provision of any service in answering a request for aid and for the costs incurred in connection with the requests. However, an aiding political subdivision may assume in whole or in part the loss, damage, expense, or other cost, or may loan the equipment or donate the services to the receiving participating government without charge or cost, and any two or more participating governments may enter into supplementary agreements establishing a different allocation of costs among the participating governments. Article VIII expenses shall not be reimbursable under this provision.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{\*\bkmkstart stylerid1_2E32_2E13_2E1_2E2}{\*\bkmkend stylerid1_2E32_2E13_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article X \u8212\'3f Evacuation and sheltering.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Plans for the orderly evacuation and reception of portions of the civilian population as the result of any emergency or disaster shall be worked out and maintained between the participating governments and the emergency management or services directors of the various jurisdictions where any type of incident requiring evacuations might occur. The plans shall be put into effect by request of the participating government from which evacuees come and shall include the manner of transporting the evacuees, the number of evacuees to be received in different areas, the manner in which food, clothing, housing, and medical care will be provided, the registration of the evacuees, the providing of facilities for the notification of relatives or friends, and the forwarding of the evacuees to other areas or the bringing in of additional materials, supplies, and all other relevant factors. The plans shall provide that the participating government receiving evacuees and the participating government from which the evacuees come shall mutually agree as to reimbursement of out-of-pocket expenses incurred in receiving and caring for the evacuees, for expenditures for transportation, food, clothing, medicines and medical care, and like items. The expenditures shall be reimbursed as agreed by the participating government from which the evacuees come. After the termination of the emergency or disaster, the participating government from which the evacuees come shall assume the responsibility for the ultimate support of repatriation of such evacuees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{\*\bkmkstart stylerid1_2E32_2E14_2E1_2E2}{\*\bkmkend stylerid1_2E32_2E14_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article XI \u8212\'3f Implementation.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This compact shall become operative July 1, 2009.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any participating government may withdraw from this compact by adopting an ordinance or resolution repealing the same, but a withdrawal shall not take effect until thirty days after the governing body of the withdrawing participating government has given notice in writing of the withdrawal to the director of the department of homeland security and emergency management who shall notify all other participating governments. The action shall not relieve the withdrawing political subdivision from obligations assumed under this compact prior to the effective date of withdrawal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Duly authenticated copies of this compact and any supplementary agreements as may be entered into shall be deposited, at the time of their approval, with the director of the department of homeland security and emergency management who shall notify all participating governments and other appropriate agencies of state government.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{\*\bkmkstart stylerid1_2E32_2E15_2E1_2E2}{\*\bkmkend stylerid1_2E32_2E15_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article XII \u8212\'3f Validity.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This compact shall be construed to effectuate the purposes stated in article I. If any provision of this compact is declared unconstitutional, or the applicability of the compact to any person or circumstances is held invalid, the constitutionality of the remainder of this compact and the applicability of this compact to other persons and circumstances shall not be affected.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1117, \'a755, 56}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 179, \'a7157}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1032, \'a7201}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 67, \'a71 \u8211\'3f 4}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 69, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 29, \'a726, 27}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1100, \'a71}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{29C.23}}}{\*\bkmkstart stylerid1_2E33_2E2_2E2}{\*\bkmkend stylerid1_2E33_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Statewide interoperable communications system.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The statewide interoperable communications system shall be under the joint purview of the department of public safety and the department of transportation. The departments shall jointly submit a biannual report to the statewide interoperable communications system board established in }}}{{\f5\fs18\hyphpar0\qj{section 80.28}}}{{\f5\fs18\hyphpar0\qj{, beginning July 1, 2016.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The treasurer of state is authorized to enter into a financing agreement in accordance with the provisions of }}}{{\f5\fs18\hyphpar0\qj{section 12.28}}}{{\f5\fs18\hyphpar0\qj{ for the purpose of building the statewide interoperable communications system.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2015 Acts, ch 129, \'a71, 7, 8}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1011, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1103, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1137, \'a723, 24}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{29C.24}}}{\*\bkmkstart stylerid1_2E34_2E2_2E2}{\*\bkmkend stylerid1_2E34_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Facilitating business rapid response to state-declared disasters Act.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E34_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E34_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Title.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ may be cited as the }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fFacilitating Business Rapid Response to State-Declared Disasters Act\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E34_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E34_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Definitions.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, unless the context otherwise requires:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCritical infrastructure\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means real and personal property and equipment owned or used by any of the following networks or systems, including related support facilities, which network or system provides service to more than one customer or person:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Communication and video networks.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Electric generation, transmission, and distribution systems.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Gas distribution systems.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Water and wastewater pipeline systems.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCritical infrastructure\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes but is not limited to buildings, structures, offices, lines, poles, pipes, and equipment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDeclared state disaster or emergency\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a disaster or emergency event that meets at least one of the following conditions:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A disaster emergency proclamation has been issued by the governor pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 29C.6}}}{{\f5\fs18\hyphpar0\qj{ in relation to the event.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A presidential declaration of a major disaster has been issued in relation to the event.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDisaster or emergency-related work\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means repairing, renovating, installing, building, or rendering services or other business activities, that relate to critical infrastructure that has been damaged, impaired, or destroyed by a declared state disaster or emergency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDisaster response period\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means, with respect to each declared state disaster or emergency, a period of time that begins ten calendar days prior to the day the governor proclaims a disaster emergency or the president declares a major disaster, whichever occurs first, and extends for a period of sixty calendar days after the end of the declared state disaster or emergency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fOut-of-state business\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a business entity that meets all of the following requirements:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The business entity is requested to perform disaster or emergency-related work in the state by a registered business or by the state or a political subdivision of the state.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except for disaster or emergency-related work, the business entity has no presence in the state and conducts no business in the state.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except for disaster or emergency-related work, the business entity had no registrations, tax filings, or nexus in the state for the tax year immediately preceding the year in which the relevant declared state disaster or emergency occurs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fOut-of-state business\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ may include a business entity that is affiliated with a registered business solely through common ownership.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fOut-of-state employee\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an employee who does not work in this state except to perform disaster or emergency-related work during a disaster response period.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fRegistered business\u8221\'3f }}}{{\f5\fs18\hyphpar0\qj{means a business entity that is registered to do business in the state prior to the declared state disaster or emergency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{\*\bkmkstart stylerid1_2E34_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E34_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Business and employee status during disaster response period.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any other provision of law to the contrary, an out-of-state business that conducts operations within the state solely for the purpose of performing disaster or emergency-related work during a disaster response period shall not be considered to have established a level of presence that would subject the out-of-state business to any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The requirement to complete or obtain any state or local registration, license, or similar authorization as a condition of doing business in this state or engaging in an occupation in this state, or to pay any related fee, including but not limited to the requirement to register with the secretary of state or a political subdivision. This subparagraph (1) does not apply to the notification and insurance verification requirements in }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The requirement to collect and remit any tax imposed upon another person or file any related tax return or obtain any related tax permit. This subparagraph division (a) does not apply to an out-of-state business for the collection and remittance of sales and use taxes under }}}{{\f5\fs18\hyphpar0\qj{chapter 423}}}{{\f5\fs18\hyphpar0\qj{ if the out-of-state business is registered voluntarily as a seller under the streamlined sales and use tax agreement.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subparagraph division (a) shall not be construed to protect or otherwise exempt any person liable for the payment of a tax, other than the out-of-state business, from the responsibility to pay such tax.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The imposition of income taxes under }}}{{\f5\fs18\hyphpar0\qj{chapter 422, subchapters II}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{III}}}{{\f5\fs18\hyphpar0\qj{, including the requirement to file tax returns under }}}{{\f5\fs18\hyphpar0\qj{sections 422.13 through 422.15}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{section 422.16B}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{section 422.36}}}{{\f5\fs18\hyphpar0\qj{, as applicable, and including the requirement to withhold and remit income tax from out-of-state employees under }}}{{\f5\fs18\hyphpar0\qj{section 422.16}}}{{\f5\fs18\hyphpar0\qj{. In addition, the performance of disaster or emergency-related work during a disaster response period by an out-of-state business or out-of-state employee shall not require an out-of-state business to be included in a consolidated return under }}}{{\f5\fs18\hyphpar0\qj{section 422.37}}}{{\f5\fs18\hyphpar0\qj{, and shall not increase the amount of net income of the out-of-state business allocated and apportioned to the state under }}}{{\f5\fs18\hyphpar0\qj{ section 422.8}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{422.33}}}{{\f5\fs18\hyphpar0\qj{, as applicable.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The employment security requirements under }}}{{\f5\fs18\hyphpar0\qj{chapter 96}}}{{\f5\fs18\hyphpar0\qj{, including but not limited to the payment of employer contributions under }}}{{\f5\fs18\hyphpar0\qj{section 96.7}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The use tax under }}}{{\f5\fs18\hyphpar0\qj{chapter 423, subchapter III}}}{{\f5\fs18\hyphpar0\qj{, or the equipment tax under }}}{{\f5\fs18\hyphpar0\qj{chapter 423D}}}{{\f5\fs18\hyphpar0\qj{, on tangible personal property or equipment purchased outside the state and brought into the state to aid in the performance of disaster or emergency-related work during a disaster response period if such tangible personal property or equipment does not remain in the state after the conclusion of the disaster response period.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The assessment of property taxes by the department of revenue under }}}{{\f5\fs18\hyphpar0\qj{sections 428.24 through 428.26}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{428.28}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{428.29}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{chapters 434}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{435}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{437 through 438}}}{{\f5\fs18\hyphpar0\qj{, or by a local assessor under another provision of law, on property brought into the state to aid in the performance of disaster or emergency-related work during a disaster response period if such property does not remain in the state after the conclusion of the disaster response period.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any other provision of law to the contrary, the performance of disaster or emergency-related work during a disaster response period by an out-of-state employee shall not be used as the basis to determine that the out-of-state employee has established residency or a level of presence that would subject the out-of-state employee to any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The requirement to complete or obtain any state or local registration, license, or similar authorization as a condition of doing business in this state or engaging in an occupation in this state, or to pay any related fee, including but not limited to the requirement to register with the secretary of state or a political subdivision.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The imposition of income taxes under }}}{{\f5\fs18\hyphpar0\qj{chapter 422, subchapter II}}}{{\f5\fs18\hyphpar0\qj{, including the requirement to file tax returns under }}}{{\f5\fs18\hyphpar0\qj{section 422.13}}}{{\f5\fs18\hyphpar0\qj{ and the requirement to be subject to withholding of income tax under }}}{{\f5\fs18\hyphpar0\qj{section 422.16}}}{{\f5\fs18\hyphpar0\qj{. In addition, the performance of disaster or emergency-related work during a disaster response period by an out-of-state employee shall not increase the amount of net income of the out-of-state employee allocated and apportioned to the state under }}}{{\f5\fs18\hyphpar0\qj{section 422.8}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The use tax under }}}{{\f5\fs18\hyphpar0\qj{chapter 423, subchapter III}}}{{\f5\fs18\hyphpar0\qj{, or the equipment tax under }}}{{\f5\fs18\hyphpar0\qj{chapter 423D}}}{{\f5\fs18\hyphpar0\qj{, on tangible personal property or equipment purchased outside the state and used in the state to aid in the performance of disaster or emergency-related work during a disaster response period if such tangible personal property or equipment does not remain in the state after the conclusion of the disaster response period.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{During a disaster response period, an out-of-state business or an out-of-state employee shall be subject to all taxes and fees not included in paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not be construed to provide protection or exemption during a disaster response period or any other period from taxes or taxable events not included in paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{\*\bkmkstart stylerid1_2E34_2E6_2E1_2E2}{\*\bkmkend stylerid1_2E34_2E6_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Business and employee status after a disaster response period.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An out-of-state business or out-of-state employee that remains in the state after the conclusion of the disaster response period during which the disaster or emergency-related work was performed shall be fully subject to the state\u8217\'3fs standards for establishing presence, residency, or doing business as otherwise provided by law, and shall be responsible for any resulting taxes, fees, licensing, registration, filing, or other requirements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{\*\bkmkstart stylerid1_2E34_2E7_2E1_2E2}{\*\bkmkend stylerid1_2E34_2E7_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Notification and insurance verification during disaster response period.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An out-of-state business that enters the state to perform disaster or emergency-related work during a disaster response period shall provide notification to the secretary of state, which notification shall contain all the following information related to the out-of-state business:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Name.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{State of domicile.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Principal business address.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Federal employer identification number.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The date the out-of-state business entered the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Contact information.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(7)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A statement that the out-of-state business is in the state for the purpose of responding to a declared state disaster or emergency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For an out-of-state business that enters this state to perform disaster or emergency-related work during a disaster response period as an affiliate of a registered business, the registered business shall provide, on behalf of the affiliate out-of-state business, the notification required in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, which notification shall also include contact information for the registered business.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon request of the secretary of state, an out-of-state business that enters the state to perform disaster or emergency-related work during a disaster response period shall provide proof of workers\u8217\'3f compensation insurance coverage and liability insurance coverage, if any. Such proof shall be provided within ten days of the request.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The secretary of state shall transmit notification and insurance verification information to the department, department of revenue, and other appropriate state and local government agencies and officials.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{\*\bkmkstart stylerid1_2E34_2E8_2E1_2E2}{\*\bkmkend stylerid1_2E34_2E8_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Powers and duties not created.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ shall not be construed to place any new mandates or duties upon a local emergency management commission or create any new authority or power for a local emergency management commission not already expressly granted in another provision of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{\*\bkmkstart stylerid1_2E34_2E9_2E1_2E2}{\*\bkmkend stylerid1_2E34_2E9_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Rules.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department, the secretary of state, and the department of revenue shall each adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ to jointly administer }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2016 Acts, ch 1095, \'a72, 14}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1138, \'a720, 21}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 29, \'a723 \u8211\'3f 25}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1158, \'a71, 28}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1062, \'a794}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1063, \'a720}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 151, \'a78, 15}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7422.8}}}{{\f5\fs12\hyphpar0\qj{, 422.13}}}{{\f5\fs12\hyphpar0\qj{, 422.16}}}{{\f5\fs12\hyphpar0\qj{, 422.16B}}}{{\f5\fs12\hyphpar0\qj{, 422.33}}}{{\f5\fs12\hyphpar0\qj{, 422.36}}}{{\f5\fs12\hyphpar0\qj{, 422.37}}}{{\f5\fs12\hyphpar0\qj{, 423.6}}}{{\f5\fs12\hyphpar0\qj{, 423.33}}}{{\f5\fs12\hyphpar0\qj{, 423.58}}}{{\f5\fs12\hyphpar0\qj{, 423D.3}}}{{\f5\fs12\hyphpar0\qj{, 427.1(41)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2021 amendment to subsection 3, paragraph a, subparagraph (3) applies to tax years beginning on or after January 1, 2022; }{{\f5\fs12\hyphpar0\qj{2021 Acts, ch 151, \'a715}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{29C.25}}}{\*\bkmkstart stylerid1_2E35_2E2_2E2}{\*\bkmkend stylerid1_2E35_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Firearms and ammunition }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ limitations }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ exceptions }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ remedies.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This chapter}}}{{\f5\fs18\hyphpar0\qj{ shall not be construed to authorize the governor or any other official of this state or any of its political subdivisions or any agent or person acting at the direction of the governor or any such official to do any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prohibit, regulate, or curtail the otherwise lawful possession, carrying, transportation, or defensive use of firearms or ammunition.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Suspend or revoke, except in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 724.13}}}{{\f5\fs18\hyphpar0\qj{, a permit issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 724.6}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{724.7}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{724.19}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Seize or confiscate firearms and ammunition possessed in accordance with the laws of this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ shall not prohibit any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The temporary closure or limitations on the operating hours of businesses that sell firearms or ammunition if the same operating restrictions apply to all businesses in the affected area.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The adoption or enforcement of regulations pertaining to firearms and ammunition used or carried for official purposes by law enforcement officers or persons acting under the authority of emergency management agencies or officials.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person aggrieved by a violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ may seek relief in an action at law or in equity or in any other proper proceeding for actual damages, injunctive relief, or other appropriate redress against a person who commits or causes the commission of such violation. }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to any other remedy available at law or in equity, a person aggrieved by the seizure or confiscation of a firearm or ammunition in violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ may make application pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 809.3}}}{{\f5\fs18\hyphpar0\qj{ for its return in the office of the clerk of court for the county in which the property was seized.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In an action or proceeding to enforce }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the court shall award the prevailing plaintiff reasonable court costs and attorney fees.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2017 Acts, ch 69, \'a736}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1021, \'a718}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{29C.26}}}{\*\bkmkstart stylerid1_2E36_2E2_2E2}{\*\bkmkend stylerid1_2E36_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Referrals }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ fraud }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ benefits inappropriately obtained.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Following a review of an applicant\u8217\'3fs or recipient\u8217\'3fs eligibility to receive moneys under }}}{{\f5\fs18\hyphpar0\qj{section 29C.20A}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{29C.20B}}}{{\f5\fs18\hyphpar0\qj{, the department may refer cases of suspected fraud, misrepresentation, inadequate documentation relating to initial or continued eligibility, or benefits being otherwise inappropriately obtained, along with any supportive information, to the department of inspections, appeals, and licensing for review.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In cases of substantiated fraud, misrepresentation, or benefits being otherwise inappropriately obtained, the state shall review all appropriate legal options including but not limited to removal of a recipient from other public assistance programs and garnishment of wages or state income tax refunds until the department recovers an amount equal to the benefits fraudulently claimed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department may refer suspected cases of fraud, misrepresentation, or inadequate documentation relating to initial or continued eligibility, or suspected cases of benefits being otherwise inappropriately obtained, to appropriate state entities for review of such issues in other programs providing public benefits.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2025 Acts, ch 89, \'a75}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{NEW section}\par}}