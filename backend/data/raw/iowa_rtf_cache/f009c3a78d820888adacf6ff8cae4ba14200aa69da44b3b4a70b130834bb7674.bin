\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F8_307}{\*\bkmkend codeChapter_5F8_307}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 807}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{PROCEEDINGS AGAINST CORPORATIONS}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a7801.1}}}\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{807.1}}}{\*\bkmkstart stylerid1_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Summons upon a complaint against a corporation, by whom issued, and when returnable.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Upon the filing of a complaint against a corporation, the magistrate shall issue a summons, signed by the magistrate, requiring the corporation to appear before the magistrate, at a specified time and place, to answer the charge, the time to be not less than twenty days after the issuing of the summons.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7807.1}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{807.2}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Form of the summons.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The summons may be in substantially the following form:}\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\sb80\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~}}}{County of }{{\f5\fs18\hyphpar0\qj{........................}}}{ (as the case may be).}\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~}}}{In the name of the people of the State of Iowa:}\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qc\fi0\ri1084\li1084{\f5\fs18\hyphpar0\qc}{To the (naming the corporation).}{\f5\fs18\hyphpar0\qc}\par}{}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~}}}{You are hereby summoned to appear before me, at (naming the place) on (specifying the day and hour), to answer a charge made against you, upon the complaint of A.B., for (designating the offense, generally).}\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~}}}{Dated at the city of }{{\f5\fs18\hyphpar0\qj{........................}}}{, the }{{\f5\fs18\hyphpar0\qj{............}}}{ day of }{{\f5\fs18\hyphpar0\qj{....................}}}{, }{{\f5\fs18\hyphpar0\qj{............}}}\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~}}}{G.H. Magistrate}\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keep\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa80{{\f5\fs18\hyphpar0\qj{\~\~}}}{(or as the case may be).}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7807.2}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{807.3}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{When and how served.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The summons for the appearance of a corporation shall be served in the manner provided for service of original notice upon a corporation in a civil action.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7807.3}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{807.4}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Examination of the charge.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{At the time appointed in the summons, the magistrate shall proceed to investigate the charge, in the same manner as in the case of a natural person brought before the magistrate, so far as those proceedings are applicable. If the corporation does not appear or plead at the time and place specified in the summons, the court shall make inquiry into the service of process, and being satisfied that same has been carried out as provided herein, the court may proceed with the matter without further process.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7807.4}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{807.5}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Bringing an indicted corporation into court.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{When an indictment or a trial information is filed against any corporation, such corporation shall be arraigned thereon. Prior to arraignment the court shall proceed as follows:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The clerk of the court wherein such indictment is found or the information filed, or the judge, must issue a summons signed by the clerk or judge with the clerk\u8217\'3fs or judge\u8217\'3fs name of office, requiring such corporation to appear and plead to the indictment, at a time and place to be specified in such summons, such time to be not less than twenty days after the issue thereof. The summons may be substantially in the following form:}}}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\sb80\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~}}}{District Court, }{{\f5\fs18\hyphpar0\qj{........................}}}{ County.}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~}}}{The People of the State of Iowa vs. The A.B. Company,}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~}}}{You are hereby summoned to appear in this court at (naming the place) on (stating the day and hour), and plead to an indictment filed against you by the grand jury of this county, on the }{{\f5\fs18\hyphpar0\qj{............}}}{ day of }{{\f5\fs18\hyphpar0\qj{....................}}}{, charging you with the crime of (designating the offense, generally), and in case of your failure to so appear and answer, judgment will be pronounced against you.}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~}}}{Dated at the city of }{{\f5\fs18\hyphpar0\qj{........................}}}{, the }{{\f5\fs18\hyphpar0\qj{............}}}{ day of }{{\f5\fs18\hyphpar0\qj{....................}}}{, }{{\f5\fs18\hyphpar0\qj{............}}}{.}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{C.D.,}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{Clerk of the District Court.}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa80{(or by order of the court)}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The summons shall be served at least ten days before the appearance fixed therein, in the same manner as is provided for the service of an original notice upon a corporation in a civil action; and if the corporation does not appear or plead at the time and place specified in the summons, the court may proceed to trial and judgment without further process.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Nothing contained in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be construed as preventing the appearance of a corporation by counsel to plead to an indictment, with or without the issuance or service of the summons provided herein. And when an indictment shall have been filed against a corporation it may voluntarily appear and plead to the same by counsel duly authorized to so appear for it.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7807.5}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7602.8102(128)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{807.6}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Collection of fines.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{When a corporation is convicted of an offense and the court imposes a fine as penalty, it may be collected in the same manner as a judgment in a civil action.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7807.6}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{807.7}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Attachment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Upon the filing of a complaint or indictment, the court wherein same is filed shall have authority to issue a writ of attachment to secure the maximum fine allowable by law for the offense charged, and costs.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7807.7}}}{]}\par}}