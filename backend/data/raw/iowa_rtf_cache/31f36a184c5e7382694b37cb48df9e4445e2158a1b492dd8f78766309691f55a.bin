0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99F.1}}}{\*\bkmkstart stylerid1_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{As used in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ unless the context otherwise requires:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAdjusted gross receipts\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the gross receipts on gambling games less winnings paid to wagerers on gambling games and less promotional play receipts on gambling games. However, for each fiscal year during the time period beginning July 1, 2021, and ending June 30, 2026, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fadjusted gross receipts\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall include promotional play receipts on gambling games.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fApplicant\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any person applying for an occupational license or applying for a license to operate an excursion gambling boat, or the officers and members of the board of directors of a qualified sponsoring organization located in Iowa applying for a license to conduct gambling games on an excursion gambling boat.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAuthorized sporting event\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a professional sporting event, collegiate sporting event, international sporting event, or professional motor race event. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAuthorized sporting event\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include a race as defined in }}}{{\f5\fs18\hyphpar0\qj{section 99D.2}}}{{\f5\fs18\hyphpar0\qj{, a fantasy sports contest as defined in }}}{{\f5\fs18\hyphpar0\qj{section 99E.1}}}{{\f5\fs18\hyphpar0\qj{, minor league sporting event, or any athletic event or competition of an interscholastic sport as defined in }}}{{\f5\fs18\hyphpar0\qj{section 9A.102}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCheat\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means to alter the selection of criteria which determine the result of a gambling game or the amount or frequency of payment in a gambling game.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fClaimant agency\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a public agency as defined in }}}{{\f5\fs18\hyphpar0\qj{section 421.65, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, or the state court administrator as defined in }}}{{\f5\fs18\hyphpar0\qj{section 602.1101}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCollegiate sporting event\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an athletic event or competition of an intercollegiate sport as defined in }}}{{\f5\fs18\hyphpar0\qj{section 9A.102}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCommission\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the state racing and gaming commission created under }}}{{\f5\fs18\hyphpar0\qj{section 99D.5}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDistributor\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person who sells, markets, or otherwise distributes gambling games or implements of gambling which are usable in the lawful conduct of gambling games pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, to a licensee authorized to conduct gambling games pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDivision\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the division of criminal investigation of the department of public safety as provided in section }}}{{\f5\fs18\hyphpar0\qj{80.4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDock\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the location where an excursion gambling boat moors for the purpose of embarking passengers for and disembarking passengers from a gambling excursion.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fExcursion boat\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a self-propelled, floating vessel that is or has been previously certified for operation as a vessel.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fExcursion gambling boat\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an excursion boat or moored barge on which lawful gambling is authorized and licensed as provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fGambling excursion\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the time during which gambling games may be operated on an excursion gambling boat whether docked or during a cruise.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fGambling game\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any game of chance authorized by the commission. However, for racetrack enclosures, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fgambling game\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include table games of chance or video machines which simulate table games of chance, unless otherwise authorized by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fGambling game\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include sports wagering.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fGambling structure\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any man-made stationary structure approved by the commission that does not include a racetrack enclosure which is subject to land-based building codes rather than maritime or Iowa department of natural resources inspection laws and regulations on which lawful gambling is authorized and licensed as provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{16.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fGaming floor\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means that portion of an excursion gambling boat, gambling structure, or racetrack enclosure in which gambling games are conducted as designated by the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{17.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fGross receipts\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the total sums wagered under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{18.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fHolder of occupational license\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person licensed by the commission to perform an occupation which the commission has identified as requiring a license to engage in the administration, control, and conduct of gambling games and sports wagering.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{19.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fInternational sporting event\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an international team or individual sporting event governed by an international sports federation or sports governing body, including sporting events governed by the international olympic committee and the international federation of association football.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{20.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLicensee\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any person licensed under }}}{{\f5\fs18\hyphpar0\qj{section 99F.7}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{99F.7A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{21.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fManufacturer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person who designs, assembles, fabricates, produces, constructs, or who otherwise prepares a product or a component part of a product of any implement of gambling usable in the lawful conduct of gambling games pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{22.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMinor league sporting event\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a sporting event conducted by a sports league which is not regarded as the premier league in the sport as determined by the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{23.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMoored barge\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a barge or vessel that is not self-propelled.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{24.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fProfessional sporting event\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an event, excluding a minor league sporting event, at which two or more persons participate in sports or athletic events and receive compensation in excess of actual expenses for their participation in such event, unless the event includes professional athletes participating in a sports or athletic event without compensation in excess of actual expenses for a charitable purpose.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{25.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPromotional play receipts\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the total sums wagered with tokens, chips, electronic credits, or other forms of cashless wagering provided by the licensee without an exchange of money as described in }}}{{\f5\fs18\hyphpar0\qj{section 99F.9, subsection 3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{26.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fQualified sponsoring organization\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a nonprofit corporation organized under the laws of this state, whether or not it is exempt from federal income taxation, or a person or association that can show to the satisfaction of the commission that the person or association is eligible for exemption from federal income taxation under section 501(c)(3), 501(c)(4), 501(c)(5), 501(c)(6), 501(c)(7), 501(c)(8), 501(c)(10), or 501(c)(19) of the Internal Revenue Code as defined in }}}{{\f5\fs18\hyphpar0\qj{section 422.3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{27.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fRacetrack enclosure\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means all real property utilized for the conduct of a race meeting, including the racetrack, grandstand, concession stands, offices, barns, kennels and barn areas, employee housing facilities, parking lots, and any additional areas designated by the commission. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fRacetrack enclosure\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ also means all real property utilized by a licensee under }}}{{\f5\fs18\hyphpar0\qj{chapter 99D}}}{{\f5\fs18\hyphpar0\qj{ who is not required to conduct live racing pursuant to the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 99D.9A}}}{{\f5\fs18\hyphpar0\qj{, on which pari-mutuel wagering on simultaneously telecast horse or dog races may be conducted and lawful gambling is authorized and licensed as provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{28.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSports-related event\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an event that takes place in relation to an authorized sporting event, but that is not tied to the outcome of a specific athletic event or contest as authorized by the commission. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSports-related event\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes but is not limited to professional sports drafts and individual player awards.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{29.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSports wagering\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the acceptance of wagers on an authorized sporting event or sports-related event by any system of wagering as authorized by the commission. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSports wagering\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include placing a wager on the performance or nonperformance of any individual athlete participating in a single game or match of a collegiate sporting event in which a collegiate team from this state is a participant, or placing a wager on the performance of athletes in an individual international sporting event governed by the international olympic committee in which any participant in the international sporting event is under eighteen years of age.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{30.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSports wagering area\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an area, as designated by the commission, in which sports wagering is conducted.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{31.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSports wagering net receipts\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the gross receipts less winnings paid to wagerers and less promotional play receipts on sports wagering.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 67, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1203, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1021, \'a77 \u8211\'3f 9}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 176, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 9, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 44, \'a734}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1136, \'a724 \u8211\'3f 30, 65}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 188, \'a75, 6}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1172, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1036, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1126, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1099, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 24, \'a798}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 132, \'a72 \u8211\'3f 4, 22, 23}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1063, \'a751}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1064, \'a76, 28}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1118, \'a773, 74}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 177, \'a768}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1143, \'a79 \u8211\'3f 11, 15}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a799B.13}}}{{\f5\fs12\hyphpar0\qj{, 99B.42}}}{{\f5\fs12\hyphpar0\qj{, 99D.7}}}{{\f5\fs12\hyphpar0\qj{, 99E.1}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99F.2}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Scope of provisions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This chapter}}}{ does not apply to the pari-mutuel system of wagering used or intended to be used in connection with the horse-race or dog-race meetings as authorized under }{{\f5\fs18\hyphpar0\qj{chapter 99D}}}{, internet fantasy sports contests authorized under }{{\f5\fs18\hyphpar0\qj{chapter 99E}}}{, lottery or lotto games authorized under }{{\f5\fs18\hyphpar0\qj{chapter 99G}}}{, or bingo or games of skill or chance authorized under }{{\f5\fs18\hyphpar0\qj{chapter 99B}}}{.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 67, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 178, \'a7106, 121}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 179, \'a7142}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 132, \'a736, 45, 46}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99F.3}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Gambling games and sports wagering authorized.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The system of wagering on a gambling game and sports wagering as provided by }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ is legal, when conducted by a licensee as provided in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 67, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 188, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 132, \'a75, 22, 23}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99F.4}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Powers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The commission shall have full jurisdiction over and shall supervise all gambling operations governed by }{{\f5\fs18\hyphpar0\qj{this chapter}}}{. The commission shall have the following powers and shall adopt rules pursuant to }{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{ to implement }{{\f5\fs18\hyphpar0\qj{this chapter}}}{:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To investigate applicants and determine the eligibility of applicants for a license and to select among competing applicants for a license the applicant which best serves the interests of the citizens of Iowa.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To license qualified sponsoring organizations, to license the operators of excursion gambling boats, to identify occupations engaged in the administration, control, and conduct of gambling games and sports wagering which require licensing, and to adopt standards for licensing the occupations including establishing fees for the occupational licenses and licenses for qualified sponsoring organizations. The fees shall be paid to the commission and deposited in the general fund of the state. All revenue received by the commission under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ from license fees and regulatory fees shall be deposited in the general fund of the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To adopt standards under which all excursion gambling boat operations shall be held and standards for the facilities within which the gambling operations are to be held. The commission may authorize the operation of gambling games on an excursion gambling boat and sports wagering in a sports wagering area which is also licensed to sell or serve alcoholic beverages, wine, or beer as defined in }}}{{\f5\fs18\hyphpar0\qj{section 123.3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To license the licensee of a pari-mutuel dog or horse racetrack enclosure subject to the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and rules adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ relating to gambling except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{section 99F.4A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To enter the office, excursion gambling boat, facilities, or other places of business of a licensee to determine compliance with }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To investigate alleged violations of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or the commission rules, orders, or final decisions and to take appropriate disciplinary action against a licensee or a holder of an occupational license for a violation, or institute appropriate legal action for enforcement, or both. Information gathered during an investigation is confidential during the pendency of the investigation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To require a licensee, an employee of a licensee or holder of an occupational license to remove a person violating a provision of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or the commission rules, orders, or final orders, or other person deemed to be undesirable, from the excursion gambling boat facilities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To require the removal of a licensee, an employee of a licensee, or a holder of an occupational license for a violation of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or a commission rule or engaging in a fraudulent practice.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To require a licensee to file an annual balance sheet and profit and loss statement pertaining to the licensee\u8217\'3fs gambling activities in this state, together with a list of the stockholders or other persons having any beneficial interest in the gambling activities of each licensee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To issue subpoenas for the attendance of witnesses and subpoenas duces tecum for the production of books, records, and other pertinent documents in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{, and to administer oaths and affirmations to the witnesses, when, in the judgment of the commission, it is necessary to enforce }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or the commission rules.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To keep accurate and complete records of its proceedings and to certify the records as may be appropriate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To assess a fine and revoke or suspend licenses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To take any other action as may be reasonable or appropriate to enforce }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and the commission rules.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To require all licensees of gambling game operations to utilize a cashless wagering system whereby all players\u8217\'3f money is converted to tokens, electronic cards, or chips which only can be used for wagering on the excursion gambling boat.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To determine the payouts from the gambling games authorized under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. In making the determination of payouts, the commission shall consider factors that provide gambling and entertainment opportunities which are beneficial to the gambling licensees and the general public.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{16.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To set the payout rate for all slot machines.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{17.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To define the excursion season and the duration of an excursion. While an excursion gambling boat is docked, passengers may embark or disembark at any time during its business hours.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{18.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To provide for the continuous recording of all gambling activities on an excursion gambling boat. The recording shall be performed under guidelines set by rule of the division of criminal investigation and the rules may require that all or part of the original recordings be submitted to the division on a timely schedule.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{19.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To provide for adequate security aboard each excursion gambling boat.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{20.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Drug testing, as permitted by }}}{{\f5\fs18\hyphpar0\qj{section 730.5}}}{{\f5\fs18\hyphpar0\qj{, shall be required periodically, not less than every sixty days, of persons employed as captains, pilots, or physical operators of excursion gambling boats under the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{21.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To provide that a licensee prominently display at each gambling facility the annual percentage rate of state and local tax revenue collected by state and local government from the gambling facility annually.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{22.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To establish a process to allow a person to be voluntarily excluded from advance deposit wagering as defined in }}}{{\f5\fs18\hyphpar0\qj{section 99D.11}}}{{\f5\fs18\hyphpar0\qj{, from an internet fantasy sports contest as defined in }}}{{\f5\fs18\hyphpar0\qj{section 99E.1}}}{{\f5\fs18\hyphpar0\qj{, from advance deposit sports wagering as defined in }}}{{\f5\fs18\hyphpar0\qj{section 99F.9}}}{{\f5\fs18\hyphpar0\qj{, from the gaming floor and sports wagering area of an excursion gambling boat, from the wagering area, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 99D.2}}}{{\f5\fs18\hyphpar0\qj{, and from the gaming floor and sports wagering area of all other licensed facilities under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{chapter 99D}}}{{\f5\fs18\hyphpar0\qj{ as provided in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. The process shall provide that an initial request by a person to be voluntarily excluded shall be for a period of five years or life and any subsequent request following any five-year period shall be for a period of five years or life. The process established shall require that licensees be provided electronic access to names and social security numbers of persons voluntarily excluded through a secured interactive internet site maintained by the commission and information regarding persons voluntarily excluded shall be disseminated to all licensees under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{chapter 99D}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{chapter 99E}}}{{\f5\fs18\hyphpar0\qj{. The names, social security numbers, and information regarding persons voluntarily excluded shall be kept confidential unless otherwise ordered by a court or by another person duly authorized to release such information. The process established shall also require a person requesting to be voluntarily excluded be provided information compiled by the department of health and human services on gambling treatment options. The state and any licensee under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{chapter 99D}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{chapter 99E}}}{{\f5\fs18\hyphpar0\qj{ shall not be liable to any person for any claim which may arise from this process. In addition to any other penalty provided by law, any money or thing of value that has been obtained by, or is owed to, a voluntarily excluded person as a result of wagers made by the person after the person has been voluntarily excluded shall be forfeited by the person and shall be credited to the general fund of the state. The commission shall not initiate any administrative action or impose penalties on a licensee who voluntarily reports to the commission activity described in }}}{{\f5\fs18\hyphpar0\qj{section 99F.15, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fn\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{23.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To approve a licensee\u8217\'3fs application to operate as a moored barge, an excursion boat that will cruise, or an excursion boat that will not cruise, as submitted pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 99F.7}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{24.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To conduct a socioeconomic study on the impact of gambling on Iowans, every eight years beginning in calendar year 2013, and issue a report on that study. The commission shall ensure that the results of each study are readily accessible to the public.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{25.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To license the licensee of a gambling structure subject to the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and rules adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ relating to gambling and as provided in }}}{{\f5\fs18\hyphpar0\qj{section 99F.4D}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{26.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To require licensees to establish a process with the state for licensees to have electronic access to names and social security numbers of debtors of claimant agencies through a secured interactive internet site maintained by the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{27.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To adopt standards under which all sports wagering is conducted, including the scope and type of wagers allowed, to identify occupations within sports wagering which require licensing, and to adopt standards for licensing and background qualifications for occupations including establishing fees for the occupational license. All revenue received by the commission under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ from license fees shall be deposited in the general fund of the state. All revenue received by the commission from regulatory fees shall be deposited into the gaming regulatory revolving fund established in }}}{{\f5\fs18\hyphpar0\qj{section 99F.20}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 67, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 139, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 260, \'a71207}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 131, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1021, \'a710 \u8211\'3f 12}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1107, \'a735}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1231, \'a737}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1136, \'a731 \u8211\'3f 35}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 188, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 215, \'a786}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1172, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 182, \'a7103}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 90, \'a7257}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 132, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1026, \'a736}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1099, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 132, \'a76, 7, 22, 23}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1143, \'a76, 16}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a765}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1185, \'a7128}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a799E.5}}}{{\f5\fs12\hyphpar0\qj{, 99F.7}}}{{\f5\fs12\hyphpar0\qj{, 99F.7A}}}{{\f5\fs12\hyphpar0\qj{, 99F.10}}}{{\f5\fs12\hyphpar0\qj{, 99F.15}}}{{\f5\fs12\hyphpar0\qj{, 99F.17}}}{{\f5\fs12\hyphpar0\qj{, 99F.19}}}{{\f5\fs12\hyphpar0\qj{, 99F.20}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For provisions governing authority of a person voluntarily excluded for life from all licensed facilities under }{{\f5\fs12\hyphpar0\qj{chapters 99D}}}{ and }{{\f5\fs12\hyphpar0\qj{99F}}}{ prior to July 1, 2017, to revoke the exclusion, see }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2017/CH0132.pdf" }{\fldrslt \cf5 \f5 \fs12{{2017 Acts, ch 132, \'a73}}}}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99F.4A}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Gambling games at pari-mutuel racetracks \u8212\'3f fees and taxes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon application, the commission shall license the licensee of a pari-mutuel dog or horse racetrack to conduct gambling games at a pari-mutuel racetrack enclosure subject to the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and rules adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ relating to gambling except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A license to conduct gambling games shall be issued only to a licensee holding a valid license to conduct pari-mutuel dog or horse racing pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 99D}}}{{\f5\fs18\hyphpar0\qj{ on January 1, 1994.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person holding a valid license pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 99D}}}{{\f5\fs18\hyphpar0\qj{ to conduct pari-mutuel wagering at a dog or horse racetrack is exempt from further investigation and examination for licensing to conduct gambling games pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. However, the commission may order future investigations or examinations as the commission finds appropriate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The regulatory fee imposed in }}}{{\f5\fs18\hyphpar0\qj{section 99D.14, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, shall be collected from a licensee of a racetrack enclosure where gambling games are licensed to operate in lieu of the regulatory fee imposed in }}}{{\f5\fs18\hyphpar0\qj{section 99F.10}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In lieu of the annual license fee specified in }}}{{\f5\fs18\hyphpar0\qj{section 99F.5}}}{{\f5\fs18\hyphpar0\qj{, the annual license fee for conducting gambling games at a pari-mutuel racetrack shall be one thousand dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The adjusted gross receipts received from gambling games shall be taxed at the same rates and the proceeds distributed in the same manner as provided in }}}{{\f5\fs18\hyphpar0\qj{section 99F.11}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensee shall keep its books and records regarding the operation of gambling games in compliance with }}}{{\f5\fs18\hyphpar0\qj{section 99F.12}}}{{\f5\fs18\hyphpar0\qj{, as applicable.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall, upon the immediate payment of the applicable table games license fee and submission to the commission by June 1, 2005, of an application by a licensee of a pari-mutuel dog or horse racetrack licensed to conduct gambling games at a pari-mutuel racetrack enclosure, issue a license to the licensee to conduct table games of chance, including video machines that simulate table games of chance, at the pari-mutuel racetrack enclosure subject to the requirements of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. However, a table games license may only be issued to a licensee required to pay a table games license fee of three million dollars under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ if the licensee, and all other licensees of an excursion gambling boat in that county, file an agreement with the commission authorizing the granting of a table games license under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ and permitting all licensees of an excursion gambling boat to operate a moored barge as of a specific date. The licensee shall be granted a table games license by the commission upon payment of the applicable license fee to the commission which table games license fee may be offset by the licensee against taxes imposed on the licensee by }}}{{\f5\fs18\hyphpar0\qj{section 99F.11}}}{{\f5\fs18\hyphpar0\qj{, to the extent of twenty percent of the table games license fee paid pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ for each of five consecutive fiscal years beginning with the fiscal year beginning July 1, 2008. Fees paid pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ are not refundable to the licensee. A licensee shall not be required to pay a fee to renew a table games license issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. Moneys collected by the commission from a table games license fee paid under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be deposited in the rebuild Iowa infrastructure fund created in }}}{{\f5\fs18\hyphpar0\qj{section 8.57}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, the applicable license fee for a licensee shall be three million dollars if the adjusted gross receipts from gambling games for the licensee in the previous fiscal year was less than one hundred million dollars, and shall be ten million dollars if the adjusted gross receipts from gambling games for the licensee in the previous fiscal year was one hundred million dollars or more.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon application, the commission shall issue a license to the licensee of the pari-mutuel dog racetrack located in Dubuque county as of May 30, 2014, to conduct gambling games at a gambling structure subject to the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and rules adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ relating to gambling. The licensee shall not be required to pay any additional fees or be assessed any additional costs for issuance of the license pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ and shall be exempt, for purposes of the initial issuance of a license under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, from further investigation and examination for a license to conduct gambling games pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To maintain a license pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ on or after July 1, 2014, the licensee shall provide written notification to the commission by September 1, 2014, as provided in }}}{{\f5\fs18\hyphpar0\qj{section 99D.9A, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, pay the live racing cessation fee as provided in }}}{{\f5\fs18\hyphpar0\qj{section 99D.9A}}}{{\f5\fs18\hyphpar0\qj{, and otherwise comply with the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 99D.9A}}}{{\f5\fs18\hyphpar0\qj{ applicable to the licensee. In addition, the licensee shall pay the annual license fee as specified in }}}{{\f5\fs18\hyphpar0\qj{section 99F.5}}}{{\f5\fs18\hyphpar0\qj{ and regulatory fee as a licensee of a gambling structure and shall otherwise be required to comply with all requirements of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ applicable to a gambling games licensee not otherwise inconsistent with the requirements of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1021, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1229, \'a719}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{; }{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts//CH0000.pdf" }{\fldrslt \f5 \fs18{{\f5\fs18\hyphpar0\qj\cf5{2002 Acts, 2nd Ex, ch 1003, \'a7168, 172}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1136, \'a736, 37, 65}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1032, \'a7201}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 111, \'a710, 13, 14}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1126, \'a79, 10, 13}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a799D.9A}}}{{\f5\fs12\hyphpar0\qj{, 99D.9C}}}{{\f5\fs12\hyphpar0\qj{, 99F.4}}}{{\f5\fs12\hyphpar0\qj{, 99F.6}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99F.4B}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Rules.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department of inspections, appeals, and licensing shall cooperate to the maximum extent possible with the division of criminal investigation in adopting rules relating to the gaming operations in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ and }{{\f5\fs18\hyphpar0\qj{chapters 99D}}}{ and }{{\f5\fs18\hyphpar0\qj{99E}}}{.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1199, \'a746}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 132, \'a737, 45, 46}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71870}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99F.4C}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Gambling games prohibition area.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any provision of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{chapter 99D}}}{{\f5\fs18\hyphpar0\qj{ to the contrary, the commission shall not grant a license to conduct gambling games to a facility to be located in the applicable area as described in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fapplicable area\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means that portion of the city of Des Moines in Polk county bounded by a line commencing at the point East Euclid avenue intersects East Fourteenth street, then proceeding south along East Fourteenth street and Southeast Fourteenth street until it intersects Park avenue, then proceeding west along Park avenue until it intersects Fleur drive, then proceeding north along Fleur drive until it intersects Eighteenth street, then proceeding north along Eighteenth street until it intersects Ingersoll avenue, then proceeding west along Ingersoll avenue until it intersects Martin Luther King Jr. parkway, then proceeding northerly along Martin Luther King Jr. parkway until it intersects Euclid avenue, then proceeding east along Euclid avenue and East Euclid avenue to the point of origin. For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, such reference to a street or other boundary means such street or boundary as it was delineated on the official Pub. L. No. 94-171 census maps used for redistricting following the 2000 United States decennial census.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1136, \'a738}}}{; }{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 3, \'a728}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99F.4D}}}{\*\bkmkstart stylerid1_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Gambling games at gambling structures \u8212\'3f requirements \u8212\'3f licensing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Unless otherwise provided by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ applicable to an excursion gambling boat shall also apply to a gambling structure.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensee authorized to conduct gambling games on an excursion boat may convert the license to authorize the conducting of gambling games on a gambling structure with the approval of the commission. In addition, a licensee authorized to conduct gambling games on a moored barge may elect to have the license treated to allow the conducting of gambling games on a gambling structure with the approval of the commission.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 188, \'a79}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a799F.4}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99F.5}}}{\*\bkmkstart stylerid1_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{License to conduct gambling games on excursion gambling boats and at gambling structures \u8212\'3f license to operate boat \u8212\'3f applications \u8212\'3f operating agreements \u8212\'3f fee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A qualified sponsoring organization may apply to the commission for a license to conduct gambling games on an excursion gambling boat or gambling structure as provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. A person may apply to the commission for a license to operate an excursion gambling boat. An operating agreement entered into on or after May 6, 2004, between a qualified sponsoring organization and an operator of an excursion gambling boat or gambling structure shall provide for a minimum distribution by the qualified sponsoring organization for educational, civic, public, charitable, patriotic, or religious uses as defined in }}}{{\f5\fs18\hyphpar0\qj{section 99B.1}}}{{\f5\fs18\hyphpar0\qj{, that averages at least three percent of the adjusted gross receipts for each license year and, if applicable, three-quarters of one percent of sports wagering net receipts for each license year. The application shall be filed with the administrator of the commission at least ninety days before the first day of the next excursion season as determined by the commission, shall identify the excursion gambling boat upon which gambling games will be authorized, shall specify the exact location where the excursion gambling boat will be docked, and shall be in a form and contain information as the commission prescribes. The minimum capacity of an excursion gambling boat or gambling structure is two hundred fifty persons.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The annual license fee to operate an excursion gambling boat shall be based on the passenger-carrying capacity including crew, for which the excursion gambling boat is registered. For a gambling structure, the annual license fee shall be based on the capacity of the gambling structure. The annual fee shall be five dollars per person capacity.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 67, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1021, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1136, \'a739, 65}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 188, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 99, \'a751}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 132, \'a78, 22, 23}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a799F.4A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99F.5A}}}{\*\bkmkstart stylerid1_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Limitations on issuance of licenses to conduct gambling games.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by its own terms; }}}{{\f5\fs18\hyphpar0\qj{2022 Acts, ch 1143, \'a717}}}{{\f5\fs18\hyphpar0\qj{.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99F.6}}}{\*\bkmkstart stylerid1_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Requirements of applicant \u8212\'3f fee \u8212\'3f penalty.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not be issued a license to conduct gambling games on an excursion gambling boat or a license to operate an excursion gambling boat under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, an occupational license, a distributor license, or a manufacturer license unless the person has completed and signed an application on the form prescribed and published by the commission. The application shall include the full name, residence, date of birth and other personal identifying information of the applicant that the commission deems necessary. The application shall also indicate whether the applicant has any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A record of conviction of a felony.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An addiction to alcohol or a controlled substance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A history of mental illness.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An applicant shall submit pictures, fingerprints, and descriptions of physical characteristics to the commission in the manner prescribed on the application forms. The fingerprints may be submitted to the federal bureau of investigation by the department of public safety through the state criminal history repository for the purpose of a national criminal history check.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall charge the applicant a fee set by the department of public safety, division of criminal investigation, to defray the costs associated with the search and classification of fingerprints required in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ and background investigations conducted by agents of the division of criminal investigation. This fee is in addition to any other license fee charged by the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Before a license is granted, the division of criminal investigation of the department of public safety shall conduct a thorough background investigation of the applicant for a license to operate a gambling game operation on an excursion gambling boat. The applicant shall provide information on a form as required by the division of criminal investigation.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A qualified sponsoring organization licensed to operate gambling games under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall distribute the receipts of all gambling games, less reasonable expenses, charges, taxes, fees, and deductions allowed under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, as winnings to players or participants or shall distribute the receipts for educational, civic, public, charitable, patriotic, or religious uses as defined in }}}{{\f5\fs18\hyphpar0\qj{section 99B.1}}}{{\f5\fs18\hyphpar0\qj{. A qualified sponsoring organization shall provide that any organization exempt from federal income taxes under section 501(c)(19) of the Internal Revenue Code, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 422.3}}}{{\f5\fs18\hyphpar0\qj{, shall be eligible for a distribution of adjusted gross receipts for educational, civic, public, charitable, patriotic, or religious uses as required by this subparagraph. However, a licensee to conduct gambling games under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall, unless an operating agreement for an excursion gambling boat otherwise provides, distribute at least three percent of the adjusted gross receipts and, if applicable, three-quarters of one percent of sports wagering net receipts for each license year for educational, civic, public, charitable, patriotic, or religious uses as defined in }}}{{\f5\fs18\hyphpar0\qj{section 99B.1}}}{{\f5\fs18\hyphpar0\qj{. However, if a licensee who is also licensed to conduct pari-mutuel wagering at a horse racetrack has unpaid debt from the pari-mutuel racetrack operations, the first receipts of the gambling games operated within the racetrack enclosure less reasonable operating expenses, taxes, and fees allowed under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall be first used to pay the annual indebtedness.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall authorize, subject to the debt payments for horse racetracks and the provisions of paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ for dog racetracks, a licensee who is also licensed to conduct pari-mutuel dog or horse racing to use receipts from gambling games and sports wagering within the racetrack enclosure to supplement purses for races particularly for Iowa-bred horses pursuant to an agreement which shall be negotiated between the licensee and representatives of the dog or horse owners. For agreements subject to commission approval concerning purses for horse racing beginning on or after January 1, 2006, the agreements shall provide that total annual purses for all horse racing shall be four percent of sports wagering net receipts and promotional play receipts on sports wagering and no less than eleven percent of the first two hundred million dollars of net receipts, and six percent of net receipts above two hundred million dollars. In addition, live standardbred horse racing shall not be conducted at the horse racetrack in Polk county, but the purse moneys designated for standardbred racing pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 99D.7, subsection 5}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, shall be included in calculating the total annual purses required to be paid pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. Agreements that are subject to commission approval concerning horse purses for a period of time beginning on or after January 1, 2006, shall be jointly submitted to the commission for approval.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A qualified sponsoring organization shall not make a contribution to a candidate, political committee, candidate\u8217\'3fs committee, state statutory political committee, county statutory political committee, national political party, or fundraising event as these terms are defined in }}}{{\f5\fs18\hyphpar0\qj{section 68A.102}}}{{\f5\fs18\hyphpar0\qj{. The membership of the board of directors of a qualified sponsoring organization shall represent a broad interest of the communities.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of this paragraph, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fnet receipts\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the annual adjusted gross receipts from all gambling games and, beginning July 1, 2026, promotional play receipts on all gambling games less the annual amount of money pledged by the owner of the facility to fund a project approved to receive vision Iowa funds as of July 1, 2004.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall authorize the licensee of the pari-mutuel dog racetrack located in Dubuque county to conduct gambling games as provided in }}}{{\f5\fs18\hyphpar0\qj{section 99F.4A}}}{{\f5\fs18\hyphpar0\qj{ if the licensee schedules at least one hundred thirty performances of twelve live races each day during a season of twenty-five weeks. For the pari-mutuel dog racetrack located in Pottawattamie county, the commission shall authorize the licensee to conduct gambling games as provided in }}}{{\f5\fs18\hyphpar0\qj{section 99F.4A}}}{{\f5\fs18\hyphpar0\qj{ if the licensee schedules at least two hundred ninety performances of twelve live races each day during a season of fifty weeks. However, the requirement to schedule performances of live races for purposes of conducting gambling games under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall not apply to a licensee as of the live racing cessation date of the licensee as provided in }}}{{\f5\fs18\hyphpar0\qj{section 99D.9A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a pari-mutuel dog racetrack authorized to conduct gambling games as of January 1, 2014, is required to schedule performances of live races for purposes of conducting gambling games under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ during any calendar year, the commission shall approve an annual contract to be negotiated between the annual recipient of the dog racing promotion fund and each dog racetrack licensee to specify the percentage or amount of gambling game proceeds which shall be dedicated to supplement the purses of live dog races. The parties shall agree to a negotiation timetable to insure no interruption of business activity. If the parties fail to agree, the commission shall impose a timetable. If the two parties cannot reach agreement, each party shall select a representative and the two representatives shall select a third person to assist in negotiating an agreement. The two representatives may select the commission or one of its members to serve as the third party. Alternately, each party shall submit the name of the proposed third person to the commission who shall then select one of the two persons to serve as the third party. All parties to the negotiations, including the commission, shall consider that the dog racetracks were built to facilitate the development and promotion of Iowa greyhound racing dogs in this state and shall negotiate and decide accordingly.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Before a license is granted, an operator of an excursion gambling boat shall work with the economic development authority to promote tourism throughout Iowa. Tourism information from local civic and private persons may be submitted for dissemination.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who knowingly makes a false statement on the application is guilty of an aggravated misdemeanor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, applicant includes each member of the board of directors of a qualified sponsoring organization.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The licensee or a holder of an occupational license shall consent to the search, without a warrant, by agents of the division of criminal investigation of the department of public safety or commission employees designated by the administrator of the commission, of the licensee\u8217\'3fs or holder\u8217\'3fs person, personal property, and effects, and premises which are located on the excursion gambling boat or adjacent facilities under control of the licensee, in order to inspect or investigate for violations of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or rules adopted by the commission pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. The department or commission may also obtain administrative search warrants under }}}{{\f5\fs18\hyphpar0\qj{section 808.14}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{However, }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not be construed to permit a warrantless inspection of living quarters or sleeping rooms on the riverboat if all of the following are true:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The licensee has specifically identified those areas which are to be used as living quarters or sleeping rooms in writing to the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Gaming is not permitted in the living quarters or sleeping rooms, and devices, records, or other items relating to the licensee\u8217\'3fs gaming operations are not stored, kept, or maintained in the living quarters or sleeping rooms.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Alcoholic beverages are not stored, kept, or maintained in the living quarters or sleeping rooms except those legally possessed by the individual occupying the quarters or room.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall adopt rules to enforce }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of directors of a qualified sponsoring organization licensed to conduct or operate gambling games under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall be residents of this state and shall include, at the option of each applicable county and city, as ex officio, nonvoting members of the board, a member of the county board of supervisors and a member of a city council for each county and city that has a licensed gambling games facility which is conducted or operated by the qualified sponsoring organization. If a vacancy for any ex officio member occurs, the vacancy shall be filled in the same manner as the original appointment for the remainder of the unexpired term of the vacancy. However,\~}}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not apply to an agency, instrumentality, or political subdivision of the state that is licensed to conduct gambling games under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 67, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 231, \'a733}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1021, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 176, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1044, \'a710, 11}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 108, \'a732}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1136, \'a740}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 35, \'a731}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 48, \'a76, 7}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 111, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 118, \'a785, 89}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1126, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 99, \'a752}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 132, \'a79, 22, 23, 51}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 143, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1066, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 177, \'a769}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 64, \'a716}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a799D.9A}}}{{\f5\fs12\hyphpar0\qj{, 99F.7A}}}{{\f5\fs12\hyphpar0\qj{, 99F.9}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99F.7}}}{\*\bkmkstart stylerid1_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Licenses \u8212\'3f terms and conditions \u8212\'3f revocation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the commission is satisfied that }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and its rules adopted under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ applicable to licensees have been or will be complied with, the commission shall issue a license for a period of not more than three years to an applicant to own a gambling game operation, to an applicant to operate a gambling structure, and to an applicant to operate an excursion gambling boat. The commission shall decide which of the gambling games authorized under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ the commission will permit. The commission shall decide the number, location, and type of gambling structures and excursion gambling boats licensed under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. The commission shall allow the operation of an excursion boat or moored barge on or within one thousand feet of the high water marks of the rivers, lakes, and reservoirs of this state as established by the commission in consultation with the United States army corps of engineers, the department of natural resources, or other appropriate regulatory agency. The license shall set forth, as applicable, the name of the licensee, the type of license granted, the location of the gambling structure or the place where the excursion gambling boats will operate and dock, and the time and number of days during the excursion season and the off season when gambling may be conducted by the licensee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An applicant for a license to conduct gambling games on an excursion gambling boat, and each licensee by June 30 of each year thereafter, shall indicate and have noted on the license whether the applicant or licensee will operate a moored barge, an excursion boat that will cruise, or an excursion boat that will not cruise subject to the requirements of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. If the applicant or licensee will operate a moored barge or an excursion boat that will not cruise, the requirements of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ concerning cruising shall not apply. If the applicant\u8217\'3fs or licensee\u8217\'3fs excursion boat will cruise, the applicant or licensee shall comply with the cruising requirements of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and the commission shall not allow such a licensee to conduct gambling games on an excursion gambling boat while docked during the off season if the licensee does not operate gambling excursions for a minimum number of days during the excursion season. The commission may delay the commencement of the excursion season at the request of a licensee.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{However, an applicant or licensee of an excursion gambling boat that is located in the same county as a racetrack enclosure conducting gambling games shall not be allowed to operate a moored barge unless either of the following applies:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the licensee is located in the same county as a racetrack enclosure conducting gambling games that had less than one hundred million dollars in adjusted gross receipts from gambling games for the fiscal year beginning July 1, 2003, the licensee of an excursion gambling boat is authorized to operate a moored barge if the licensee, the licensee of the racetrack enclosure, and all other licensees of an excursion gambling boat in that county file an agreement with the commission agreeing to the granting of a table games license under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and permitting all licensees of an excursion gambling boat in the county to operate a moored barge as of a specific date.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the licensee is located in the same county as a racetrack enclosure conducting gambling games that had one hundred million dollars or more in adjusted gross receipts from gambling games for the fiscal year beginning July 1, 2003, the licensee of an excursion gambling boat is authorized to operate a moored barge the earlier of July 1, 2007, or the date any form of gambling games, as defined in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, is operational in any state that is contiguous to the county where the licensee is located.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person awarded a new license to conduct gambling games on an excursion gambling boat or gambling structure in the same county as another licensed excursion gambling boat or gambling structure shall only be licensed to operate an excursion gambling boat or gambling structure that is located at a similarly situated site and operated as a substantially similar facility as any other excursion gambling boat or gambling structure in the county.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A license shall only be granted to an applicant upon the express conditions that:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant shall not, by a lease, contract, understanding, or arrangement of any kind, grant, assign, or turn over to a person the operation of an excursion gambling boat licensed under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ or of the system of wagering described in }}}{{\f5\fs18\hyphpar0\qj{section 99F.9}}}{{\f5\fs18\hyphpar0\qj{. }}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not prohibit a management contract approved by the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant shall not in any manner permit a person other than the licensee to have a share, percentage, or proportion of the money received for admissions to the excursion gambling boat.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall require, as a condition of granting a license, that an applicant to operate an excursion gambling boat develop and, as nearly as practicable, re-create boats or moored barges that resemble Iowa\u8217\'3fs riverboat history.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall require that an applicant utilize Iowa resources, goods and services in the operation of an excursion gambling boat. The commission shall develop standards to assure that a substantial amount of all resources and goods used in the operation of an excursion gambling boat emanate from and are made in Iowa and that a substantial amount of all services and entertainment are provided by Iowans.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall, as a condition of granting a license, require an applicant to provide written documentation that, on each excursion gambling boat:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An applicant shall make every effort to ensure that a substantial number of the staff and entertainers employed are residents of Iowa.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A section is reserved for promotion and sale of arts, crafts, and gifts native to and made in Iowa.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It is the intent of the general assembly that employees be paid at least twenty-five percent above the federal minimum wage level in effect on December 31, 2020.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A license shall not be granted if there is substantial evidence that any of the following apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant has been suspended from operating a game of chance or gambling operation in another jurisdiction by a board or commission of that jurisdiction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant has not demonstrated financial responsibility sufficient to meet adequately the requirements of the enterprise proposed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant is not the true owner of the enterprise proposed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant is not the sole owner, and other persons have ownership in the enterprise, which fact has not been disclosed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant is a corporation and ten percent of the stock of the corporation is subject to a contract or option to purchase at any time during the period for which the license is to be issued unless the contract or option was disclosed to the commission and the commission approved the sale or transfer during the period of the license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant has knowingly made a false statement of a material fact to the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant has failed to meet a monetary obligation in connection with an excursion gambling boat.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A license shall not be granted if there is substantial evidence that the applicant is not of good repute and moral character or if the applicant has pled guilty to, or has been convicted of, a felony.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensee shall not loan to any person money or any other thing of value for the purpose of permitting that person to wager on any game of chance.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensee shall not permit a financial institution, vendor, or other person to dispense cash or credit through an electronic or mechanical device including but not limited to a satellite terminal, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 527.2}}}{{\f5\fs18\hyphpar0\qj{, that is located on the gaming floor. However, this paragraph shall not apply to cashless wagering systems where a person accesses a cash account through a mobile application used by the licensee to conduct cashless wagering. The mobile application shall include the statewide telephone number authorized by the department of health and human services to provide problem gambling information and extensive responsible gaming features in addition to those described in }}}{{\f5\fs18\hyphpar0\qj{section 99F.4, subsection 22}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When technologically available, a licensee shall ensure that a person may voluntarily bar the person\u8217\'3fs access to receive cash or credit from a financial institution, vendor, or other person through an electronic or mechanical device including but not limited to a satellite terminal as defined in }}}{{\f5\fs18\hyphpar0\qj{section 527.2}}}{{\f5\fs18\hyphpar0\qj{ that is located on the licensed premises.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A license to conduct gambling games in a county shall be issued only if the county electorate approves the conduct of the gambling games as provided in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. The board of supervisors, upon receipt of a valid petition meeting the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 331.306}}}{{\f5\fs18\hyphpar0\qj{, and subject to the requirements of paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, shall direct the commissioner of elections to submit to the registered voters of the county a proposition to approve or disapprove the conduct of gambling games in the county. The proposition shall be submitted at an election held on a date specified in }}}{{\f5\fs18\hyphpar0\qj{section 39.2, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. If a majority of the county voters voting on the proposition favor the conduct of gambling games, the commission may issue one or more licenses as provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. If a majority of the county voters voting on the proposition do not favor the conduct of gambling games, a license to conduct gambling games in the county shall not be issued.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a license to conduct gambling games is in effect pursuant to a referendum as set forth in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and is subsequently disapproved by a referendum of the county electorate, the license issued by the commission after a referendum approving gambling games shall remain valid and is subject to renewal for a total of nine years from the date of original issue or one year from the date of the referendum disapproving the conduct of gambling games, whichever is later, unless the commission revokes a license at an earlier date as provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a licensee of a pari-mutuel racetrack who held a valid license issued under }}}{{\f5\fs18\hyphpar0\qj{chapter 99D}}}{{\f5\fs18\hyphpar0\qj{ as of January 1, 1994, requests a license to operate gambling games as provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, the board of supervisors of a county in which the licensee of a pari-mutuel racetrack requests a license to operate gambling games shall submit to the county electorate a proposition to approve or disapprove the operation of gambling games at pari-mutuel racetracks at an election held on a date specified in }}}{{\f5\fs18\hyphpar0\qj{section 39.2, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. If the operation of gambling games at the pari-mutuel racetrack is not approved by a majority of the county electorate voting on the proposition at the election, the commission shall not issue a license to operate gambling games at the racetrack.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the proposition to operate gambling games is approved by a majority of the county electorate voting on the proposition, the board of supervisors shall submit a proposition requiring the approval or defeat of gambling games to the county electorate as provided in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, unless the operation of gambling games is terminated earlier as provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{chapter 99D}}}{{\f5\fs18\hyphpar0\qj{. However, if a proposition to operate gambling games is approved by a majority of the county electorate voting on the proposition in two successive elections, a subsequent submission and approval of a proposition under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not thereafter be required to authorize the conduct of gambling games pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{After a referendum has been held which approved or defeated a proposal to conduct gambling games as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, another referendum on a proposal to conduct gambling games shall not be held until the eighth calendar year thereafter.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a docking fee is charged by a city or a county, a licensee operating an excursion gambling boat shall pay the docking fee one year in advance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensee shall not be delinquent in the payment of property taxes or other taxes or fees or in the payment of any other contractual obligation or debt due or owed to a city or county.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When applicable, an excursion gambling boat operated on inland waters of this state or an excursion boat that has been removed from navigation and is designated as a permanently moored vessel by the United States coast guard shall be subject to the exclusive jurisdiction of the department of natural resources and meet all of the requirements of }}}{{\f5\fs18\hyphpar0\qj{chapter 462A}}}{{\f5\fs18\hyphpar0\qj{ and is further subject to an inspection of its sanitary facilities to protect the environment and water quality before a certificate of registration is issued by the department of natural resources or a license is issued or renewed under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a licensed excursion boat stops at more than one harbor and travels past a county without stopping at any port in that county, the commission shall require the excursion boat operator to develop a schedule for ports of call that have the necessary facilities to handle the boat. The commission may limit the schedule to only one port of call per county.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{16.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon a violation of any of the conditions listed in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the commission shall immediately revoke the license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{17.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall require each licensee operating gambling games to post in conspicuous locations specified by the commission the average percentage payout from the gambling machines.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 67, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 139, \'a72 \u8211\'3f 5}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1203, \'a715, 16}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 143, \'a742}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1021, \'a716 \u8211\'3f 18}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 49, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 176, \'a74, 5}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1136, \'a741 \u8211\'3f 47, 65}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1175, \'a7328}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 188, \'a711, 12}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1115, \'a730, 71}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 111, \'a711 \u8211\'3f 14}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 147, \'a747, 54}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 174, \'a746}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1143, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a766}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a799F.1}}}{{\f5\fs12\hyphpar0\qj{, 99F.4}}}{{\f5\fs12\hyphpar0\qj{, 99F.8}}}{{\f5\fs12\hyphpar0\qj{, 99F.10}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99F.7A}}}{\*\bkmkstart stylerid1_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Sports wagering }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ license }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ terms and conditions }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ fees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall, upon payment of an initial license fee of forty-five thousand dollars and submission of an application to the commission consistent with the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 99F.6}}}{{\f5\fs18\hyphpar0\qj{, issue a license to conduct sports wagering to a licensee authorized to conduct gambling games at a pari-mutuel racetrack enclosure or a licensee authorized to operate an excursion gambling boat or gambling structure, subject to the requirements of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. The annual renewal fee for a license to conduct sports wagering shall be ten thousand dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensee under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall do all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Include on the internet site or mobile application used by the licensee to conduct advance deposit sports wagering as authorized in }}}{{\f5\fs18\hyphpar0\qj{section 99F.9}}}{{\f5\fs18\hyphpar0\qj{ the statewide telephone number authorized by the department of health and human services to provide problem gambling information and extensive responsible gaming features in addition to those described in }}}{{\f5\fs18\hyphpar0\qj{section 99F.4, subsection 22}}}{{\f5\fs18\hyphpar0\qj{. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Establish, subject to commission approval, sports wagering rules that specify the amounts to be paid on winning sports wagers, the effect of changes in the scheduling of an authorized sporting event or sports-related event subject to sports wagering, and the source of the information used to determine the outcome of a sports wager. The sports wagering rules shall be displayed in the licensee\u8217\'3fs sports wagering area, posted on the internet site or mobile application used by the licensee to conduct advance deposit sports wagering as authorized in }}}{{\f5\fs18\hyphpar0\qj{section 99F.9}}}{{\f5\fs18\hyphpar0\qj{, and included in the terms and conditions of the licensee\u8217\'3fs advance deposit sports wagering system.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensee under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ may enter into operating agreements with one or two entities to have up to a total of two individually branded internet sites to conduct advance deposit sports wagering for the licensee, unless one additional operating agreement or individually branded internet site is authorized by the commission. However, a person shall not sell, grant, assign, or turn over to another person the operation of an individually branded internet site to conduct advance deposit sports wagering for the licensee without the approval of the commission. }}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not prohibit an agreement entered into between a licensee under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and an advanced deposit sports wagering operator as approved by the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensee issued a license to conduct sports wagering under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall employ reasonable steps to prohibit coaches, athletic trainers, officials, players, or other individuals who participate in an authorized sporting event or sports-related event that is the subject of sports wagering from sports wagering under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. In addition, a licensee shall employ reasonable steps to prohibit persons who are employed in a position with direct involvement with coaches, players, athletic trainers, officials, players, or participants in an authorized sporting event or sports-related event that is the subject of sports wagering from sports wagering under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2019 Acts, ch 89, \'a737}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 132, \'a710, 22, 23}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 80, \'a756}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1143, \'a712, 13}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a767}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a799F.1}}}{{\f5\fs12\hyphpar0\qj{, 99F.9}}}{{\f5\fs12\hyphpar0\qj{, 99F.12}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99F.8}}}{\*\bkmkstart stylerid1_2E18_2E2_2E2}{\*\bkmkend stylerid1_2E18_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Bond of licensee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A licensee licensed under }{{\f5\fs18\hyphpar0\qj{section 99F.7}}}{ shall post a bond to the state of Iowa before the license is issued in a sum as the commission shall fix, with sureties to be approved by the commission. The bond shall be used to guarantee that the licensee faithfully makes the payments, keeps its books and records and makes reports, and conducts its gambling games and sports wagering in conformity with }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ and the rules adopted by the commission. The bond shall not be canceled by a surety on less than thirty days\u8217\'3f notice in writing to the commission. If a bond is canceled and the licensee fails to file a new bond with the commission in the required amount on or before the effective date of cancellation, the licensee\u8217\'3fs license shall be revoked. The total and aggregate liability of the surety on the bond is limited to the amount specified in the bond.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 67, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 132, \'a711, 22, 23}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99F.9}}}{\*\bkmkstart stylerid1_2E19_2E2_2E2}{\*\bkmkend stylerid1_2E19_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Wagering }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ advance deposit sports wagering }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ age restrictions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as permitted in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the licensee shall not permit sports wagering or any form of wagering on gambling games.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The licensee may receive wagers only from a person present on a licensed excursion gambling boat, licensed gambling structure, or in a licensed racetrack enclosure.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The licensee shall exchange the money of each wagerer for tokens, chips, or other forms of credit to be wagered on the gambling games. However, nickels and quarters of legal tender may be used for wagering in lieu of tokens or other forms of credit. The licensee shall exchange the gambling tokens, chips, or other forms of wagering credit for money at the request of the wagerer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, unless the context otherwise requires:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAdvance deposit sports wagering\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a method of sports wagering in which an eligible individual may, in an account established with a licensee under }}}{{\f5\fs18\hyphpar0\qj{section 99F.7A}}}{{\f5\fs18\hyphpar0\qj{, deposit moneys into the account and use the account balance to pay for sports wagering. Prior to January 1, 2021, an account must be established by an eligible individual in person with a licensee. }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAdvance deposit sports wagering operator\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an advance deposit sports wagering operator licensed by the commission who has entered into an agreement with a licensee under }}}{{\f5\fs18\hyphpar0\qj{section 99F.7A}}}{{\f5\fs18\hyphpar0\qj{ to provide advance deposit sports wagering.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fEligible individual\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an individual who is at least twenty-one years of age or older who is located within this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission may authorize a licensee under }}}{{\f5\fs18\hyphpar0\qj{section 99F.7A}}}{{\f5\fs18\hyphpar0\qj{ to conduct advance deposit sports wagering. An advance deposit sports wager may be placed in person in the sports wagering area, or from any other location via a telephone-type device or any other electronic means. The commission may also issue an advance deposit sports wagering operator license to an entity who complies with }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{section 99F.6}}}{{\f5\fs18\hyphpar0\qj{ and may require the advance deposit sports wagering operator to conduct an audit consistent with the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 99F.13}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An unlicensed person taking or receiving sports wagers from residents of this state is guilty of a class \u8220\'3fD\u8221\'3f felony.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person under the age of twenty-one years shall not make or attempt to make a wager pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{ or on an excursion gambling boat, gambling structure, or in a racetrack enclosure and shall not be allowed on the gaming floor of an excursion gambling boat or gambling structure or in the wagering area, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 99D.2}}}{{\f5\fs18\hyphpar0\qj{, or on the gaming floor of a racetrack enclosure. However, a person eighteen years of age or older may be employed to work on the gaming floor of an excursion gambling boat or gambling structure or in the wagering area or on the gaming floor of a racetrack enclosure. A person who violates }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ with respect to making or attempting to make a wager commits a scheduled violation under }}}{{\f5\fs18\hyphpar0\qj{section 805.8C, subsection 5}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person under the age of twenty-one years shall not enter or attempt to enter the gaming floor or wagering area, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 99D.2}}}{{\f5\fs18\hyphpar0\qj{, of a facility licensed under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ to operate gambling games.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person under the age of twenty-one years does not violate }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ if any of the following circumstances apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person is employed to work at the facility.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person is an employee or agent of the commission, the division, a distributor, or a manufacturer, and acting within the scope of the person\u8217\'3fs employment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person is present in a racetrack enclosure and does not enter or attempt to enter the gaming floor or wagering area of the facility.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who violates }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ commits a simple misdemeanor punishable as a scheduled violation under }}}{{\f5\fs18\hyphpar0\qj{section 805.8C, subsection 5}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensee shall not accept a credit card as defined in }}}{{\f5\fs18\hyphpar0\qj{section 537.1301, subsection 17}}}{{\f5\fs18\hyphpar0\qj{, for sports wagering or to purchase coins, tokens, or other forms of credit to be wagered on gambling games.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 67, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 139, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 144, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1021, \'a719 \u8211\'3f 24}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1136, \'a748}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 188, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 88, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1026, \'a723}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 132, \'a712 \u8211\'3f 14, 22, 23}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1066, \'a74}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a799D.7}}}{{\f5\fs12\hyphpar0\qj{, 99F.1}}}{{\f5\fs12\hyphpar0\qj{, 99F.4}}}{{\f5\fs12\hyphpar0\qj{, 99F.7}}}{{\f5\fs12\hyphpar0\qj{, 99F.7A}}}{{\f5\fs12\hyphpar0\qj{, 99F.15}}}{{\f5\fs12\hyphpar0\qj{, 99F.16}}}{{\f5\fs12\hyphpar0\qj{, 805.8C(5)(a)}}}{{\f5\fs12\hyphpar0\qj{, 805.8C(5)(b)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99F.10}}}{\*\bkmkstart stylerid1_2E2_30_2E2_2E2}{\*\bkmkend stylerid1_2E2_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Regulatory fee \u8212\'3f local fees \u8212\'3f initial license fee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A qualified sponsoring organization conducting gambling games on an excursion gambling boat or gambling structure licensed under }}}{{\f5\fs18\hyphpar0\qj{section 99F.7}}}{{\f5\fs18\hyphpar0\qj{ shall pay the tax imposed by }}}{{\f5\fs18\hyphpar0\qj{section 99F.11}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An excursion gambling boat or gambling structure licensee shall pay to the commission a regulatory fee to be charged as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subject to approval of excursion gambling boat docking by the voters, a city may adopt, by ordinance, an admission fee not exceeding fifty cents for each person embarking on an excursion gambling boat docked within the city, or a county may adopt, by ordinance, an admission fee not exceeding fifty cents for each person embarking on an excursion gambling boat docked outside the boundaries of a city. The admission revenue received by a city or a county shall be credited to the city general fund or county general fund as applicable.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In determining the license fees and state regulatory fees to be charged as provided under }}}{{\f5\fs18\hyphpar0\qj{section 99F.4}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the commission shall use as the basis for determining the amount of revenue to be raised from the license fees and regulatory fees the amount appropriated to the commission plus the cost of salaries for no more than three special agents for each excursion gambling boat or gambling structure as assigned pursuant to the provisions of }}}{{\f5\fs18\hyphpar0\qj{section 80.25A}}}{{\f5\fs18\hyphpar0\qj{, plus any direct and indirect support costs for the division of criminal investigation\u8217\'3fs duties pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapters 99D}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{99E}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{99F}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{section 80.25A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{ section 99F.4}}}{{\f5\fs18\hyphpar0\qj{, the portion of the fee paid pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ relating to the costs of special agents and officers plus any direct and indirect support costs for the agents and officers, for the division of criminal investigation\u8217\'3fs excursion gambling boat or gambling structure activities, shall be deposited into the gaming enforcement revolving fund established in }}}{{\f5\fs18\hyphpar0\qj{section 80.43}}}{{\f5\fs18\hyphpar0\qj{. However, the department of public safety shall transfer, on an annual basis, the portion of the regulatory fee attributable to the indirect support costs of the special agents and gaming enforcement officers to the general fund of the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{ section 99F.4}}}{{\f5\fs18\hyphpar0\qj{, the portion of the fee paid pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ relating to the costs of the commission shall be deposited into the gaming regulatory revolving fund established in }}}{{\f5\fs18\hyphpar0\qj{section 99F.20}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Indirect support costs under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall be calculated at the same rate used in accordance with the federal office of management and budget cost principles for state, local, and Indian tribal governments that receive a federally approved indirect cost rate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The aggregate amount of the regulatory fee assessed under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ during each fiscal year shall be reduced by an amount equal to the unexpended moneys from the previous fiscal year that were deposited into the revolving funds established in section }}}{{\f5\fs18\hyphpar0\qj{80.43}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{99F.20}}}{{\f5\fs18\hyphpar0\qj{ during that previous fiscal year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{By January 1, 2015, and by January 1 of every year thereafter, the division of criminal investigation shall provide the co-chairpersons and ranking members of the joint appropriations subcommittee on the justice system, the legislative services agency, and the commission with a report detailing the activities of the division during the previous fiscal year for each excursion gambling boat and gambling structure.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The division of criminal investigation shall review the number of special agents permitted for each excursion gambling boat or gambling structure under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ and the activities of such agents. The review shall also include comments from the commission and licensees and be combined with the review conducted under }}}{{\f5\fs18\hyphpar0\qj{section 99D.14, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ff\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. The division of criminal investigation shall file a report detailing the review conducted pursuant to this paragraph with the co-chairpersons and ranking members of the joint appropriations subcommittee on the justice system and the legislative services agency by July 1, 2020.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the fiscal year beginning July 1, 2021, and each fiscal year thereafter, the seven licensees with the lowest adjusted gross receipts for the previous fiscal year shall pay a reduced regulatory fee. The division of criminal investigation shall calculate the regulatory fee to be paid by each licensee using a methodology that reduces the regulatory fee for the seven licensees with the lowest adjusted gross receipts by an amount equivalent to the portion of the regulatory fees associated with one special agent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{No other license tax, permit tax, occupation tax, excursion fee, or taxes on fees shall be levied, assessed, or collected from a licensee by the state or by a political subdivision, except as provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{No other excise tax shall be levied, assessed, or collected from the licensee relating to gambling excursions or admission charges by the state or by a political subdivision, except as provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to any other fees required by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, a person awarded a new license to conduct gambling games pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 99F.7}}}{{\f5\fs18\hyphpar0\qj{ on or after January 1, 2004, shall pay the applicable initial license fee to the commission as provided by }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. A person awarded a new license shall pay one-fifth of the applicable initial license fee immediately upon the granting of the license, one-fifth of the applicable initial license fee within one year of the granting of the license, one-fifth of the applicable initial license fee within two years of the granting of the license, one-fifth of the applicable initial license fee within three years of the granting of the license, and the remaining one-fifth of the applicable initial license fee within four years of the granting of the license. However, the license fee provided for in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall only apply when a new license is issued to a person for a facility that increases the number of licensed facilities in the applicable county or counties. Fees paid pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ are not refundable to the licensee. For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, the applicable initial license fee shall be five million dollars if the population of the county where the licensee shall conduct gambling games is fifteen thousand or less based upon the most recent federal decennial census, shall be ten million dollars if the population of the county where the licensee shall conduct gambling games is more than fifteen thousand and less than one hundred thousand based upon the most recent federal decennial census, and shall be twenty million dollars if the population of the county where the licensee shall conduct gambling games is one hundred thousand or more based upon the most recent federal decennial census. Moneys collected by the commission from an initial license fee paid under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be deposited in the rebuild Iowa infrastructure fund created in }}}{{\f5\fs18\hyphpar0\qj{section 8.57}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 67, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 267, \'a7605}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 207, \'a722}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1229, \'a718}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1136, \'a749}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 48, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 188, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1190, \'a725}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 127, \'a747, 89}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1134, \'a716, 21}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 139, \'a750}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 142, \'a736}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1091, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1063, \'a752}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 166, \'a726, 27}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 174, \'a747}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1185, \'a7129}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a780.43}}}{{\f5\fs12\hyphpar0\qj{, 99D.14}}}{{\f5\fs12\hyphpar0\qj{, 99F.4A}}}{{\f5\fs12\hyphpar0\qj{, 99F.20}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Retention of special agents on or after July 1, 2016; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2016/CH1137.pdf" }{\fldrslt \cf5 \f5 \fs12{{2016 Acts, ch 1137, \'a722}}}}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99F.11}}}{\*\bkmkstart stylerid1_2E21_2E2_2E2}{\*\bkmkend stylerid1_2E21_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Gambling games and sports wagering taxes \u8212\'3f rate \u8212\'3f allocations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A tax is imposed on the adjusted gross receipts received each fiscal year from gambling games authorized under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ at the rate of five percent on the first one million dollars of adjusted gross receipts and at the rate of ten percent on the next two million dollars of adjusted gross receipts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The tax rate imposed each fiscal year on any amount of adjusted gross receipts over three million dollars shall be as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the licensee is an excursion gambling boat or gambling structure, twenty-two percent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the licensee is a racetrack enclosure conducting gambling games and another licensee that is an excursion gambling boat or gambling structure is located in the same county, then the following rate, as applicable:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the licensee of the racetrack enclosure has not been issued a table games license during the fiscal year or if the adjusted gross receipts from gambling games of the licensee in the prior fiscal year were less than one hundred million dollars, twenty-two percent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the licensee of the racetrack enclosure has been issued a table games license during the fiscal year or prior fiscal year and the adjusted gross receipts from gambling games of the licensee in the prior fiscal year were one hundred million dollars or more, twenty-two percent on adjusted gross receipts received prior to the operational date and twenty-four percent on adjusted gross receipts received on or after the operational date. For purposes of this subparagraph, the operational date is the date the commission determines table games became operational at the racetrack enclosure.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the licensee is a racetrack enclosure conducting gambling games and no licensee that is an excursion gambling boat or gambling structure is located in the same county, twenty-four percent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any provision of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ to the contrary, the tax rate imposed on a licensee each fiscal year on any amount of promotional play receipts on gambling games included as adjusted gross receipts shall be determined by multiplying the adjusted percentage by the wagering tax applicable to the licensee pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fadjusted percentage\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the fiscal year beginning July 1, 2021, and ending June 30, 2022, eighty-three and one-third percent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the fiscal year beginning July 1, 2022, and ending June 30, 2023, sixty-six and two-thirds percent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the fiscal year beginning July 1, 2023, and ending June 30, 2024, fifty percent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the fiscal year beginning July 1, 2024, and ending June 30, 2025, thirty-three and one-third percent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the fiscal year beginning July 1, 2025, and ending June 30, 2026, sixteen and two-thirds percent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ is repealed July 1, 2026.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The taxes imposed by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ on adjusted gross receipts from gambling games authorized under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall be paid by the licensee to the treasurer of state within ten days after the close of the day when the wagers were made and shall be distributed as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the gambling excursion originated at a dock located in a city, one-half of one percent of the adjusted gross receipts shall be remitted to the treasurer of the city in which the dock is located and shall be deposited in the general fund of the city. Another one-half of one percent of the adjusted gross receipts shall be remitted to the treasurer of the county in which the dock is located and shall be deposited in the general fund of the county.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the gambling excursion originated at a dock located in a part of the county outside a city, one-half of one percent of the adjusted gross receipts shall be remitted to the treasurer of the county in which the dock is located and shall be deposited in the general fund of the county. Another one-half of one percent of the adjusted gross receipts shall be remitted to the treasurer of the Iowa city nearest to where the dock is located and shall be deposited in the general fund of the city.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Eight-tenths of one percent of the adjusted gross receipts tax shall be deposited in the county endowment fund created in }}}{{\f5\fs18\hyphpar0\qj{section 15E.311}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Two-tenths of one percent of the adjusted gross receipts tax shall be allocated each fiscal year as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Five hundred twenty thousand dollars is appropriated each fiscal year to the economic development authority for deposit in the arts and culture enhancement fund established in }}}{{\f5\fs18\hyphpar0\qj{section 15.436}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{One-half of the moneys remaining after the appropriation in subparagraph (1) is appropriated to the economic development authority for the purposes of tourism marketing. The moneys appropriated in this subparagraph shall be disbursed to the authority in quarterly allotments. However, none of the moneys appropriated under this subparagraph shall be used for administrative purposes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{One-half of the moneys remaining after the appropriation in subparagraph (1) shall be credited, on a quarterly basis, to the rebuild Iowa infrastructure fund created in }}}{{\f5\fs18\hyphpar0\qj{section 8.57}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The remaining amount of the adjusted gross receipts tax shall be credited as provided in }}}{{\f5\fs18\hyphpar0\qj{section 8.57, subsection 3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A tax is imposed on the sports wagering net receipts received each fiscal year by a licensed operator from sports wagering authorized under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ at the rate of six and three-quarters percent.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The taxes imposed by }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ for sports wagering authorized under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall be paid by the licensed operator to the treasurer of state as determined by the commission and shall be credited as provided in }}}{{\f5\fs18\hyphpar0\qj{section 8.57I}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 67, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 139, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1021, \'a725}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1186, \'a733}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1221, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 178, \'a7107, 121}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 179, \'a7142}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1136, \'a750}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1151, \'a76, 8}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 100, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 188, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 215, \'a787}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 182, \'a7104}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 118, \'a785, 89}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 126, \'a712 \u8211\'3f 14}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 142, \'a737 \u8211\'3f 39}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1026, \'a724}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 132, \'a715, 16, 22, 23}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 177, \'a770}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72082}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1150, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1185, \'a7130}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 147, \'a736}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a78.57}}}{{\f5\fs12\hyphpar0\qj{, 99F.4A}}}{{\f5\fs12\hyphpar0\qj{, 99F.10}}}{{\f5\fs12\hyphpar0\qj{, 99G.39}}}{{\f5\fs12\hyphpar0\qj{, 123.17}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{See Iowa Acts for special provisions relating to appropriations in a given year}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 4, paragraph d, subparagraph (1) amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99F.12}}}{\*\bkmkstart stylerid1_2E22_2E2_2E2}{\*\bkmkend stylerid1_2E22_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Licensees \u8212\'3f records \u8212\'3f reports \u8212\'3f supervision \u8212\'3f confidentiality.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensee shall keep its books and records so as to clearly show all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The total number of admissions for each day of operation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The total amount of money wagered and the adjusted gross receipts for each day of operation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The licensee shall furnish to the commission reports and information as the commission may require with respect to the licensee\u8217\'3fs activities.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensee under }}}{{\f5\fs18\hyphpar0\qj{section 99F.7A}}}{{\f5\fs18\hyphpar0\qj{ shall promptly report to the commission any criminal or disciplinary proceedings commenced against the licensee or its employees in connection with the licensee conducting sports wagering or advance deposit sports wagering, any abnormal wagering activity or patterns that may indicate a concern about the integrity of an authorized sporting event or sports-related event, and any other conduct with the potential to corrupt a wagering outcome of an authorized sporting event or sports-related event for purposes of financial gain, including but not limited to match fixing, and suspicious or illegal wagering activities, including the use of funds derived from illegal activity, wagers to conceal or launder funds derived from illegal activity, use of agents to place wagers, or use of false identification. The commission is required to share any information received pursuant to this paragraph with the division of criminal investigation, any other law enforcement entity upon request, or any regulatory agency the commission deems appropriate. The commission shall promptly report any information received pursuant to this paragraph with any sports team or sports governing body as the commission deems appropriate, but shall not share any information that would interfere with an ongoing criminal investigation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The gross receipts and adjusted gross receipts from gambling shall be separately handled and accounted for from all other moneys received from operation of an excursion gambling boat or from operation of a racetrack enclosure or gambling structure licensed to conduct gambling games. The commission may designate a representative to board a licensed excursion gambling boat or to enter a racetrack enclosure or gambling structure licensed to conduct gambling games. The representative shall have full access to all places within the enclosure of the boat, the gambling structure, or the racetrack enclosure and shall directly supervise the handling and accounting of all gross receipts and adjusted gross receipts from gambling. The representative shall supervise and check the admissions. The compensation of a representative shall be fixed by the commission but shall be paid by the licensee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{With the approval of the commission, a licensee under }}}{{\f5\fs18\hyphpar0\qj{section 99F.7A}}}{{\f5\fs18\hyphpar0\qj{ shall cooperate with investigations conducted by sports governing bodies, including but not limited to providing or facilitating the provision of account-level betting information and audio or video files relating to persons placing wagers. However, a licensee shall not share information that would interfere with an ongoing criminal investigation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{, the books and records kept by a licensee as provided by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ are public records and the examination, publication, and dissemination of the books and records are governed by the provisions of }}}{{\f5\fs18\hyphpar0\qj{chapter 22}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The records of the commission shall be governed by the provisions of }}}{{\f5\fs18\hyphpar0\qj{chapter 22}}}{{\f5\fs18\hyphpar0\qj{, provided that, in addition to records that may be kept confidential pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 22.7}}}{{\f5\fs18\hyphpar0\qj{, the following records provided by a licensee to the commission shall be kept confidential, unless otherwise ordered by a court, by the lawful custodian of the records, or by another person duly authorized to release such information:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Promotional play receipts records.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Patron and customer records.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Surveillance records.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Security reports and network audits.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Internal control and compliance records.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Employee records. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Marketing expenses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Supplemental schedules to the certified audit, except for those books and records as described in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, that are obtained by the commission in connection with the annual audit under }}}{{\f5\fs18\hyphpar0\qj{section 99F.13}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any information specifically requested for inspection by the commission or a representative of the commission.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 67, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 139, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1136, \'a751}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 188, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1032, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 22, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 132, \'a717, 22, 23}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1143, \'a714}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a799F.4A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99F.13}}}{\*\bkmkstart stylerid1_2E23_2E2_2E2}{\*\bkmkend stylerid1_2E23_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Annual audit of licensee operations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Within ninety days after the end of the licensee\u8217\'3fs fiscal year, the licensee shall transmit to the commission an audit of the licensee\u8217\'3fs total gambling operations, including an itemization of all expenses and subsidies. For a licensed subsidiary of a parent company, an audit of the parent company meets the requirements of }{{\f5\fs18\hyphpar0\qj{this section}}}{. All audits shall be conducted by certified public accountants authorized to practice in the state of Iowa under }{{\f5\fs18\hyphpar0\qj{chapter 542}}}{.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 67, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 166, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 55, \'a722, 38}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1136, \'a752}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 29, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 89, \'a738}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a799F.9}}}{{\f5\fs12\hyphpar0\qj{, 99F.12}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99F.14}}}{\*\bkmkstart stylerid1_2E24_2E2_2E2}{\*\bkmkend stylerid1_2E24_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Annual report of commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The commission shall make an annual report to the governor, for the period ending December 31 of each year. Included in the report shall be an account of the commission\u8217\'3fs actions, its financial position and results of operation under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, the practical results attained under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, and any recommendations for legislation which the commission deems advisable.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 67, \'a714}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99F.15}}}{\*\bkmkstart stylerid1_2E25_2E2_2E2}{\*\bkmkend stylerid1_2E25_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Prohibited activities \u8212\'3f penalties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person is guilty of an aggravated misdemeanor for any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Operating a gambling excursion where wagering is used or to be used without a license issued by the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Operating a gambling excursion where wagering is permitted other than in the manner specified by }}}{{\f5\fs18\hyphpar0\qj{section 99F.9}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Acting, or employing a person to act, as a shill or decoy to encourage participation in a gambling game or sports wagering.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person knowingly permitting a person under the age of twenty-one years to make a wager is guilty of a simple misdemeanor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person wagering or accepting a wager at any location outside an excursion gambling boat, gambling structure, or a racetrack enclosure is in violation of }}}{{\f5\fs18\hyphpar0\qj{section 725.7}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person commits a class \u8220\'3fD\u8221\'3f felony and, in addition, shall be barred for life from excursion gambling boats and gambling structures under the jurisdiction of the commission, if the person does any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Offers, promises, or gives anything of value or benefit to a person who is connected with an excursion gambling boat or gambling structure operator including, but not limited to, an officer or employee of a licensee or holder of an occupational license pursuant to an agreement or arrangement or with the intent that the promise or thing of value or benefit will influence the actions of the person to whom the offer, promise, or gift was made in order to affect or attempt to affect the outcome of a gambling game, or to influence official action of a member of the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Solicits or knowingly accepts or receives a promise of anything of value or benefit while the person is connected with an excursion gambling boat or gambling structure including, but not limited to, an officer or employee of a licensee, or holder of an occupational license, pursuant to an understanding or arrangement or with the intent that the promise or thing of value or benefit will influence the actions of the person to affect or attempt to affect the outcome of a gambling game, or to influence official action of a member of the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Uses a device to assist in any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In projecting the outcome of the game.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In keeping track of the cards played.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In analyzing the probability of the occurrence of an event relating to the gambling game.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In analyzing the strategy for playing or betting to be used in the game except as permitted by the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Cheats at a gambling game, including but not limited to committing any act which alters the outcome of the game, or cheats at sports wagering.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Manufactures, sells, or distributes any cards, chips, dice, game or device which is intended to be used to violate any provision of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Instructs a person in cheating or in the use of a device for that purpose with the knowledge or intent that the information or use conveyed may be employed to violate any provision of the chapter.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Alters or misrepresents the outcome of a gambling game on which wagers have been made after the outcome is made sure but before it is revealed to the players.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Claims, collects, or takes, or attempts to claim, collect, or take, money or anything of value in or from the gambling games or sports wagering, with intent to defraud, without having made a wager contingent on winning a gambling game or sports wager, or claims, collects, or takes an amount of money or thing of value of greater value than the amount won.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Knowingly entices or induces a person to go to any place where a gambling game or sports wagering is being conducted or operated in violation of the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ with the intent that the other person plays or participates in that gambling game or sports wagering.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Uses counterfeit chips or tokens in a gambling game.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{k.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Knowingly uses, other than chips, tokens, coin, or other methods or credit approved by the commission, legal tender of the United States of America, or uses coin not of the denomination as the coin intended to be used in the gambling games.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{l.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Has in the person\u8217\'3fs possession any device intended to be used to violate a provision of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{m.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Has in the person\u8217\'3fs possession, except a gambling licensee or employee of a gambling licensee acting in furtherance of the employee\u8217\'3fs employment, any key or device designed for the purpose of opening, entering, or affecting the operation of a gambling game, drop box, or an electronic or mechanical device connected with the gambling game or for removing coins, tokens, chips or other contents of a gambling game.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{n.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Knowingly or intentionally passes a winning wager or share to another person or provides fraudulent identification in order to avoid the forfeiture of any money or thing of value as a voluntarily excluded person pursuant to the processes established under }}}{{\f5\fs18\hyphpar0\qj{section 99F.4, subsection 22}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{o.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Knowingly or intentionally passes a winning wager or share to another person or provides fraudulent identification in order to avoid the application of a setoff as provided in }}}{{\f5\fs18\hyphpar0\qj{section 99F.19}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The possession of more than one of the devices described in }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{, paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fl\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fm\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, permits a rebuttable inference that the possessor intended to use the devices for cheating.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who places, removes, increases, or decreases a bet after acquiring knowledge of the outcome of the gambling game which is the subject of the bet or who aids a person in acquiring the knowledge for the purpose of placing, removing, increasing, or decreasing a bet contingent on that outcome commits the offense of unlawful betting.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person is guilty of a class \u8220\'3fD\u8221\'3f felony if the person commits the offense of unlawful betting where the potential winnings from the bet exceed one thousand dollars in value.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person is guilty of an aggravated misdemeanor if the person commits the offense of unlawful betting where the potential winnings from the bet exceed five hundred dollars in value but do not exceed one thousand dollars in value.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person is guilty of a serious misdemeanor if the person commits the offense of unlawful betting where the potential winnings from the bet exceed two hundred dollars in value but do not exceed five hundred dollars in value.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person is guilty of a simple misdemeanor if the person commits the offense of unlawful betting where the potential winnings from the bet do not exceed two hundred dollars in value.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Two convictions of the offense of unlawful betting as provided in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall result in the person being barred for life from excursion gambling boats and gambling structures under the jurisdiction of the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except for wagers on gambling games or exchanges for money as provided in }}}{{\f5\fs18\hyphpar0\qj{section 99F.9, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, a licensee who exchanges tokens, chips, or other forms of credit to be used on gambling games for anything of value commits a simple misdemeanor.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 67, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 139, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 144, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1021, \'a727, 28}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 188, \'a717 \u8211\'3f 19}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1026, \'a7138}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 44, \'a71 \u8211\'3f 3}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1073, \'a730}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 132, \'a718, 19, 22, 23}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1143, \'a77}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a799F.4}}}{{\f5\fs12\hyphpar0\qj{, 99F.19}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99F.16}}}{\*\bkmkstart stylerid1_2E26_2E2_2E2}{\*\bkmkend stylerid1_2E26_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Forfeiture of property.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Anything of value, including all traceable proceeds including but not limited to real and personal property, moneys, negotiable instruments, securities, and conveyances, is subject to forfeiture to the state of Iowa if the item was used for any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In exchange for a bribe intended to affect the outcome of a gambling game.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In exchange for or to facilitate a violation of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except for coins authorized in }}}{{\f5\fs18\hyphpar0\qj{section 99F.9, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, all moneys, coin, and currency found in close proximity of wagers, or of records of wagers are presumed forfeited. The burden of proof is upon the claimant of the property to rebut this presumption.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subsections 1 and 2}}}{{\f5\fs18\hyphpar0\qj{ do not apply if the act or omission which would give rise to the forfeiture was committed or omitted without the owner\u8217\'3fs knowledge or consent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon receipt of forfeited property, the county attorney or attorney general shall permit an owner or lienholder of record having a nonforfeitable property interest in the property the opportunity to purchase the property interest forfeited. If the owner or lienholder does not exercise the option under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ within thirty days the option is terminated, unless the time for exercising the option is extended by the county attorney or attorney general.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person having a valid, recorded lien or property interest in forfeited property, which has not been purchased pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{, shall either be reimbursed to the extent of the nonforfeitable interest or to the extent that the sale of the item produces sufficient revenue to do so, whichever amount is less. The sale of forfeited property should be conducted in a manner which is commercially reasonable and calculated to provide a sufficient return to cover the costs of the sale and reimburse any nonforfeitable interest. The validity of a lien or property interest is determined as of the date upon which property becomes forfeitable.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not preclude a civil suit by an owner of an interest in forfeited property against the party who, by criminal use, caused the property to become forfeited to the state.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 67, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 167, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1021, \'a729}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1026, \'a7139}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99F.17}}}{\*\bkmkstart stylerid1_2E27_2E2_2E2}{\*\bkmkend stylerid1_2E27_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Distributors and manufacturers \u8212\'3f licenses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A manufacturer or distributor of gambling games or implements of gambling shall annually apply for a license upon a form prescribed by the commission before the first day of April in each year and shall submit the appropriate license fee. An applicant shall provide the necessary information as the commission requires. The license fee for a distributor is one thousand dollars, and the license fee for a manufacturer is two hundred fifty dollars. The license fees shall be credited to the general fund of the state as provided for in }}}{{\f5\fs18\hyphpar0\qj{section 99F.4, subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensee shall acquire all gambling games or implements of gambling from a distributor licensed pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. A licensee shall not sell or give gambling games or implements of gambling to another licensee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensee shall not be a manufacturer or distributor of gambling games or implements of gambling.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission may suspend or revoke the license of a distributor or manufacturer for a violation of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or a rule adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ committed by the distributor or manufacturer or an officer, director, employee, or agent of the manufacturer or distributor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The manufacturer or distributor of gambling games or implements of gambling shall provide the commission with written notice showing the items shipped to the licensee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subsection 2}}}{{\f5\fs18\hyphpar0\qj{ does not apply in the following cases, if approved by the commission:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Gambling games or implements of gambling previously installed in a gambling location licensed in another jurisdiction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Gambling games or implements of gambling previously installed in a gambling location licensed in this state.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 67, \'a717}}}{; }{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1203, \'a718}}}{; }{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1100, \'a76, 7}}}{; }{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1107, \'a737}}}{; }{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1136, \'a753}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a799F.17A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99F.17A}}}{\*\bkmkstart stylerid1_2E28_2E2_2E2}{\*\bkmkend stylerid1_2E28_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Inspection of gambling games or implements of gambling.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A licensed manufacturer or distributor of gambling games or implements of gambling shall deliver the gambling games or implements of gambling to a location approved by the commission for inspection and approval prior to being placed in operation. Gambling games or implements of gambling acquired pursuant to }{{\f5\fs18\hyphpar0\qj{section 99F.17, subsection 6}}}{, shall be inspected and approved by the commission prior to being placed in operation. Gambling games or implements of gambling passing inspection and receiving approval may then be placed in operation on an excursion gambling boat.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1207, \'a73}}}{; }{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1100, \'a78}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99F.18}}}{\*\bkmkstart stylerid1_2E29_2E2_2E2}{\*\bkmkend stylerid1_2E29_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Tax on winnings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All winnings derived from slot machines operated pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ are Iowa earned income and are subject to state and federal income tax laws. An amount deducted from winnings for payment of the state tax, pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 422.16, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, shall be remitted to the department of revenue on behalf of the winner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All winnings from sports wagering authorized under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ are Iowa earned income and are subject to state and federal income tax laws. An amount deducted from winnings for payment of state tax pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 422.16, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, shall be remitted to the department of revenue on behalf of the winner.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, 2nd Ex, ch 1001, \'a7235}}}{; }{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 145, \'a7286}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 115, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 7, \'a71, 3}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2025 amendment effective January 1, 2026; }{{\f5\fs12\hyphpar0\qj{2025 Acts, ch 7, \'a73}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99F.19}}}{\*\bkmkstart stylerid1_2E3_30_2E2_2E2}{\*\bkmkend stylerid1_2E3_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Setoff.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensee or a person acting on behalf of a licensee shall be provided electronic access to the names of the persons indebted to a claimant agency pursuant to the process established pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 99F.4, subsection 26}}}{{\f5\fs18\hyphpar0\qj{. The electronic access provided by the claimant agency shall include access to the names of the debtors, their social security numbers, and any other information that assists the licensee in identifying the debtors. If the name of a debtor provided to the licensee through electronic access is retrieved by the licensee and the winnings are required to be reported on internal revenue service form W-2G for gambling winnings, the retrieval of such a name shall constitute a valid lien upon and claim of lien against the winnings of the debtor whose name is electronically retrieved from the claimant agency. If a debtor\u8217\'3fs winnings are required to be reported on internal revenue service form W-2G for gambling winnings, the full amount of the debt shall be collectible from any winnings due the debtor without regard to limitations on the amounts that may be collectible in increments through setoff or other proceedings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The licensee is authorized and directed to withhold any winnings of a debtor which are paid out directly by the licensee subject to the lien created by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and provide notice of such withholding to the winner when the winner appears and claims winnings in person. The licensee shall pay the funds over to the collection entity which administers the setoff program pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 421.65}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any other provision of law to the contrary, the licensee may provide to a claimant agency all information necessary to accomplish and effectuate the intent of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, and likewise the claimant agency may provide all information necessary to accomplish and effectuate the intent of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The information obtained by a claimant agency from the licensee in accordance with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall retain its confidentiality and shall only be used by a claimant agency in the pursuit of its debt collection duties and practices. An employee or prior employee of a claimant agency who unlawfully discloses any such information for any other purpose, except as otherwise specifically authorized by law, shall be subject to the penalties specified by law for unauthorized disclosure of confidential information by an agent or employee of the claimant agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The information obtained by a licensee from a claimant agency in accordance with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall retain its confidentiality and only be used by the licensee in the pursuit of debt collection duties and practices. An employee or prior employee of a licensee who unlawfully discloses any such information for any other purpose, except as otherwise specifically authorized by law, shall be subject to the same penalties specified by law for unauthorized disclosure of confidential information by an agent or employee of the licensee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, attachments, setoffs, or executions authorized and issued pursuant to law shall be withheld if timely served upon the licensee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A claimant agency or licensee, acting in good faith, shall not be liable to any person for actions taken pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. In addition, the commission shall not initiate any administrative action or impose penalties on a licensee who voluntarily reports to the commission activity described in }}}{{\f5\fs18\hyphpar0\qj{section 99F.15, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fo\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1172, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1031, \'a7173, 174}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1064, \'a77, 28}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1066, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1118, \'a773, 74}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1143, \'a78}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a799F.15}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{99F.20}}}{\*\bkmkstart stylerid1_2E31_2E2_2E2}{\*\bkmkend stylerid1_2E31_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Gaming regulatory revolving fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A gaming regulatory revolving fund is created in the state treasury under the control of the department of inspections, appeals, and licensing. The fund shall consist of fees collected and deposited into the fund paid by licensees pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 99D.14, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, fees paid by licensees pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 99E.5, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, regulatory fees paid by licensees pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 99F.4, subsection 27}}}{{\f5\fs18\hyphpar0\qj{, and fees paid by licensees pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 99F.10, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. All costs relating to racetrack, excursion boat, gambling structure, internet fantasy sports contests as defined in }}}{{\f5\fs18\hyphpar0\qj{section 99E.1}}}{{\f5\fs18\hyphpar0\qj{, and sports wagering regulation shall be paid from the fund as provided in appropriations made for this purpose by the general assembly. The department shall provide quarterly reports to the department of management and the legislative services agency specifying revenues billed and collected and expenditures from the fund in a format as determined by the department of management in consultation with the legislative services agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To meet the department\u8217\'3fs cash flow needs, the department may temporarily use funds from the general fund of the state to pay expenses in excess of moneys available in the revolving fund if those additional expenditures are fully reimbursable and the department reimburses the general fund of the state and ensures all moneys are repaid in full by the close of the fiscal year. Notwithstanding any provision to the contrary, the department shall, to the fullest extent possible, make an estimate of billings and make such billings as early as possible in each fiscal year, so that the need for the use of general fund moneys is minimized to the lowest extent possible. Periodic billings shall be deemed sufficient to satisfy this requirement. Because any general fund moneys used shall be fully reimbursed, such temporary use of funds from the general fund of the state shall not constitute an appropriation for purposes of calculating the state general fund expenditure limitation pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 8.54}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Section 8.33}}}{{\f5\fs18\hyphpar0\qj{ does not apply to any moneys credited or appropriated to the revolving fund from any other fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The establishment of the revolving fund pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not be interpreted in any manner to compromise or impact the accountability of, or limit authority with respect to, the department under state law. Any provision applicable to, or responsibility of, the department shall not be altered or impacted by the existence of the fund and shall remain applicable to the same extent as if the department were receiving moneys pursuant to a general fund appropriation. The department shall comply with directions by the governor to executive branch departments regarding restrictions on out-of-state travel, hiring justifications, association memberships, equipment purchases, consulting contracts, and any other expenditure efficiencies that the governor deems appropriate.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2011 Acts, ch 127, \'a748, 89}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 132, \'a720, 22, 23}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71871}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a799D.14}}}{{\f5\fs12\hyphpar0\qj{, 99E.5}}}{{\f5\fs12\hyphpar0\qj{, 99F.4}}}{{\f5\fs12\hyphpar0\qj{, 99F.10}}}\par}}