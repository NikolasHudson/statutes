\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F368}{\*\bkmkend codeChapter_5F368}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 368}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{CITY DEVELOPMENT}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a7362.1}}}{{\f5\fs12\qc{, 362.9}}}{{\f5\fs12\qc{, 376.1}}}{{\f5\fs12\qc{, 414.23}}}{{\f5\fs12\qc{, 455B.306A}}}\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0{\f5\fs18\chcbpat2}\par}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER I}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E5_2E2_2E2}{DEFINITIONS}{\*\bkmkend stylerid1_2E5_2E2_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{368.1}}}{\*\bkmkstart stylerid1_2E5_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{As used in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, unless the context otherwise requires:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAdjoining\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means having a common boundary for not less than fifty feet. Land areas may be adjoining although separated by a roadway or waterway.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAnnexation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the addition of territory to a city.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fBoard\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the city development board established in }}}{{\f5\fs18\hyphpar0\qj{section 368.9}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fBoundary adjustment\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means annexation, severance or consolidation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCity development\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an incorporation, discontinuance or boundary adjustment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCommittee\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the board members, and the local representatives appointed as provided in }}}{{\f5\fs18\hyphpar0\qj{sections 368.14}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{368.14A}}}{{\f5\fs18\hyphpar0\qj{, to hear and make a decision on a petition or plan for city development.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fConsolidation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the combining of two or more cities into one city.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDiscontinuance\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means termination of a city.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fIncorporation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means establishment of a new city.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fIsland\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means land which is not part of a city and which is completely surrounded by the corporate boundaries of one or more cities. However, a part of the boundary of an }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fisland\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ may be contiguous with a boundary of the state, a river, or similar natural barrier which prevents service access from an adjoining area of land outside the boundaries of a city.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPublic land\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means land owned by the federal government, the state, or a political subdivision of the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPublic utility\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a public utility subject to regulation pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 476}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fRegistered voter\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person who is registered to vote pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 48A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSeverance\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the deletion of territory from a city.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fTerritory\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the land area or areas proposed to be incorporated, annexed, or severed, whether or not contiguous to all other areas proposed to be incorporated, annexed, or severed. Except as provided for by an agreement pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 28E}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fterritory\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ having a common boundary with the right-of-way of a secondary road extends to the center line of the road.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{16.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fUrbanized area\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any area of land within two miles of the boundaries of a city.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C58, 62, 66, 71, 73, \'a7362.1; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7368.1}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 98, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{89 Acts, ch 299, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{91 Acts, ch 187, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{91 Acts, ch 250, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1174, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{93 Acts, ch 152, \'a71 \u8211\'3f 3}}}{; }{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1169, \'a761}}}{; }{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 148, \'a71, 9}}}\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0{\f5\fs18\chcbpat2}\par}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER II}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E6_2E2_2E2}{GENERAL PROVISIONS}{\*\bkmkend stylerid1_2E6_2E2_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{368.2}}}{\*\bkmkstart stylerid1_2E6_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Name change.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A city may change its name as follows:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The council shall propose the name change and shall notify the county commissioner of elections that the question shall be submitted at the next regular city election.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county commissioner of elections shall publish notice, as provided in }}}{{\f5\fs18\hyphpar0\qj{section 362.3}}}{{\f5\fs18\hyphpar0\qj{, of the proposed new name, and of the fact that the question will be submitted at the next regular city election. The county commissioner of elections shall report the results of the balloting on the question to the mayor and the city council.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a majority of those voting on the question approves the proposed new name, the city clerk shall enter the new name upon the city records and file certified copies of the proceedings, including the council\u8217\'3fs proposal, proof of publication of notice, and certification of the election result, with the county recorder of each county which contains part of the city, and with the secretary of state. Upon proper filing the name change is complete and effective.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a7628 \u8211\'3f 630; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5619 \u8211\'3f 5622;}}}{ C46, 50, 54, \'a7362.34 \u8211\'3f 362.37; C58, 62, 66, 71, 73, \'a7362.38 \u8211\'3f 362.41; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7368.2}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{368.3}}}{\*\bkmkstart stylerid1_2E6_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Discontinuance \u8212\'3f cemetery fund transfer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city is discontinued if, for a period of six years or more, it has held no city election and has caused no taxes to be levied. If the board receives knowledge of facts which cause an automatic discontinuance under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, it shall make a determination that the city is discontinued, shall take control of the property of the discontinued city, and shall carry out all necessary procedures as if the city were discontinued under a petition or plan.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city may also be discontinued in accordance with the following procedures. The council shall adopt a resolution of intent to discontinue and shall call a public hearing on the proposal to discontinue. Notice of the time and place of the public hearing and the proposed action shall be published as provided in }}}{{\f5\fs18\hyphpar0\qj{section 362.3}}}{{\f5\fs18\hyphpar0\qj{. At the public hearing, the council shall receive oral and written comments regarding the proposal from any person. Thereafter, the council, at the same meeting or at a subsequent meeting, may pass a resolution of discontinuance or pass a resolution abandoning the proposal. If the council passes a resolution of discontinuance, a petition may be filed with the clerk in the manner provided in }}}{{\f5\fs18\hyphpar0\qj{section 362.4}}}{{\f5\fs18\hyphpar0\qj{, within thirty days following the effective date of the resolution, requesting that the question of discontinuance be submitted to the registered voters of the city. Upon receipt of a petition requesting an election, the council shall direct the county commissioner of elections to call a special election on the question of discontinuance or shall adopt a resolution abandoning the discontinuance. Notice of the election shall be given by publication as required in }}}{{\f5\fs18\hyphpar0\qj{section 49.53}}}{{\f5\fs18\hyphpar0\qj{. If a majority of those voting approve the discontinuance or if no petition for an election is filed, the clerk shall send a copy of the resolution of discontinuance and, if an election is held, the results of the election to the board. The board shall take control of the property of the discontinued city and shall supervise procedures necessary to carry out the discontinuance in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 368.21}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When a city is discontinued under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ or under }}}{{\f5\fs18\hyphpar0\qj{sections 368.11 through 368.22}}}{{\f5\fs18\hyphpar0\qj{, and that city owns a cemetery, the board shall determine if any perpetual care funds exist and provide for their transfer to a trustee named by a district court or to the county or other suitable governmental entity.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C46, 50, 54, 58, 62, 66, 71, 73, \'a7362.18; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7368.3}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 188, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1006, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 54, \'a776}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 130, \'a74}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 2 amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{368.4}}}{\*\bkmkstart stylerid1_2E6_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Annexing moratorium.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A city, following notice and hearing, may by resolution agree with another city or cities to refrain from annexing specifically described territory for a period not to exceed ten years and, following notice and hearing, may by resolution extend the agreement for subsequent periods not to exceed ten years each. Notice of a hearing shall be served by regular mail at least thirty days before the hearing on the city development board and on the board of supervisors of the county in which the territory is located and shall be published in an official county newspaper in each county containing a city conducting a hearing regarding the agreement, in an official county newspaper in any county within two miles of any such city, and in an official newspaper of each city conducting a hearing regarding the agreement. The notice shall include the time and place of the hearing, describe the territory subject to the proposed agreement, and the general terms of the agreement. After passage of a resolution by the cities approving the agreements, a copy of the agreement and a copy of any resolution extending an agreement shall be filed with the city development board within ten days of enactment. If such an agreement is in force, the board shall dismiss a petition or plan which violates the terms of the agreement.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, \'a7362.26(7, 8); C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7368.4}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1132, \'a74, 11}}}{; }{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1175, \'a731}}}{; }{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 148, \'a72, 9}}}{; }{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1101, \'a742}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{368.5}}}{\*\bkmkstart stylerid1_2E6_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Annexing state and county property.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Territory owned by the state of Iowa may be annexed, but the attorney general must be served with notice of the hearing and a copy of the proposal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Territory within the road right-of-way owned by a county may be annexed, but the county attorney of that county must be served with notice of the hearing and a copy of the proposal.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C58, 62, 66, 71, 73, \'a7362.34, 362.35; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7368.5}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 98, \'a72}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{368.6}}}{\*\bkmkstart stylerid1_2E6_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Intent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{It is the intent of the general assembly to provide an annexation approval procedure which gives due consideration to the wishes of the residents of territory to be annexed, and to the interests of the residents of all territories affected by an annexation. The general assembly presumes that a voluntary annexation of territory more closely reflects the wishes of the residents of territory to be annexed, and, therefore, intends that the annexation approval procedure include a presumption of validity for voluntary annexation approval.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 250, \'a72}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{368.7}}}{\*\bkmkstart stylerid1_2E6_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Voluntary annexation of territory.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All of the owners of land in a territory adjoining a city may apply in writing to the council of the adjoining city requesting annexation of the territory. Territory comprising railway right-of-way or territory comprising not more than twenty percent of the land area may be included in the application without the consent of the owner to avoid creating an island or to create more uniform boundaries. Public land may be included in the territory to be annexed. However, the area of the territory that is public land included without the written consent of the agency with jurisdiction over the public land shall not be used to determine the percentage of territory that is included with the consent of the owner and without the consent of the owner.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prior to notification in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the annexing city shall provide written notice to the board of supervisors and township trustees of each county and township that contains all or a portion of the territory to be annexed. The written notice shall include the same information required in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and shall set a time for a consultation on the proposed annexation between the annexing city and each county and township that contains all or a portion of the territory to be annexed. The consultation shall be held at least fourteen business days before the applications in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ are mailed. The governing body of each such county and township may designate one of its members to attend the consultation. Each such county and township may make written recommendations for modification to the proposed annexation no later than seven business days following the date of the consultation.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Not later than thirty days after the consultation, the board of supervisors of each county that contains all or a portion of the territory to be annexed shall, by resolution, state whether or not it supports the application or whether it takes no position in support of or against the application. If there is a comprehensive plan for the county, the board shall take the plan into account when considering its resolution. A copy of the resolution shall be immediately filed with the annexing city and shall be considered by the city council when taking action on the application. The city council shall forward a copy of the resolution to the city development board as part of the city proceedings on the annexation. Failure of a board of supervisors to adopt a resolution shall not delay the proceedings on the application nor shall such failure be considered a deficiency either in the application or in the annexing city\u8217\'3fs proceedings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A copy of the application shall be mailed by certified mail to the nonconsenting owner and each affected public utility, at least fourteen business days prior to any action taken by the city council on the application. The application must contain a legal description and a map of the territory showing its location in relationship to the city.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The city shall provide for a public hearing on the application before approving or denying it. The city shall provide written notice at least fourteen business days prior to any action by the city council regarding the application, including a public hearing, by regular mail to the chairperson of the board of supervisors of each county which contains a portion of the territory proposed to be annexed, each public utility which serves the territory proposed to be annexed, each owner of property located within the territory to be annexed who is not a party to the application, and each owner of property that adjoins the territory to be annexed unless the adjoining property is in a city. The city shall publish notice of the application and public hearing on the application in an official county newspaper in each county which contains a portion of the territory proposed to be annexed. Both the written and published notice shall include the time and place of the public hearing and a legal description of the territory to be annexed. The city shall not assess the costs of providing notice as required in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ to the applicants. The city council shall approve or deny the application by resolution of the council.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An application for annexation under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ may be withdrawn by an applicant at any time within three business days after the public hearing unless the application was made pursuant to a written agreement for the extension of city services or unless the right to withdraw the application was specifically identified and waived by the applicant in the application. A landowner who has consented to the annexation may, within three business days after the public hearing, withdraw the landowner\u8217\'3fs consent to the annexation unless the landowner has entered into a written agreement for extension of city services or unless the right to withdraw consent was specifically identified and waived by the landowner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An annexation including territory comprising not more than twenty percent of the land area without consent of the property owners is not complete without approval by four-fifths of the members of the city development board after a hearing for all affected property owners and the county. When considering such an annexation application, the board may request that the annexing city provide information on the amount of land located in the annexing city that is currently vacant or undeveloped and whether municipal services are being provided to current residents of the annexing city.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An application for annexation of territory not within an urbanized area of a city other than the city to which the annexation is directed must be approved by resolution of the council which receives the application. The city council shall mail a copy of the application by certified mail to the board of supervisors of each county which contains a portion of the territory at least fourteen business days prior to any action taken by the city council on the application. The council shall also publish notice of the application in an official county newspaper in each county which contains a portion of the territory at least fourteen days prior to any action taken by the council on the application. Upon receiving approval of the council, the city clerk shall file a copy of the resolution, map, and legal description of the territory involved with the secretary of state, the county board of supervisors of each county which contains a portion of the territory, each affected public utility, and the state department of transportation. The city clerk shall also record a copy of the legal description, map, and resolution with the county recorder of each county which contains a portion of the territory. The secretary of state shall not accept and acknowledge a copy of a legal description, map, and resolution of annexation which would create an island. The annexation is completed upon acknowledgment by the secretary of state that the secretary of state has received the legal description, map, and resolution.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An application for annexation of territory within an urbanized area of a city other than the city to which the annexation is directed must be approved both by resolution of the council which receives the application and by the board. The board shall not approve an application which creates an island. Notice of the application shall be mailed by certified mail, by the city to which the annexation is directed, at least fourteen business days prior to any action by the city council on the application to the council of each city whose boundary adjoins the territory or is within two miles of the territory, to the board of supervisors of each county which contains a portion of the territory, each affected public utility, and to the regional planning authority of the territory. Notice of the application shall be published in an official county newspaper in each county which contains a portion of the territory at least ten business days prior to any action by the city council on the application. The annexation is completed when the board has filed and recorded copies of applicable portions of the proceedings as required by }}}{{\f5\fs18\hyphpar0\qj{section 368.20, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If one or more applications for a voluntary annexation and one or more petitions for an involuntary annexation or incorporation for a common territory are submitted to the board within thirty days of the date the first application or petition was submitted to the board, the board shall approve the application for voluntary annexation, if the application meets the applicable requirements of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, unless the board determines by a preponderance of the evidence that the application was filed in bad faith, or that the application as filed is contrary to the best interests of the citizens of the urbanized area, or that the applicant cannot within a reasonable period of time meet its obligation to provide services to the territory to be annexed sufficient to meet the needs of the territory. In consideration of the requests, the board may appoint a committee in the manner provided in }}}{{\f5\fs18\hyphpar0\qj{section 368.14}}}{{\f5\fs18\hyphpar0\qj{ to seek additional information from the applicant for voluntary annexation as necessary, including the information required of petitioners pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 368.11}}}{{\f5\fs18\hyphpar0\qj{. The board, or the committee, if applicable, shall hold a public hearing on the application for voluntary annexation in the manner provided for involuntary petitions in }}}{{\f5\fs18\hyphpar0\qj{section 368.15}}}{{\f5\fs18\hyphpar0\qj{. The decision of the board under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be made within ninety days of receipt of the application by the board. The failure of the board to approve an application under this paragraph shall be deemed final agency action subject to judicial review.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If an application for voluntary annexation is not approved pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the board shall cause the conversion of the application to a petition pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 368.13}}}{{\f5\fs18\hyphpar0\qj{ and shall proceed under }}}{{\f5\fs18\hyphpar0\qj{section 368.14A}}}{{\f5\fs18\hyphpar0\qj{. The conversion of an application to a petition shall not prejudice the status of the applicant. Judicial review of a board decision under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ may be requested by an aggrieved party.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In the discretion of a city council, the resolution provided for in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{subsection 2 or 3}}}{{\f5\fs18\hyphpar0\qj{, may include a provision for a transition for the imposition of city taxes against property within the annexation area as provided in }}}{{\f5\fs18\hyphpar0\qj{section 368.11, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fm\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a71038; C73, \'a7426; C97, \'a7617, 621; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5615, 5616;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7362.30, 362.31; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7368.7}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1245, \'a7845}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 299, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 187, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 250, \'a73, 4}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1174, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 152, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1132, \'a75 \u8211\'3f 8, 11}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 148, \'a73, 9}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 19, \'a750}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 111, \'a71 \u8211\'3f 3, 5}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7179, 180}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7368.12}}}{{\f5\fs12\hyphpar0\qj{, 368.25A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{368.7A}}}{\*\bkmkstart stylerid1_2E6_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Secondary road annexation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of supervisors of each affected county shall notify the city development board of the existence of that portion of any secondary road which extends to the center line but has not become part of the city by annexation and has a common boundary with a city. The notification shall include a legal description and a map identifying the location of the secondary road. The city development board shall provide notice and an opportunity to be heard to each city in or next to which the secondary road is located. The city development board shall certify that the notification is correct and declare the road, or portion of the road extending to the center line, annexed to the city as of the date of certification. }}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ is not intended to interfere with or modify existing }}}{{\f5\fs18\hyphpar0\qj{chapter 28E}}}{{\f5\fs18\hyphpar0\qj{ agreements on jurisdictional transfer of roads, or continuing negotiations between jurisdictions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The remaining title and interest of a county in any secondary road or portion of the road which has been annexed by a city is transferred to the annexing city on July 1, 1993. The title and interest of a county in any secondary road which is annexed by a city after July 1, 1993, is transferred to the city upon the effective date of the annexation.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{93 Acts, ch 152, \'a75}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{368.8}}}{\*\bkmkstart stylerid1_2E6_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Voluntary severing of territory.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Any territory may be severed upon the unanimous consent of all owners of the territory and approval by resolution of the council of the city in which the territory is located. The council shall provide in the resolution for the equitable distribution of assets and equitable distribution and assumption of liabilities of the territory as between the city and the severed territory. The city clerk shall file a copy of the resolution, map, and a legal description of the territory involved with the county board of supervisors, secretary of state, and state department of transportation. The city clerk shall also record a copy of the map and resolution with the county recorder. The secretary of state shall not accept and acknowledge a copy of a map and resolution of severance which would create an island. The severance is completed upon acknowledgment by the secretary of state that the secretary of state has received the map and resolution.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a71048 \u8211\'3f 1052; C73, \'a7440 \u8211\'3f 444; C97, \'a7622 \u8211\'3f 626; S13, \'a7622; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5617;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7362.32; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7368.8}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1245, \'a7846}}}{; }{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1174, \'a73}}}{; }{{\f5\fs18\hyphpar0\qj{93 Acts, ch 152, \'a76}}}\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0{\f5\fs18\chcbpat2}\par}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER III}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E7_2E2_2E2}{CITY DEVELOPMENT BOARD}{\*\bkmkend stylerid1_2E7_2E2_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{368.9}}}{\*\bkmkstart stylerid1_2E7_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Board created.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city development board is created. The economic development authority shall provide office space and staff assistance, and shall budget funds to cover expenses of the board and committees. The board consists of five members appointed by the governor subject to confirmation by the senate. The appointments must be for four-year staggered terms beginning and ending as provided by }}}{{\f5\fs18\hyphpar0\qj{section 69.19}}}{{\f5\fs18\hyphpar0\qj{, or to fill an unexpired term in case of a vacancy. Members are eligible for reappointment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall be composed of the following members:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{One member appointed from a city with a population of more than forty-five thousand, according to the most recent certified federal census.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{One member appointed from a city with a population of forty-five thousand or less, according to the most recent certified federal census.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{One member appointed from a county with a population of more than fifty thousand, according to the most recent certified federal census.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{One member appointed from a county with a population of fifty thousand or less, according to the most recent certified federal census.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{One member appointed to represent the general public.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each member is entitled to receive from the state actual and necessary expenses in performance of board duties and may also be eligible to receive compensation as provided in }}}{{\f5\fs18\hyphpar0\qj{section 7E.6}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7368.9}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1245, \'a7847}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 250, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1038, \'a71 \u8211\'3f 3}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 118, \'a785, 89}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a715.108}}}{{\f5\fs12\hyphpar0\qj{, 368.1}}}{{\f5\fs12\hyphpar0\qj{, 368.10}}}{{\f5\fs12\hyphpar0\qj{, 384.38}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Confirmation, see }{{\f5\fs12\hyphpar0\qj{\'a72.32}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{368.10}}}{\*\bkmkstart stylerid1_2E7_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Rules }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ filing fees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The board may establish rules for the performance of its duties and the conduct of proceedings before it. The rules may include establishing filing fees for applications and petitions submitted to the board. The amounts collected from the establishment of such fees are appropriated to the board for the purpose of reimbursing the economic development authority for the budgeted costs of covering the board\u8217\'3fs expenses as described in }{{\f5\fs18\hyphpar0\qj{section 368.9, subsection 1}}}{. Any amounts collected in a fiscal year by the board in excess of such budgeted costs shall be deposited in the general fund of the state. The board\u8217\'3fs rules are subject to }{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{, as applicable.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7368.10}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{93 Acts, ch 152, \'a77, 8}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 126, \'a715}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{368.11}}}{\*\bkmkstart stylerid1_2E7_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Petition for involuntary city development action.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A petition for incorporation, discontinuance, or boundary adjustment may be filed with the board by a city council, a county board of supervisors, a regional planning authority, or five percent of the registered voters of a city or territory involved in the proposal. Notice of the filing, including a copy of the petition, must be served upon the council of each city for which a discontinuance or boundary adjustment is proposed, the board of supervisors for each county which contains a portion of a city to be discontinued or territory to be incorporated, annexed or severed, the council of a city if an incorporation includes territory within the city\u8217\'3fs urbanized area, and any regional planning authority for the area involved.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Within ninety days of receipt of a petition, the board shall initiate appropriate proceedings or dismiss the petition. The board may combine for consideration petitions or plans which concern the same territory or city or which provide for a boundary adjustment or incorporation affecting common territory. The combined petitions may be submitted for consideration by a special local committee pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 368.14A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The petition must include substantially the following information as applicable:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A general statement of the proposal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A map of the territory, city or cities involved.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Assessed valuation of platted and unplatted land.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Names of property owners.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Population density.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Description of topography.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Plans for disposal of assets and assumption of liabilities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Description of existing municipal services, including but not limited to water supply, sewage disposal, and fire and police protection.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Plans for agreements with any existing special service districts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In a case of annexation or incorporation, the petition must state that none of the territory is within a city.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{k.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In a case of incorporation or consolidation, the petition must state the name of the proposed city.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{l.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Plans shall include a formal agreement between affected municipal corporations and counties for the maintenance, improvement, and traffic control of any shared roads involved in an incorporation or boundary adjustment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{m.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In the discretion of a city council, a provision for a transition for the imposition of city taxes against property within an annexation area. The provision shall allow for an exemption from taxation of the following percentages of assessed valuation according to the following schedule:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the first and second years, seventy-five percent.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the third and fourth years, sixty percent.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the fifth and sixth years, forty-five percent.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the seventh and eighth years, thirty percent.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(e)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the ninth and tenth years, fifteen percent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An alternative schedule may be adopted by the city council. However, an alternative schedule shall not allow a greater exemption than that provided in this paragraph. The exemption shall be applied in the levy and collection of taxes. The provision may also allow for the partial provision of city services during the time in which the exemption from taxation is in effect. If the city council provides for a transition for the imposition of city taxes against property in an annexation area, all property owners included in the annexation area must receive the transition upon completion of the annexation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{n.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In the case of an annexation, a plan for extending municipal services to be provided by the annexing city to the annexed territory within three years of July 1 of the fiscal year in which city taxes are collected against property in the annexed territory.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At least fourteen business days before a petition for involuntary annexation is filed as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the petitioner shall make its intention known by sending a letter of intent by certified mail to the council of each city whose urbanized area contains a portion of the territory, the board of supervisors of each county which contains a portion of the territory, the regional planning authority of the territory involved, each affected public utility, and to each property owner listed in the petition. The written notification shall include notice that the petitioners shall hold a public meeting on the petition for involuntary annexation prior to the filing of the petition.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Before a petition for involuntary annexation may be filed, the petitioner shall hold a public meeting on the petition. Notice of the meeting shall be published in an official county newspaper in each county which contains a part of the territory at least five days before the date of the public meeting. The mayor of the city proposing to annex the territory, or that person\u8217\'3fs designee, shall serve as chairperson of the public meeting. The city clerk of the same city or the city clerk\u8217\'3fs designee shall record the proceedings of the public meeting. Any person attending the meeting may submit written comments and may be heard on the petition. The minutes of the public meeting and all documents submitted at the public meeting shall be forwarded to the county board of supervisors of each county where the territory is located and to the board by the chairperson of the meeting.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Within thirty days after receiving notice that a petition for involuntary annexation has been filed with the board, the board of supervisors of each county that contains all or a portion of the territory to be annexed shall, by resolution, state whether or not it supports the petition or whether it takes no position in support of or against the petition. If there is a comprehensive plan for the county, the board shall take the plan into account when considering its resolution. A copy of the resolution shall be immediately filed with the annexing city and with the city development board. Failure of a board of supervisors to adopt a resolution shall not delay the proceedings on the petition nor shall such failure be considered a deficiency either in the petition or in the annexing city\u8217\'3fs proceedings.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a71031, 1038, 1043; C73, \'a7421, 426, 430, 431, 447, 448; C97, \'a7599, 604, 610, 611, 615, 617, 621; S13, \'a7615; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5588, 5598, 5612 \u8211\'3f 5614, 5616;}}}{ C46, 50, \'a7362.1, 362.11, 362.26, 362.28, 362.29, 362.31; C54, 58, 62, 66, 71, 73, \'a7362.1, 362.11, 362.26, 362.31; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7368.11}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 299, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 250, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1174, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 152, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 56, \'a731}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1132, \'a79, 11}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 108, \'a7126, 132}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 148, \'a74 \u8211\'3f 6, 9}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 111, \'a74, 5}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1158, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7180}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.304}}}{{\f5\fs12\hyphpar0\qj{, 368.3}}}{{\f5\fs12\hyphpar0\qj{, 368.7}}}{{\f5\fs12\hyphpar0\qj{, 368.20}}}{{\f5\fs12\hyphpar0\qj{, 368.25}}}{{\f5\fs12\hyphpar0\qj{, 368.25A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{368.12}}}{\*\bkmkstart stylerid1_2E7_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Dismissal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The board may dismiss a petition only if it finds that the petition does not meet the requirements of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, or that substantially the same incorporation, discontinuance, or boundary adjustment has been disapproved by a committee formed to consider the proposal, or by the voters, within the two years prior to the date the petition is filed with the board, or that the territory to be annexed, or a portion of that territory, has been voluntarily annexed under }{{\f5\fs18\hyphpar0\qj{section 368.7}}}{. The board shall file for record a statement of each dismissal and the reason for it, and shall promptly notify the parties to the proceeding of its decision.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7368.12}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 250, \'a77}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7368.3}}}{{\f5\fs12\hyphpar0\qj{, 368.20}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{368.13}}}{\*\bkmkstart stylerid1_2E7_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Board may initiate proceedings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Based on the results of its studies, the board may initiate proceedings for the incorporation, discontinuance, or boundary adjustment of a city. The board may request a city to submit a plan for city development or may formulate its own plan for city development. A plan submitted at the board\u8217\'3fs initiation must include the same information as a petition and be filed and acted upon in the same manner as a petition. A petition or plan may include any information relevant to the proposal, including but not limited to results of studies and surveys, and arguments.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7368.13}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{93 Acts, ch 152, \'a710}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7368.3}}}{{\f5\fs12\hyphpar0\qj{, 368.7}}}{{\f5\fs12\hyphpar0\qj{, 368.20}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{368.14}}}{\*\bkmkstart stylerid1_2E7_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Local representatives.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If an involuntary petition is not dismissed, the board shall direct the appointment of local representatives to serve with board members as a committee to consider the proposal. Each local representative is entitled to receive from the state the representative\u8217\'3fs actual and necessary expenses spent in performance of committee duties. Three board members and one local representative, or if the number of local representatives exceeds one, three board members and at least one-half of the appointed local representatives, are required for a quorum of the committee. A local representative must be a registered voter of the territory or city which the representative represents, and must be selected as follows:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{From a territory to be incorporated, one representative appointed by the county board of supervisors. If the territory is in more than one county, the board shall direct the appointment of a local representative from each county involved.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{From a city to be discontinued, one representative appointed by the city council.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{From a territory to be annexed to or severed from a city, one representative appointed by the county board of supervisors. If there are no registered voters residing in an area to be annexed to or severed from a city, the county board of supervisors shall appoint as local representative an individual owning property in the territory whether or not the individual is a registered voter or appoint a designee of such individual. If the territory is in more than one county, the board shall direct the appointment of a local representative from each county involved by its board of supervisors.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{From a city to which territory is to be annexed or from which territory is to be severed, one representative appointed by the city council. If the territory is in more than one county, the board shall direct the appointment of an equal number of city and county local representatives.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{From each city to be consolidated, one representative appointed by each city council.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7368.14}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 250, \'a78}}}{; }{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1169, \'a764}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.321}}}{{\f5\fs12\hyphpar0\qj{, 368.1}}}{{\f5\fs12\hyphpar0\qj{, 368.3}}}{{\f5\fs12\hyphpar0\qj{, 368.7}}}{{\f5\fs12\hyphpar0\qj{, 368.14A}}}{{\f5\fs12\hyphpar0\qj{, 368.20}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{368.14A}}}{\*\bkmkstart stylerid1_2E7_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Special local committees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{When two or more petitions for city development action or applications for voluntary annexation describing common territory are being considered together, the board shall direct the appointment of representatives for each of the petitions to serve on one special committee to consider the petitions. Expense reimbursement and qualifications of these representatives shall be as provided in }{{\f5\fs18\hyphpar0\qj{section 368.14}}}{. Three board members and at least one-half of the appointed local representatives are required for a quorum of the special local committee. The manner of appointment of representatives shall be the same as for single petition committees as provided in }{{\f5\fs18\hyphpar0\qj{section 368.14}}}{. The special committee shall consider the petitions in conformity with the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, and shall resolve common territory issues between petitioners. The special committee shall conduct a public hearing on the petitions pursuant to }{{\f5\fs18\hyphpar0\qj{section 368.15}}}{. If the common territory issue is resolved, the special local committee may approve the resulting compatible petitions by a single vote or separately, in its discretion.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 250, \'a79}}}{; }{{\f5\fs18\hyphpar0\qj{93 Acts, ch 152, \'a711}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7368.1}}}{{\f5\fs12\hyphpar0\qj{, 368.3}}}{{\f5\fs12\hyphpar0\qj{, 368.7}}}{{\f5\fs12\hyphpar0\qj{, 368.11}}}{{\f5\fs12\hyphpar0\qj{, 368.20}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{368.15}}}{\*\bkmkstart stylerid1_2E7_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Public hearing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The committee shall conduct a public hearing on a proposal as soon as practicable. Notice of the hearing must be served upon the council of each city for which a discontinuance or boundary adjustment is proposed, the county board of supervisors for each county that contains a portion of a city to be discontinued or territory to be incorporated, annexed, or severed, and any regional planning authority for the area involved. A notice of the hearing, which includes a brief description of the proposal and a statement of where the petition or plan is available for public inspection, must be published as provided in }{{\f5\fs18\hyphpar0\qj{section 362.3}}}{. Any person may submit written briefs and, in the committee\u8217\'3fs discretion, may be heard on the proposal. The board may subpoena witnesses and documents relevant to the proposal.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7368.15}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2025 Acts, ch 130, \'a75}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7368.3}}}{{\f5\fs12\hyphpar0\qj{, 368.7}}}{{\f5\fs12\hyphpar0\qj{, 368.14A}}}{{\f5\fs12\hyphpar0\qj{, 368.18}}}{{\f5\fs12\hyphpar0\qj{, 368.20}}}{{\f5\fs12\hyphpar0\qj{, 368.21}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{368.16}}}{\*\bkmkstart stylerid1_2E7_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Approval of proposal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Subject to }{{\f5\fs18\hyphpar0\qj{section 368.17}}}{, the committee shall approve any proposal which it finds to be in the public interest. A committee shall base its finding upon all relevant information before the committee, including but not limited to the following:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Statements in the petition or plan, and evidence supporting those statements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Recommendations of the regional planning authority for the area.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Commercial and industrial development.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Potential growth in population.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Cost and adequacy of existing services and facilities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Potential effect of the proposal and of possible alternative proposals on the cost and adequacy of services and facilities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Potential effect of the proposal on adjacent areas, and on any unit of government directly affected, including but not limited to the potential effect on future revenues of any such unit of government.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7368.16}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7368.3}}}{{\f5\fs12\hyphpar0\qj{, 368.20}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{368.17}}}{\*\bkmkstart stylerid1_2E7_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{When approval barred.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The committee may not approve:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An incorporation unless it finds that the city to be incorporated will be able to provide customary municipal services within a reasonable time.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A discontinuance or severance if the city to be discontinued or the territory to be severed will be surrounded by one or more cities unless a petition for annexation of the same area is also filed and approved.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A discontinuance or severance unless it finds that the county or another city will be able to provide necessary municipal services to the residents.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An annexation unless the territory is adjoining the city to which it will be annexed, and the committee finds that the city will be able to provide to the territory substantial municipal services and benefits not previously enjoyed by such territory, and that the motive for annexation is not solely to increase revenues to the city.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A consolidation unless the cities are contiguous.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An incorporation of territory, any part of which is within two miles of an existing city, unless a petition for annexation of substantially the same territory to such city has been dismissed, disapproved, or voted upon unfavorably within the last five years.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city development action which creates an island.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a71043; C73, \'a7430, 431; C97, \'a7610, 611, 615; S13, \'a7615; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5612 \u8211\'3f 5614;}}}{ C46, 50, \'a7362.26, 362.28, 362.29; C54, \'a7362.26; C58, 62, 66, 71, 73, \'a7362.1, 362.26; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7368.17}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 187, \'a74}}}{; }{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1174, \'a75}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7368.3}}}{{\f5\fs12\hyphpar0\qj{, 368.16}}}{{\f5\fs12\hyphpar0\qj{, 368.20}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{368.18}}}{\*\bkmkstart stylerid1_2E7_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Amendment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The committee may amend a petition or plan. If a petition or plan is substantially amended, the committee shall continue the hearing to a later date and serve and publish a notice describing the amended petition or plan, as required in }{{\f5\fs18\hyphpar0\qj{section 368.15}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a7600; S13, \'a7600; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5591;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7362.4; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7368.18}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7368.3}}}{{\f5\fs12\hyphpar0\qj{, 368.20}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{368.19}}}{\*\bkmkstart stylerid1_2E7_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Time limit \u8212\'3f election.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The committee shall approve or disapprove the petition or plan as amended, within ninety days of the final hearing, and shall file its decision for record and promptly notify the parties to the proceeding of its decision. If a petition or plan is approved, the board shall submit the proposal at an election held on a date specified in }}}{{\f5\fs18\hyphpar0\qj{section 39.2, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, whichever is applicable, and the county commissioner of elections shall conduct the election. In a case of incorporation or discontinuance, registered voters of the territory or city may vote, and the proposal is authorized if a majority of those voting approves it. In a case of annexation or severance, registered voters of the territory and of the city may vote, and the proposal is authorized if a majority of the total number of persons voting approves it. In a case of consolidation, registered voters of each city to be consolidated may vote, and the proposal is authorized only if it receives a favorable majority vote in each city. The county commissioner of elections shall publish notice of the election as provided in }}}{{\f5\fs18\hyphpar0\qj{section 49.53}}}{{\f5\fs18\hyphpar0\qj{ and shall conduct the election in the same manner as other special elections.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The city shall provide to the commissioner of elections a map of the area to be incorporated, discontinued, annexed, severed, or consolidated, which must be approved by the commissioner as suitable for posting. The map shall be displayed prominently in at least one place within the voting precinct, and inside each voting booth.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The costs of an incorporation election shall be borne by the initiating petitioners if the election fails, but if the proposition is approved the cost shall become a charge of the new city.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a71032, 1037, 1043, 1044; C73, \'a7422, 423, 425, 430 \u8211\'3f 432, 447 \u8211\'3f 450; C97, \'a7600 \u8211\'3f 605, 610 \u8211\'3f 612, 615; S13, \'a7600 \u8211\'3f 602, 615; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5592 \u8211\'3f 5594, 5596, 5598, 5599, 5605, 5606, 5612 \u8211\'3f 5614;}}}{ C46, 50, \'a7362.5 \u8211\'3f 362.7, 362.9, 362.11, 362.12, 362.19, 362.20, 362.26, 362.28, 362.29; C54, 58, 62, 66, 71, 73, \'a7362.5 \u8211\'3f 362.7, 362.9, 362.11, 362.12, 362.19, 362.20, 362.26; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7368.19}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 250, \'a710}}}{; }{{\f5\fs18\hyphpar0\qj{95 Acts, ch 67, \'a753}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1123, \'a716}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1115, \'a762, 71}}}{; }{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 57, \'a790}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7368.3}}}{{\f5\fs12\hyphpar0\qj{, 368.20}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{368.20}}}{\*\bkmkstart stylerid1_2E7_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Procedure after approval.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{After the county commissioner of elections has certified the results to the board, the board shall:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Serve and publish notice of the result as provided in }}}{{\f5\fs18\hyphpar0\qj{section 362.3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{File with the secretary of state and the clerk of each city incorporated or involved in a boundary adjustment, and record with the recorder of each county which contains a portion of any city or territory involved, copies of the proceedings including the original petition or plan and any amendments, the order of the board approving the petition or plan, proofs of service and publication of required notices, certification of the election result, and any other material deemed by the board to be of primary importance to the proceedings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon proper filing and expiration of time for appeal, the incorporation, discontinuance, or boundary adjustment is complete. However, if an appeal to any of the proceedings is pending, completion does not occur until the appeal is decided, unless a subsequent date is provided in the proposal. The board shall also file with the state department of transportation a copy of the map and legal land description of each completed incorporation or corporate boundary adjustment completed under }}}{{\f5\fs18\hyphpar0\qj{sections 368.11 through 368.22}}}{{\f5\fs18\hyphpar0\qj{ or approved annexation within an urbanized area.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a71044, 1053, 1054; C73, \'a7432, 445, 446, 452; C97, \'a7267, 603, 608, 612; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5596, 5603, 5606, 5618;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7362.9, 362.16, 362.20, 362.33; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7368.20}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 22, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 152, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7149}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7368.3}}}{{\f5\fs12\hyphpar0\qj{, 368.7}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{368.21}}}{\*\bkmkstart stylerid1_2E7_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Supervision of procedures.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{When an incorporation, discontinuance, or boundary adjustment is complete, the board shall supervise procedures necessary to carry out the proposal. In the case of an incorporation, the county commissioner of elections shall conduct an election for mayor and council of the city, who shall serve until their successors take office following the next regular city election. In the case of a discontinuance, the board shall publish two notices as provided in }{{\f5\fs18\hyphpar0\qj{section 368.15}}}{ that it will receive and adjudicate claims against the discontinued city for a period of six months from the date of last notice, and shall cause necessary taxes to be levied against the property within the discontinued city to pay claims allowed. All records of a discontinued city shall be deposited with the county auditor of the county designated by the board. Any remaining balances shall be deposited in the county treasury where the former city was located. In the case of boundary adjustments, the proper city officials shall carry out procedures necessary to implement the proposal.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a71037, 1045; C73, \'a7425, 433, 449, 451, 453; C97, \'a7602, 603, 605 \u8211\'3f 607, 613; S13, \'a7602; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5594, 5597, 5600 \u8211\'3f 5602, 5607;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7362.7, 362.10, 362.13 \u8211\'3f 362.15, 362.21; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7368.21}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 123, \'a7172, 209}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.427}}}{{\f5\fs12\hyphpar0\qj{, 368.3}}}{{\f5\fs12\hyphpar0\qj{, 368.20}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{368.22}}}{\*\bkmkstart stylerid1_2E7_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Appeal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city or a resident or property owner in the territory or city involved may appeal a decision of the board or a committee, or the legality of an election, to the district court of a county which contains a portion of any city or territory involved.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Appeal must be filed within thirty days of the filing of a decision or the publication of notice of the result of an election.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Appeal of an approval of a petition or plan does not stay the election.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The judicial review provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ shall be the exclusive means by which a person or party who is aggrieved or adversely affected by agency action may seek judicial review of that agency action. The court\u8217\'3fs review on appeal of a decision is limited to questions relating to jurisdiction, regularity of proceedings, and whether the decision appealed from is arbitrary, unreasonable, or without substantial supporting evidence. The court may reverse and remand a decision of the board or a committee, with appropriate directions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The following portions of }}}{{\f5\fs18\hyphpar0\qj{section 17A.19}}}{{\f5\fs18\hyphpar0\qj{ are not applicable to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The part of }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ which relates to where proceedings for judicial review shall be instituted.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subsection 5}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subsection 8}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subsection 9}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subsection 10}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subsection 11}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7368.22}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1202, \'a740, 46}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7150}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7368.3}}}{{\f5\fs12\hyphpar0\qj{, 368.20}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{368.23}}}{\*\bkmkstart stylerid1_2E7_2E18_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E18_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Fees and taxes of public utilities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Additional or increased fees or taxes, other than ad valorem taxes, imposed on a public utility as a result of an annexation of territory to a city shall become effective sixty days after the effective date of the annexation.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{93 Acts, ch 152, \'a713}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{368.24}}}{\*\bkmkstart stylerid1_2E7_2E19_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E19_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Notification to public utilities and to the department of revenue.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Notwithstanding any other provision of law to the contrary, any city that annexes territory or any city from which territory is severed shall provide written notification consisting of a legal description and map of the annexed or severed territory, each street address within the annexed or severed area, where possible, a statement containing the effective date of the annexation or severance and a copy of the order, resolution, or ordinance proclaiming the annexation or severance to all public utilities operating in the annexed or severed area and to the department of revenue. If the notification of an annexation is provided to a public utility less than sixty days prior to the effective date of the annexation, the public utility shall have sixty days from the date of notification to adjust its tax and accounting records to reflect the annexation for any tax purpose.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1204, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1110, \'a725}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{368.25}}}{\*\bkmkstart stylerid1_2E7_2E2_30_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Failure to provide municipal services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Prior to expiration of the three-year period established in }{{\f5\fs18\hyphpar0\qj{section 368.11, subsection 3}}}{, paragraph }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fn\u8221\'3f}}}{, the annexing city shall submit a report to the board describing the status of the provision of municipal services identified in the plan required in }{{\f5\fs18\hyphpar0\qj{section 368.11, subsection 3}}}{, paragraph }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fn\u8221\'3f}}}{. If a city fails to provide municipal services, or fails to show substantial and continuing progress in the provision of municipal services, to territory involuntarily annexed, according to the plan for extending municipal services filed pursuant to }{{\f5\fs18\hyphpar0\qj{section 368.11, subsection 3}}}{, paragraph }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fn\u8221\'3f}}}{, within the time period specified in that subsection, the city development board may initiate proceedings to sever the annexed territory from the city. The board shall notify the city of the severance proceedings and shall hold a public hearing on the proposed severance. The board shall give notice of the hearing in the same manner as notice of a public meeting in }{{\f5\fs18\hyphpar0\qj{section 368.11}}}{. The board may order severance of all or a portion of the territory and the order to sever is not subject to approval at an election. A city may request that the board allow up to an additional three years to provide municipal services if good cause is shown. As an alternative to severance of the territory, the board may impose a moratorium on additional annexation by the city until the city complies with its plan for extending municipal services. For purposes of }{{\f5\fs18\hyphpar0\qj{this section}}}{, }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fmunicipal services\u8221\'3f}}}{ means services included in the plan required by }{{\f5\fs18\hyphpar0\qj{section 368.11, subsection 3}}}{, paragraph }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fn\u8221\'3f}}}{, for extending municipal services.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1132, \'a710, 11}}}{; }{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1175, \'a732}}}{; }{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 148, \'a77, 9}}}{; }{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 19, \'a751}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{368.25A}}}{\*\bkmkstart stylerid1_2E7_2E21_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E21_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Boundary adjustment between cities by petition and consent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A real property owner within the boundaries of a city may file a petition for severance with the city council if the petitioner\u8217\'3fs real property, if severed, would be eligible for annexation by a different city and if such annexation would not create an island. Contiguous property owners may file a combined petition under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The petition shall be filed with the city council of the city from which severance is sought and the city council of the city to which annexation is requested. The petition shall be in substantially the form required of an application under }}}{{\f5\fs18\hyphpar0\qj{section 368.7}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the city councils of both cities approve the petition, the petition shall be filed with the board. Approval by either city council may be conditioned upon an agreement entered into by the cities providing for the transition of property taxes or the sharing of property tax revenues from the real property described in the petition for a period not to exceed forty years and providing for all necessary zoning ordinance changes within a period not to exceed ten years. An agreement between cities under this subsection shall be filed with the board at the same time the approved petition is filed. An agreement may include additional transition provisions relating to the transfer or sharing of property tax revenues for property outside the boundaries of the territory described in the petition and any other provisions deemed by the cities to be in the public interest if such actions are within the authority of the cities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Following receipt of a petition, the board shall initiate proceedings to sever the territory from the city in which it is located and annex the territory to the annexing city. The board shall notify both cities of the severance and annexation proceedings and shall hold a public hearing on the severance, annexation, and any agreement between the cities pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{. The board shall give notice of the hearing in the same manner as notice of a public meeting in }}}{{\f5\fs18\hyphpar0\qj{section 368.11, subsection 5}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board may only approve the petition if the board also approves any agreements between the cities pursuant to subsection 3, and filed with the board. The board may only approve or deny the severance and annexation of the territory described in the petition, and the order of the board approving the petition is not subject to approval at an election. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The severance and annexation approved by the board is completed when the board files with the secretary of state and the clerk of each city involved in the severance and annexation, and records with the recorder of each county which contains a portion of any city or territory involved, copies of the proceedings including the petition, any agreements between the cities, the order of the board approving the petition, proofs of service and publication of required notices, and any other material deemed by the board to be of primary importance to the proceedings. The board shall also file with the state department of transportation a copy of the map and legal land description of each completed severance and annexation under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2010 Acts, ch 1022, \'a71}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{368.26}}}{\*\bkmkstart stylerid1_2E7_2E22_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E22_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Annexation of certain property }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ compliance with less stringent regulations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city ordinance or regulation that regulates a condition or activity occurring on protected farmland or regulates a person who owns and operates protected farmland is unenforceable against the owner of the protected farmland for a period of ten years from the effective date of the annexation, to the extent the city ordinance or regulation is more stringent than county legislation. }}}{{\f5\fs18\hyphpar0\qj{Section 335.2}}}{{\f5\fs18\hyphpar0\qj{ shall apply to the protected farmland until the owner of the protected farmland determines that the land will no longer be operated as an agricultural operation. Any enforcement activity conducted in violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is void.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{\i\f5\fs18\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{ For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCondition or activity occurring on protected farmland\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes but is not limited to the raising, harvesting, drying, or storage of crops; the marketing of products at roadside stands or farm markets; the creation of noise, odor, dust, or fumes; the production, care, feeding, or housing of animals including but not limited to the construction, operation, or management of an animal feeding operation, an animal feeding operation structure, or aerobic structure, and to the storage, handling, or application of manure or egg washwater; the operation of machinery including but not limited to planting and harvesting equipment, grain dryers, grain handling equipment, and irrigation pumps; ground and aerial seeding and spraying; the application of chemical fertilizers, conditioners, insecticides, pesticides, and herbicides; and the employment and use of labor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCounty legislation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any ordinance, motion, resolution, or amendment adopted by a county pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 331.302}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{ \u8220\'3fProtected farmland\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means land that is part of a century farm as that term is defined in }}}{{\f5\fs18\hyphpar0\qj{section 403.17, subsection 10}}}{{\f5\fs18\hyphpar0\qj{. }}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 148, \'a78, 9}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1101, \'a743}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 90, \'a797}}}\par}}