\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F811}{\*\bkmkend codeChapter_5F811}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 811}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{PRETRIAL AND POST-TRIAL RELEASE \u8212\'3f BAIL}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a780A.2}}}{{\f5\fs12\qc{, 232.22}}}{{\f5\fs12\qc{, 232.44}}}{{\f5\fs12\qc{, 602.6405}}}{{\f5\fs12\qc{, 801.1}}}\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{811.1}}}{\*\bkmkstart stylerid1_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Bail and bail restrictions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAssault\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as defined in }}}{{\f5\fs18\hyphpar0\qj{section 708.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCharged\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fcharge\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ as defined in }}}{{\f5\fs18\hyphpar0\qj{section 801.4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fFelonious assault upon an officer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the defendant committed an assault, for which the penalty is a felony, with the knowledge the person against whom the felonious assault was committed was a peace officer or correctional officer, acting in the peace officer\u8217\'3fs or correctional officer\u8217\'3fs official capacity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPeace officer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as defined in }}}{{\f5\fs18\hyphpar0\qj{section 801.4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All defendants are bailable both before and after conviction, by sufficient surety, or subject to release upon condition or on their own recognizance, except that the following defendants shall not be admitted to bail:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A defendant charged with murder in the first degree of a peace officer in violation of }}}{{\f5\fs18\hyphpar0\qj{section 707.2}}}{{\f5\fs18\hyphpar0\qj{, if the murder in the first degree was committed with the knowledge the person against whom the murder was committed was a peace officer or correctional officer, acting in the peace officer\u8217\'3fs or correctional officer\u8217\'3fs official capacity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A defendant awaiting judgment of conviction and sentencing following either a plea or verdict of guilty of a class \u8220\'3fA\u8221\'3f felony; forcible felony as defined in }}}{{\f5\fs18\hyphpar0\qj{section 702.11}}}{{\f5\fs18\hyphpar0\qj{; a felonious assault upon an officer; any class \u8220\'3fB\u8221\'3f felony included in }}}{{\f5\fs18\hyphpar0\qj{section 462A.14}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{707.6A}}}{{\f5\fs18\hyphpar0\qj{; any felony included in }}}{{\f5\fs18\hyphpar0\qj{section 124.401, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{; a second or subsequent offense under }}}{{\f5\fs18\hyphpar0\qj{section 124.401, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{; any public offense committed while detained pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 229A.5}}}{{\f5\fs18\hyphpar0\qj{; or any public offense committed while subject to an order of commitment pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 229A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A defendant appealing a conviction of a class \u8220\'3fA\u8221\'3f felony; forcible felony as defined in }}}{{\f5\fs18\hyphpar0\qj{section 702.11}}}{{\f5\fs18\hyphpar0\qj{; a felonious assault upon an officer; any class \u8220\'3fB\u8221\'3f or \u8220\'3fC\u8221\'3f felony included in }}}{{\f5\fs18\hyphpar0\qj{section 462A.14}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{707.6A}}}{{\f5\fs18\hyphpar0\qj{; any felony included in }}}{{\f5\fs18\hyphpar0\qj{section 124.401, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{; or a second or subsequent conviction under }}}{{\f5\fs18\hyphpar0\qj{section 124.401, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{; any public offense committed while detained pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 229A.5}}}{{\f5\fs18\hyphpar0\qj{; or any public offense committed while subject to an order of commitment pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 229A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, a defendant awaiting judgment of conviction and sentencing following either a plea or verdict of guilty of, or appealing a conviction of, any felony offense included in }}}{{\f5\fs18\hyphpar0\qj{section 708.11, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, or a felony offense under }}}{{\f5\fs18\hyphpar0\qj{chapter 124}}}{{\f5\fs18\hyphpar0\qj{ not provided for in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, is presumed to be ineligible to be admitted to bail unless the court determines that such release reasonably will not result in the person failing to appear as required and will not jeopardize the personal safety of another person or persons.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a73211 \u8211\'3f 3213; R60, \'a74885, 4962; C73, \'a73845, 4107, 4511; C97, \'a75096, 5442; S13, \'a75096; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{13609, 13610, 13966;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, \'a7763.1, 763.2, 789.19; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7811.1}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1236, \'a71}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 138, \'a74, 5}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1251, \'a761}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1179, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1093, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 87, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 177, \'a730}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1138, \'a727}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 12, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 71, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 123, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1099, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1139, \'a722, 27}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 22, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1021, \'a7117}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 30, \'a7255}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 86, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1127, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1154, \'a725}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7124.416}}}{{\f5\fs12\hyphpar0\qj{, 229A.5C}}}{{\f5\fs12\hyphpar0\qj{, 232.44}}}{{\f5\fs12\hyphpar0\qj{, 805.1}}}{{\f5\fs12\hyphpar0\qj{, 811.2}}}{{\f5\fs12\hyphpar0\qj{, 811.5}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Bail bonds, see }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0{{\f5\fs12\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/ACO/CourtRulesChapter/2.pdf" }{\fldrslt \f5 \fs12{{\f5\b\fs12\hyphpar0\qj\cf5{R.Cr.P. 2.37}}}}}}}\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{ \u8211\'3f Form 1 }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{811.1A}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Detention hearing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When a defendant is awaiting sentencing after conviction for a felony or is pursuing an appeal in such a case following sentencing, and the defendant would otherwise be eligible to be admitted to bail under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, but it appears by clear and convincing evidence that if released the defendant is likely to pose a danger to another person or to the property of others, the defendant may be detained under the authority of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and in the manner provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The following procedures shall apply to a detention hearing:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The prosecuting attorney may initiate a detention hearing by a verified ex parte written motion. Upon such motion, the district court may issue a warrant for the immediate arrest of the defendant, if the defendant is not in custody.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The defendant shall be brought before the district court within twenty-four hours after arrest, or if the defendant is in custody, the defendant shall be brought before the district court within twenty-four hours of the prosecuting attorney\u8217\'3fs filing of the motion. The detention hearing shall be held within seventy-two hours of the defendant\u8217\'3fs arrest, or if the defendant is in custody, the detention hearing shall be held within seventy-two hours of the filing of the motion.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The defendant shall be entitled to representation by counsel, including appointed counsel if indigent, and shall be entitled to the right of cross-examination and to present information, to testify, and to present witnesses in the defendant\u8217\'3fs own behalf, but shall not be entitled to being admitted to bail.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Testimony of the defendant given during the hearing shall not be admissible on the issue of guilt in any other judicial proceeding, except that such testimony shall be admissible in proceedings under }}}{{\f5\fs18\hyphpar0\qj{section 811.2, subsection 8}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{section 811.8}}}{{\f5\fs18\hyphpar0\qj{, and in perjury proceedings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Appeals from orders of detention may be taken in the manner provided under }}}{{\f5\fs18\hyphpar0\qj{section 811.2, subsection 7}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the trial court issues an order of detention, the order shall be accompanied by a written finding of fact and the reasons for the detention order.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of such proceedings, the trial court is not divested of jurisdiction by the filing of a notice of appeal.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1084, \'a74}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a713B.4}}}{{\f5\fs12\hyphpar0\qj{, 331.653}}}{{\f5\fs12\hyphpar0\qj{, 815.9}}}{{\f5\fs12\hyphpar0\qj{, 815.10}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{811.2}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Conditions of release \u8212\'3f penalty for failure to appear.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E7_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E7_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Conditions for release of defendant.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All bailable defendants shall be ordered released from custody pending judgment or entry of deferred judgment on their personal recognizance, or upon the execution of an unsecured appearance bond in an amount specified by the magistrate unless the magistrate determines in the exercise of the magistrate\u8217\'3fs discretion, that such a release will not reasonably assure the appearance of the defendant as required or that release will jeopardize the personal safety of another person or persons. When such determination is made, the magistrate shall, either in lieu of or in addition to the above methods of release, impose the first of the following conditions of release which will reasonably assure the appearance of the person for trial or deferral of judgment and the safety of other persons, or, if no single condition gives that assurance, any combination of the following conditions:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Place the defendant in the custody of a designated person or organization agreeing to supervise the defendant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Place restrictions on the travel, association or place of abode of the defendant during the period of release.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Require the execution of an appearance bond in a specified amount and the deposit with the clerk of the district court or a public officer designated under }}}{{\f5\fs18\hyphpar0\qj{section 602.1211, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, in cash or other qualified security, of a sum not to exceed ten percent of the amount of the bond, the deposit to be returned to the person who deposited the specified amount with the clerk upon the performance of the appearances as required in }}}{{\f5\fs18\hyphpar0\qj{section 811.6}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Require the execution of a bail bond with sufficient surety, or the deposit of cash in lieu of bond. However, except as provided in }}}{{\f5\fs18\hyphpar0\qj{section 811.1}}}{{\f5\fs18\hyphpar0\qj{, bail initially given remains valid until final disposition of the offense or entry of an order deferring judgment. If the amount of bail is deemed insufficient by the court before whom the offense is pending, the court may order an increase of bail and the defendant must provide the additional undertaking, written or in cash, to secure release.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Impose any other condition deemed reasonably necessary to assure appearance as required, or the safety of another person or persons including a condition requiring that the defendant return to custody after specified hours, or a condition that the defendant have no contact with the victim or other persons specified by the court.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any bailable defendant who is charged with unlawful possession, manufacture, delivery, or distribution of a controlled substance or other drug under }}}{{\f5\fs18\hyphpar0\qj{chapter 124}}}{{\f5\fs18\hyphpar0\qj{ and is ordered released shall be required, as a condition of that release, to submit to a substance use disorder evaluation and follow any recommendations proposed in the evaluation for appropriate substance use disorder treatment. However, if a bailable defendant is charged with manufacture, delivery, possession with the intent to manufacture or deliver, or distribution of methamphetamine, its salts, optical isomers, and salts of its optical isomers, the defendant shall, in addition to a substance use disorder evaluation, remain under supervision and be required to undergo random drug tests as a condition of release.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E7_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E7_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Determination of conditions.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In determining which conditions of release will reasonably assure the defendant\u8217\'3fs appearance and the safety of another person or persons, the magistrate shall, on the basis of available information, take into account the nature and circumstances of the offense charged, the defendant\u8217\'3fs family ties, employment, financial resources, character and mental condition, the length of the defendant\u8217\'3fs residence in the community, the defendant\u8217\'3fs record of convictions, including the defendant\u8217\'3fs failure to pay any fine, surcharge, or court costs, and the defendant\u8217\'3fs record of appearance at court proceedings or of flight to avoid prosecution or failure to appear at court proceedings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{\*\bkmkstart stylerid1_2E7_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E7_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Release at initial appearance.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This chapter}}}{{\f5\fs18\hyphpar0\qj{ does not preclude the release of an arrested person as authorized by }}}{{\f5\fs18\hyphpar0\qj{section 804.21}}}{{\f5\fs18\hyphpar0\qj{, unless the arrested person is charged with manufacture, delivery, possession with the intent to manufacture or deliver, or distribution of methamphetamine.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{\*\bkmkstart stylerid1_2E7_2E6_2E1_2E2}{\*\bkmkend stylerid1_2E7_2E6_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Statement to all defendants.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When a defendant appears before a magistrate pursuant to }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/ACO/CourtRulesChapter/2.pdf" }{\fldrslt \f5 \fs18{{\f5\b\fs18\hyphpar0\qj\cf5{rule of criminal procedure 2.2}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{ or }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/ACO/CourtRulesChapter/2.pdf" }{\fldrslt \f5 \fs18{{\f5\b\fs18\hyphpar0\qj\cf5{2.3}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{, the defendant shall be informed of the defendant\u8217\'3fs right to have said conditions of release reviewed. If the defendant indicates that the defendant desires such a review and is indigent and unable to retain legal counsel, the magistrate shall appoint an attorney to represent the defendant for the purpose of such review. Unless the conditions of release are amended and the defendant is thereupon released, the magistrate shall set forth in writing the reasons for requiring conditions imposed. A defendant who is ordered released by a magistrate other than a district court judge or district associate judge on a condition which required that the defendant return to custody after specified hours, shall, upon application, be entitled to review by the magistrate who imposed the condition in the same manner as a defendant who remains in full-time custody. In the event that the magistrate who imposed conditions of release is not available, any other magistrate in the judicial district may review such conditions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{\*\bkmkstart stylerid1_2E7_2E7_2E1_2E2}{\*\bkmkend stylerid1_2E7_2E7_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Statement of conditions when defendant is released.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A magistrate authorizing the release of a defendant under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall issue a written order containing a statement of the conditions imposed if any, shall inform the defendant of the penalties applicable to violation of the conditions of release and shall advise the defendant that a warrant for the defendant\u8217\'3fs arrest will be issued immediately upon such violation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{\*\bkmkstart stylerid1_2E7_2E8_2E1_2E2}{\*\bkmkend stylerid1_2E7_2E8_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Amendment of release conditions.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A magistrate ordering the release of the defendant on any conditions specified in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ may at any time amend the order to impose additional or different conditions of release, provided that, if the imposition of different or additional conditions results in the detention of the defendant as a result of the defendant\u8217\'3fs inability to meet such conditions, the provisions of }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall apply.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{\*\bkmkstart stylerid1_2E7_2E9_2E1_2E2}{\*\bkmkend stylerid1_2E7_2E9_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Appeal from conditions of release.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A defendant who is detained, or whose release on a condition requiring the defendant to return to custody after specified hours is continued, after review of the defendant\u8217\'3fs application pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 3 or 5}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, by a magistrate, other than a district judge or district associate judge having original jurisdiction of the offense with which the defendant is charged, may make application to a district judge or district associate judge having jurisdiction to amend the order. Said motion shall be promptly set for hearing and a record made thereof.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In any case in which a court denied a motion under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ to amend an order imposing conditions of release, or a defendant is detained after conditions of release have been imposed or amended upon such a motion, an appeal may be taken from the district court. The appeal shall be determined summarily, without briefs, on the record made. However, the defendant may elect to file briefs and may be heard in oral argument, in which case the prosecution shall have a right to respond as in an ordinary appeal from a criminal conviction. The appellate court may, on its own motion, order the parties to submit briefs and set the time in which such briefs shall be filed. Any order so appealed shall be affirmed if it is supported by the proceeding below. If the order is not so supported, the court may remand the case for a further hearing or may, with or without additional evidence, order the defendant released pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{\*\bkmkstart stylerid1_2E7_2E1_30_2E1_2E2}{\*\bkmkend stylerid1_2E7_2E1_30_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Failure to appear \u8212\'3f penalty.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any person who, having been released pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, willfully fails to appear before any court or magistrate as required shall, in addition to the forfeiture of any security given or pledged for the person\u8217\'3fs release, if the person was released in connection with a charge which constitutes a felony, or while awaiting sentence or pending appeal after conviction of any public offense, be guilty of a class \u8220\'3fD\u8221\'3f felony. If the defendant was released before conviction or acquittal in connection with a charge which constitutes any public offense not a felony, the defendant shall be guilty of a serious misdemeanor. If the person was released for appearance as a material witness, the person shall be guilty of a simple misdemeanor. In addition, nothing herein shall limit the power of the court to punish for contempt.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a72876, 3216 \u8211\'3f 3218; R60, \'a74601, 4967; C73, \'a74248, 4573; C97, \'a75232, 5500; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{13547, 13611;}}}{ C46, 50, 54, 58, 62, 66, \'a7761.21, 763.3; C71, 73, 75, 77, \'a7761.21, 763.17 \u8211\'3f 763.19; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7811.2}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 19, \'a71 \u8211\'3f 3}}}{{\f5\fs18\hyphpar0\qj{; 83 Acts, ch 50, \'a76, 7}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1152, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 17, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1033, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 157, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 12, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1131, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 15, \'a710, 11, 14}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 174, \'a723 \u8211\'3f 25}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 30, \'a7221}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71319}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.44}}}{{\f5\fs12\hyphpar0\qj{, 321.486}}}{{\f5\fs12\hyphpar0\qj{, 602.1211}}}{{\f5\fs12\hyphpar0\qj{, 664A.3}}}{{\f5\fs12\hyphpar0\qj{, 708.11}}}{{\f5\fs12\hyphpar0\qj{, 804.23}}}{{\f5\fs12\hyphpar0\qj{, 811.1A}}}{{\f5\fs12\hyphpar0\qj{, 811.5}}}{{\f5\fs12\hyphpar0\qj{, 811.10}}}{{\f5\fs12\hyphpar0\qj{, 812.3}}}{{\f5\fs12\hyphpar0\qj{, 812.4}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Order for discharge of defendant upon bail, see }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0{{\f5\fs12\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/ACO/CourtRulesChapter/2.pdf" }{\fldrslt \f5 \fs12{{\f5\b\fs12\hyphpar0\qj\cf5{R.Cr.P. 2.37}}}}}}}\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{ \u8211\'3f Forms 2 and 3 }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{811.2A}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Pretrial release.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2007/CH0215.pdf" }{\fldrslt \cf5 \f5 \fs18{{2007 Acts, ch 215, \'a7134}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{811.3}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Qualification and examination of surety.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Insurance companies doing business in this state under the provisions of }}}{{\f5\fs18\hyphpar0\qj{section 515.48, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, may act as surety. Resident owners of property that is located within the state and that is worth the amount specified in the undertaking may act as surety and must in all cases justify by an affidavit taken before an officer authorized to administer oaths that such surety possesses such qualifications.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A company acting as surety shall not engage in conduct or activities substantially similar to those of a bail enforcement agent or bail enforcement business, as those terms are defined in }}}{{\f5\fs18\hyphpar0\qj{section 80A.1}}}{{\f5\fs18\hyphpar0\qj{, without receiving a license from the department of public safety as specified in }}}{{\f5\fs18\hyphpar0\qj{chapter 80A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In taking bail each signer may justify severally in amounts less than that expressed in the undertaking, if the whole justification be equivalent to one sufficient bail.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court in which the action is pending, or the clerk thereof, or magistrate may require the personal appearance of sureties offered, and may thereupon further examine them upon oath concerning their sufficiency, and may also receive other evidence for or against the sufficiency of the bail. When such examination is closed, the official conducting such examination must make an order, either allowing or disallowing the bail, and forthwith cause the same, with the affidavits or justification and undertaking of bail, to be filed with the clerk of the court to which the papers on the preliminary examination are required to be sent.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a73220 \u8211\'3f 3224; R60, \'a74969 \u8211\'3f 4973; C73, \'a74575 \u8211\'3f 4579; C97, \'a75507 \u8211\'3f 5510; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{13619 \u8211\'3f 13622;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, \'a7763.11 \u8211\'3f 763.14; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7811.3}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2024 Acts, ch 1028, \'a72}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{811.4}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Undertaking of bail as liens on real estate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Undertakings of bail, immediately after such undertakings are filed with the clerk of the district court, shall be docketed as liens on real estate, entered upon the lien index as required for judgments in civil cases, and from the time of such entries, shall be liens upon real estate of the persons executing the same. Attested copies of such undertakings may be filed in the office of the clerk of the district court of the county in which the real estate is situated, in the same manner and with like effect as attested copies of civil judgments, and shall be immediately docketed and indexed in the same manner.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a75000 \u8211\'3f 5002; C73, \'a74606 \u8211\'3f 4608; C97, \'a75513, 5514; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{13625, 13626;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, \'a7764.1, 764.2; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7811.4}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7602.8102(130)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{811.5}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Bail on appeal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{After conviction, upon appeal to the appellate court, the defendant must be admitted to bail, if it be from the judgment imposing a fine, upon the undertaking of bail that the defendant will, in all respects, abide the orders and the judgment of the appellate court upon appeal; if from a judgment of imprisonment, except as provided in }{{\f5\fs18\hyphpar0\qj{section 811.1}}}{ upon the undertaking of bail that the defendant will surrender in execution of the judgment and direction of the appellate court, and in all respects abide the orders and judgment of the appellate court upon the appeal. Such bail may be taken, either by the court where the judgment was rendered, or the district court of the county in which the defendant is imprisoned, or by the appellate court, or a judge or clerk of any of such courts. Provided, that in lieu of bail, bailable defendants as described herein may be released in accordance with the provisions of }{{\f5\fs18\hyphpar0\qj{section 811.2}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a74966, 4981; C73, \'a74587; C97, \'a75506; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{13617, 13618;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, \'a7763.9, 763.10; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7811.5}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7915.13}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{811.6}}}{\*\bkmkstart stylerid1_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Forfeiture of bail.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A defendant released pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall appear at arraignment, trial, judgment, or such other proceedings where the defendant\u8217\'3fs appearance is required. If the defendant fails to appear at the time and place when the defendant\u8217\'3fs personal appearance is lawfully required, or to surrender in execution of the judgment, the court must direct an entry of the failure to be made of record, and the undertaking of the defendant\u8217\'3fs bail, or the money deposited, is thereupon forfeited. As a part of the entry, except as provided in }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/ACO/CourtRulesChapter/2.pdf" }{\fldrslt \f5 \fs18{{\f5\b\fs18\hyphpar0\qj\cf5{rule of criminal procedure 2.72}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{, the court shall direct the clerk of the district court of the county to give thirty days\u8217\'3f notice in writing to the defendant and the defendant\u8217\'3fs sureties to appear and show cause, if any, why judgment should not be entered for the amount of bail. If such appearance is not made, judgment shall be entered by the court. If appearance is made, the court shall set the case down for immediate hearing as an ordinary action.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Where a forfeiture and judgment have been entered as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, and the amount of the judgment has been paid to the clerk, the clerk shall hold the amount paid as funds of the clerk\u8217\'3fs office for a period of one hundred fifty days from the date of judgment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court may, upon application, set aside such judgment if, within one hundred fifty days from the date of the judgment, any of the following occur:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The defendant voluntarily surrenders to the sheriff of the county.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The defendant\u8217\'3fs sureties, at their own expense, deliver the defendant or facilitate delivery of the defendant to the custody of the sheriff. }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court determines, upon consideration of all circumstances, that setting aside the judgment is warranted.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A judgment shall not be set aside under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ unless as a condition precedent thereto, the defendant and the defendant\u8217\'3fs sureties have paid all costs and expenses incurred in connection with the judgment.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a74990 \u8211\'3f 4994; C73, \'a74596 \u8211\'3f 4600; C97, \'a75515 \u8211\'3f 5517, 5519; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{13631, 13633, 13635, 13636;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, \'a7766.1 \u8211\'3f 766.3, 766.5, 766.6; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7811.6}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1032, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 54, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 64, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1021, \'a7175}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1044, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.653}}}{{\f5\fs12\hyphpar0\qj{, 602.8102(131)}}}{{\f5\fs12\hyphpar0\qj{, 811.2}}}{{\f5\fs12\hyphpar0\qj{, 811.9}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{811.7}}}{\*\bkmkstart stylerid1_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Recommitment after bail.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The magistrate may, by an order entered on the record, direct the defendant to be arrested and committed to jail until legally discharged, after the defendant has given bail or deposited money in lieu thereof, or otherwise is released pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, when it satisfactorily appears to the court that the defendant has failed to appear as required, or the defendant has violated a condition of release, or when, after the filing of an indictment or information, the court finds the bail taken or money deposited is insufficient.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Such order for recommitment must recite generally the facts upon which it is founded, and must direct that the defendant be arrested and committed to the custody of the sheriff of the county in which such order is entered. The defendant may be arrested pursuant to such order, upon a certified copy thereof, in any county of the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the order recites, as the ground on which it is made, the failure of the defendant to appear for judgment upon conviction, the defendant must be committed according to the requirements of the order; if made for any other cause and the offense is bailable, the court must cause a direction to be inserted in the order that the defendant be admitted to bail, in a sum to be stated in the order.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a73243 \u8211\'3f 3247; R60, \'a74995-4999; C73, \'a74601 \u8211\'3f 4605; C97, \'a75520 \u8211\'3f 5523; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{13637 \u8211\'3f 13640;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, \'a7767.1 \u8211\'3f 767.4; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7811.7}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2023 Acts, ch 64, \'a7101}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.653}}}{{\f5\fs12\hyphpar0\qj{, 811.9}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{811.8}}}{\*\bkmkstart stylerid1_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Surrender of defendant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At any time before the forfeiture of the undertaking, the surety may surrender the defendant, or the defendant may surrender, to the officer to whose custody the defendant was committed at the time of giving bail, and such officer shall detain the defendant as upon a commitment and must, upon such surrender and the receipt of a certified copy of the undertaking of bail, acknowledge the surrender by a certificate in writing. A company acting as surety shall not engage in conduct or activities substantially similar to those of a bail enforcement agent or bail enforcement business, as those terms are defined in }}}{{\f5\fs18\hyphpar0\qj{section 80A.1}}}{{\f5\fs18\hyphpar0\qj{, without receiving a license from the department of public safety as specified in }}}{{\f5\fs18\hyphpar0\qj{chapter 80A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon the filing of the undertaking and the certificate of the officer, or the certificate of the officer alone if money has been deposited instead of bail, the court or clerk shall immediately order return of the money deposited to the person who deposited the same, or order an exoneration of the surety.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a73236 \u8211\'3f 3238; R60, \'a74987 \u8211\'3f 4989; C73, \'a74593 \u8211\'3f 4595; C97, \'a75528 \u8211\'3f 5530; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{13641 \u8211\'3f 13643;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, \'a7768.1 \u8211\'3f 768.3; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7811.8}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1149, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1028, \'a73, 4}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a780A.3A}}}{{\f5\fs12\hyphpar0\qj{, 811.1A}}}{{\f5\fs12\hyphpar0\qj{, 811.9}}}{{\f5\fs12\hyphpar0\qj{, 812.3}}}{{\f5\fs12\hyphpar0\qj{, 812.4}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{811.9}}}{\*\bkmkstart stylerid1_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Forfeiture of appearance bond and conditions to set aside.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Sections 811.6 through 811.8}}}{ shall not apply in a case where a simple misdemeanor is charged upon a uniform citation and complaint and where the defendant has submitted an unsecured appearance bond or has submitted bail in the form of cash, check, credit card as provided in }{{\f5\fs18\hyphpar0\qj{section 805.14}}}{, or guaranteed arrest bond certificate as defined in }{{\f5\fs18\hyphpar0\qj{section 321.1}}}{. When a defendant fails to appear as required in such cases, the court, or the clerk of the district court, shall enter a judgment of forfeiture of the bond or bail. The judgment shall be final upon entry and shall not be set aside unless the conviction is for a scheduled violation under }{{\f5\fs18\hyphpar0\qj{chapter 321}}}{ that was set aside under the procedures established in }{{\f5\fs18\hyphpar0\qj{section 321.200A}}}{, or upon a showing of good cause after the filing of a motion within ninety days of entry of the judgment, for mistake, inadvertence, surprise, excusable neglect, or unavoidable casualty.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7811.9}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{99 Acts, ch 144, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 124, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1069, \'a765}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1130, \'a72}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{811.10}}}{\*\bkmkstart stylerid1_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Discharge of surety.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{When a defendant is admitted to bail by means of a surety bail bond pursuant to }{{\f5\fs18\hyphpar0\qj{section 811.2, subsection 1}}}{, paragraph }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{, subparagraph (4), the obligation of surety shall be discharged, and the surety released, upon any of the following conditions:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Dismissal of the charges against the defendant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Judgment of acquittal against the defendant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Judgment of conviction against the defendant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Entry of an order deferring judgment of the defendant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Entry of an order by the court which, by its terms, continues the case against the defendant for a period exceeding six months.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1152, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 30, \'a7256}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7811.11}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{811.11}}}{\*\bkmkstart stylerid1_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Bail after deferred judgment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Upon entry of an order by the court deferring judgment, effecting a discharge of the surety as required under }{{\f5\fs18\hyphpar0\qj{section 811.10}}}{, the defendant may be admitted to bail, as a condition of the deferral of judgment. Admittance to bail under }{{\f5\fs18\hyphpar0\qj{this section}}}{, if required by the court, requires a new bail undertaking by the defendant. The surety under }{{\f5\fs18\hyphpar0\qj{this section}}}{ is responsible only for the failure of the defendant to appear at required court appearances during the period of deferral of judgment.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1152, \'a74}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{811.12}}}{\*\bkmkstart stylerid1_2E18_2E2_2E2}{\*\bkmkend stylerid1_2E18_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Limitations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not take or attempt to take into custody the principal on a bail bond, either as a surety on a bail bond in a criminal proceeding or as an agent of such surety, unless such person has complied with all of the following, if applicable:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notification or registration with a chief law enforcement officer under }}}{{\f5\fs18\hyphpar0\qj{section 80A.3A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Licensing requirements for bail enforcement businesses and bail enforcement agents under }}}{{\f5\fs18\hyphpar0\qj{chapter 80A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person other than a certified peace officer shall not be authorized to apprehend, detain, or arrest a principal on a bail bond, wherever issued, unless one of the following applies:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person is a bail enforcement agent licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 80A}}}{{\f5\fs18\hyphpar0\qj{ and has notified the chief law enforcement officer under }}}{{\f5\fs18\hyphpar0\qj{section 80A.3A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person is a bail enforcement agent licensed under the laws of another state and has registered with the chief law enforcement officer under }}}{{\f5\fs18\hyphpar0\qj{section 80A.3A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person is a bail enforcement agent from a state that does not license such businesses who has registered with the chief law enforcement officer under }}}{{\f5\fs18\hyphpar0\qj{section 80A.3A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1149, \'a713}}}{; }{{\f5\fs18\hyphpar0\qj{99 Acts, ch 105, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1028, \'a75}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a780A.3A}}}\par}}