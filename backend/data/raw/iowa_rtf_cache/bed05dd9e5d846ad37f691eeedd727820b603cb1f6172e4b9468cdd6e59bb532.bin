\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{633.5}}}{\*\bkmkstart stylerid1_2E6_2E4_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E4_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Nonestate property \u8212\'3f insurance proceeds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A decedent\u8217\'3fs estate shall not include life insurance proceeds, unless the proceeds are payable to the decedent\u8217\'3fs estate.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1153, \'a77}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{633.6 through 633.9}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0{\f5\fs18\chcbpat2}\par}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER II}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E7_2E2_2E2}{PROBATE COURT, CLERK OF PROBATE COURT, AND PROCEDURE IN PROBATE}{\*\bkmkend stylerid1_2E7_2E2_2E2}\par}{}{}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{PART 1}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E7_2E3_2E1_2E2}{PROBATE COURT}{\*\bkmkend stylerid1_2E7_2E3_2E1_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{633.10}}}{\*\bkmkstart stylerid1_2E7_2E3_2E2_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E3_2E2_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Jurisdiction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{In addition to the jurisdiction granted the district court under the trust code, }{{\f5\fs18\hyphpar0\qj{chapter 633A}}}{, or elsewhere, the district court sitting in probate shall have jurisdiction of:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E7_2E3_2E2_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E7_2E3_2E2_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Estates of decedents and absentees.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The probate and contest of wills; the appointment of personal representatives; the granting of letters testamentary and of administration; the administration, settlement and distribution of estates of decedents and absentees, whether such estates consist of real or personal property or both.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E7_2E3_2E2_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E7_2E3_2E2_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Construction of wills.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The construction of wills during the administration of the estate, whether said construction be incident to such administration, or as a separate proceeding.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{\*\bkmkstart stylerid1_2E7_2E3_2E2_2E6_2E1_2E2}{\*\bkmkend stylerid1_2E7_2E3_2E2_2E6_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Conservatorships and guardianships.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as provided for in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the appointment of conservators and guardians; the granting of letters of conservatorship and guardianship; the administration, settlement and closing of conservatorships and guardianships.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Beginning January 1, 2020, minor guardianships are under the exclusive jurisdiction of the juvenile court pursuant to, and except as limited by, }}}{{\f5\fs18\hyphpar0\qj{chapter 232D}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{\*\bkmkstart stylerid1_2E7_2E3_2E2_2E7_2E1_2E2}{\*\bkmkend stylerid1_2E7_2E3_2E2_2E7_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Trusts and trustees.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The ongoing administration and supervision, including but not limited to the appointment of trustees, the granting of letters of trusteeship, trust administration, and trust settlement and closing, of the following trusts:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A trust that was in existence on July 1, 2005, and that is subject to continuous court supervision.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A trust established by court decree that is subject to continuous court supervision.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A trust described in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall be governed by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and the provisions of }}}{{\f5\fs18\hyphpar0\qj{chapter 633A}}}{{\f5\fs18\hyphpar0\qj{ which are not inconsistent with the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A trust not described in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall be governed exclusively by }}}{{\f5\fs18\hyphpar0\qj{chapter 633A}}}{{\f5\fs18\hyphpar0\qj{ and shall be subject to the jurisdiction of the district court sitting in probate only as provided in }}}{{\f5\fs18\hyphpar0\qj{section 633A.6101}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon joint application by all trustees administering a trust described in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and following notice to the beneficiaries pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 633.40}}}{{\f5\fs18\hyphpar0\qj{, the court shall release the trust from further jurisdiction unless a beneficiary objects. The court whose decree created the trust may release the trust from continuous court supervision following notice to the beneficiary pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 633.40}}}{{\f5\fs18\hyphpar0\qj{. If such judicial release occurs for a trust previously governed by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, such trust shall be governed by }}}{{\f5\fs18\hyphpar0\qj{chapter 633A}}}{{\f5\fs18\hyphpar0\qj{ and the district court sitting in probate only as provided in }}}{{\f5\fs18\hyphpar0\qj{section 633A.6101}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{\*\bkmkstart stylerid1_2E7_2E3_2E2_2E8_2E1_2E2}{\*\bkmkend stylerid1_2E7_2E3_2E2_2E8_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Actions for accounting.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An action for an accounting against a beneficiary of a transfer on death security registration, pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 633D}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, \'a72312; C97, \'a7225; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{10763, 10764;}}}{ C46, 50, 54, 58, 62, \'a7604.3, 604.4; C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7633.10}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 154, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 36, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 178, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 56, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 38, \'a76 \u8211\'3f 8, 55}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 179, \'a7139}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1010, \'a7155}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 56, \'a736, 44, 45}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7633.3}}}{{\f5\fs12\hyphpar0\qj{, 633.27}}}{{\f5\fs12\hyphpar0\qj{, 633.751}}}{{\f5\fs12\hyphpar0\qj{, 633A.1107}}}{{\f5\fs12\hyphpar0\qj{, 633A.6101}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Applicability of probate code to trusts, see }{{\f5\fs12\hyphpar0\qj{\'a7633.751}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Scope of trust code, see }{{\f5\fs12\hyphpar0\qj{\'a7633A.1107}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{633.11}}}{\*\bkmkstart stylerid1_2E7_2E3_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E3_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Declaratory judgments \u8212\'3f determination of heirship \u8212\'3f distribution.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{During the administration of an estate, the district court sitting in probate shall have full, legal and equitable powers to make declaratory judgments in all matters involved in the administration of the estate, including those pertaining to the title of real estate, the determination of heirship, and the distribution of the estate. It shall have full, legal and equitable powers to enter final orders and decrees in all probate matters to effectuate its jurisdiction and to carry out its orders, judgments, and decrees.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7633.11}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{633.12}}}{\*\bkmkstart stylerid1_2E7_2E3_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E3_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{County of jurisdiction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The court of each county shall have original and exclusive jurisdiction to administer the estates of all persons who are residents of the county, or who were residents at the time of their death, and all nonresidents of the state who have property, or who die leaving property in the county subject to administration, or whose property is afterwards brought into the county; to appoint conservators for nonresidents having property in the county; and to appoint conservators and guardians of residents of the county.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, \'a72312; C97, \'a7225; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{10763, 10764;}}}{ C46, 50, 54, 58, 62, \'a7604.3, 604.4; C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7633.12}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{633.13}}}{\*\bkmkstart stylerid1_2E7_2E3_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E3_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Extent of jurisdiction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court of the county in which a will is probated, or in which administration, conservatorship or guardianship is granted, shall have jurisdiction coextensive with the state in the settlement of the estate, and in the sale and distribution thereof.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A district judge or a district associate judge has statewide jurisdiction to enter orders in probate matters not requiring notice and hearing, although the judge is not a judge of or present in the district in which the probate matter is pending. The orders shall be made in conformity with the rules of the district in which the probate matter is pending.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a72472; C73, \'a72319; C97, \'a73265; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{11825;}}}{ C46, 50, 54, 58, 62, \'a7631.7; C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7633.13}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 186, \'a710119, 10201}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1122, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1062, \'a794}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{633.14}}}{\*\bkmkstart stylerid1_2E7_2E3_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E3_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Concurrent jurisdiction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{When a case is originally within the jurisdiction of the courts of two or more counties, the court which first takes cognizance of the case by the commencement of the proceedings shall retain jurisdiction throughout the case.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a71274; R60, \'a72306; C73, \'a72318; C97, \'a73264; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{11824;}}}{ C46, 50, 54, 58, 62, \'a7631.6; C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7633.14}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2020 Acts, ch 1063, \'a7334}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{633.15}}}{\*\bkmkstart stylerid1_2E7_2E3_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E3_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Probate court always open.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2003/CH0151.pdf" }{\fldrslt \cf5 \f5 \fs18{{2003 Acts, ch 151, \'a762}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{633.16}}}{\*\bkmkstart stylerid1_2E7_2E3_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E3_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Control of probate records.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The court shall have jurisdiction and supervision of the probate records of the clerk, and may direct the destruction of records it deems to be old, obsolete or unnecessary.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7633.16}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{93 Acts, ch 70, \'a710}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{633.17}}}{\*\bkmkstart stylerid1_2E7_2E3_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E3_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Judge disqualified \u8212\'3f procedure.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{When a judge is disqualified from acting in a probate matter, the matter shall be heard before another judge of the same district, or shall be transferred to the court of another district, or a judge of another district shall be procured to hold court for the hearing of the matter.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, \'a72317; C97, \'a73263; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{11823;}}}{ C46, 50, 54, 58, 62, \'a7631.5; C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7633.17}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 186, \'a710120, 10201}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Disqualification of judicial officer, see }{{\f5\fs12\hyphpar0\qj{\'a7602.1606}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{633.18}}}{\*\bkmkstart stylerid1_2E7_2E3_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E3_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Rules in probate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Actions and proceedings under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ are subject to rules prescribed by the supreme court under }}}{{\f5\fs18\hyphpar0\qj{section 602.4201}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The judicial officers of a judicial district, excluding the magistrates, acting under }}}{{\f5\fs18\hyphpar0\qj{section 602.1213}}}{{\f5\fs18\hyphpar0\qj{ may prescribe rules for probate actions and proceedings within the district, but these rules must be consistent with }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, and are subject to the approval of the supreme court.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7633.18}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 186, \'a710121, 10201}}}{; }{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1153, \'a77}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Rules adopted by the supreme court are published in the compilation \u8220\'3fIowa Court Rules\u8221\'3f }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{633.19}}}{\*\bkmkstart stylerid1_2E7_2E3_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E3_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Process revoked.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Any process or authority emanating from the court in probate matters may for good cause be revoked and a new one issued.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a71275; R60, \'a72307; C73, \'a72320; C97, \'a73266; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{11827;}}}{ C46, 50, 54, 58, 62, \'a7631.9; C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7633.19}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{633.20}}}{\*\bkmkstart stylerid1_2E7_2E3_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E3_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Referee \u8212\'3f clerk \u8212\'3f associate probate judge.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The chief judge of the judicial district may appoint a referee in probate for the auditing of the accounts of fiduciaries and for the performance of other ministerial duties the chief judge prescribes. A person shall not be appointed as referee in a matter where the person is acting as a fiduciary or as the attorney.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The chief judge of the judicial district may appoint the clerk as referee in probate. In such cases, the fees received by the clerk for serving in the capacity of referee are fees of the office of the clerk of court and shall be deposited in the account established under }}}{{\f5\fs18\hyphpar0\qj{section 602.8108}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person appointed as an associate probate judge shall have jurisdiction to audit accounts of fiduciaries and to perform ministerial duties as a referee provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and shall have additional jurisdiction to perform the judicial functions provided in }}}{{\f5\fs18\hyphpar0\qj{section 633.20D}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, \'a72412; C97, \'a73393; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{12041;}}}{ C46, 50, 54, 58, 62, \'a7638.1; C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7633.20}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 186, \'a710122, 10201}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 70, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1074, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 93, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1057, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1159, \'a713}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{633.20A}}}{\*\bkmkstart stylerid1_2E7_2E3_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E3_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Part-time associate probate judge \u8212\'3f appointment \u8212\'3f removal \u8212\'3f qualifications.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The chief judge of a judicial district may appoint a part-time associate probate judge and may remove the part-time associate probate judge for cause following a hearing. The part-time associate probate judge shall be an attorney admitted to practice law in this state and shall be qualified for the position by training and experience.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{99 Acts, ch 93, \'a712}}}{; }{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1154, \'a738}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{633.20B}}}{\*\bkmkstart stylerid1_2E7_2E3_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E3_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Appointment and resignation of full-time associate probate judges.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Full-time associate probate judges shall be appointed by the governor from persons nominated by the district judicial nominating commission in the same manner as district judges under }}}{{\f5\fs18\hyphpar0\qj{chapter 46}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A full-time associate probate judge who seeks to resign from the office of full-time associate probate judge shall notify in writing the governor, the chief judge of the judicial district, and the state commissioner of elections as to the full-time associate probate judge\u8217\'3fs intention to resign and the effective date of the resignation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When a vacancy occurs or will occur within one hundred twenty days in the office of a full-time associate probate judge, the state commissioner of elections shall forthwith so notify the governor. The governor shall call a meeting of the commission within ten days after such notice. If the governor fails to do so, the chief justice shall call such meeting.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{99 Acts, ch 93, \'a713, 15}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 208, \'a762}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 151, \'a751, 64}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1033, \'a712}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7602.2301}}}{{\f5\fs12\hyphpar0\qj{, 602.6113}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{633.20C}}}{\*\bkmkstart stylerid1_2E7_2E3_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E3_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Full-time associate probate judges \u8212\'3f term, retention, qualifications.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Full-time associate probate judges shall serve terms and shall stand for retention in office within the judicial election districts of their appointment as provided under }}}{{\f5\fs18\hyphpar0\qj{sections 46.16 through 46.24}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person does not qualify for appointment to the office of full-time associate probate judge unless the person is at the time of appointment licensed to practice law in Iowa and will be able, measured by the person\u8217\'3fs age at the time of appointment, to complete the initial term of office prior to reaching age seventy-eight. A nominee to the office of full-time associate probate judge must reside in the judicial election district to which the nominee is nominated or in a contiguous county to the judicial election district to which the nominee is nominated.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A full-time associate probate judge must be a resident of the judicial election district or a resident of a county contiguous with the judicial election district in which the office is held before assuming office and during the entire term of office. A full-time associate probate judge shall serve within the judicial district in which appointed, as directed by the chief judge, and is subject to reassignment under }}}{{\f5\fs18\hyphpar0\qj{section 602.6108}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Full-time associate probate judges shall qualify for office as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 63}}}{{\f5\fs18\hyphpar0\qj{ for district judges.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{99 Acts, ch 93, \'a714, 15}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1033, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 101, \'a75, 14, 15}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2025 amendment to subsection 2 applies to judicial officers retiring on or after July 1, 2025; }{{\f5\fs12\hyphpar0\qj{2025 Acts, ch 101, \'a715}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsections 1 \u8211\'3f 3 amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{633.20D}}}{\*\bkmkstart stylerid1_2E7_2E3_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E3_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Associate probate judge }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ jurisdiction }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ appeals.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An associate probate judge shall have the same jurisdiction to conduct probate court proceedings, to issue no-contact or protective orders, injunctions, contempt orders for adults in probate court proceedings, and to issue orders, findings, and decisions as the judge of the probate court. However, the chief judge may limit the exercise of probate court jurisdiction by the associate probate judge.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The parties to a proceeding heard by an associate probate judge are entitled to appeal the order, finding, or decision of an associate probate judge, in the manner of an appeal from orders, findings, or decisions of district court judges. An appeal does not automatically stay the order, finding, or decision of an associate probate judge.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2010 Acts, ch 1159, \'a714}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7633.20}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{633.21}}}{\*\bkmkstart stylerid1_2E7_2E3_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E3_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Appraisers\u8217\'3f fees and referees\u8217\'3f fees fixed by rule.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The district judges of each judicial district shall by rule fix the fees of probate referees, and also provide, insofar as practicable, a uniform schedule of compensation for tax appraisers, other appraisers, brokers, and agents employed at estate expense.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7633.21}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 186, \'a710123, 10201}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 148, \'a738, 53, 54}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2025 amendment applies retroactively to January 1, 2025, to the estates of decedents dying on or after January 1, 2025; }{{\f5\fs12\hyphpar0\qj{2025 Acts, ch 148, \'a754}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section amended}\par}{}{}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{PART 2}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E7_2E4_2E1_2E2}{CLERK OF PROBATE COURT}{\*\bkmkend stylerid1_2E7_2E4_2E1_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{633.22}}}{\*\bkmkstart stylerid1_2E7_2E4_2E2_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E4_2E2_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Probate powers of clerk.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The clerk shall have and may exercise within the county all the powers and jurisdiction of the court and of the judge thereof, in the following matters:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The examination and approval of all intermediate and interlocutory accounts and reports of fiduciaries under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and converting and closing small estates under }}}{{\f5\fs18\hyphpar0\qj{chapter 635}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The entering of routine scheduling orders in probate matters as established by the chief judge in each judicial district.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a71276; R60, \'a72308; C73, \'a72315, 2321; C97, \'a7250, 3267, 3268; S13, \'a73268; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{11828, 11832, 11838;}}}{ C46, 50, 54, 58, 62, \'a7631.10, 632.1, 632.7; C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7633.22}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1050, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 38, \'a751}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1027, \'a71, 8}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7633.23}}}{{\f5\fs12\hyphpar0\qj{, 633.25}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{633.23}}}{\*\bkmkstart stylerid1_2E7_2E4_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E4_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Clerk\u8217\'3fs actions reviewed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Any person aggrieved by any order made or entered by the clerk under the powers conferred in }{{\f5\fs18\hyphpar0\qj{section 633.22, subsection 1}}}{, may have the same reviewed in court upon motion filed within six months or before the hearing on the final report of the fiduciary, whichever is the earlier, and upon such notice as provided in }{{\f5\fs18\hyphpar0\qj{section 633.40}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a7251; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{11834;}}}{ C46, 50, 54, 58, 62, \'a7632.3; C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7633.23}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{633.24}}}{\*\bkmkstart stylerid1_2E7_2E4_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E4_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Docketing and hearing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Upon the filing of such a motion, the clerk shall place the cause or proceeding on the docket without additional docket fee, and the matter shall stand for hearing or trial de novo in open court.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a7251; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{11835;}}}{ C46, 50, 54, 58, 62, \'a7632.4; C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7633.24}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{633.25}}}{\*\bkmkstart stylerid1_2E7_2E4_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E4_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Validity of clerk\u8217\'3fs orders.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Records, orders, and judgments made and entered by the clerk under }{{\f5\fs18\hyphpar0\qj{section 633.22}}}{, which have not been reversed, set aside, or modified by the court, shall stand, and shall be of the same force, validity, and effect, and be entitled to the same faith and credit, as if they had been made by the court.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a7252; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{11836;}}}{ C46, 50, 54, 58, 62, \'a7632.5; C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7633.25}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2019 Acts, ch 59, \'a7214}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{633.26}}}{\*\bkmkstart stylerid1_2E7_2E4_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E4_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Clerk not to prepare reports.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A clerk of the district court or employee of the clerk shall not act as attorney for a fiduciary, or make or assist in making, drafting, or filling out any report of any fiduciary or any other report to be filed in the clerk\u8217\'3fs office.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a7252; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{11837;}}}{ C46, 50, 54, 58, 62, \'a7632.6; C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7633.26}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1233, \'a738}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{633.27}}}{\*\bkmkstart stylerid1_2E7_2E4_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E4_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Probate docket.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The clerk shall keep an electronic record to be known as the \u8220\'3fProbate Docket\u8221\'3f, which shall show:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The name of every deceased person whose estate is administered or whose will is admitted to probate, and the date of the person\u8217\'3fs death.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The name of each person as to whom application for conservatorship or guardianship is made.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The names of all the heirs in intestate estates and the surviving spouse of such deceased intestate, and whether each person is an adult or a minor and each person\u8217\'3fs place of residence, so far as they can be ascertained.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The title of each trust described in }}}{{\f5\fs18\hyphpar0\qj{section 633.10}}}{{\f5\fs18\hyphpar0\qj{ that has not been released by the court from continuous court supervision.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A note of every sale of real estate made under the order of the court.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, \'a72490; C97, \'a73411; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{11841;}}}{ C46, 50, 54, 58, 62, \'a7632.10; C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7633.27}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 38, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1027, \'a72, 8}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{633.27A}}}{\*\bkmkstart stylerid1_2E7_2E4_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E4_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\