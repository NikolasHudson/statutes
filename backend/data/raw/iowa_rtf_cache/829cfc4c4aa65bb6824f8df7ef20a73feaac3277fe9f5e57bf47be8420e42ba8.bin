\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F169C}{\*\bkmkend codeChapter_5F169C}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 169C}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{TRESPASSING OR STRAY LIVESTOCK}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a7314.30}}}\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{169C.1}}}{\*\bkmkstart stylerid1_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{As used in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, unless the context otherwise requires:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAggrieved party\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a landowner or a local authority.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCounty system\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as defined in }}}{{\f5\fs18\hyphpar0\qj{section 445.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fFence\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a fence as described in }}}{{\f5\fs18\hyphpar0\qj{chapter 359A}}}{{\f5\fs18\hyphpar0\qj{ which is lawful and tight as provided in that chapter, including but not limited to a partition fence. For purposes of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ffence\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes a fence bordering a public road.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLandowner\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person who holds an interest in land, including a titleholder or tenant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLivestock\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an animal belonging to the bovine, caprine, equine, ovine, or porcine species; ostriches, rheas, or emus; farm deer as defined in }}}{{\f5\fs18\hyphpar0\qj{section 170.1}}}{{\f5\fs18\hyphpar0\qj{; or poultry.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLivestock care provider\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person designated by a local authority to provide care to livestock which is distrained by a local authority.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLivestock owner\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the person who holds title to livestock or who is primarily responsible for the care and feeding of the livestock as provided by the titleholder.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLocal authority\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a city as defined in }}}{{\f5\fs18\hyphpar0\qj{section 362.2}}}{{\f5\fs18\hyphpar0\qj{ or a county as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 331}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMaintenance\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the provision of shelter, food, water, or a nutritional formulation as required pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 717}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPublic road\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a thoroughfare and its right-of-way, whether reserved by public ownership or easement, for use by the traveling public.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 57, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 149, \'a73, 23}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 64, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1118, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7314.30}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Further definitions, see }{{\f5\fs12\hyphpar0\qj{\'a7159.1}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{169C.2}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Custody.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A landowner may take custody of livestock if the livestock trespasses upon the landowner\u8217\'3fs land or strays from the livestock owner\u8217\'3fs control on a public road which adjoins the landowner\u8217\'3fs land. A local authority may take custody of the livestock as provided by the local authority. The landowner shall not transfer custody of the livestock to a person other than the livestock owner or a local authority, unless the livestock owner approves of the transfer. A local authority shall not transfer custody of the livestock to a person other than the livestock owner or a livestock care provider.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 57, \'a72}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7169C.4}}}{{\f5\fs12\hyphpar0\qj{, 169C.5}}}{{\f5\fs12\hyphpar0\qj{, 314.30}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{169C.3}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Notice to livestock owner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If livestock trespasses upon a landowner\u8217\'3fs land or the landowner takes custody of the livestock, the landowner shall deliver notice of the trespass or custody to the livestock owner within forty-eight hours following discovery of the trespass or taking custody of livestock which has not trespassed. If a local authority takes custody of the livestock, the local authority shall deliver notice of the custody to the livestock owner within forty-eight hours after taking custody of the livestock. The forty-eight-hour period shall exclude any time that falls on a Sunday or a holiday recognized by the state or the United States. The notice shall be made in writing and delivered by certified mail or personal service to the last known mailing address of the livestock owner.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the aggrieved party does not know the name and address of the livestock owner, the aggrieved party shall make reasonable efforts to determine the identity of the livestock owner. The reasonable efforts shall include obtaining the name and address of the owner of the brand appearing on the livestock from the department of agriculture and land stewardship under }}}{{\f5\fs18\hyphpar0\qj{chapter 169A}}}{{\f5\fs18\hyphpar0\qj{. If the name and address of the livestock owner cannot be determined, the aggrieved party shall publish the notice as soon as possible at least once each week for two consecutive weeks in a newspaper having general circulation in the county where the livestock is located.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A notice required under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall at least provide all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The name and address of the landowner or local authority.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A description of the livestock and where it trespassed or strayed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An estimate of the amount of the livestock owner\u8217\'3fs liability.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 57, \'a73}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7169C.4}}}{{\f5\fs12\hyphpar0\qj{, 169C.5}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{169C.4}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Liability.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A livestock owner shall be liable to the following persons:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To a landowner for damages caused by the livestock owner\u8217\'3fs livestock which have trespassed on the landowner\u8217\'3fs land, including but not limited to property damage and costs incurred by the landowner\u8217\'3fs custody of the livestock including maintenance costs. A livestock owner\u8217\'3fs liability is not affected by the failure of a landowner to take custody of the livestock. A livestock owner shall not be liable for damages incurred by a landowner if the livestock trespassed through a fence that was not maintained by the landowner as required pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 359A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To a landowner who takes custody of livestock on a public road as provided in }}}{{\f5\fs18\hyphpar0\qj{section 169C.2}}}{{\f5\fs18\hyphpar0\qj{ for costs incurred by the landowner in taking custody of the livestock, including maintenance costs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To a local authority which takes custody of livestock for costs incurred by the local authority in taking custody of the livestock, including maintenance costs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An aggrieved party who fails to provide timely notice of a livestock\u8217\'3fs trespass or custody as required by }}}{{\f5\fs18\hyphpar0\qj{section 169C.3}}}{{\f5\fs18\hyphpar0\qj{ shall not be entitled to compensation for damages for the period of time during which the aggrieved party fails to provide timely notice.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A landowner is not liable for an injury or death suffered by the livestock in the landowner\u8217\'3fs custody, unless the landowner caused the injury or death. The landowner is not liable for livestock that strays from the landowner\u8217\'3fs land. An aggrieved party is not liable for livestock that strays from the control of the aggrieved party.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 57, \'a74}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1100, \'a721, 22}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7314.30}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{169C.5}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Satisfaction for damages.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{After receiving notice by an aggrieved party as required by }}}{{\f5\fs18\hyphpar0\qj{section 169C.3}}}{{\f5\fs18\hyphpar0\qj{, the livestock owner shall pay all damages to the aggrieved party for which the livestock owner is liable.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The aggrieved party or the livestock owner may bring a civil action in order to determine the livestock owner\u8217\'3fs liability and the amount of any claim for damages. The aggrieved party or livestock owner must bring the action within thirty days following receipt or publication of the notice as required by }}}{{\f5\fs18\hyphpar0\qj{section 169C.3}}}{{\f5\fs18\hyphpar0\qj{. The court may join all other claims arising out of the same facts that are alleged in the claim for damages. The civil action may be heard by a district judge or a district associate judge. The civil action may be heard by the district court sitting in small claims as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 631}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the livestock is in the custody of an aggrieved party or livestock care provider, a rebuttable presumption arises that the livestock has trespassed or strayed from the control of the livestock owner. The rebuttable presumption shall not apply if a criminal charge has been filed involving the removal or transfer of the livestock. The burden of proof regarding all other matters of dispute shall be on the aggrieved party.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The failure of an aggrieved party to provide notice as required by }}}{{\f5\fs18\hyphpar0\qj{section 169C.3}}}{{\f5\fs18\hyphpar0\qj{ shall not bar the aggrieved party from being awarded a judgment, if the court determines that the livestock owner had actual knowledge that the livestock had trespassed or strayed and the name and address of the aggrieved party.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a civil action is brought by the livestock owner or aggrieved party, the matter shall be heard by a court on an expedited basis. The aggrieved party shall provide for the transfer of the livestock to the livestock owner, if the livestock owner posts a bond or other security with the court in the amount of the aggrieved party\u8217\'3fs claim. If a bond or security is not posted, the aggrieved party or livestock care provider shall keep custody of and provide maintenance to the livestock. However, the livestock owner shall post the bond or other security if the matter is set for hearing more than thirty days from the date that the petition bringing the civil action is filed. The court shall order the immediate disposition of the livestock as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 717}}}{{\f5\fs18\hyphpar0\qj{, if the livestock is permanently distressed by disease or injury to a degree that would result in severe or prolonged suffering.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a civil action is not timely brought as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, title to the livestock shall transfer to the aggrieved party thirty days following receipt of the notice by the livestock owner or the first date of the notice\u8217\'3fs publication as required pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 169C.3}}}{{\f5\fs18\hyphpar0\qj{, if the parties fail to agree to the amount, terms, or conditions of payment or if the identity of the livestock owner cannot be determined. Title to the livestock shall transfer subject to any applicable security interests or liens.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A landowner is liable to the livestock owner for twice the fair market value of livestock that the landowner transfers to a person other than a local authority in violation of }}}{{\f5\fs18\hyphpar0\qj{section 169C.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the aggrieved party is a local authority, the local authority shall reimburse the landowner for the landowner\u8217\'3fs damages from proceeds received from the sale of the livestock, after satisfying any superior security interests or liens.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 57, \'a75}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{169C.6}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Habitual trespass.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A habitual trespass occurs when livestock trespasses from the land where the livestock are kept onto the land of a neighboring landowner or strays from the land where the livestock are kept onto a public road, and on three or more separate occasions within the prior twelve-month period the same or different livestock kept on that land have trespassed onto the land of the same neighboring landowner or strayed from the land where the livestock are kept onto the same public road.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The local authority upon its own initiative or upon receipt of a complaint shall determine whether livestock are trespassing or straying from the land where the livestock are kept onto a public road, and make a record of its findings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Once a habitual trespass occurs, a neighboring landowner may request that the responsible landowner of the land where the trespassing or stray livestock are kept erect or maintain a fence on the land. The neighboring landowner shall make the request to the responsible landowner in writing. The responsible landowner may compel an adjacent landowner to contribute to the erection or maintenance of the fence as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 359A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the responsible landowner does not erect or maintain a fence within thirty days after receiving the request, the neighboring landowner may apply to the fence viewers as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 359A}}}{{\f5\fs18\hyphpar0\qj{ as if the matter were a controversy between the responsible landowner and an adjacent landowner, and the matter shall be resolved by an order issued by the fence viewers, subject to appeal, as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 359A}}}{{\f5\fs18\hyphpar0\qj{. The neighboring landowner shall be a party to the controversy as if the neighboring party were an adjacent landowner. The neighboring landowner is not liable for erecting or maintaining the fence, unless the neighboring landowner is an adjacent landowner who is otherwise required to make a contribution under }}}{{\f5\fs18\hyphpar0\qj{chapter 359A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the fence is not erected or maintained as required in }}}{{\f5\fs18\hyphpar0\qj{section 359A.6}}}{{\f5\fs18\hyphpar0\qj{, and upon the written request of the board of township trustees, the board of supervisors of the county where the fence is to be erected or maintained shall act in the same manner as the board of township trustees under that section, including by erecting or maintaining the fence, ordering payment from a defaulted party, and certifying an amount due to the county treasurer in the same manner as in }}}{{\f5\fs18\hyphpar0\qj{section 359A.6}}}{{\f5\fs18\hyphpar0\qj{. The amount due shall include the total costs required to erect or maintain the fence and a penalty equal to five percent of the total costs. The amount shall be placed upon the county system and collected in the same manner as ordinary taxes. Upon certification to the county treasurer, the amount assessed shall be a lien on the parcel until paid.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 64, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1118, \'a72}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7314.30}}}{{\f5\fs12\hyphpar0\qj{, 359A.22A}}}{{\f5\fs12\hyphpar0\qj{, 445.1}}}\par}}