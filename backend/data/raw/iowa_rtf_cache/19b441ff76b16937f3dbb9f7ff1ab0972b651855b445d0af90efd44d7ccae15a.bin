rd\plain\keep\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER I}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E6_2E1_2E2}{MEDICAL ASSISTANCE ELIGIBILITY AND MISCELLANEOUS PROVISIONS}{\*\bkmkend stylerid1_2E6_2E1_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{249A.1}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Title.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This chapter}}}{ may be cited as the }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMedical Assistance Act\u8221\'3f}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7249A.1}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{249A.2}}}{\*\bkmkstart stylerid1_2E6_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{As used in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDepartment\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the department of health and human services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDirector\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the director of health and human services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDiscretionary medical assistance\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means mandatory medical assistance or optional medical assistance provided to medically needy individuals whose income and resources are in excess of eligibility limitations but are insufficient to meet all of the costs of necessary medical care and services, provided that if the assistance includes services in institutions for mental diseases or intermediate care facilities for persons with an intellectual disability, or both, for any group of such individuals, the assistance also includes for all covered groups of such individuals at least the care and services enumerated in Tit. XIX of the }}}{{\f5\fs18\hyphpar0\qj{federal Social Security Act, section 1905(a), paragraphs (1) through (5), and (17)}}}{{\f5\fs18\hyphpar0\qj{, as codified in }}}{{\f5\fs18\hyphpar0\qj{42 U.S.C. \'a71396d(a), paragraphs (1) through (5), and (17)}}}{{\f5\fs18\hyphpar0\qj{, or any seven of the care and services enumerated in Tit. XIX of the }}}{{\f5\fs18\hyphpar0\qj{federal Social Security Act, section 1905(a), paragraphs (1) through (24)}}}{{\f5\fs18\hyphpar0\qj{, as codified in }}}{{\f5\fs18\hyphpar0\qj{42 U.S.C. \'a71396d(a), paragraphs (1) through (24)}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fFamily investment program\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the family investment program eligibility requirements under }}}{{\f5\fs18\hyphpar0\qj{chapter 239B}}}{{\f5\fs18\hyphpar0\qj{, except to the extent federal law requires application of the eligibility requirements under }}}{{\f5\fs18\hyphpar0\qj{chapter 239, Code 1997}}}{{\f5\fs18\hyphpar0\qj{, as in effect on July 16, 1996.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fGroup health plan cost sharing\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means payment under the medical assistance program of a premium, a coinsurance amount, a deductible amount, or any other cost sharing obligation for a group health plan as required by Tit. XIX of the federal Social Security Act, section 1906, as codified in 42 U.S.C. \'a71396e.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMandatory medical assistance\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means payment of all or part of the costs of the care and services required to be provided by }}}{{\f5\fs18\hyphpar0\qj{Tit. XIX of the federal Social Security Act, section 1905(a), paragraphs (1) through (5), (17), (21), and (28)}}}{{\f5\fs18\hyphpar0\qj{, as codified in }}}{{\f5\fs18\hyphpar0\qj{42 U.S.C. \'a71396d(a), paragraphs (1) through (5), (17), (21), and (28)}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMedical assistance\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMedicaid\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means payment of all or part of the costs of the care and services made in accordance with }}}{{\f5\fs18\hyphpar0\qj{Tit. XIX of the federal Social Security Act}}}{{\f5\fs18\hyphpar0\qj{ and authorized pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMedical assistance program\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMedicaid program\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the program established under this chapter to provide medical assistance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMedicare cost sharing\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means payment under the medical assistance program of a premium, a coinsurance amount, or a deductible amount for federal Medicare as provided by Tit. XIX of the federal Social Security Act, section 1905(p)(3), as codified in 42 U.S.C. \'a71396d(p)(3).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fOptional medical assistance\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means payment of all or part of the costs of any or all of the care and services authorized to be provided by }}}{{\f5\fs18\hyphpar0\qj{Tit. XIX of the federal Social Security Act, section 1905(a), paragraphs (6) through (16), (18) through (20), (22) through (27), and (29)}}}{{\f5\fs18\hyphpar0\qj{, as codified in }}}{{\f5\fs18\hyphpar0\qj{42 U.S.C. \'a71396d(a), paragraphs (6) through (16), and (18) through (20), (22) through (27), and (29)}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fOverpayment\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any funds that a provider receives or retains under the medical assistance program to which the person, after applicable reconciliation, is not entitled. To the extent the provider and the department disagree as to whether the provider is entitled to funds received or retained under the medical assistance program, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3foverpayment\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes such funds for which the provider\u8217\'3fs administrative and judicial review remedies under }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/ACO/chapter/441.7.pdf" }{\fldrslt \cf5 \f5 \fs18{{441 IAC ch. 7}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ have been exhausted. For purposes of repayment, an overpayment may include interest in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 249A.41}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fProvider\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an individual, firm, corporation, association, or institution which is providing or has been approved to provide medical assistance to recipients under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fRecipient\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person who receives medical assistance under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fRetained life estate\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A life estate created by the recipient or recipient\u8217\'3fs spouse, in which either the recipient or the recipient\u8217\'3fs spouse held any interest in the property at the time of the creation of the life estate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A life estate created for the benefit of the recipient or the recipient\u8217\'3fs spouse in property in which either the recipient or the recipient\u8217\'3fs spouse held any interest in the property within five years prior to the creation of the life estate.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7249A.2}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 96, \'a7157, 159}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1297, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 104, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1039, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 107, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 158, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 54, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1129, \'a7113}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 41, \'a725}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1086, \'a71, 21}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7180}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1019, \'a796}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 24, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 138, \'a762 \u8211\'3f 64}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7796}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7135D.2}}}{{\f5\fs12\hyphpar0\qj{, 239.1}}}{{\f5\fs12\hyphpar0\qj{, 249B.1}}}{{\f5\fs12\hyphpar0\qj{, 249F.1}}}{{\f5\fs12\hyphpar0\qj{, 633C.1}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{249A.3}}}{\*\bkmkstart stylerid1_2E6_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Eligibility.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The extent of and the limitations upon eligibility for assistance under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ is prescribed by }{{\f5\fs18\hyphpar0\qj{this section}}}{, subject to federal requirements, and by laws appropriating funds for assistance provided pursuant to }{{\f5\fs18\hyphpar0\qj{this chapter}}}{.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Mandatory medical assistance shall be provided to, or on behalf of, any individual or family residing in the state of Iowa, including those residents who are temporarily absent from the state, who:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is a recipient of federal supplemental security income or who would be eligible for federal supplemental security income if living in their own home.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is an individual who is eligible for the family investment program or is an individual who would be eligible for unborn child payments under the family investment program, as authorized by Tit. IV-A of the federal Social Security Act, if the family investment program provided for unborn child payments during the entire pregnancy.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Was a recipient of one of the previous categorical assistance programs as of December 31, 1973, and would continue to meet the eligibility requirements for one of the previous categorical assistance programs as the requirements existed on that date.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is a child up to one year of age who was born on or after October 1, 1984, to a woman receiving medical assistance on the date of the child\u8217\'3fs birth, who continues to be a member of the mother\u8217\'3fs household, and whose mother continues to receive medical assistance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is a pregnant woman whose pregnancy has been medically verified and who qualifies under either of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The woman would be eligible for cash assistance under the family investment program, if the child were born and living with the woman in the month of payment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The woman meets the income and resource requirements of the family investment program, provided the unborn child is considered a member of the household, and the woman\u8217\'3fs family is treated as though deprivation exists.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is a child who is less than seven years of age and who meets the income and resource requirements of the family investment program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is a child who is one through five years of age as prescribed by the federal Omnibus Budget Reconciliation Act of 1989, Pub. L. No. 101-239, \'a76401, whose income is not more than one hundred thirty-three percent of the federal poverty level as defined by the most recently revised poverty income guidelines published by the United States department of health and human services.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is a child who has attained six years of age but has not attained nineteen years of age, whose income is not more than one hundred thirty-three percent of the federal poverty level, as defined by the most recently revised poverty income guidelines published by the United States department of health and human services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is a woman who, while pregnant, meets eligibility requirements for assistance under the federal }}}{{\f5\fs18\hyphpar0\qj{Social Security Act, section 1902(l)}}}{{\f5\fs18\hyphpar0\qj{, and continues to meet the requirements except for income. The woman is eligible to receive assistance until twelve months after the date pregnancy ends.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is a pregnant woman who is determined to be presumptively eligible by a health care provider qualified under the federal Omnibus Budget Reconciliation Act of 1986, Pub. L. No. 99-509, \'a79407. The woman is eligible for ambulatory prenatal care assistance until the last day of the month following the month of the presumptive eligibility determination. If the department receives the woman\u8217\'3fs medical assistance application by the last day of the month following the month of the presumptive eligibility determination, the woman is eligible for ambulatory prenatal care assistance until the department actually determines the woman\u8217\'3fs eligibility or ineligibility for medical assistance. The costs of services provided during the presumptive eligibility period shall be paid by the medical assistance program for those persons who are determined to be ineligible through the regular eligibility determination process.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is a pregnant woman or infant less than one year of age whose income does not exceed the federally prescribed percentage of the poverty level in accordance with the federal Medicare Catastrophic Coverage Act of 1988, Pub. L. No. 100-360, \'a7302.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{k.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is a pregnant woman or infant whose income is more than the limit prescribed under the federal Medicare Catastrophic Coverage Act of 1988, Pub. L. No. 100-360, \'a7302, but not more than two hundred percent of the federal poverty level as defined by the most recently revised poverty income guidelines published by the United States department of health and human services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{l.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is an infant whose family income is not more than two hundred fifteen percent of the federal poverty level, as defined by the most recently revised income guidelines published by the United States department of health and human services.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is a pregnant woman whose family income while pregnant is at or below two hundred fifteen percent of the federal poverty level, as defined by the most recently revised poverty income guidelines published by the United States department of health and human services, if otherwise eligible.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{m.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is a child for whom adoption assistance or foster care maintenance payments are paid under Tit. IV-E of the federal Social Security Act.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{n.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is an individual or family who is ineligible for the family investment program because of requirements that do not apply under Tit. XIX of the federal Social Security Act.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{o.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Was a federal supplemental security income or a state supplementary assistance recipient, as defined by }}}{{\f5\fs18\hyphpar0\qj{section 249.1}}}{{\f5\fs18\hyphpar0\qj{, and a recipient of federal social security benefits at one time since August 1, 1977, and would be eligible for federal supplemental security income or state supplementary assistance but for the increases due to the cost of living in federal social security benefits since the last date of concurrent eligibility.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{p.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is an individual whose spouse is deceased and who is ineligible for federal supplemental security income or state supplementary assistance, as defined by }}}{{\f5\fs18\hyphpar0\qj{section 249.1}}}{{\f5\fs18\hyphpar0\qj{, due to the elimination of the actuarial reduction formula for federal social security benefits under the federal Social Security Act and subsequent cost of living increases.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{q.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is an individual who is at least sixty years of age and is ineligible for federal supplemental security income or state supplementary assistance, as defined by }}}{{\f5\fs18\hyphpar0\qj{section 249.1}}}{{\f5\fs18\hyphpar0\qj{, because of receipt of social security widow or widower benefits and is not eligible for federal Medicare, part A coverage.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{r.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is an individual with a disability, and is at least eighteen years of age, who receives parental social security benefits under the federal Social Security Act and is not eligible for federal supplemental security income or state supplementary assistance, as defined by }}}{{\f5\fs18\hyphpar0\qj{section 249.1}}}{{\f5\fs18\hyphpar0\qj{, because of the receipt of the social security benefits.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{s.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is an individual who is no longer eligible for the family investment program due to earned income. The department shall provide transitional medical assistance to the individual for the maximum period allowed for federal financial participation under federal law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{t.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is an individual who is no longer eligible for the family investment program due to the receipt of child or spousal support. The department shall provide transitional medical assistance to the individual for the maximum period allowed for federal financial participation under federal law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{u.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As allowed under the federal Deficit Reduction Act of 2005, Pub. L. No. 109-171, \'a76062, is an individual who is less than nineteen years of age who meets the federal supplemental security income program rules for disability but whose income or resources exceed such program rules, who is a member of a family whose income is at or below three hundred percent of the most recently revised official poverty guidelines published by the United States department of health and human services for the family, and whose parent complies with the requirements relating to family coverage offered by the parent\u8217\'3fs employer. Such assistance shall be provided on a phased-in basis, based upon the age of the individual.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{v.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Beginning January 1, 2014, in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 1902(a)(10)(A)(i)(VIII) of the federal Social Security Act}}}{{\f5\fs18\hyphpar0\qj{, as codified in }}}{{\f5\fs18\hyphpar0\qj{42 U.S.C. \'a71396a(a)(10)(A)(i)(VIII)}}}{{\f5\fs18\hyphpar0\qj{, is an individual who is nineteen years of age or older and under sixty-five years of age; is not pregnant; is not entitled to or enrolled for Medicare benefits under }}}{{\f5\fs18\hyphpar0\qj{part A}}}{{\f5\fs18\hyphpar0\qj{, or enrolled for Medicare benefits under }}}{{\f5\fs18\hyphpar0\qj{part B, of Tit. XVIII of the federal Social Security Act}}}{{\f5\fs18\hyphpar0\qj{; is not otherwise described in }}}{{\f5\fs18\hyphpar0\qj{section 1902(a)(10)(A)(i) of the federal Social Security Act}}}{{\f5\fs18\hyphpar0\qj{; is not exempt pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 1902(k)(3)}}}{{\f5\fs18\hyphpar0\qj{, as codified in }}}{{\f5\fs18\hyphpar0\qj{42 U.S.C. \'a71396a(k)(3)}}}{{\f5\fs18\hyphpar0\qj{, and whose income as determined under }}}{{\f5\fs18\hyphpar0\qj{1902(e)(14) of the federal Social Security Act}}}{{\f5\fs18\hyphpar0\qj{, as codified in }}}{{\f5\fs18\hyphpar0\qj{42 U.S.C. \'a71396a(e)(14)}}}{{\f5\fs18\hyphpar0\qj{, does not exceed one hundred thirty-three percent of the poverty line as defined in }}}{{\f5\fs18\hyphpar0\qj{section 2110(c)(5) of the federal Social Security Act}}}{{\f5\fs18\hyphpar0\qj{, as codified in }}}{{\f5\fs18\hyphpar0\qj{42 U.S.C. \'a71397j}}}{{\f5\fs18\hyphpar0\qj{j(c)(5) for the applicable family size.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any provision to the contrary, individuals eligible for medical assistance under this paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fv\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall receive coverage for benefits pursuant to }}}{{\f5\fs18\hyphpar0\qj{42 U.S.C. \'a71396u-7(b)(1)(B)}}}{{\f5\fs18\hyphpar0\qj{; adjusted as necessary to provide the essential health benefits as required pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 1302 of the federal Patient Protection and Affordable Care Act}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{Pub. L. No. 111-148}}}{{\f5\fs18\hyphpar0\qj{; adjusted to provide prescription drugs and dental services consistent with the medical assistance state plan benefits package for individuals otherwise eligible under this subsection; and adjusted to provide habilitation services consistent with the state medical assistance program section 1915(i) waiver.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For individuals whose income as determined under this paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fv\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ is at or below one hundred percent of the federal poverty level, covered benefits under subparagraph (2) shall be administered consistent with program administration under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For individuals whose income as determined under this paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fv\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ is above one hundred percent but not in excess of one hundred thirty-three percent of the federal poverty level, covered benefits shall be administered through provision of premium assistance for the purchase of covered benefits through the American health benefits exchange created pursuant to the }}}{{\f5\fs18\hyphpar0\qj{Affordable Care Act}}}{{\f5\fs18\hyphpar0\qj{, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 249N.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{w.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Beginning January 1, 2014, is an individual who meets all of the following requirements:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is under twenty-six years of age.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Was in foster care under the responsibility of the state on the date of attaining eighteen years of age or such higher age to which foster care is provided.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Was enrolled in the medical assistance program under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ while in such foster care.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Mandatory medical assistance may also, within the limits of available funds and in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 249A.4, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, be provided to, or on behalf of, other individuals and families who are not excluded under }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and whose incomes and resources are insufficient to meet the cost of necessary medical care and services in accordance with the following order of priorities:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As allowed under }}}{{\f5\fs18\hyphpar0\qj{42 U.S.C. \'a71396a(a)(10)(A)(ii)(XIII)}}}{{\f5\fs18\hyphpar0\qj{, individuals with disabilities, who are less than sixty-five years of age, who are members of families whose income is less than two hundred fifty percent of the most recently revised official poverty guidelines published by the United States department of health and human services for the family, who have earned income and who are eligible for mandatory medical assistance or optional medical assistance under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ if earnings are disregarded. As allowed by }}}{{\f5\fs18\hyphpar0\qj{42 U.S.C. \'a71396a(r)(2)}}}{{\f5\fs18\hyphpar0\qj{, unearned income shall also be disregarded in determining whether an individual is eligible for assistance under this subparagraph. For the purposes of determining the amount of an individual\u8217\'3fs resources under this subparagraph and as allowed by }}}{{\f5\fs18\hyphpar0\qj{42 U.S.C. \'a71396a(r)(2)}}}{{\f5\fs18\hyphpar0\qj{, a maximum of ten thousand dollars of available resources for an individual and twenty-one thousand dollars of available resources for a couple shall be disregarded, and any additional resources held in a retirement account, in a medical savings account, or in any other account approved under rules adopted by the department shall also be disregarded.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Individuals eligible for assistance under this subparagraph, whose individual income exceeds one hundred fifty percent of the official poverty guidelines published by the United States department of health and human services for an individual, shall pay a premium. The amount of the premium shall be based on a sliding fee schedule adopted by rule of the department and shall be based on a percentage of the individual\u8217\'3fs income. The maximum premium payable by an individual whose income exceeds one hundred fifty percent of the official poverty guidelines shall be commensurate with the cost of state employees\u8217\'3f group health insurance in this state. The payment to and acceptance by an automated case management system or the department of the premium required under this subparagraph shall not automatically confer initial or continuing program eligibility on an individual. A premium paid to and accepted by the department\u8217\'3fs premium payment process that is subsequently determined to be untimely or to have been paid on behalf of an individual ineligible for the program shall be refunded to the remitter in accordance with rules adopted by the department. Any unpaid premium shall be a debt owed the department.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As provided under the federal }}}{{\f5\fs18\hyphpar0\qj{Breast and Cervical Cancer Prevention and Treatment Act of 2000}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{Pub. L. No. 106-354}}}{{\f5\fs18\hyphpar0\qj{, individuals who meet all of the following criteria:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Are not described in }}}{{\f5\fs18\hyphpar0\qj{42 U.S.C. \'a71396a(a)(10)(A)(i).}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Have not attained age sixty-five.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(iii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Have been screened for breast and cervical cancer under the United States centers for disease control and prevention breast and cervical cancer early detection program established under }}}{{\f5\fs18\hyphpar0\qj{42 U.S.C. \'a7300k et seq.}}}{{\f5\fs18\hyphpar0\qj{, in accordance with the requirements of }}}{{\f5\fs18\hyphpar0\qj{42 U.S.C. \'a7300n}}}{{\f5\fs18\hyphpar0\qj{, and need treatment for breast or cervical cancer. An individual is considered screened for breast and cervical cancer under this subparagraph subdivision if the individual is screened by any provider or entity, and the state grantee of the United States centers for disease control and prevention funds under }}}{{\f5\fs18\hyphpar0\qj{Tit. XV of the federal Public Health Services Act}}}{{\f5\fs18\hyphpar0\qj{ has elected to include screening activities by that provider or entity as screening activities pursuant to }}}{{\f5\fs18\hyphpar0\qj{Tit. XV of the federal Public Health Services Act}}}{{\f5\fs18\hyphpar0\qj{. This screening includes breast or cervical cancer screenings or related diagnostic services provided or funded by family planning centers, community health centers, or nonprofit organizations, and the screenings or services are provided to individuals who meet the eligibility requirements established by the state grantee of the United States centers for disease control and prevention funds under }}}{{\f5\fs18\hyphpar0\qj{Tit. XV of the federal Public Health Services Act}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(iv)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Are not otherwise covered under creditable coverage as defined in }}}{{\f5\fs18\hyphpar0\qj{42 U.S.C. \'a7300gg(c)}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An individual who meets the criteria of this subparagraph (2) shall be presumptively eligible for medical assistance.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Individuals who are receiving care in a hospital or in a basic nursing home, intermediate nursing home, skilled nursing home or extended care facility, as defined by }}}{{\f5\fs18\hyphpar0\qj{section 135C.1}}}{{\f5\fs18\hyphpar0\qj{, and who meet all eligibility requirements for federal supplemental security income except that their income exceeds the allowable maximum for such eligibility, but whose income is not in excess of the maximum established for eligibility for discretionary medical assistance and is insufficient to meet the full cost of their care in the hospital or health care facility on the basis of standards established by the department.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Individuals under twenty-one years of age living in a licensed foster home, or in a private home pursuant to a subsidized adoption arrangement, for whom the department accepts financial responsibility in whole or in part and who are not eligible under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Individuals who are receiving care in an institution for mental diseases, and who are under twenty-one years of age and whose income and resources are such that they are eligible for the family investment program, or who are sixty-five years of age or older and who meet the conditions for eligibility in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (1).}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Individuals and families whose incomes and resources are such that they are eligible for federal supplemental security income or the family investment program, but who are not actually receiving such public assistance.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(7)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Individuals who are receiving state supplementary assistance as defined by }}}{{\f5\fs18\hyphpar0\qj{section 249.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(8)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Individuals under twenty-one years of age who qualify on a financial basis for, but who are otherwise ineligible to receive assistance under the family investment program.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(9)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{ Individuals eligible for family planning services under a federally approved demonstration waiver.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(10)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Individuals and families who would be eligible under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ except for excess income or resources, or a reasonable category of those individuals and families.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(11)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Individuals who have attained the age of twenty-one but have not yet attained the age of sixty-five who qualify on a financial basis for, but who are otherwise ineligible to receive, federal supplemental security income or assistance under the family investment program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding the provisions of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ establishing priorities for individuals and families to receive mandatory medical assistance, the department may determine within the priorities listed in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ which persons shall receive mandatory medical assistance based on income levels established by the department, subject to the limitations provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Optional medical assistance may, within the limits of available funds and in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 249A.4, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, be provided to, or on behalf of, either of the following groups of individuals and families:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Only those individuals and families described in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Those individuals and families described in both }}}{{\f5\fs18\hyphpar0\qj{subsections 1 and 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Discretionary medical assistance, within the limits of available funds and in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 249A.4, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, may be provided to or on behalf of those individuals and families described in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (11), of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Assistance shall not be granted under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ to:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An individual or family whose income, considered to be available to the individual or family, exceeds federally prescribed limitations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An individual or family whose resources, considered to be available to the individual or family, exceed federally prescribed limitations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5A.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In determining eligibility for children under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ff\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fg\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fj\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fk\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fn\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fs\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{; }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraphs (3), (5), (6), (8), and (11); and }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, all resources of the family, other than monthly income, shall be disregarded.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5B.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In determining eligibility for adults under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fh\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fj\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fk\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fn\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fs\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ft\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{; }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraphs (4), (5), (8), (11), and (12); and }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, one motor vehicle per household shall be disregarded.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In determining the eligibility of an individual for medical assistance under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, for resources transferred to the individual\u8217\'3fs spouse before October 1, 1989, or to a person other than the individual\u8217\'3fs spouse before July 1, 1989, the department shall include, as resources still available to the individual, those nonexempt resources or interests in resources, owned by the individual within the preceding twenty-four months, which the individual gave away or sold at less than fair market value for the purpose of establishing eligibility for medical assistance under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A transaction described in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ is presumed to have been for the purpose of establishing eligibility for medical assistance under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ unless the individual furnishes convincing evidence to establish that the transaction was exclusively for some other purpose.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The value of a resource or an interest in a resource in determining eligibility under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ is the fair market value of the resource or interest at the time of the transaction less the amount of any compensation received.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a transaction described in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ results in uncompensated value exceeding twelve thousand dollars, the department shall provide by rule for a period of ineligibility which exceeds twenty-four months and has a reasonable relationship to the uncompensated value above twelve thousand dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In determining the eligibility of an individual for medical assistance under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, the department shall consider resources transferred to the individual\u8217\'3fs spouse on or after October 1, 1989, or to a person other than the individual\u8217\'3fs spouse on or after July 1, 1989, and prior to August 11, 1993, as provided by the federal Medicare Catastrophic Coverage Act of 1988, Pub. L. No. 100-360, \'a7303(b), as amended by the federal Family Support Act of 1988, Pub. L. No. 100-485, \'a7608(d)(16)(B), (D), and the federal Omnibus Budget Reconciliation Act of 1989, Pub. L. No. 101-239, \'a76411(e)(1).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Medicare cost sharing shall be provided in accordance with the provisions of Tit. XIX of the federal Social Security Act, section 1902(a)(10)(E), as codified in 42 U.S.C. \'a71396a(a)(10)(E), to or on behalf of an individual who is a resident of the state or a resident who is temporarily absent from the state, and who is a member of any of the following eligibility categories:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A qualified Medicare beneficiary as defined under Tit. XIX of the federal Social Security Act, section 1905(p)(1), as codified in 42 U.S.C. \'a71396d(p)(1).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A qualified disabled and working person as defined under Tit. XIX of the federal Social Security Act, section 1905(s), as codified in 42 U.S.C. \'a71396d(s).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A specified low-income Medicare beneficiary as defined under Tit. XIX of the federal Social Security Act, section 1902(a)(10)(E)(iii), as codified in 42 U.S.C. \'a71396a(a)(10)(E)(iii).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An additional specified low-income Medicare beneficiary as described under Tit. XIX of the federal Social Security Act, section 1902(a)(10)(E)(iv)(I), as codified in 42 U.S.C. \'a71396a(a)(10)(E)(iv)(I).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An additional specified low-income Medicare beneficiary described under Tit. XIX of the federal Social Security Act, section 1902(a)(10)(E)(iv)(II), as codified in 42 U.S.C. \'a71396a(a)(10)(E)(iv)(II).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In determining the eligibility of an institutionalized individual for assistance under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, the department shall establish a minimum community spouse resource allowance in an amount which is the greater of twenty-four thousand dollars or the minimum required as a condition of receipt of federal funding pursuant to}}}{{\f5\fs18\hyphpar0\qj{ section 1924(f)(2)(A)(i) of the federal Social Security Act}}}{{\f5\fs18\hyphpar0\qj{, as codified in }}}{{\f5\fs18\hyphpar0\qj{42 U.S.C. \'a71396r-5(f)(2)(A)(i)174}}}{{\f5\fs18\hyphpar0\qj{, and as adjusted pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 1924(g) of the federal Social Security Act}}}{{\f5\fs18\hyphpar0\qj{ as codified in }}}{{\f5\fs18\hyphpar0\qj{42 U.S.C. \'a71396r-5(g)}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Group health plan cost sharing shall be provided as required by Tit. XIX of the federal Social Security Act, section 1906, as codified in 42 U.S.C. \'a71396e.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In determining the eligibility of an individual for medical assistance, the department shall consider transfers of assets made on or after August 11, 1993, as provided by the federal Social Security Act, section 1917(c), as codified in 42 U.S.C. \'a71396p(c).}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall exercise the option provided in }}}{{\f5\fs18\hyphpar0\qj{42 U.S.C. \'a71396p(c)}}}{{\f5\fs18\hyphpar0\qj{ to provide a period of ineligibility for medical assistance due to a transfer of assets by a noninstitutionalized individual or the spouse of a noninstitutionalized individual. For noninstitutionalized individuals, the number of months of ineligibility shall be equal to the total, cumulative uncompensated value of all assets transferred by the individual or the individual\u8217\'3fs spouse on or after the look-back date specified in }}}{{\f5\fs18\hyphpar0\qj{42 U.S.C. \'a71396p(c)(1)(B)(i)}}}{{\f5\fs18\hyphpar0\qj{, divided by the average monthly cost to a private patient for nursing facility services in Iowa at the time of application. The services for which noninstitutionalized individuals shall be made ineligible shall include any long-term care services for which medical assistance is otherwise available. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 17A.4}}}{{\f5\fs18\hyphpar0\qj{, the department may adopt rules providing a period of ineligibility for medical assistance due to a transfer of assets by a noninstitutionalized individual or the spouse of a noninstitutionalized individual without notice of opportunity for public comment, to be effective immediately upon filing under }}}{{\f5\fs18\hyphpar0\qj{section 17A.5, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (1), subparagraph division (a).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A disclaimer of any property, interest, or right pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 633E.5}}}{{\f5\fs18\hyphpar0\qj{ constitutes a transfer of assets for the purpose of determining eligibility for medical assistance in an amount equal to the value of the property, interest, or right disclaimed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Unless a surviving spouse is precluded from making an election under the terms of a premarital agreement, the failure of a surviving spouse to take an elective share pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 633, subchapter V}}}{{\f5\fs18\hyphpar0\qj{, constitutes a transfer of assets for the purpose of determining eligibility for medical assistance to the extent that the value received by taking an elective share would have exceeded the value of the inheritance received under the will.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In determining the eligibility of an individual for medical assistance, the department shall consider income or assets relating to trusts or similar legal instruments or devices established on or before August 10, 1993, as available to the individual, in accordance with the federal }}}{{\f5\fs18\hyphpar0\qj{Comprehensive Omnibus Budget Reconciliation Act of 1985}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{Pub. L. No. 99-272, \'a79506(a)}}}{{\f5\fs18\hyphpar0\qj{, as amended by the federal }}}{{\f5\fs18\hyphpar0\qj{Omnibus Budget Reconciliation Act of 1986}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{Pub. L. No. 99-509, \'a79435(c)}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In determining the eligibility of an individual for medical assistance, the department shall consider income or assets relating to trusts or similar legal instruments or devices established after August 10, 1993, as available to the individual, in accordance with 42 U.S.C. \'a71396p(d) and }}}{{\f5\fs18\hyphpar0\qj{sections 633C.2}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{633C.3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Once initial ongoing eligibility for medical assistance is determined for a child under the age of nineteen, the department shall provide continuous eligibility for a period of up to twelve months regardless of changes in family circumstances, until the child\u8217\'3fs next annual review of eligibility under the medical assistance program, with the exception of the following children:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A newborn child of a medical assistance-eligible woman.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A child whose eligibility was determined under the medically needy program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A child who is eligible under a state-only funded program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A child who is no longer an Iowa resident.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A child who is incarcerated in a jail or other correctional institution.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C62, 66, \'a7249A.3, 249A.4; C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7249A.3}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 7, \'a715}}}{, }{{\f5\fs18\hyphpar0\qj{ch 82, \'a71}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1297, \'a73 \u8211\'3f 5}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 146, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 104, \'a72 \u8211\'3f 4}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 304, \'a7202}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1258, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1270, \'a748}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 158, \'a73, 4}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1043, \'a74}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{; }{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts//CH0000.pdf" }{\fldrslt \f5 \fs18{{\f5\fs18\hyphpar0\qj\cf5{92 Acts, 2nd Ex, ch 1001, \'a7420}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 97, \'a737}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1120, \'a71, 8, 9, 16}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 68, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1129, \'a764}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 41, \'a726 \u8211\'3f 28}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1218, \'a777}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 94, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 203, \'a750}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 208, \'a750}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1060, \'a71 \u8211\'3f 3}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1221, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1228, \'a741}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 184, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 62, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1015, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 38, \'a71, 55}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1104, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1159, \'a74, 8}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 218, \'a741 \u8211\'3f 43, 124, 126}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1014, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1188, \'a72, 3, 55}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 41, \'a7242}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 118, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 182, \'a7132, 134}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 98, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 120, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 138, \'a765 \u8211\'3f 71, 77, 92, 93, 106, 177, 178, 187}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1092, \'a7174}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 30, \'a7224}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1041, \'a7127}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 116, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1141, \'a71, 4}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 133, \'a77}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7217.34}}}{{\f5\fs12\hyphpar0\qj{, 249N.2}}}{{\f5\fs12\hyphpar0\qj{, 249N.5}}}{{\f5\fs12\hyphpar0\qj{, 249N.6}}}{{\f5\fs12\hyphpar0\qj{, 421.65}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Spousal support debt for medical assistance to institutionalized spouse; community spouse resource allowance; }{{\f5\fs12\hyphpar0\qj{chapter 249B}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Elimination of monthly budget maximum or cap for individuals eligible for medical assistance program home and community-based services elderly waiver; department of health and human services required to track average expended per waiver recipient and report annually to general assembly by December 30; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2020/CH1053.pdf" }{\fldrslt \cf5 \f5 \fs12{{2020 Acts, ch 1053, \'a71}}}}}}\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2022/CH1109.pdf" }{\fldrslt \cf5 \f5 \fs12{{2022 Acts, ch 1109, \'a73}}}}}}\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2023/CH19.pdf" }{\fldrslt \cf5 \f5 \fs12{{2023 Acts, ch 19, \'a71358}}}}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 2, paragraph a, subparagraph (1), subparagraph division (a) amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{249A.3A}}}{\*\bkmkstart stylerid1_2E6_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Medical assistance \u8212\'3f all income-eligible children.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department shall provide medical assistance to individuals under nineteen years of age who meet the income eligibility requirements for the state medical assistance program and for whom federal financial participation is or becomes available for the cost of such assistance.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 118, \'a713}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{249A.4}}}{\*\bkmkstart stylerid1_2E6_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Duties of director.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The director shall be responsible for the effective and impartial administration of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ and shall, in accordance with the standards and priorities established by }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, by applicable federal law, by the regulations and directives issued pursuant to federal law, by applicable court orders, and by the state plan approved in accordance with federal law, make rules, establish policies, and prescribe procedures to implement }{{\f5\fs18\hyphpar0\qj{this chapter}}}{. Without limiting the generality of the foregoing delegation of authority, the director is hereby specifically empowered and directed to:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Determine the greatest amount, duration, and scope of assistance which may be provided, and the broadest range of eligible individuals to whom assistance may effectively be provided, under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ within the limitations of available funds. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Require providers to share information with the department as necessary to identify, prevent, or respond to child abuse as defined in }}}{{\f5\fs18\hyphpar0\qj{section 232.68}}}{{\f5\fs18\hyphpar0\qj{, and dependent adult abuse as defined in }}}{{\f5\fs18\hyphpar0\qj{section 235B.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Have authority to provide for payment under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ of assistance rendered to any applicant prior to the date the application is filed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Have authority to contract with any corporation authorized to engage in this state in insuring groups or individuals for all or part of the cost of medical, hospital, or other health care or with any corporation maintaining and operating a medical, hospital, or health service prepayment plan under the provisions of }}}{{\f5\fs18\hyphpar0\qj{chapter 514}}}{{\f5\fs18\hyphpar0\qj{ or with any health maintenance organization authorized to operate in this state, for any or all of the benefits to which any recipients are entitled under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ to be provided by such corporation or health maintenance organization on a prepaid individual or group basis.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{May, to the extent possible, contract with a private organization or organizations whereby such organization will handle the processing of and the payment of claims for services rendered under the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and under such rules and regulations as shall be promulgated by such department. The state department may give due consideration to the advantages of contracting with any organization which may be serving in Iowa as \u8220\'3fintermediary\u8221\'3f or \u8220\'3fcarrier\u8221\'3f under Tit. XVIII of the federal Social Security Act, as amended.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Shall cooperate with any agency of the state or federal government in any manner as may be necessary to qualify for federal aid and assistance for medical assistance in conformity with the provisions of }}}{{\f5\fs18\hyphpar0\qj{chapter 249}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, and Tit. XVI and XIX of the federal Social Security Act, as amended.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Shall provide for the professional freedom of those licensed practitioners who determine the need for or provide medical care and services, and shall provide freedom of choice to recipients to select the provider of care and services, except when the recipient is eligible for participation in a health maintenance organization or prepaid health plan which limits provider selection and which is approved by the department.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{However, this shall not limit the freedom of choice to recipients to select providers in instances where such provider services are eligible for reimbursement under the medical assistance program but are not provided under the health maintenance organization or under the prepaid health plan, or where the recipient has an already established program of specialized medical care with a particular provider. The department may also restrict the recipient\u8217\'3fs selection of providers to control the individual recipient\u8217\'3fs overuse of care and services, provided the department can document this overuse. The department shall promulgate rules for determining the overuse of services, including rights of appeal by the recipient.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Advanced registered nurse practitioners licensed pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 152}}}{{\f5\fs18\hyphpar0\qj{ and physician assistants licensed pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 148C}}}{{\f5\fs18\hyphpar0\qj{ shall be regarded as approved providers of health care services, including primary care, for purposes of managed care or prepaid services contracts under the medical assistance program. This paragraph shall not be construed to expand the scope of practice of an advanced registered nurse practitioner pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 152}}}{{\f5\fs18\hyphpar0\qj{ or physician assistants pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 148C}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Implement the premium assistance program options described under the federal Children\u8217\'3fs Health Insurance Program Reauthorization Act of 2009, Pub. L. No. 111-3, for the medical assistance program. The department may adopt rules as necessary to administer these options.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ in determining the method and level of reimbursement for all medical and health services to be provided under the medical assistance program, after considering all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The promotion of efficient and cost-effective delivery of medical and health services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Compliance with federal law and regulations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The level of state and federal appropriations for medical assistance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reimbursement at a level as near as possible to actual costs and charges after priority is given to the considerations in paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Allow supplementation of the combination of client participation and payment made through the medical assistance program for those items and services identified in }}}{{\f5\fs18\hyphpar0\qj\cf1{42 C.F.R. \'a7483.10(c)(8)(ii)}}}{{\f5\fs18\hyphpar0\qj{, by the resident of a nursing facility or the resident\u8217\'3fs family. Supplementation under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ may include supplementation for provision of a private room not otherwise covered under the medical assistance program unless either of the following applies:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The private room is therapeutically required pursuant to }}}{{\f5\fs18\hyphpar0\qj\cf1{42 C.F.R. \'a7483.10(c)(8)(ii)}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{No room other than the private room is available.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The rules adopted to administer }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall require all of the following if a nursing facility provides for supplementation for provision of a private room:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The nursing facility shall inform all current and prospective residents and residents\u8217\'3f legal representatives of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the resident desires a private room, the resident or resident\u8217\'3fs family may provide supplementation by directly paying the facility the amount of supplementation. Supplementation by a resident\u8217\'3fs family shall not be treated as income of the resident for purposes of medical assistance program eligibility or client participation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The nursing facility\u8217\'3fs policy if a resident residing in a private room converts from private pay to payment under the medical assistance program, but the resident or resident\u8217\'3fs family is not willing or able to pay supplementation for the private room.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A description and identification of the private rooms for which supplementation is available.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The process for an individual to take legal responsibility for providing supplementation, including identification of the individual and the extent of the legal responsibility.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For a resident for whom the nursing facility receives supplementation, the nursing facility shall indicate in the resident\u8217\'3fs record all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A description and identification of the private room for which the nursing facility is receiving supplementation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The identity of the individual making the supplemental payments.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The private pay charge for the private room for which the nursing facility is receiving supplementation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The total charge to the resident for the private room for which the nursing facility is receiving supplementation, the portion of the total charge reimbursed under the medical assistance program, and the portion of the total charge reimbursed through supplementation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the nursing facility only provides one type of room or all private rooms, the nursing facility shall not be eligible to request supplementation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A nursing facility may base the supplementation amount on the difference between the amount paid for a room covered under the medical assistance program and the private pay rate for the private room identified for supplementation. However, the total payment for the private room from all sources shall not be greater than the aggregate average private room rate for the type of rooms covered under the medical assistance program for which the resident would be eligible.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Supplementation pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not be required as a precondition of admission, expedited admission, or continued stay in a facility.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Supplementation shall not be applicable if the facility\u8217\'3fs occupancy rate is less than fifty percent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(7)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The nursing facility shall ensure that all appropriate care is provided to all residents notwithstanding the applicability or availability of supplementation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(8)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A private room for which supplementation is required shall be retained for the resident consistent with existing bed-hold policies.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A nursing facility that utilizes the supplementation option and receives supplementation under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ during any calendar year shall report to the department annually, by January 15, the following information for the preceding calendar year:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The total number of nursing facility beds available at the nursing facility, the number of such beds available in private rooms, and the number of such beds available in other types of rooms.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The average occupancy rate of the facility on a monthly basis. }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The total number of residents for which supplementation was utilized.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The average private pay charge for a private room in the nursing facility.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(e)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For each resident for whom supplementation was utilized, the total charge to the resident for the private room, the portion of the total charge reimbursed under the Medicaid program, and the total charge reimbursed through supplementation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall compile the information received and shall submit the compilation to the general assembly, annually by May 1.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Shall provide an opportunity for a fair hearing before the department of inspections, appeals, and licensing to an individual whose claim for medical assistance under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ is denied or is not acted upon with reasonable promptness. Upon completion of a hearing, the department of inspections, appeals, and licensing shall issue a decision which is subject to review by the department. Judicial review of the decisions of the department may be sought in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{. If a petition for judicial review is filed, the department shall furnish the petitioner with a copy of the application and all supporting papers, a transcript of the testimony taken at the hearing, if any, and a copy of its decision.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In determining the medical assistance eligibility of a pregnant woman, infant, or child under the federal Social Security Act, \'a71902(l), resources which are used as tools of the trade shall not be considered.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In implementing }}}{{\f5\fs18\hyphpar0\qj{subsection 9}}}{{\f5\fs18\hyphpar0\qj{, relating to reimbursement for medical and health services under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, when a selected out-of-state acute care hospital facility is involved, a contractual arrangement may be developed with the out-of-state facility that is in accordance with the requirements of Tit. XVIII and XIX of the federal Social Security Act. The contractual arrangement is not subject to other reimbursement standards, policies, and rate setting procedures required under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A medical assistance copayment shall only be applied to those services and products specified in administrative rules of the department in effect on February 1, 1991, which under federal medical assistance requirements, are provided at the option of the state.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C62, 66, \'a7249A.5, 249A.10; C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7249A.4}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1260, \'a7121, 122}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 96, \'a7157, 159}}}{{\f5\fs18\hyphpar0\qj{; 83 Acts, ch 153, \'a712, 13}}}{{\f5\fs18\hyphpar0\qj{; 83 Acts, ch 201, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1245, \'a72031}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 37, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 104, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 304, \'a7203}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1204, \'a761, 62}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1223, \'a721}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1256, \'a741}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1264, \'a734}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 97, \'a732}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 158, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1229, \'a729, 30}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1150, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 165, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1181, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 96, \'a727}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1029, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 24, \'a765, 74}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 74, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 21, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1090, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 120, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 167, \'a746, 66}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 41, \'a7243}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 118, \'a718}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1031, \'a7389}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1034, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 138, \'a772}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1140, \'a787, 88}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1020, \'a78, 12}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1063, \'a794}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7797, 798, 1961}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1018, \'a710, 13, 14}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1161, \'a7101, 137}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 135, \'a745}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7249A.3}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 amendment to subsection 1 applies retroactively to reports due on or after January 1, 2024; }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 1018, \'a714}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 strike of subsection 15 effective July 1, 2025; }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 1161, \'a7137}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{NEW subsection 2}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 15 stricken}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{249A.4A}}}{\*\bkmkstart stylerid1_2E6_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Health care coordination and intervention teams.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fhealth care provider\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a health care provider as defined in }}}{{\f5\fs18\hyphpar0\qj{section 135.24}}}{{\f5\fs18\hyphpar0\qj{, a mental health professional, or a substance use professional.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director may establish health care coordination and intervention teams as part of the state medical assistance program to conduct individual case reviews to determine whether additional health services or interventions may be appropriate for an individual\u8217\'3fs care needs. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A health care coordination and intervention team shall review individual cases including but not limited to cases involving individuals with complex conditions who are in need of urgent placement and services.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A review of an individual case by a health care coordination and intervention team may be initiated by the department or by a health care provider.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In conducting an individual case review, a health care coordination and intervention team shall:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Review and analyze all relevant case information for the purpose of recommending additional health services, treatments, and interventions as appropriate to meet the individual\u8217\'3fs needs and to ensure the protection of human health and safety.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Consult with the individual\u8217\'3fs health care providers to assist and facilitate care coordination and treatment referral actions as appropriate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Collect and review clinical records and other pertinent information, both confidential and nonconfidential, from hospitals and health care providers as necessary to review the individual\u8217\'3fs health treatment needs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon request of a health care coordination and intervention team, a hospital or health care provider shall provide records relating to an individual case being reviewed by the health care coordination and intervention team.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon request of a health care coordination and intervention team, a person in possession or control of medical, investigative, assessment, or other information pertaining to an individual case under review by the health care coordination and intervention team shall provide the information to the health care coordination and intervention team.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Confidential records and information provided to a health care coordination and intervention team under}}}{{\f5\fs18\hyphpar0\qj{ this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall remain confidential and the health care coordination and intervention team shall not release the records or information to any person or entity without a court order.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person or entity shall not be liable for providing records or information requested by a health care coordination and intervention team under}}}{{\f5\fs18\hyphpar0\qj{ this subsection}}}{{\f5\fs18\hyphpar0\qj{ to the health care coordination and intervention team or to the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A health care coordination and intervention team member, and an agent of a health care coordination and intervention team member, shall be immune from any liability, civil or criminal, which might otherwise be incurred or imposed as a result of any act, omission, proceeding, decision, or determination undertaken or performed, or recommendation made provided that the team member or agent acted in good faith and without malice in carrying out official duties as a member of a health care coordination and intervention team or an agent of a health care coordination and intervention team member.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subject to federal law, individual case reviews conducted pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be considered care coordination as defined in }}}{{\f5\fs18\hyphpar0\qj{section 135D.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2024 Acts, ch 1075, \'a77, 8}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7282.35}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{249A.4B}}}{\*\bkmkstart stylerid1_2E6_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Medical assistance advisory council.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A medical assistance advisory council is created to comply with }}}{{\f5\fs18\hyphpar0\qj\cf1{42 C.F.R. \'a7431.12}}}{{\f5\fs18\hyphpar0\qj{ based on section 1902(a)(4) of the federal }}}{{\f5\fs18\hyphpar0\qj{Social Security Act}}}{{\f5\fs18\hyphpar0\qj{ and to advise the director about health and medical care services under the medical assistance program. The council shall meet as necessary. The director\u8217\'3fs designee responsible for public health or their designee and a public member of the council selected by the public members of the council shall serve as co-chairpersons of the council.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The council shall consist of the following voting members:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Five professional or business entity members selected by the entities specified pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Five public members appointed pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. Of the five public members, at least one member shall be a recipient of medical assistance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The council shall include all of the following nonvoting members:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director\u8217\'3fs designee responsible for public health or their designee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The long-term care ombudsman, or the long-term care ombudsman\u8217\'3fs designee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The dean of Des Moines university college of osteopathic medicine, or the dean\u8217\'3fs designee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The dean of the university of Iowa college of medicine, or the dean\u8217\'3fs designee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The following members of the general assembly, each for a term of two years as provided in }}}{{\f5\fs18\hyphpar0\qj{section 4A.13}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Two members of the house of representatives, one appointed by the speaker of the house of representatives and one appointed by the minority leader of the house of representatives fr