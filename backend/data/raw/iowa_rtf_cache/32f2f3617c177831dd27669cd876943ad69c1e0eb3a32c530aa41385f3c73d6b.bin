\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F38_30}{\*\bkmkend codeChapter_5F38_30}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 380}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{CITY LEGISLATION}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a7331.251}}}{{\f5\fs12\qc{, 362.1}}}{{\f5\fs12\qc{, 362.9}}}{{\f5\fs12\qc{, 376.1}}}{{\f5\fs12\qc{, 455D.21}}}\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{380.1}}}{\*\bkmkstart stylerid1_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{As used in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, unless the context otherwise requires: }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAll of the members of the council\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ refers to all of the seats of the council including a vacant seat and a seat where the member is absent, but does not include a seat where the council member declines to vote by reason of a conflict of interest.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fBook\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3flist\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3frecord\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fschedule\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ kept by a county auditor, assessor, treasurer, recorder, sheriff, or other county officer means the county system as defined in }}}{{\f5\fs18\hyphpar0\qj{section 445.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1148, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1069, \'a7124}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{380.1A}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Title of ordinance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The subject matter of an ordinance or amendment must be generally described in the title of the ordinance or amendment.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a71122; C73, \'a7489; C97, \'a7681; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5715;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7366.2; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7380.1}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 168, \'a71}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2001, \'a7380.1A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{380.2}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Amendment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{An amendment to an ordinance or to a code of ordinances must specifically identify the ordinance or code, or the section, subsection, or paragraph to be amended, and must set forth the ordinance, code, section, subsection, or paragraph as amended, which action is deemed to be a repeal of the previous ordinance, code, section, subsection, or paragraph amended.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a71122; C73, \'a7489; C97, \'a7681; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5715;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7366.2; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7380.2}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 145, \'a73}}}{; }{{\f5\fs18\hyphpar0\qj{97 Acts, ch 168, \'a72}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{380.3}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Two considerations before final passage \u8212\'3f how waived.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A proposed ordinance or amendment must be considered and voted on for passage at two council meetings prior to the meeting at which it is to be finally passed, unless this requirement is suspended by a recorded vote of not less than three-fourths of all of the members of the council. If a proposed ordinance, amendment, or resolution fails to receive sufficient votes for passage at any consideration and vote thereon, the proposed ordinance, amendment, or resolution shall be considered defeated.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a71122; C73, \'a7489; C97, \'a7682; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5716;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7366.3; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7380.3}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1246, \'a75}}}{; }{{\f5\fs18\hyphpar0\qj{97 Acts, ch 168, \'a73, 4}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321P.2}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{380.4}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Majority requirement }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ tie vote }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ conflicts of interest.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Passage of an ordinance, amendment, or resolution requires a majority vote of all of the members of the council, except when the mayor may vote to break a tie vote in a city with an even number of council members, as provided in }}}{{\f5\fs18\hyphpar0\qj{section 372.4}}}{{\f5\fs18\hyphpar0\qj{. Passage of a motion requires a majority vote of a quorum of the council. A resolution must be passed to spend public funds in excess of one hundred thousand dollars on a public improvement project, or to accept public improvements and facilities upon their completion. Each council member\u8217\'3fs vote on a measure must be recorded. A measure which fails to receive sufficient votes for passage shall be considered defeated.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A measure voted upon is not invalid by reason of a conflict of interest in a member of the council, unless the vote of the member of the council was decisive to passage of the measure. The vote must be computed on the basis of the number of members not disqualified by reason of conflict of interest. However, a majority of all members is required for a quorum. For the purpose of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the statement of a council member that the council member declines to vote by reason of conflict of interest is conclusive and must be entered of record.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a71122, 1134, 1135; C73, \'a7466, 489, 493, 494; C97, \'a7683, 684, 793; S13, \'a7683, 693; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5717;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7366.4; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7380.4}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 168, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 144, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1069, \'a7125}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{380.5}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Mayor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The mayor may sign, veto, or take no action on an ordinance, amendment, or resolution passed by the council. However, the mayor may not veto an ordinance, amendment, or resolution if the mayor was entitled to vote on such measure at the time of passage.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a7685; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5718;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7366.5; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7380.5}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 168, \'a76}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{380.6}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Effective date.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Measures passed by the council become effective in one of the following ways:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An ordinance or amendment signed by the mayor becomes effective when the ordinance or a summary of the ordinance is published, as provided in }}}{{\f5\fs18\hyphpar0\qj{section 380.7, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, unless a subsequent effective date is provided within the ordinance or amendment.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A resolution signed by the mayor becomes effective immediately upon signing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A motion becomes effective immediately upon passage of the motion by the council.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The mayor may veto an ordinance, amendment, or resolution within fourteen days after passage. The mayor shall explain the reasons for the veto in a written message to the council at the time of the veto. Within thirty days after the mayor\u8217\'3fs veto, the council may pass the measure again by a vote of not less than two-thirds of all of the members of the council. If the mayor vetoes an ordinance, amendment, or resolution and the council repasses the measure after the mayor\u8217\'3fs veto, a resolution becomes effective immediately upon repassage, and an ordinance or amendment becomes a law when the ordinance or a summary of the ordinance is published, unless a subsequent effective date is provided within the ordinance or amendment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the mayor takes no action on an ordinance, amendment, or resolution, a resolution becomes effective fourteen days after the date of passage and an ordinance or amendment becomes a law when the ordinance or a summary of the ordinance is published, but not sooner than fourteen days after the date of passage, unless a subsequent effective date is provided within the ordinance or amendment.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a71133; C73, \'a7492; C97, \'a7685 \u8211\'3f 687; C24, 27, 31, 35, \'a75718, 5720, 5721, 5721-a1; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5718, 5720, 5721, 5721.1;}}}{ C46, 50, \'a7366.5, 366.7 \u8211\'3f 366.9; C54, 58, 62, 66, 71, 73, \'a7366.5, 366.7; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7380.6}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 39, \'a710}}}{; }{{\f5\fs18\hyphpar0\qj{97 Acts, ch 168, \'a77}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{380.7}}}{\*\bkmkstart stylerid1_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{City clerk.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The city clerk shall:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Promptly record each measure.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Record a statement with the measure, where applicable, indicating whether the mayor signed, vetoed, or took no action on the measure, and whether the measure was repassed after the mayor\u8217\'3fs veto.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Publish a summary of all ordinances or the complete text of ordinances and amendments in the manner provided in }}}{{\f5\fs18\hyphpar0\qj{section 362.3}}}{{\f5\fs18\hyphpar0\qj{. As used in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fsummary\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall mean a narrative description of the terms and conditions of an ordinance setting forth the main points of the ordinance in a manner calculated to inform the public in a clear and understandable manner the meaning of the ordinance and which shall provide the public with sufficient notice to conform to the desired conduct required by the ordinance. The description shall include the title of the ordinance, an accurate and intelligible abstract or synopsis of the essential elements of the ordinance, a statement that the description is a summary, the location and the normal business hours of the office where the ordinance may be inspected, when the ordinance becomes effective, and the full text of any provisions imposing fines, penalties, forfeitures, fees, or taxes. Legal descriptions of property set forth in ordinances shall be described in full, provided that maps or charts may be substituted for legal descriptions when they contain sufficient detail to clearly define the area with which the ordinance is concerned. The narrative description shall be written in a clear and coherent manner and shall, to the extent possible, avoid the use of technical or legal terms not generally familiar to the public. When necessary to use technical or legal terms not generally familiar to the public, the narrative description shall include definitions of those terms.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Authenticate all measures except motions with the clerk\u8217\'3fs signature and certification as to time and manner of publication, if any. The clerk\u8217\'3fs certification is presumptive evidence of the facts stated therein.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Maintain for public use copies of all effective ordinances and codes.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a71133; C73, \'a7492; C97, \'a7686, 687; C24, 27, 31, 35, \'a75719 \u8211\'3f 5721, 5721-a1; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5719 \u8211\'3f 5721, 5721.1;}}}{ C46, 50, \'a7366.6 \u8211\'3f 366.9; C54, 58, 62, 66, 71, 73, \'a7366.6, 366.7; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7380.7}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1098, \'a72}}}{; }{{\f5\fs18\hyphpar0\qj{97 Acts, ch 168, \'a78}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7380.6}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{380.8}}}{\*\bkmkstart stylerid1_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Code of ordinances published.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city shall compile a code of ordinances containing all of the city ordinances in effect, except grade ordinances, bond ordinances, zoning map ordinances, ordinances vacating streets and alleys, and ordinances containing legal descriptions of urban revitalization areas and urban renewal areas.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city may maintain a code of ordinances either by compiling at least annually a supplement to the code of ordinances consisting of all new ordinances and amendments to ordinances which became effective during the previous year and adopting the supplement by resolution or by adding at least annually new ordinances and amendments to ordinances to the code of ordinances itself.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city which does not maintain the city code of ordinances as provided in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall compile a code of ordinances at least once every five years.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a proposed code of ordinances contains only existing ordinances without change in substance, the council may adopt the code by ordinance.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a proposed code of ordinances contains a new ordinance or an amendment to existing ordinances, the council shall hold a public hearing on the proposed code before adoption. The clerk shall publish notice of the hearing as provided in }}}{{\f5\fs18\hyphpar0\qj{section 362.3}}}{{\f5\fs18\hyphpar0\qj{. Copies of the proposed code of ordinances must be available at the city clerk\u8217\'3fs office and the notice must so state. Within thirty days after the hearing, the council may adopt the proposed code of ordinances. A new ordinance or an amendment to an existing ordinance becomes effective upon publication of the ordinance adopting the code of ordinances unless a subsequent effective date is provided within an ordinance. If the council substantially amends the proposed code of ordinances after the hearing, notice and hearing must be repeated before the code may be adopted.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A code of ordinances compiled and maintained at least annually, or compiled at least once every five years, is presumptive evidence of the passage, publication, and content of the ordinances codified therein as of the date of the clerk\u8217\'3fs certification of the ordinance adopting the code or supplement.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a71133; C73, \'a7492; C97, \'a7686, 687; C24, 27, 31, 35, \'a75720, 5721, 5721-a1; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5720, 5721, 5721.1;}}}{ C46, 50, \'a7366.7 \u8211\'3f 366.9; C54, 58, 62, 66, 71, 73, \'a7366.7; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7380.8}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 168, \'a79}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.302}}}{{\f5\fs12\hyphpar0\qj{, 622.62}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{380.9}}}{\*\bkmkstart stylerid1_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Fee for publication.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The compensation paid to a newspaper for any publication required by }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ may not exceed the fee provided in }{{\f5\fs18\hyphpar0\qj{section 618.11}}}{. The compensation paid to a newspaper for publication of the complete text of an ordinance shall not exceed three-fourths of the fee provided in }{{\f5\fs18\hyphpar0\qj{section 618.11}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a7687-b; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5723;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7366.11; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7380.9}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1098, \'a73}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{380.10}}}{\*\bkmkstart stylerid1_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Adoption by reference.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city may adopt the provisions of any statewide or nationally recognized standard code or portions of any such code by an ordinance which identifies the code by subject matter, source and date, and which incorporates the provisions of the code or portions of the code by reference without setting them forth in full. Copies of the proposed code or portions of such code shall be available at the office of the city clerk.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city may by ordinance adopt by reference any portion of the Code of Iowa in effect at the time of the adoption in the manner provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, subject to the following limitations:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The ordinance shall describe the subject matter and identify the portion of the Code of Iowa adopted by chapter, section, and subsection or other subpart, as applicable.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A portion of the Code of Iowa may be adopted by reference only if the criminal penalty provided by the law adopted does not exceed the maximum fine and term of imprisonment for a simple misdemeanor under }}}{{\f5\fs18\hyphpar0\qj{section 903.1, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Amendments or other changes to those portions of the Code of Iowa which have been adopted by reference shall serve as an automatic modification of the applicable ordinance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An ordinance which adopts by reference any portion of the Code of Iowa may provide that violations of the ordinance are municipal infractions and subject to the limitations of }}}{{\f5\fs18\hyphpar0\qj{section 364.22}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Copies of any portions of the Code of Iowa to be adopted by reference shall be available at the city clerk\u8217\'3fs office. The council shall hold a public hearing on any proposed standard code or on the portions of any standard code to be adopted by reference. The council shall hold a public hearing on any portion of the Code of Iowa to be adopted by reference. The clerk shall publish notice of the hearing as provided in }}}{{\f5\fs18\hyphpar0\qj{section 362.3}}}{{\f5\fs18\hyphpar0\qj{. The notice must state that copies of the proposed standard code or portions thereof, or of the portion of the Iowa Code, are available at the city clerk\u8217\'3fs office. If the council substantially amends the proposed code after the hearing, notice and hearing must be repeated before the code may be adopted. Within thirty days after the hearing, the council by ordinance may adopt the proposed code which becomes effective upon publication of the ordinance adopting it, unless a subsequent effective date is provided within the adopting ordinance.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a71133; C73, \'a7492; C97, \'a7686, 687; C24, 27, 31, 35, \'a75720, 5721, 5721-a1; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5720, 5721, 5721.1;}}}{ C46, 50, \'a7366.7 \u8211\'3f 366.9; C54, 58, 62, 66, 71, 73, \'a7366.7; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7380.10}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 145, \'a74}}}{; }{{\f5\fs18\hyphpar0\qj{97 Acts, ch 168, \'a710, 11}}}{; }{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1203, \'a722}}}{; }{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 21, \'a77}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{380.11}}}{\*\bkmkstart stylerid1_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Certain measures recorded.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Immediately after the effective date of a measure establishing any zoning district, building lines, or fire limits, the city clerk shall certify the measure and a plat showing the district, lines, or limits to the recorder of any county which contains part of the city. The county recorder shall index and record the measure and plat. The city shall pay the recording fee.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5724 \u8211\'3f 5727;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7366.12 \u8211\'3f 366.15; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7380.11}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 44, \'a717}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.602}}}\par}}