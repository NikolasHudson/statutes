        {
          "number": "455B.283",
          "heading": "through 455B.290Reserved",
          "body_text": "PART 5\nWATER POLLUTION CONTROL WORKS\n\nAND DRINKING WATER FACILITIES\n\nFINANCING PROGRAM\nSimilar programs under Iowa finance authority, see §16.131 – 16.135",
          "body_chars": 154,
