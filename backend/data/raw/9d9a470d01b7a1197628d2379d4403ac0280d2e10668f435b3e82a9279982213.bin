          ],
          "citation_pdf_url": "https://www.legis.iowa.gov/docs/ico/section/2026/232.62.pdf"
        },
        {
          "number": "232.63",
          "heading": "through 232.66Reserved",
          "body_text": "PART 2\nCHILD ABUSE REPORTING,\n\nASSESSMENT, AND REHABILITATION",
          "body_chars": 61,
          "history_brackets": [],
          "acts_citations": [],
          "referred_to_in": [
            "135L.3",
