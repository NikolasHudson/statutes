        {
          "number": "97B.64",
          "heading": "Insurance laws not applicable",
          "body_text": "None of the laws of this state regulating insurance or insurance companies shall apply to the system or to the retirement system or any of its funds.\n\n;",
          "body_chars": 152,
          "history_brackets": [
            "C46, 50, §97.47; C54, 58, 62, 66, 71, 73, 75, 77, 79, 81, §97B.64"
