            "SS15, §254-a16; C24, 27, 31, 35, 39, §3631; C46, 50, 54, 58, 62, §232.15; C66, 71, 73, 75, 77, §232.11; C79, 81, §232.91"
          ],
          "acts_citations": [
            "2007 Acts, ch 172, §13",
            "2008 Acts, ch 1114, §1",
            "2008 Acts, ch 1187, §133",
            "2010 Acts, ch 1065, §1, 2",
            "2020 Acts, ch 1062, §94",
            "2022 Acts, ch 1098, §37\nR"
          ],
          "referred_to_in": [
            "600A.7"
          ],
          "citation_pdf_url": "https://www.legis.iowa.gov/docs/ico/section/2026/232.91.pdf"
        },
        {
          "number": "232.92",
          "heading": "Exclusion of public from hearings",
          "body_text": "Hearings held under this subchapter are open to the public unless the court, on the motion of any of the parties or upon the court’s own motion, excludes the public. The court shall exclude the public from a hearing if the court determines that the possibility of damage or harm to the child outweighs the public’s interest in having an open hearing. Upon closing the hearing to the public, the court may admit those persons who have direct interest in the case or in the work of the court.\n\n89 Acts, ch 230, §17; eferred to in §232.147, 600A.7",
          "body_chars": 544,
          "history_brackets": [
            "C79, 81, §232.92"
          ],
          "acts_citations": [
            "2020 Acts, ch 1062, §94\nR"
          ],
          "referred_to_in": [
            "232.147",
            "600A.7"
          ],
          "citation_pdf_url": "https://www.legis.iowa.gov/docs/ico/section/2026/232.92.pdf"
        },
        {
          "number": "232.93",
          "heading": "Other issues adjudicated",
          "body_text": "When it appears during the course of any hearing or proceeding that some action or remedy other than those indicated by the application or pleading appears appropriate, the court may, provided all necessary parties consent, proceed to hear and determine the other issues as though originally properly sought and pleaded.",
