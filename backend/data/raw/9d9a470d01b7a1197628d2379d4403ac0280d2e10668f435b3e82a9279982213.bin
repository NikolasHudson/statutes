        {
          "number": "97B.2",
          "heading": "Purpose of chapter",
          "body_text": "The purpose of this chapter is to promote economy and efficiency in the public service by providing an orderly means for employees, without hardship or prejudice, to have a retirement system which will provide for the payment of annuities, enabling the employees to care for themselves in retirement, and which will improve public employment within the state, reduce excessive personnel turnover, and offer suitable attraction to high-grade men and women to enter public service in the state.\n\n88 Acts, ch 1242, §8",
          "body_chars": 514,
          "history_brackets": [
            "C46, 50, §97.2; C54, 58, 62, 66, 71, 73, 75, 77, 79, 81, §97B.2"
          ],
          "acts_citations": [],
          "referred_to_in": [
            "97B.1A"
          ],
          "citation_pdf_url": "https://www.legis.iowa.gov/docs/ico/section/2026/97B.2.pdf",
          "citation_html_url": "https://www.legis.iowa.gov/docs/ico/section/2026/97B.2.html",
