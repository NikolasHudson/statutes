        {
          "number": "97B.49I",
          "heading": "Qualified benefits arrangement",
          "body_text": "The system, by rule, may establish and maintain a qualified benefits arrangement under section 415(m) of the federal Internal Revenue Code. The amount of any annual benefit that would be payable pursuant to this chapter but for the limitation imposed by section 415 of the federal Internal Revenue Code shall be paid from a qualified benefits arrangement established and maintained pursuant to this section.\n98 Acts, ch 1183, §44; ;",
          "body_chars": 432,
          "history_brackets": [],
          "acts_citations": [
            "2001 Acts, ch 68, §21, 24",
            "2003 Acts, ch 145, §286"
          ],
          "referred_to_in": [],
          "citation_pdf_url": "https://www.legis.iowa.gov/docs/ico/section/2026/97B.49I.pdf",
          "citation_html_url": "https://www.legis.iowa.gov/docs/ico/section/2026/97B.49I.html",
          "source_rtf_url": "https://www.legis.iowa.gov/docs/ico/section/2026/97B.49I.rtf"
