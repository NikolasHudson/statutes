            "2001 Acts, ch 68, §21, 24",
            "2002 Acts, ch 1135, §18",
            "2003 Acts, ch 145, §286",
            "2004 Acts, ch 1103, §26 ",
            "2006 Acts, ch 1092, §4, 8\nR"
          ],
          "referred_to_in": [
            "97B.48A",
            "97B.52",
            "97B.52A"
