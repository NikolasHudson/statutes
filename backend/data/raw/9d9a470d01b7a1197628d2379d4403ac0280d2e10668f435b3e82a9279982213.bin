          "source_rtf_url": "https://www.legis.iowa.gov/docs/ico/section/2026/97B.44.rtf"
        },
        {
          "number": "97B.45",
          "heading": "Normal retirement date",
          "body_text": "A member’s normal retirement date is any of the following, whichever is applicable to the member:\n  1.  The first of the month in which a member attains the age of sixty-five years if the member has not completed twenty years of membership service.\n  2.  The first of the month in which the member attains the age of sixty-two years if the member has completed twenty years of membership service.\n  3.  The first of any month in which the member has completed twenty years of membership service if the member has attained the age of sixty-two years but is not yet sixty-five years of age.\n  4.  The first of any month in which the member is at least fifty-five years of age and for which the sum of the number of years of membership service and prior service and the member’s age in years as of the member’s last birthday equals or exceeds eighty-eight.\n\n86 Acts, ch 1243, §9; 88 Acts, ch 1242, §32; 94 Acts, ch 1183, §27; 98 Acts, ch 1183, §27, 77; ; ; ; eferred to in §97B.18",
          "body_chars": 977,
          "history_brackets": [
            "C46, 50, §97.13, 97.39; C54, 58, 62, 66, 71, 73, 75, 77, 79, 81, §97B.45"
          ],
          "acts_citations": [
            "2001 Acts, ch 68, §21, 24",
            "2002 Acts, ch 1135, §17",
            "2003 Acts, ch 145, §286",
            "2004 Acts, ch 1103, §23\nR"
          ],
          "referred_to_in": [
            "97B.18"
          ],
