        },
        {
          "number": "600.7B",
          "heading": "Postadoption information",
          "body_text": "The department shall develop and furnish to the state registrar of vital statistics a document listing all postadoption services available to adoptive families in the state, to be delivered along with a copy of the new birth certificate to the parents named in the adoption decree pursuant to section 600.13.\neferred to in §600.14A",
          "body_chars": 331,
          "history_brackets": [],
