          "citation_pdf_url": "https://www.legis.iowa.gov/docs/ico/section/2026/29C.3.pdf"
        },
        {
          "number": "29C.4",
          "heading": "Judicial protections",
          "body_text": "The supreme court shall promulgate rules for emergency proceedings to be effective upon the declaration of a state of public disorder emergency in order that the constitutional rights of all persons taken into custody shall be adequately protected.",
