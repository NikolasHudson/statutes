            "2000 Acts, ch 1067, §9",
            "2001 Acts, ch 135, §16",
            "2020 Acts, ch 1062, §94",
            "2022 Acts, ch 1098, §41 ",
            "2023 Acts, ch 19, §617\nR"
          ],
          "referred_to_in": [
