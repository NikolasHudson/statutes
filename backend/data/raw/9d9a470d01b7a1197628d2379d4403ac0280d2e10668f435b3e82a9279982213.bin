          "citation_pdf_url": "https://www.legis.iowa.gov/docs/ico/section/2026/97B.51.pdf",
          "citation_html_url": "https://www.legis.iowa.gov/docs/ico/section/2026/97B.51.html",
          "source_rtf_url": "https://www.legis.iowa.gov/docs/ico/section/2026/97B.51.rtf"
