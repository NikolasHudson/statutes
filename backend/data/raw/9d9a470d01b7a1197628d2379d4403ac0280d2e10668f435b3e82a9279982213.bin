          "citation_html_url": "https://www.legis.iowa.gov/docs/ico/section/2026/4.9.html",
          "source_rtf_url": "https://www.legis.iowa.gov/docs/ico/section/2026/4.9.rtf"
        },
        {
          "number": "4.10",
          "heading": "Reenactment of statutes — continuation",
          "body_text": "A statute which is reenacted, revised or amended is intended to be a continuation of the prior statute and not a new enactment, so far as it is the same as the prior statute.",
          "body_chars": 174,
          "history_brackets": [
            "C73, 75, 77, 79, 81, §4.10"
          ],
          "acts_citations": [],
          "referred_to_in": [],
          "citation_pdf_url": "https://www.legis.iowa.gov/docs/ico/section/2026/4.10.pdf",
          "citation_html_url": "https://www.legis.iowa.gov/docs/ico/section/2026/4.10.html",
          "source_rtf_url": "https://www.legis.iowa.gov/docs/ico/section/2026/4.10.rtf"
        },
        {
          "number": "4.11",
          "heading": "Conflicting amendments to same statutes — interpretation",
          "body_text": "If amendments to the same statute are enacted at the same or different sessions of the general assembly, one amendment without reference to another, the amendments are to be harmonized, if possible, so that effect may be given to each. If the amendments are irreconcilable, the latest in date of enactment by the general assembly prevails.",
          "body_chars": 339,
          "history_brackets": [
            "C73, 75, 77, 79, 81, §4.11"
          ],
          "acts_citations": [],
          "referred_to_in": [],
