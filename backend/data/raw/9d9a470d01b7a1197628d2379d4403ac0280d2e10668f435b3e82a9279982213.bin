        {
          "number": "97B.56",
          "heading": "Abolished system — liquidation fund",
          "body_text": "The assets of the old-age and survivors’ liquidation fund, established by sections 97.50 through 97.53 and any future payments or assets payable to the old-age and survivors’ liquidation fund, are transferred to the retirement fund, and all payments due in accordance with the provisions of sections 97.50 through 97.53 shall be paid from the retirement fund.\n\n86 Acts, ch 1246, §723; 94 Acts, ch 1183, §49; ; .57  Repealed by \n.",
          "body_chars": 429,
          "history_brackets": [
            "C54, 58, 62, 66, 71, 73, 75, 77, 79, 81, §97B.56"
          ],
          "acts_citations": [
            "2021 Acts, ch 80, §54",
            "2022 Acts, ch 1021, §38\n  \n     \n97B",
            "2001 Acts, ch 68, §23, 24\n"
          ],
          "referred_to_in": [],
          "citation_pdf_url": "https://www.legis.iowa.gov/docs/ico/section/2026/97B.56.pdf",
          "citation_html_url": "https://www.legis.iowa.gov/docs/ico/section/2026/97B.56.html",
          "source_rtf_url": "https://www.legis.iowa.gov/docs/ico/section/2026/97B.56.rtf"
        },
        {
          "number": "97B.58",
          "heading": "Information furnished by employer",
          "body_text": "To enable the system to administer this chapter and perform its functions, the employer shall, upon the request of and in the manner provided by the system, provide accurate, complete, and timely information to the system of all matters relating to the pay of all members, date of birth, their retirement, death, or other cause for termination of employment, and other pertinent facts the system may require in the manner provided by the system. The system shall not be liable to any member, retiree, or beneficiary for any monetary or other relief due to the failure of the employer to comply with this section.\n\n92 Acts, ch 1201, §57; ; ;",
          "body_chars": 640,
          "history_brackets": [
            "C46, 50, §97.23 – 97.25; C54, 58, 62, 66, 71, 73, 75, 77, 79, 81, §97B.58"
