            "144.23",
            "261I.1",
            "280.33"
          ],
          "citation_pdf_url": "https://www.legis.iowa.gov/docs/ico/section/2026/4.1A.pdf",
          "citation_html_url": "https://www.legis.iowa.gov/docs/ico/section/2026/4.1A.html",
          "source_rtf_url": "https://www.legis.iowa.gov/docs/ico/section/2026/4.1A.rtf"
        },
        {
          "number": "4.2",
          "heading": "Common law rule of construction",
          "body_text": "The rule of the common law, that statutes in derogation thereof are to be strictly construed, has no application to this Code. Its provisions and all proceedings under it shall be liberally construed with a view to promote its objects and assist the parties in obtaining justice.",
          "body_chars": 279,
          "history_brackets": [
            "C51, §2503; R60, §2622; C73, §2528; C97, §3446; C24, 27, 31, 35, 39, §64; C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, 81, §4.2"
          ],
          "acts_citations": [],
          "referred_to_in": [],
          "citation_pdf_url": "https://www.legis.iowa.gov/docs/ico/section/2026/4.2.pdf",
          "citation_html_url": "https://www.legis.iowa.gov/docs/ico/section/2026/4.2.html",
          "source_rtf_url": "https://www.legis.iowa.gov/docs/ico/section/2026/4.2.rtf"
        },
        {
          "number": "4.3",
          "heading": "References to other statutes",
          "body_text": "Any statute which adopts by reference the whole or a portion of another statute of this state shall be construed to include subsequent amendments of the statute or the portion thereof so adopted by reference unless a contrary intent is expressed.",
          "body_chars": 246,
          "history_brackets": [
            "C58, 62, 66, 71, 73, 75, 77, 79, 81, §4.3"
          ],
          "acts_citations": [],
          "referred_to_in": [],
          "citation_pdf_url": "https://www.legis.iowa.gov/docs/ico/section/2026/4.3.pdf",
          "citation_html_url": "https://www.legis.iowa.gov/docs/ico/section/2026/4.3.html",
          "source_rtf_url": "https://www.legis.iowa.gov/docs/ico/section/2026/4.3.rtf"
        },
        {
          "number": "4.4",
          "heading": "Presumption of enactment",
          "body_text": "In enacting a statute, it is presumed that:\n  1.  Compliance with the Constitutions of the state and of the United States is intended.\n  2.  The entire statute is intended to be effective.\n  3.  A just and reasonable result is intended.\n  4.  A result feasible of execution is intended.\n  5.  Public interest is favored over any private interest.",
          "body_chars": 346,
          "history_brackets": [
            "C73, 75, 77, 79, 81, §4.4"
          ],
          "acts_citations": [],
          "referred_to_in": [],
          "citation_pdf_url": "https://www.legis.iowa.gov/docs/ico/section/2026/4.4.pdf",
          "citation_html_url": "https://www.legis.iowa.gov/docs/ico/section/2026/4.4.html",
          "source_rtf_url": "https://www.legis.iowa.gov/docs/ico/section/2026/4.4.rtf"
        },
        {
          "number": "4.5",
          "heading": "Prospective statutes",
          "body_text": "A statute is presumed to be prospective in its operation unless expressly made retrospective.",
          "body_chars": 93,
          "history_brackets": [
            "C73, 75, 77, 79, 81, §4.5"
          ],
          "acts_citations": [],
          "referred_to_in": [],
          "citation_pdf_url": "https://www.legis.iowa.gov/docs/ico/section/2026/4.5.pdf",
          "citation_html_url": "https://www.legis.iowa.gov/docs/ico/section/2026/4.5.html",
          "source_rtf_url": "https://www.legis.iowa.gov/docs/ico/section/2026/4.5.rtf"
        },
        {
          "number": "4.6",
          "heading": "Ambiguous statutes — interpretation",
          "body_text": "If a statute is ambiguous, the court, in determining the intention of the legislature, may consider among other matters:\n  1.  The object sought to be attained.\n  2.  The circumstances under which the statute was enacted.\n  3.  The legislative history.\n  4.  The common law or former statutory provisions, including laws upon the same or similar subjects.\n  5.  The consequences of a particular construction.\n  6.  The administrative construction of the statute.\n  7.  The preamble or statement of policy.",
          "body_chars": 505,
          "history_brackets": [
            "C73, 75, 77, 79, 81, §4.6"
          ],
          "acts_citations": [],
          "referred_to_in": [],
          "citation_pdf_url": "https://www.legis.iowa.gov/docs/ico/section/2026/4.6.pdf",
          "citation_html_url": "https://www.legis.iowa.gov/docs/ico/section/2026/4.6.html",
          "source_rtf_url": "https://www.legis.iowa.gov/docs/ico/section/2026/4.6.rtf"
        },
        {
          "number": "4.7",
          "heading": "Conflicts between general and special statutes",
          "body_text": "If a general provision conflicts with a special or local provision, they shall be construed, if possible, so that effect is given to both. If the conflict between the provisions is irreconcilable, the special or local provision prevails as an exception to the general provision.\n\nIntent of general assembly that §7E.6 govern compensation of members of boards, committees, commissions, or councils except for certain provisions enacted subsequent to July 1, 1986; see §7E.6(1) and (7)",
          "body_chars": 483,
          "history_brackets": [
            "C73, 75, 77, 79, 81, §4.7"
          ],
          "acts_citations": [],
          "referred_to_in": [
            "7E.6"
          ],
          "citation_pdf_url": "https://www.legis.iowa.gov/docs/ico/section/2026/4.7.pdf",
          "citation_html_url": "https://www.legis.iowa.gov/docs/ico/section/2026/4.7.html",
          "source_rtf_url": "https://www.legis.iowa.gov/docs/ico/section/2026/4.7.rtf"
        },
        {
          "number": "4.8",
          "heading": "Irreconcilable statutes",
          "body_text": "If statutes enacted at the same or different sessions of the legislature are irreconcilable, the statute latest in date of enactment by the general assembly prevails. If provisions of the same Act are irreconcilable, the provision listed last in the Act prevails.\n\nCode editor authority to harmonize and rules for codification of irreconcilable statutes, see also §2B.13(1)(h)",
          "body_chars": 376,
          "history_brackets": [
            "C73, 75, 77, 79, 81, §4.8"
          ],
          "acts_citations": [],
          "referred_to_in": [],
          "citation_pdf_url": "https://www.legis.iowa.gov/docs/ico/section/2026/4.8.pdf",
          "citation_html_url": "https://www.legis.iowa.gov/docs/ico/section/2026/4.8.html",
          "source_rtf_url": "https://www.legis.iowa.gov/docs/ico/section/2026/4.8.rtf"
        },
        {
          "number": "4.9",
          "heading": "Official copy prevails",
          "body_text": "If the language of the official copy of a statute conflicts with the language of any subsequent printing or reprinting of the statute, the language of the official copy prevails.",
          "body_chars": 178,
          "history_brackets": [
            "C73, 75, 77, 79, 81, §4.9"
          ],
          "acts_citations": [],
          "referred_to_in": [],
