        {
          "number": "600.7A",
          "heading": "Adoption services provided by or through the department — selection of adoptive parent criteria",
          "body_text": "The department shall adopt rules which provide that if adoption services are provided by or through the department, notwithstanding any other selection of adoptive parent criteria, the overriding criterion shall be a preference for placing a child in a stable home environment as expeditiously as possible.\n96 Acts, ch 1174, §7; eferred to in §600.14A",
          "body_chars": 351,
          "history_brackets": [],
