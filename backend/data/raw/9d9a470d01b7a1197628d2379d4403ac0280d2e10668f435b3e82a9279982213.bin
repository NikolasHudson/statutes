          ],
          "acts_citations": [
            "2003 Acts, ch 179, §157",
            "2005 Acts, ch 119, §4",
            "2013 Acts, ch 29, §16",
            "2017 Acts, ch 28, §1\nR"
          ],
          "referred_to_in": [
            "7E.5",
